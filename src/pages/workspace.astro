---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---
<BaseLayout title="Starling AIX | Workspace — Your Domain Language Model, Live" description="Starling Workspace is where your Domain Language Model lives. An AI work surface with your entire Org Brain behind it.">
<Nav currentPage="workspace" />
<main>

<!-- ===== HERO ===== -->
<section class="ws-hero" id="hero">
    <div class="ws-hero__bg">
        <canvas id="heroCanvas"></canvas>
    </div>
    <div class="ws-hero__inner">
        <div class="ws-hero__text">
            <div class="ws-hero__badge">
                <span class="ws-hero__badge-dot"></span>
                Coming March 2026
            </div>
            <h1 class="ws-hero__title"><strong>Work that</strong> <em>remembers.</em></h1>
            <p class="ws-hero__subtitle">Starling Workspace is where your Domain Language Model lives.</p>
            <p class="ws-hero__desc">An AI work surface with your entire Org Brain behind it &mdash; every deliverable you produce makes the next one better.</p>
            <div class="ws-hero__cta">
                <div class="btn-group">
                    <a href="#beta" class="btn btn--primary btn--large">
                        Request Beta Access
                        <svg class="arrow" width="10" height="10" fill="none" stroke="currentColor" stroke-width="2"><path d="M0.5 5.5h7"/><path d="M5.5 1.5l4 4-4 4"/></svg>
                    </a>
                    <a href="#dlm" class="btn btn--secondary btn--large">See How It Works</a>
                </div>
                <p class="ws-hero__note">Beta opens March 2026 &middot; Free for 14 days</p>
            </div>
        </div>
        <div class="ws-hero__visual">
            <div class="ws-illo" id="wsIllo">

                <!-- Floating memory chips -->
                <div class="ws-mem ws-mem--0" id="wsMem0">
                    <span class="ws-mem__dot" style="color:var(--brand);background:var(--brand)"></span>
                    <div class="ws-mem__info"><span class="ws-mem__code">MA20</span><span class="ws-mem__name">Position</span></div>
                    <div class="ws-mem__popup ws-mem__popup--below">Competitive positioning loaded</div>
                </div>
                <div class="ws-mem ws-mem--1" id="wsMem1">
                    <span class="ws-mem__dot" style="color:var(--accent-teal);background:var(--accent-teal)"></span>
                    <div class="ws-mem__info"><span class="ws-mem__code">MA28</span><span class="ws-mem__name">Identity</span></div>
                    <div class="ws-mem__popup ws-mem__popup--below">Brand voice &amp; tone applied</div>
                </div>
                <div class="ws-mem ws-mem--2" id="wsMem2">
                    <span class="ws-mem__dot" style="color:#635bff;background:#635bff"></span>
                    <div class="ws-mem__info"><span class="ws-mem__code">AM55</span><span class="ws-mem__name">Churn</span></div>
                    <div class="ws-mem__popup ws-mem__popup--above">Q1 churn analysis context</div>
                </div>
                <div class="ws-mem ws-mem--3" id="wsMem3">
                    <span class="ws-mem__dot" style="color:var(--accent-pink);background:var(--accent-pink)"></span>
                    <div class="ws-mem__info"><span class="ws-mem__code">VL01</span><span class="ws-mem__name">Offering</span></div>
                    <div class="ws-mem__popup ws-mem__popup--above">Core value proposition injected</div>
                </div>
                <div class="ws-mem ws-mem--4" id="wsMem4">
                    <span class="ws-mem__dot" style="color:#d97706;background:#d97706"></span>
                    <div class="ws-mem__info"><span class="ws-mem__code">LM82</span><span class="ws-mem__name">Learned</span></div>
                    <div class="ws-mem__popup ws-mem__popup--above">Direct outreach converts 3&times; cold email</div>
                </div>
                <div class="ws-mem ws-mem--5" id="wsMem5">
                    <span class="ws-mem__dot" style="color:#2563eb;background:#2563eb"></span>
                    <div class="ws-mem__info"><span class="ws-mem__code">MA05</span><span class="ws-mem__name">Vision</span></div>
                    <div class="ws-mem__popup ws-mem__popup--above">Company vision &amp; mission aligned</div>
                </div>

                <!-- Workspace card -->
                <div class="ws-illo__card" id="wsCard">
                    <div class="ws-illo__bar">
                        <span class="ws-illo__bar-dot" id="illoDot1"></span>
                        <span class="ws-illo__bar-dot" id="illoDot2"></span>
                        <span class="ws-illo__bar-dot" id="illoDot3"></span>
                        <span class="ws-illo__bar-title">
                            <span class="ws-illo__bar-status" id="illoBarStatus"></span>
                            Workspace
                        </span>
                    </div>
                    <div class="ws-illo__body">
                        <div class="ws-illo__prompt" id="illoPrompt">
                            <span class="ws-illo__prompt-icon">&#9656;</span>
                            <span class="ws-illo__prompt-text" id="illoPromptText"></span>
                            <span class="ws-illo__prompt-cursor" id="illoCursor"></span>
                        </div>
                        <div class="ws-illo__output" id="illoOutput">
                            <div class="ws-illo__out-row" id="illoRow0">
                                <div class="ws-illo__out-title">Subject: We built what you asked for</div>
                            </div>
                            <div class="ws-illo__out-row" id="illoRow1">
                                <div class="ws-illo__out-bar ws-illo__out-bar--full"></div>
                            </div>
                            <div class="ws-illo__out-row" id="illoRow2">
                                <div class="ws-illo__out-bar ws-illo__out-bar--full ws-illo__out-bar--brand"></div>
                            </div>
                            <div class="ws-illo__out-row" id="illoRow3">
                                <div class="ws-illo__out-bar ws-illo__out-bar--long"></div>
                            </div>
                            <div class="ws-illo__out-row" id="illoRow4">
                                <div class="ws-illo__out-bar ws-illo__out-bar--med"></div>
                            </div>
                            <div class="ws-illo__out-row" id="illoRow5">
                                <div class="ws-illo__out-inline">
                                    <span class="ws-illo__out-chip ws-illo__out-chip--brand" id="illoChip0">MA20</span>
                                    <span class="ws-illo__out-chip ws-illo__out-chip--teal" id="illoChip1">MA28</span>
                                    <span class="ws-illo__out-chip ws-illo__out-chip--purple" id="illoChip2">VL01</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Status badge -->
                <div class="ws-illo__badge" id="illoBadge">
                    <span class="ws-illo__badge-dot"></span>
                    <span id="illoBadgeText">Initializing&hellip;</span>
                </div>

                <!-- Replay -->
                <button class="ws-illo__replay" id="illoReplay">&#x21bb; Replay</button>
            </div>
        </div>
    </div>
</section>

<hr class="glow-line">

<!-- ===== SECTION 2: YOUR DOMAIN LANGUAGE MODEL ===== -->
<section class="dlm-section" id="dlm">
    <div class="dlm-section__canvas"><canvas id="dlmCanvas"></canvas></div>
    <div class="dlm-section__inner">
        <div class="section__header reveal" style="position:relative;z-index:2">
            <h2 class="section__h"><strong>Your Domain Language Model.</strong> The model processes. The domain remembers.</h2>
            <div class="section__header-right">
                <p class="body-lg">Workspace assembles your DLM on every request. It loads the right organizational context from your Org Brain, routes it through semantic addressing, and delivers intelligence no general-purpose AI can match.</p>
            </div>
        </div>

        <!-- Interactive equation bar -->
        <div class="dlm-bar reveal reveal-d1" id="dlmBar">
            <div class="dlm-bar__line"></div>
            <div class="dlm-bar__node is-active" data-dlm="llm">
                <div class="dlm-bar__pip dlm-bar__pip--llm">LLM</div>
                <div class="dlm-bar__label">LLM</div>
                <div class="dlm-bar__sub">Stateless Processing</div>
            </div>
            <div class="dlm-bar__op">&times;</div>
            <div class="dlm-bar__node" data-dlm="mcp">
                <div class="dlm-bar__pip dlm-bar__pip--mcp">MCP</div>
                <div class="dlm-bar__label">MCP</div>
                <div class="dlm-bar__sub">Connection Protocol</div>
            </div>
            <div class="dlm-bar__op">&times;</div>
            <div class="dlm-bar__node" data-dlm="uca">
                <div class="dlm-bar__pip dlm-bar__pip--uca">UCA</div>
                <div class="dlm-bar__label">UCA</div>
                <div class="dlm-bar__sub">Semantic Addressing</div>
            </div>
            <div class="dlm-bar__op">&times;</div>
            <div class="dlm-bar__node" data-dlm="org">
                <div class="dlm-bar__pip dlm-bar__pip--org">ORG</div>
                <div class="dlm-bar__label">Org Brain</div>
                <div class="dlm-bar__sub">Sovereign Repository</div>
            </div>
            <div class="dlm-bar__op">=</div>
            <div class="dlm-bar__node" data-dlm="dlm">
                <div class="dlm-bar__pip dlm-bar__pip--dlm">DLM</div>
                <div class="dlm-bar__label">DLM</div>
                <div class="dlm-bar__sub">Domain Language Model</div>
            </div>
        </div>

        <!-- Expanding detail panel -->
        <div class="dlm-detail" id="dlmDetail">
            <div class="dlm-detail__card is-active" data-dlm-panel="llm">
                <div class="dlm-detail__header">
                    <span class="dlm-detail__tag dlm-detail__tag--llm">Large Language Model</span>
                </div>
                <div class="dlm-detail__title">Stateless processing. Reads, reasons, advises &mdash; then forgets.</div>
                <p class="dlm-detail__desc">Powerful, but starts from zero every time. An LLM has no memory of your organization, your strategy, or your voice. It's a general-purpose engine &mdash; brilliant at language, blind to your business.</p>
            </div>
            <div class="dlm-detail__card" data-dlm-panel="mcp">
                <div class="dlm-detail__header">
                    <span class="dlm-detail__tag dlm-detail__tag--mcp">Model Context Protocol</span>
                </div>
                <div class="dlm-detail__title">Anthropic's open standard for connecting AI to external data.</div>
                <p class="dlm-detail__desc">The pipe &mdash; not the water. MCP is the protocol that lets any LLM talk to external tools and data sources. It's how context flows from your Org Brain into the model at inference time.</p>
            </div>
            <div class="dlm-detail__card" data-dlm-panel="uca">
                <div class="dlm-detail__header">
                    <span class="dlm-detail__tag dlm-detail__tag--uca">Universal Cognitive Architecture</span>
                </div>
                <div class="dlm-detail__title">Eleven cognates. Four memory tiers. Semantic addressing.</div>
                <p class="dlm-detail__desc">UCA gives business knowledge permanent coordinates. O(1) lookup, not O(n) search. Every piece of organizational intelligence gets a semantic address your AI can call by name &mdash; no vector search, no token burn.</p>
            </div>
            <div class="dlm-detail__card" data-dlm-panel="org">
                <div class="dlm-detail__header">
                    <span class="dlm-detail__tag dlm-detail__tag--org">Your Sovereign Repository</span>
                </div>
                <div class="dlm-detail__title">Values, strategy, positioning, operations, culture &mdash; governed and addressable.</div>
                <p class="dlm-detail__desc">Your Org Brain lives in Notion. You own it. It travels with you. Switch AI providers tomorrow and every memory comes along. This is information sovereignty &mdash; your knowledge is never locked inside someone else's platform.</p>
            </div>
            <div class="dlm-detail__card" data-dlm-panel="dlm">
                <div class="dlm-detail__header">
                    <span class="dlm-detail__tag dlm-detail__tag--dlm">Domain Language Model</span>
                </div>
                <div class="dlm-detail__title">Not a fine-tuned model. A general-purpose model with your complete organizational context loaded on every request.</div>
                <p class="dlm-detail__desc">The DLM is what happens when stateless processing meets sovereign memory. It doesn't know "business." It knows <em>your</em> business &mdash; your voice, your strategy, your competitive position, your culture. Every output is grounded in your canon.</p>
            </div>
        </div>
    </div>
</section>

<!-- ===== SECTION 3: HOW IT WORKS — THREE LAYERS ===== -->
<section class="layers" id="how-it-works">
    <div class="layers__inner">
        <div class="section__header reveal">
            <h2 class="section__h"><strong>Build once. Deploy anywhere.</strong> Three layers. One stores. One translates. One thinks.</h2>
            <div class="section__header-right">
                <p class="body-lg">You own the first two. The third is stateless and swappable.</p>
            </div>
        </div>

        <div class="layers__grid reveal reveal-d1">
            <!-- Layer 1: Store -->
            <div class="layer-card">
                <div class="layer-card__num">01 &mdash; Store</div>
                <div class="layer-card__icon layer-card__icon--store">
                    <svg viewBox="0 0 24 24" fill="none" stroke="#635bff" stroke-width="1.5"><path d="M4 7v10c0 2.21 3.582 4 8 4s8-1.79 8-4V7"/><path d="M20 7c0 2.21-3.582 4-8 4S4 9.21 4 7"/><ellipse cx="12" cy="7" rx="8" ry="4"/></svg>
                </div>
                <div class="layer-card__title">Org Brain</div>
                <div class="layer-card__sub">Notion</div>
                <div class="layer-card__desc">Your sovereign knowledge repository. Structured memories with semantic addresses. PMNs, AMNs, and LMNs &mdash; governed, versioned, and human-owned.</div>
                <div class="layer-arrow">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                </div>
            </div>

            <!-- Layer 2: Translate -->
            <div class="layer-card">
                <div class="layer-card__num">02 &mdash; Translate</div>
                <div class="layer-card__icon layer-card__icon--translate">
                    <svg viewBox="0 0 24 24" fill="none" stroke="var(--brand)" stroke-width="1.5"><path d="M8 3H5a2 2 0 00-2 2v3m18 0V5a2 2 0 00-2-2h-3m0 18h3a2 2 0 002-2v-3M3 16v3a2 2 0 002 2h3"/><path d="M12 8v8M8 12h8"/></svg>
                </div>
                <div class="layer-card__title">MCP Server</div>
                <div class="layer-card__sub">Starling</div>
                <div class="layer-card__desc">The orchestration layer. Reads your Org Brain, assembles context, injects it into any LLM. Automatic memory management and token budgeting.</div>
                <div class="layer-arrow">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                </div>
            </div>

            <!-- Layer 3: Think -->
            <div class="layer-card">
                <div class="layer-card__num">03 &mdash; Think</div>
                <div class="layer-card__icon layer-card__icon--think">
                    <svg viewBox="0 0 24 24" fill="none" stroke="#1a9e82" stroke-width="1.5"><path d="M12 2a7 7 0 017 7c0 3-2 5-3.5 6.5S14 18 14 20h-4c0-2-.5-3.5-2-5S5 12 5 9a7 7 0 017-7z"/><path d="M10 20h4v1a2 2 0 01-2 2 2 2 0 01-2-2v-1z"/></svg>
                </div>
                <div class="layer-card__title">Any LLM</div>
                <div class="layer-card__sub">Your Choice</div>
                <div class="layer-card__desc">Claude today. GPT tomorrow. Gemini next week. The intelligence isn't in the model &mdash; it's in your Org Brain. Switch providers without losing a single memory.</div>
            </div>
        </div>
    </div>
</section>

<!-- ===== SECTION 4: INSIDE THE PLATFORM ===== -->
<section class="platform" id="platform">
    <div class="platform__inner">
        <div class="section__header reveal">
            <h2 class="section__h"><strong>Two modes. One intelligence layer.</strong></h2>
            <div class="section__header-right">
                <p class="body-lg">Workspace operates in two modes &mdash; Excavation for building the Org Brain, Document for putting it to work. Both connect to the same memory system through the same AI Chief of Staff.</p>
            </div>
        </div>

        <div class="platform__modes">
            <!-- Excavation Mode -->
            <div class="mode-card reveal">
                <div class="mode-card__icon mode-card__icon--excavation">&#9998;</div>
                <div class="mode-card__title">Excavation Mode</div>
                <div class="mode-card__desc">Guided installers excavate organizational knowledge through structured conversation. Your answers become governed memory.</div>
                <div class="mode-card__visual">
                    <div class="mode-mock__line">
                        <span class="mode-mock__dot" style="background:var(--brand)"></span>
                        <span class="mode-mock__text mode-mock__text--long mode-mock__text--brand"></span>
                    </div>
                    <div class="mode-mock__line">
                        <span class="mode-mock__dot" style="background:var(--border)"></span>
                        <span class="mode-mock__text mode-mock__text--med"></span>
                    </div>
                    <div class="mode-mock__divider"></div>
                    <div class="mode-mock__line">
                        <span class="mode-mock__dot" style="background:var(--accent-teal)"></span>
                        <span class="mode-mock__text mode-mock__text--long mode-mock__text--teal"></span>
                    </div>
                    <div class="mode-mock__line">
                        <span class="mode-mock__dot" style="background:var(--border)"></span>
                        <span class="mode-mock__text mode-mock__text--short"></span>
                    </div>
                    <div class="mode-mock__divider"></div>
                    <div style="display:flex;gap:8px;margin-top:4px">
                        <span class="mode-mock__chip">MA01 Purpose</span>
                        <span class="mode-mock__chip">MA05 Vision</span>
                    </div>
                </div>
            </div>

            <!-- Document Mode -->
            <div class="mode-card reveal reveal-d1">
                <div class="mode-card__icon mode-card__icon--document">&#128196;</div>
                <div class="mode-card__title">Document Mode</div>
                <div class="mode-card__desc">Work on project deliverables with your entire Org Brain loaded as context. Web copy, proposals, reports &mdash; all in your organization's voice.</div>
                <div class="mode-card__visual">
                    <div class="mode-mock__line">
                        <span class="mode-mock__dot" style="background:#635bff"></span>
                        <span class="mode-mock__text mode-mock__text--long mode-mock__text--purple"></span>
                    </div>
                    <div class="mode-mock__line">
                        <span class="mode-mock__dot" style="background:var(--border)"></span>
                        <span class="mode-mock__text mode-mock__text--long"></span>
                    </div>
                    <div class="mode-mock__line">
                        <span class="mode-mock__dot" style="background:var(--border)"></span>
                        <span class="mode-mock__text mode-mock__text--med"></span>
                    </div>
                    <div class="mode-mock__divider"></div>
                    <div class="mode-mock__line">
                        <span class="mode-mock__dot" style="background:var(--border)"></span>
                        <span class="mode-mock__text mode-mock__text--long"></span>
                    </div>
                    <div class="mode-mock__line">
                        <span class="mode-mock__dot" style="background:var(--border)"></span>
                        <span class="mode-mock__text mode-mock__text--short"></span>
                    </div>
                    <div style="display:flex;gap:8px;margin-top:4px">
                        <span class="mode-mock__chip">MA20 Position</span>
                        <span class="mode-mock__chip">MA28 Identity</span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Feature cards -->
        <div class="platform__features">
            <div class="feat-card reveal reveal-d2">
                <div class="feat-card__icon">&#128279;</div>
                <div class="feat-card__body">
                    <div class="feat-card__title">Inline References</div>
                    <div class="feat-card__desc">Semantic addresses appear as clickable chips. Click MA20 mid-conversation to see your Competitive Position without leaving the thread.</div>
                </div>
            </div>
            <div class="feat-card reveal reveal-d3">
                <div class="feat-card__icon">&#128218;</div>
                <div class="feat-card__body">
                    <div class="feat-card__title">Capture Learning</div>
                    <div class="feat-card__desc">Extract patterns from every project. Lessons learned and process improvements become Learning Memories that compound over time.</div>
                </div>
            </div>
        </div>
    </div>
</section>

<hr class="glow-line">

<!-- ===== SECTION 5: THREE STEPS ===== -->
<section class="steps" id="steps">
    <div class="steps__inner">
        <div class="section__header reveal">
            <h2 class="section__h"><strong>Three steps to intelligence.</strong></h2>
            <div class="section__header-right">
                <p class="body-lg">Open a project. Let context load. Generate an artifact that already knows you.</p>
            </div>
        </div>

        <div class="steps__grid">
            <!-- Step 1 -->
            <div class="step reveal">
                <div class="step__text">
                    <div class="step__num">01 &mdash; Create a Session</div>
                    <div class="step__title">Open a project, create a session.</div>
                    <div class="step__desc">The system already knows you. Your Org Brain loads automatically.</div>
                </div>
                <div class="step__visual">
                    <div class="step-mock__bar">
                        <div class="step-mock__dots"><span class="step-mock__dot"></span><span class="step-mock__dot"></span><span class="step-mock__dot"></span></div>
                        <div class="step-mock__title">Projects</div>
                    </div>
                    <div class="step-mock__body">
                        <div class="step1-projects" id="step1Projects">
                            <div class="step1-proj is-active">
                                <div class="step1-proj__icon step1-proj__icon--brain">&#129504;</div>
                                <div class="step1-proj__info">
                                    <div class="step1-proj__name">Q2 Campaign Strategy</div>
                                    <div class="step1-proj__meta">3 sessions &middot; Updated 2h ago</div>
                                </div>
                                <span class="step1-proj__badge step1-proj__badge--connected">Connected</span>
                            </div>
                            <div class="step1-proj">
                                <div class="step1-proj__icon step1-proj__icon--doc">&#128196;</div>
                                <div class="step1-proj__info">
                                    <div class="step1-proj__name">Enterprise Page Copy</div>
                                    <div class="step1-proj__meta">1 session &middot; Updated 1d ago</div>
                                </div>
                                <span class="step1-proj__badge step1-proj__badge--brain">Org Brain</span>
                            </div>
                            <div class="step1-proj">
                                <div class="step1-proj__icon step1-proj__icon--gear">&#9881;</div>
                                <div class="step1-proj__info">
                                    <div class="step1-proj__name">Investor Update Draft</div>
                                    <div class="step1-proj__meta">2 sessions &middot; Updated 3d ago</div>
                                </div>
                                <span class="step1-proj__badge step1-proj__badge--brain">Org Brain</span>
                            </div>
                        </div>
                        <div class="step1-status">
                            <span class="step1-status__dot"></span>
                            Org Brain connected &middot; 28 memories loaded
                        </div>
                    </div>
                </div>
            </div>

            <!-- Step 2 -->
            <div class="step step--reverse reveal reveal-d1">
                <div class="step__text">
                    <div class="step__num">02 &mdash; Add Context</div>
                    <div class="step__title">The right knowledge loads.</div>
                    <div class="step__desc">Persistent memory, active work, and learned patterns &mdash; all through semantic addressing.</div>
                </div>
                <div class="step__visual">
                    <div class="step-mock__bar">
                        <div class="step-mock__dots"><span class="step-mock__dot"></span><span class="step-mock__dot"></span><span class="step-mock__dot"></span></div>
                        <div class="step-mock__title">Context</div>
                    </div>
                    <div class="step-mock__body">
                        <div class="step2-ctx" id="step2Ctx">
                            <div class="step2-mem is-loaded">
                                <span class="step2-mem__dot" style="background:var(--brand)"></span>
                                <div class="step2-mem__info">
                                    <div class="step2-mem__label">Brand Voice &amp; Tone</div>
                                    <div class="step2-mem__sub">Persistent Memory</div>
                                </div>
                                <span class="step2-mem__code">MA28</span>
                                <span class="step2-mem__check">
                                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#1a9e82" stroke-width="3"><path d="M5 13l4 4L19 7"/></svg>
                                </span>
                            </div>
                            <div class="step2-mem is-loaded">
                                <span class="step2-mem__dot" style="background:var(--accent-teal)"></span>
                                <div class="step2-mem__info">
                                    <div class="step2-mem__label">Competitive Position</div>
                                    <div class="step2-mem__sub">Persistent Memory</div>
                                </div>
