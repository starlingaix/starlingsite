<script is:inline>
/* ========================================================
   SCROLL REVEAL
   ======================================================== */
(function(){
    const io = new IntersectionObserver((entries) => {
        entries.forEach(e => { if(e.isIntersecting){ e.target.classList.add('is-visible'); io.unobserve(e.target); }});
    }, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' });
    document.querySelectorAll('.reveal').forEach(el => io.observe(el));
})();

/* ========================================================
   HERO CANVAS — Floating particle network
   ======================================================== */
(function(){
    const canvas = document.getElementById('heroCanvas');
    if(!canvas) return;
    const ctx = canvas.getContext('2d');
    let w, h, particles = [];
    const COLORS = ['rgba(212,112,44,0.12)','rgba(54,209,183,0.10)','rgba(155,93,229,0.10)','rgba(99,91,255,0.10)'];

    function resize(){ w = canvas.width = canvas.offsetWidth; h = canvas.height = canvas.offsetHeight; }
    function init(){
        resize();
        particles = [];
        const count = Math.min(60, Math.floor(w * h / 12000));
        for(let i = 0; i < count; i++){
            particles.push({
                x: Math.random()*w, y: Math.random()*h,
                vx: (Math.random()-0.5)*0.3, vy: (Math.random()-0.5)*0.3,
                r: Math.random()*2+1,
                color: COLORS[Math.floor(Math.random()*COLORS.length)]
            });
        }
    }
    function draw(){
        ctx.clearRect(0,0,w,h);
        for(let i = 0; i < particles.length; i++){
            const p = particles[i];
            p.x += p.vx; p.y += p.vy;
            if(p.x < 0 || p.x > w) p.vx *= -1;
            if(p.y < 0 || p.y > h) p.vy *= -1;
            ctx.beginPath();
            ctx.arc(p.x, p.y, p.r, 0, Math.PI*2);
            ctx.fillStyle = p.color;
            ctx.fill();
            for(let j = i+1; j < particles.length; j++){
                const q = particles[j];
                const dx = p.x-q.x, dy = p.y-q.y;
                const dist = Math.sqrt(dx*dx+dy*dy);
                if(dist < 120){
                    ctx.beginPath();
                    ctx.moveTo(p.x, p.y);
                    ctx.lineTo(q.x, q.y);
                    ctx.strokeStyle = `rgba(212,112,44,${0.06*(1-dist/120)})`;
                    ctx.lineWidth = 0.5;
                    ctx.stroke();
                }
            }
        }
        requestAnimationFrame(draw);
    }
    init(); draw();
    window.addEventListener('resize', init);
})();

/* ========================================================
   HERO — Trigger is-loaded + Interactive Workspace Illustration
   ======================================================== */
(function(){
    const hero = document.querySelector('.ws-hero');
    if(!hero) return;
    requestAnimationFrame(() => hero.classList.add('is-loaded'));

    const card      = document.getElementById('wsCard');
    const mems      = [];
    for(let i=0;i<6;i++) mems.push(document.getElementById('wsMem'+i));
    const prompt    = document.getElementById('illoPrompt');
    const promptTxt = document.getElementById('illoPromptText');
    const cursor    = document.getElementById('illoCursor');
    const rows      = [];
    for(let i=0;i<6;i++) rows.push(document.getElementById('illoRow'+i));
    const chips     = [];
    for(let i=0;i<3;i++) chips.push(document.getElementById('illoChip'+i));
    const badge     = document.getElementById('illoBadge');
    const badgeTxt  = document.getElementById('illoBadgeText');
    const barStatus = document.getElementById('illoBarStatus');
    const dot1      = document.getElementById('illoDot1');
    const dot2      = document.getElementById('illoDot2');
    const dot3      = document.getElementById('illoDot3');
    const replay    = document.getElementById('illoReplay');

    const PROMPT = 'Draft a win-back email for churned enterprise accounts';
    const FLOAT_DELAYS = [0, 0.7, 1.3, 0.5, 1.0, 0.3];

    function reset(){
        card.classList.remove('is-visible');
        mems.forEach(m => { m.classList.remove('is-visible','is-pulsing','is-floating'); m.style.animationDelay = ''; });
        prompt.classList.remove('is-visible','is-active');
        promptTxt.textContent = '';
        cursor.style.display = 'none';
        rows.forEach(r => r.classList.remove('is-visible'));
        chips.forEach(ch => ch.classList.remove('is-visible'));
        badge.classList.remove('is-visible','is-complete');
        badgeTxt.textContent = 'Initializing\u2026';
        barStatus.classList.remove('is-active');
        [dot1,dot2,dot3].forEach(d => d.classList.remove('is-green'));
        replay.classList.remove('is-visible');
    }

    function run(){
        reset();
        let t = 400;

        /* 1 — Workspace card slides in */
        setTimeout(() => { card.classList.add('is-visible'); dot1.classList.add('is-green'); }, t);

        /* 2 — Memory chips pop in one by one */
        [0,1,2,3,4,5].forEach((idx,i) => {
            setTimeout(() => mems[idx].classList.add('is-visible'), t + 300 + i * 250);
        });

        /* 3 — Badge appears */
        t += 300 + 6 * 250 + 200;
        setTimeout(() => { badge.classList.add('is-visible'); badgeTxt.textContent = 'Loading memories\u2026'; }, t);

        /* 4 — Prompt typing */
        t += 300;
        setTimeout(() => {
            prompt.classList.add('is-visible','is-active');
            cursor.style.display = '';
            let ci = 0;
            const typeInt = setInterval(() => {
                ci++;
                promptTxt.textContent = PROMPT.slice(0, ci);
                if(ci >= PROMPT.length){
                    clearInterval(typeInt);
                    setTimeout(() => { cursor.style.display = 'none'; prompt.classList.remove('is-active'); }, 300);
                }
            }, 28);
        }, t);

        /* 5 — Pulse memory chips (consult) with popup flash */
        t += PROMPT.length * 28 + 500;
        [0,1,2,3,4,5].forEach((idx,i) => {
            setTimeout(() => {
                mems[idx].classList.add('is-pulsing');
                badgeTxt.textContent = `${i+1}/6 memories consulted`;
                setTimeout(() => mems[idx].classList.remove('is-pulsing'), 800);
            }, t + i * 350);
        });

        /* 6 — Generate output */
        t += 6 * 350 + 300;
        setTimeout(() => { dot2.classList.add('is-green'); barStatus.classList.add('is-active'); }, t);
        rows.forEach((row,i) => {
            setTimeout(() => row.classList.add('is-visible'), t + 80 + i * 180);
        });

        /* 7 — Inline ref chips */
        t += 80 + 6 * 180 + 250;
        chips.forEach((ch,i) => {
            setTimeout(() => ch.classList.add('is-visible'), t + i * 180);
        });

        /* 8 — Complete */
        t += 3 * 180 + 350;
        setTimeout(() => {
            dot3.classList.add('is-green');
            badge.classList.add('is-complete');
            badgeTxt.textContent = '\u2726 Artifact Ready \u2014 DLM Active';
            /* Start gentle floating */
            mems.forEach((m,i) => {
                m.classList.add('is-floating');
                m.style.animationDelay = FLOAT_DELAYS[i] + 's';
            });
            setTimeout(() => replay.classList.add('is-visible'), 500);
        }, t);
    }

    /* Interactive: hover ref chips → highlight corresponding memory */
    const MEM_MAP = [0,1,3]; // chip 0→mem0 (MA20), chip 1→mem1 (MA28), chip 2→mem3 (VL01)
    chips.forEach((ch,i) => {
        ch.addEventListener('mouseenter', () => {
            const m = mems[MEM_MAP[i]];
            if(m) m.classList.add('is-pulsing');
        });
        ch.addEventListener('mouseleave', () => {
            const m = mems[MEM_MAP[i]];
            if(m) m.classList.remove('is-pulsing');
        });
    });

    replay.addEventListener('click', run);
    setTimeout(run, 700);
})();

/* ========================================================
   STEP 2 — Animated context loading
   ======================================================== */
(function(){
    const items = document.querySelectorAll('#step2Ctx .step2-mem');
    if(!items.length) return;
    const io = new IntersectionObserver((entries) => {
        entries.forEach(e => {
            if(!e.isIntersecting) return;
            items.forEach((item, i) => {
                item.classList.remove('is-loaded');
                setTimeout(() => item.classList.add('is-loaded'), 300 + i * 350);
            });
            io.unobserve(e.target);
        });
    }, { threshold: 0.3 });
    io.observe(document.getElementById('step2Ctx'));
})();

/* ========================================================
   DLM EQUATION — Interactive node switching + auto-cycle
   ======================================================== */
(function(){
    const nodes = document.querySelectorAll('#dlmBar .dlm-bar__node');
    const panels = document.querySelectorAll('#dlmDetail .dlm-detail__card');
    if(!nodes.length) return;

    function activate(key){
        nodes.forEach(n => n.classList.toggle('is-active', n.dataset.dlm === key));
        panels.forEach(p => {
            p.classList.remove('is-active');
            p.style.animation = 'none';
        });
        const target = document.querySelector(`[data-dlm-panel="${key}"]`);
        if(target){
            // Trigger reflow to restart animation
            void target.offsetWidth;
            target.style.animation = '';
            target.classList.add('is-active');
        }
    }

    nodes.forEach(n => n.addEventListener('click', () => {
        activate(n.dataset.dlm);
        clearInterval(autoTimer);
        // Restart auto-cycle after 10s of inactivity
        autoTimer = setInterval(cycle, 4500);
    }));

    const keys = ['llm','mcp','uca','org','dlm'];
    let idx = 0;
    function cycle(){
        idx = (idx + 1) % keys.length;
        activate(keys[idx]);
    }
    let autoTimer = setInterval(cycle, 4500);
})();

/* ========================================================
   DLM SECTION CANVAS — Subtle floating grid
   ======================================================== */
(function(){
    const canvas = document.getElementById('dlmCanvas');
    if(!canvas) return;
    const ctx = canvas.getContext('2d');
    let w, h, dots = [];

    function resize(){ w = canvas.width = canvas.offsetWidth; h = canvas.height = canvas.offsetHeight; }
    function init(){
        resize(); dots = [];
        const count = Math.min(40, Math.floor(w * h / 20000));
        for(let i = 0; i < count; i++){
            dots.push({
                x: Math.random()*w, y: Math.random()*h,
                vx: (Math.random()-0.5)*0.15, vy: (Math.random()-0.5)*0.15,
                r: Math.random()*1.5+0.5,
                color: ['rgba(212,112,44,0.12)','rgba(54,209,183,0.10)','rgba(155,93,229,0.10)','rgba(99,91,255,0.08)'][Math.floor(Math.random()*4)]
            });
        }
    }
    function draw(){
        ctx.clearRect(0,0,w,h);
        for(let i=0;i<dots.length;i++){
            const p = dots[i];
            p.x += p.vx; p.y += p.vy;
            if(p.x<0||p.x>w) p.vx*=-1;
            if(p.y<0||p.y>h) p.vy*=-1;
            ctx.beginPath(); ctx.arc(p.x,p.y,p.r,0,Math.PI*2);
            ctx.fillStyle = p.color; ctx.fill();
            for(let j=i+1;j<dots.length;j++){
                const q=dots[j], dx=p.x-q.x, dy=p.y-q.y, dist=Math.sqrt(dx*dx+dy*dy);
                if(dist<150){
                    ctx.beginPath();ctx.moveTo(p.x,p.y);ctx.lineTo(q.x,q.y);
                    ctx.strokeStyle=`rgba(255,255,255,${0.04*(1-dist/150)})`;ctx.lineWidth=0.5;ctx.stroke();
                }
            }
        }
        requestAnimationFrame(draw);
    }
    init(); draw();
    window.addEventListener('resize', init);
})();
</script>
</BaseLayout>

