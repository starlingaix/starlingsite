---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---
<BaseLayout title="Starling AIX | Cognitive Design — Build Your Org Brain" description="9 weeks to your working Org Brain. Build your cognitive AI system and get certified as the dataset administrator every AI-native company needs.">
<Nav currentPage="cognitive-design" />
<main>

<!-- ===== HERO ===== -->
<section class="cd-hero">
    <!-- clean white hero bg -->
    <div class="cd-hero__inner">
        <div>
            <div class="cd-hero__badge reveal">
                <span class="cd-hero__badge-dot"></span>
                9-Week Certification Program
            </div>
            <h1 class="cd-hero__title reveal reveal-d1"><strong>Build your working Org Brain</strong> in 9 weeks.</h1>
            <p class="cd-hero__desc reveal reveal-d2">A drip-learning system undertaken in natural conversation with AI. Build your cognitive AI system and get certified as the dataset administrator every AI-native company needs.</p>
            <div class="btn-group reveal reveal-d3">
                <a href="#pricing" class="btn btn--primary btn--large">
                    Enroll Now
                    <svg class="arrow" width="10" height="10" fill="none" stroke="currentColor" stroke-width="2"><path d="M0.5 5.5h7"/><path d="M5.5 1.5l4 4-4 4"/></svg>
                </a>
                <a href="#program" class="btn btn--secondary btn--large">See the Curriculum</a>
            </div>
        </div>
        <div class="cd-hero__visual reveal reveal-d2">
            <div class="brain-builder" id="brainBuilder">
                <div class="brain-builder__bar">
                    <div class="brain-builder__dots">
                        <span class="brain-builder__dot" id="bbDot1"></span>
                        <span class="brain-builder__dot" id="bbDot2"></span>
                        <span class="brain-builder__dot" id="bbDot3"></span>
                    </div>
                    <span class="brain-builder__bar-title">
                        <span class="brain-builder__bar-status"></span>
                        Org Brain Builder
                    </span>
                </div>
                <div class="brain-builder__body">
                    <div class="bb-week" data-week="1"><div class="bb-week__num" style="background:linear-gradient(135deg,var(--brand),#e8945a)">1</div><div class="bb-week__info"><div class="bb-week__name">Cognitive Design</div><div class="bb-week__tag">Starling OS</div></div><div class="bb-week__progress"><div class="bb-week__fill" style="background:var(--brand)"></div></div></div>
                    <div class="bb-week" data-week="2"><div class="bb-week__num" style="background:linear-gradient(135deg,var(--brand),#e8945a)">2</div><div class="bb-week__info"><div class="bb-week__name">The 17 Value Systems</div><div class="bb-week__tag">Identity</div></div><div class="bb-week__progress"><div class="bb-week__fill" style="background:var(--brand)"></div></div></div>
                    <div class="bb-week" data-week="3"><div class="bb-week__num" style="background:linear-gradient(135deg,#1a9e82,var(--accent-teal))">3</div><div class="bb-week__info"><div class="bb-week__name">Open Road</div><div class="bb-week__tag">Market</div></div><div class="bb-week__progress"><div class="bb-week__fill" style="background:#1a9e82"></div></div></div>
                    <div class="bb-week" data-week="4"><div class="bb-week__num" style="background:linear-gradient(135deg,var(--accent-blue),#9b5de5)">4</div><div class="bb-week__info"><div class="bb-week__name">Value Mapping</div><div class="bb-week__tag">Innovation</div></div><div class="bb-week__progress"><div class="bb-week__fill" style="background:#635bff"></div></div></div>
                    <div class="bb-week" data-week="5"><div class="bb-week__num" style="background:linear-gradient(135deg,var(--accent-pink),#e06090)">5</div><div class="bb-week__info"><div class="bb-week__name">Impact Branding</div><div class="bb-week__tag">Brand</div></div><div class="bb-week__progress"><div class="bb-week__fill" style="background:#F56493"></div></div></div>
                    <div class="bb-milestone"><div class="bb-milestone__dot"></div>First Fifteen<div class="bb-milestone__line"></div></div>
                    <div class="bb-week" data-week="6"><div class="bb-week__num" style="background:linear-gradient(135deg,#0d0f14,#2a2f42)">6</div><div class="bb-week__info"><div class="bb-week__name">Domain Depth</div><div class="bb-week__tag">Strategy</div></div><div class="bb-week__progress"><div class="bb-week__fill" style="background:#2a2f42"></div></div></div>
                    <div class="bb-week" data-week="7"><div class="bb-week__num" style="background:linear-gradient(135deg,#1a9e82,var(--accent-teal))">7</div><div class="bb-week__info"><div class="bb-week__name">Work as Memory</div><div class="bb-week__tag">Active Memory</div></div><div class="bb-week__progress"><div class="bb-week__fill" style="background:#1a9e82"></div></div></div>
                    <div class="bb-week" data-week="8"><div class="bb-week__num" style="background:linear-gradient(135deg,var(--accent-blue),var(--accent-teal))">8</div><div class="bb-week__info"><div class="bb-week__name">The Intelligence Loop</div><div class="bb-week__tag">Learning</div></div><div class="bb-week__progress"><div class="bb-week__fill" style="background:#635bff"></div></div></div>
                    <div class="bb-week" data-week="9"><div class="bb-week__num" style="background:linear-gradient(135deg,var(--brand-dark),var(--brand))">9</div><div class="bb-week__info"><div class="bb-week__name">Governing Intelligence</div><div class="bb-week__tag">Certification</div></div><div class="bb-week__progress"><div class="bb-week__fill" style="background:var(--brand)"></div></div></div>
                </div>
                <div class="brain-builder__footer">
                    <div class="bb-stat"><div class="bb-stat__val" id="bbMemories">0</div><div class="bb-stat__label">Memories</div></div>
                    <div class="bb-stat"><div class="bb-stat__val" id="bbWeek">—</div><div class="bb-stat__label">Active Week</div></div>
                    <div class="bb-stat"><div class="bb-stat__val" id="bbProgress">0%</div><div class="bb-stat__label">Complete</div></div>
                </div>
            </div>
        </div>
    </div>
</section>

<hr class="glow-line">

<!-- ===== SECTION 2: THE CORE INSIGHT ===== -->
<section class="section section--gray" id="insight">
    <div class="container">
        <div class="section__header reveal">
            <h2 class="section__h"><strong>The Core Insight.</strong> Every AI conversation disappears when the session ends.</h2>
            <div class="section__header-right">
                <p class="body-lg">Every workflow you build inside a platform belongs to that platform. Switch tools, lose everything. An Org Brain changes that — sovereign, portable, structured in plain language that any LLM can read.</p>
            </div>
        </div>

        <div class="insight-cards">
            <div class="insight-card insight-card--before reveal reveal-d1">
                <span class="insight-card__tag insight-card__tag--before">
                    <span class="insight-card__tag-dot" style="background:var(--accent-pink)"></span>
                    Without Org Brain
                </span>
                <h3 class="insight-card__title">Every session starts from zero.</h3>
                <div class="insight-card__list">
                    <div class="insight-card__item"><span class="insight-card__item-icon">🔄</span><span><strong>Context vanishes</strong> — re-teach your AI every conversation</span></div>
                    <div class="insight-card__item"><span class="insight-card__item-icon">🔗</span><span><strong>Platform lock-in</strong> — switch vendors, lose everything</span></div>
                    <div class="insight-card__item"><span class="insight-card__item-icon">📈</span><span><strong>Token cost scales</strong> with org size — no ceiling</span></div>
                    <div class="insight-card__item"><span class="insight-card__item-icon">🧱</span><span><strong>Generic outputs</strong> — AI doesn't know your business</span></div>
                </div>
                <div class="insight-card__stream">
                    <div class="insight-card__stream-line" style="background:var(--accent-pink);animation-delay:0s"></div>
                    <div class="insight-card__stream-line" style="background:var(--accent-pink);animation-delay:1.2s;opacity:0.5"></div>
                    <div class="insight-card__stream-line" style="background:var(--accent-pink);animation-delay:2.4s;opacity:0.3"></div>
                </div>
            </div>

            <div class="insight-card insight-card--after reveal reveal-d2">
                <span class="insight-card__tag insight-card__tag--after">
                    <span class="insight-card__tag-dot" style="background:#1a9e82"></span>
                    With Org Brain
                </span>
                <div class="insight-card__pulse"></div>
                <h3 class="insight-card__title">Intelligence that compounds.</h3>
                <div class="insight-card__list">
                    <div class="insight-card__item"><span class="insight-card__item-icon">📍</span><span><strong>Persistent memory</strong> — every session builds on the last</span></div>
                    <div class="insight-card__item"><span class="insight-card__item-icon">🏗️</span><span><strong>Sovereign architecture</strong> — you own it, move it, control it</span></div>
                    <div class="insight-card__item"><span class="insight-card__item-icon">⚡</span><span><strong>O(1) lookup</strong> — constant cost regardless of scale</span></div>
                    <div class="insight-card__item"><span class="insight-card__item-icon">🎯</span><span><strong>Strategic outputs</strong> — AI knows your identity, values, goals</span></div>
                </div>
            </div>
        </div>

        <div class="stat-bar reveal reveal-d3">
            <div class="stat-item"><div class="stat-item__val"><span class="counter" data-target="9">0</span></div><div class="stat-item__label">Weeks to completion</div></div>
            <div class="stat-item"><div class="stat-item__val"><span class="counter" data-target="15" data-suffix="+">0</span></div><div class="stat-item__label">Constitutional Memories</div></div>
            <div class="stat-item"><div class="stat-item__val"><span class="counter" data-target="4">0</span></div><div class="stat-item__label">Memory Tiers</div></div>
            <div class="stat-item"><div class="stat-item__val"><span class="counter" data-target="1">0</span></div><div class="stat-item__label">Certification</div></div>
        </div>
    </div>
</section>

<!-- ===== SECTION 3: WHAT YOU BUILD — Interactive Memory Explorer ===== -->
<section class="section section--white" id="architecture">
    <div class="container">
        <div class="section__header reveal">
            <h2 class="section__h"><strong>A complete organizational memory system.</strong> Four tiers. Semantic addressing.</h2>
            <div class="section__header-right">
                <p class="body-lg">This is the architecture that makes session-based AI remember your business. Governed knowledge that your AI reads by name — not by searching.</p>
            </div>
        </div>

        <div class="tier-explorer reveal reveal-d1" id="tierExplorer">
            <div class="tier-explorer__sidebar">
                <span class="tier-explorer__sidebar-title">Memory Tiers</span>
                <div class="tier-explorer__tab is-active" data-tier="system">
                    <span class="tier-explorer__tab-dot" style="background:var(--brand)"></span>
                    System
                    <span class="tier-explorer__tab-range">00–19</span>
                </div>
                <div class="tier-explorer__tab" data-tier="constitutional">
                    <span class="tier-explorer__tab-dot" style="background:var(--accent-teal)"></span>
                    Constitutional
                    <span class="tier-explorer__tab-range">20–23</span>
                </div>
                <div class="tier-explorer__tab" data-tier="persistent">
                    <span class="tier-explorer__tab-dot" style="background:var(--accent-blue)"></span>
                    Persistent
                    <span class="tier-explorer__tab-range">20–49</span>
                </div>
                <div class="tier-explorer__tab" data-tier="active">
                    <span class="tier-explorer__tab-dot" style="background:var(--accent-pink)"></span>
                    Active
                    <span class="tier-explorer__tab-range">50–79</span>
                </div>
                <div class="tier-explorer__tab" data-tier="learned">
                    <span class="tier-explorer__tab-dot" style="background:var(--accent-yellow)"></span>
                    Learned
                    <span class="tier-explorer__tab-range">80–99</span>
                </div>
            </div>
            <div class="tier-explorer__content">
                <div class="tier-explorer__panel is-active" data-tier-panel="system">
                    <div class="tier-explorer__panel-header">
                        <span class="tier-explorer__panel-badge" style="background:var(--brand)">00–19</span>
                        <span class="tier-explorer__panel-name">System Memory</span>
                    </div>
                    <p class="tier-explorer__panel-desc">Operating logic and architecture. The foundational layer that governs how your AI reads, writes, and references organizational memory. This tier includes the operating prompt, cognitive architecture, and semantic addressing protocol.</p>
                    <div class="tier-explorer__examples">
                        <span class="tier-explorer__example">Operating Prompt</span>
                        <span class="tier-explorer__example">Cognitive Architecture</span>
                        <span class="tier-explorer__example">Semantic Addressing</span>
                        <span class="tier-explorer__example">UCA Framework</span>
                    </div>
                </div>
                <div class="tier-explorer__panel" data-tier-panel="constitutional">
                    <div class="tier-explorer__panel-header">
                        <span class="tier-explorer__panel-badge" style="background:var(--accent-teal)">20–23</span>
                        <span class="tier-explorer__panel-name">Constitutional Memory</span>
                    </div>
                    <p class="tier-explorer__panel-desc">Core identity and strategy. The 15+ memories that define who your organization is — values, competitive position, product roadmap, brand voice. These are the memories that make AI output sound like you.</p>
                    <div class="tier-explorer__examples">
                        <span class="tier-explorer__example">Cultural Values</span>
                        <span class="tier-explorer__example">Competitive Position</span>
                        <span class="tier-explorer__example">Product Roadmap</span>
                        <span class="tier-explorer__example">Brand Voice</span>
                    </div>
                </div>
                <div class="tier-explorer__panel" data-tier-panel="persistent">
                    <div class="tier-explorer__panel-header">
                        <span class="tier-explorer__panel-badge" style="background:var(--accent-blue)">20–49</span>
                        <span class="tier-explorer__panel-name">Persistent Memory</span>
                    </div>
                    <p class="tier-explorer__panel-desc">Extended strategic depth. Core innovations, intellectual property strategy, technology infrastructure, brand nomenclature, brand story — the deeper context that gives your AI expert-level domain knowledge.</p>
                    <div class="tier-explorer__examples">
                        <span class="tier-explorer__example">IP Strategy</span>
                        <span class="tier-explorer__example">Brand Nomenclature</span>
                        <span class="tier-explorer__example">Remote Work Protocols</span>
                        <span class="tier-explorer__example">Tech Infrastructure</span>
                    </div>
                </div>
                <div class="tier-explorer__panel" data-tier-panel="active">
                    <div class="tier-explorer__panel-header">
                        <span class="tier-explorer__panel-badge" style="background:var(--accent-pink)">50–79</span>
                        <span class="tier-explorer__panel-name">Active Memory</span>
                    </div>
                    <p class="tier-explorer__panel-desc">Daily work as addressable memory. Live campaigns, projects, and deliverables that reference your Constitutional Memories by semantic address. This is where strategy meets execution.</p>
                    <div class="tier-explorer__examples">
                        <span class="tier-explorer__example">Q2 Campaign Brief</span>
                        <span class="tier-explorer__example">Enterprise Page Copy</span>
                        <span class="tier-explorer__example">Product Launch Plan</span>
                        <span class="tier-explorer__example">Hiring Strategy</span>
                    </div>
                </div>
                <div class="tier-explorer__panel" data-tier-panel="learned">
                    <div class="tier-explorer__panel-header">
                        <span class="tier-explorer__panel-badge" style="background:var(--accent-yellow)">80–99</span>
                        <span class="tier-explorer__panel-name">Learned Memory</span>
                    </div>
                    <p class="tier-explorer__panel-desc">Extracted patterns from operations. Decision patterns, communication approaches, process improvements, market insights discovered through real work. This is where your Org Brain gets smarter over time.</p>
                    <div class="tier-explorer__examples">
                        <span class="tier-explorer__example">Direct outreach converts 3× cold email</span>
                        <span class="tier-explorer__example">Process Improvements</span>
                        <span class="tier-explorer__example">Market Insights</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- ===== SECTION 4: THE PROGRAM (9 Modules) ===== -->
<section class="section section--gray" id="program">
    <div class="container">
        <div class="section__header reveal">
            <h2 class="section__h"><strong>Your business canon,</strong> built week by week.</h2>
            <div class="section__header-right">
                <p class="body-lg">Each week, we ship an iPub — a training framework that doubles as a dataset plug-in. You read the narrative. Your AI runs the framework. Together, you establish the Single Sources of Truth.</p>
            </div>
        </div>

        <div class="module-list">
            <div class="module reveal reveal-d1">
                <div class="module__header"><div class="module__icon" style="background:linear-gradient(135deg,var(--brand),#e8945a)">1</div><div class="module__info"><div class="module__week">Week 1</div><div class="module__name">Cognitive Design</div></div><span class="module__badge">Starling OS</span><svg class="module__chevron" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z"/></svg></div>
                <div class="module__body"><div class="module__content"><p>Cognitive Design is the methodology that makes organizations speakable to AI. This iPub introduces the discipline — what it is, why it exists, and how it works. You'll learn the memory tier architecture, semantic addressing, and why persistence beats permanence.</p><p>This iPub ships with Starling OS — the operating logic that governs how your AI reads, writes, and references organizational memory.</p><div class="module__outputs"><span class="module__output-tag">Starling OS</span><span class="module__output-tag">Context Node</span><span class="module__output-tag">UCA Framework</span><span class="module__output-tag">Semantic Addressing</span></div></div></div>
            </div>
            <div class="module reveal reveal-d2">
                <div class="module__header"><div class="module__icon" style="background:linear-gradient(135deg,var(--brand),#e8945a)">2</div><div class="module__info"><div class="module__week">Week 2</div><div class="module__name">The 17 Value Systems</div></div><span class="module__badge">Identity</span><svg class="module__chevron" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z"/></svg></div>
                <div class="module__body"><div class="module__content"><p>The foundation everything else builds on. Anchors your business in dynamic Value Systems — operational values that prove themselves through observable behavior. Each system includes discovery questions, self-validation tests, and integration logic.</p><p>Tell an AI "we value excellence" and it produces platitudes. Give it codified Value Systems — with validation patterns and measurement logic — and it becomes a strategic asset.</p><div class="module__outputs"><span class="module__output-tag">Cultural Values</span><span class="module__output-tag">Product Values</span><span class="module__output-tag">Dual Metrics</span><span class="module__output-tag">Customer Values</span><span class="module__output-tag">Market Values</span></div></div></div>
            </div>
            <div class="module reveal reveal-d3">
                <div class="module__header"><div class="module__icon" style="background:linear-gradient(135deg,#1a9e82,var(--accent-teal))">3</div><div class="module__info"><div class="module__week">Week 3</div><div class="module__name">Open Road</div></div><span class="module__badge">Market</span><svg class="module__chevron" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z"/></svg></div>
                <div class="module__body"><div class="module__content"><p>Three frameworks that map your competitive landscape: the Four Corner Analysis for positioning, the Open Road Canvas for business model design, and the Four Factor Method for revenue optimization.</p><div class="module__outputs"><span class="module__output-tag">Competitive Position</span><span class="module__output-tag">Business Model</span><span class="module__output-tag">Revenue Strategy</span></div></div></div>
            </div>
            <div class="module reveal reveal-d4">
                <div class="module__header"><div class="module__icon" style="background:linear-gradient(135deg,var(--accent-blue),#9b5de5)">4</div><div class="module__info"><div class="module__week">Week 4</div><div class="module__name">Value Mapping</div></div><span class="module__badge">Innovation</span><svg class="module__chevron" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z"/></svg></div>
                <div class="module__body"><div class="module__content"><p>Customer Value Mapping builds your product roadmap through the Viable → Lovable → Indispensable progression. Market Value Mapping defines your growth strategy with release architecture and market entry sequencing.</p><div class="module__outputs"><span class="module__output-tag">Product Roadmap</span><span class="module__output-tag">Growth Strategy</span></div></div></div>
            </div>
            <div class="module reveal reveal-d5">
                <div class="module__header"><div class="module__icon" style="background:linear-gradient(135deg,var(--accent-pink),#e06090)">5</div><div class="module__info"><div class="module__week">Week 5</div><div class="module__name">Impact Branding</div></div><span class="module__badge">Brand</span><svg class="module__chevron" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z"/></svg></div>
                <div class="module__body"><div class="module__content"><p>The Four Quadrants framework for brand positioning. The Four Campaigns architecture for market expression. Brand strategy that your AI can execute — not just describe.</p><div class="module__outputs"><span class="module__output-tag">Brand Positioning</span><span class="module__output-tag">Market Expression</span><span class="module__output-tag">Stakeholder Comms</span></div></div></div>
            </div>

            <div class="milestone reveal"><div class="milestone__dot"></div><div class="milestone__text"><strong>Milestone — The First Fifteen.</strong> You've codified enough constitutional memories to give your AI the strategic context to extrapolate what comes next.</div></div>

            <div class="module reveal">
                <div class="module__header"><div class="module__icon" style="background:linear-gradient(135deg,#0d0f14,#2a2f42)">6</div><div class="module__info"><div class="module__week">Week 6</div><div class="module__name">Domain Depth</div></div><span class="module__badge">Strategy</span><svg class="module__chevron" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z"/></svg></div>
                <div class="module__body"><div class="module__content"><p>The First Fifteen give your AI strategic context. Persistent Intelligence deepens it — core innovations, intellectual property strategy, technology infrastructure, brand nomenclature, brand story, and the systematic intelligence process.</p><div class="module__outputs"><span class="module__output-tag">Core Innovations</span><span class="module__output-tag">IP Strategy</span><span class="module__output-tag">Tech Infrastructure</span><span class="module__output-tag">Brand Nomenclature</span><span class="module__output-tag">Brand Story</span></div></div></div>
            </div>
            <div class="module reveal">
                <div class="module__header"><div class="module__icon" style="background:linear-gradient(135deg,#1a9e82,var(--accent-teal))">7</div><div class="module__info"><div class="module__week">Week 7</div><div class="module__name">Work as Memory</div></div><span class="module__badge">Active Memory</span><svg class="module__chevron" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z"/></svg></div>
                <div class="module__body"><div class="module__content"><p>Work is the most valuable form of organizational memory. This module builds your Active Memory layer — live campaigns, projects, and deliverables that reference your Constitutional Memories by semantic address.</p><div class="module__outputs"><span class="module__output-tag">Active Memory Structure</span><span class="module__output-tag">Campaign Masters</span><span class="module__output-tag">Project Architecture</span><span class="module__output-tag">Canon-Connected Work</span></div></div></div>
            </div>
            <div class="module reveal">
