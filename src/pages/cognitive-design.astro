---
import Layout from '../layouts/Layout.astro';

const weeks = [
  {
    n:'01', name:'Cognitive Design', badge:'Starling OS +',
    title:'Cognitive Design: The Operating System for AI-Native Business',
    one:'The methodology, the operating system, and your first Memory Node. Everything starts here.',
    body:'Cognitive Design is the methodology that makes organisations speakable to AI. This iPub introduces the discipline — what it is, why it exists, and how it works. You\'ll learn the memory tier architecture, semantic addressing, and why persistence beats permanence.\n\nThis iPub ships with Starling OS — the operating logic that governs how your AI reads, writes, and references organisational memory.',
    tags:['Starling OS','Context Node','UCA Framework','Semantic Addressing'],
  },
  {
    n:'02', name:'The 17 Value Systems', badge:'Identity +',
    title:'The 17 Value Systems Every Business Needs to Codify',
    one:'Your product, cultural, customer, and market values — and the machine and human metrics that measure them.',
    body:'The foundation everything else builds on. The 17 Value Systems anchors your business in dynamic Value Systems — operational values that prove themselves through observable behaviour. Each system includes discovery questions, self-validation tests, and integration logic.',
    tags:['Cultural Values','Product Values','Dual Metrics','Customer Values','Market Values'],
  },
  {
    n:'03', name:'Open Road', badge:'Market +',
    title:'Open Road Canvas: From Competitive Analysis to Category Creation',
    one:'Where you compete. Competitive position, business model, and revenue strategy.',
    body:'Three frameworks that map your competitive landscape: the Four Corner Analysis for positioning, the Open Road Canvas for business model design, and the Four Factor Method for revenue optimisation.\n\nYou finish knowing exactly where you compete, how your business model works, and the levers that drive revenue.',
    tags:['Competitive Position','Business Model','Revenue Strategy'],
  },
  {
    n:'04', name:'Value Mapping', badge:'Innovation +',
    title:'Value Mapping: Customer Impact Analysis and Innovation Planning',
    one:'What you\'re building. Product roadmap and growth strategy, codified.',
    body:'Customer Value Mapping (CVM) builds your product roadmap through the Viable → Lovable → Indispensable progression. Market Value Mapping (MVM) defines your growth strategy with release architecture and market entry sequencing.',
    tags:['Product Roadmap','Growth Strategy'],
  },
  {
    n:'05', name:'Impact Branding', badge:'Brand +',
    title:'Impact Branding: The Four Quadrants of Authentic Market Expression',
    one:'How you\'re known. Brand positioning, campaigns, and stakeholder communications.',
    body:'The Four Quadrants framework for brand positioning. The Four Campaigns architecture for market expression. The Four Archetypes for stakeholder communications. Brand strategy that your AI can execute — not just describe.',
    tags:['Brand Positioning','Market Expression','Stakeholder Comms'],
    milestone:'The First Fifteen. You\'ve codified enough constitutional memories to give your AI the strategic context to extrapolate what comes next.',
  },
  {
    n:'06', name:'Domain Depth', badge:'Strategy +',
    title:'Domain Depth: Extending Your Strategic Foundation',
    one:'Extended strategic depth. Core Boosters that expand your Org Brain beyond the First Fifteen.',
    body:'Persistent Intelligence deepens your foundation — core innovations, intellectual property strategy, technology infrastructure, brand nomenclature, brand story, and the systematic intelligence process.',
    tags:['Core Innovations','IP Strategy','Technology Infrastructure','Brand Nomenclature','Brand Story'],
  },
  {
    n:'07', name:'Work as Memory', badge:'Active Memory +',
    title:'Work As Memory: How Active Projects Build Organisational Intelligence',
    one:'Active campaigns and projects, connected to your canon. Your work becomes organisational memory.',
    body:'Work is the most valuable form of organisational memory. This module builds your Active Memory layer — live campaigns, projects, and deliverables that reference your Constitutional Memories by semantic address.',
    tags:['Active Memory Structure','Campaign Masters','Project Architecture','Canon-Connected Work'],
  },
  {
    n:'08', name:'The Intelligence Loop', badge:'Learning Memory +',
    title:'The Intelligence Loop: How Work Becomes Wisdom',
    one:'Lessons learned. The patterns your organisation discovers through real work.',
    body:'The third memory tier — Learning Memories. Decision patterns, communication approaches, process improvements, market insights, and team dynamics extracted from actual operations.',
    tags:['Learning Memory Structure','Decision Patterns','Process Improvements','Market Insights'],
  },
  {
    n:'09', name:'Governing Intelligence', badge:'Certification +',
    title:'Governing Intelligence: Human Oversight for AI-Native Organisations',
    one:'The essential tools of a System Librarian. Demonstrate mastery and earn the credential.',
    body:'The capstone iPub. What a System Librarian does, what tools they use, and what competencies define the role. How to maintain an Org Brain over time — updating memories, running diagnostics, managing active work folders, and extracting learned patterns.\n\nThen prove it. Record a Loom walkthrough that demonstrates you can build, explain, and defend the work.',
    tags:['System Librarian Competency Model','Org Brain Maintenance Protocol','Mastery Walkthrough Certification'],
    cert: true,
  },
];

const testimonials = [
  { quote:'In 20 minutes, it took me from being overwhelmed with information to only 53 of my attachments being unattached. That huge mental burden on recall — gone.', name:'Brady Patterson', role:'CEO, Brady OS' },
  { quote:'I ran the diagnostic on our Org Brain and spent 12 hours straight rebuilding everything. Found hallucinations, contradictions from old positioning mixed with new SOPs, missing elements. It was the most productive day we\'d had all year.', name:'Tristan Guilbeault', role:'CEO, Wrks Online' },
  { quote:'Now I feel like the cloud has clarity and lightness. You\'ve taken something incredibly complex and dynamic — like very dynamic, functional living systems — and structured it into something that can work for someone.', name:'Jamie Sullivan', role:'Founder, The Truffle Box' },
];
---

<Layout
  title="Cognitive Design — 9 Weeks to Your Org Brain | Starling AIX"
  description="An AI-guided discovery process. 9 weeks to your working Org Brain. Build your cognitive AI system and get certified as the dataset administrator every AI-native company needs."
>

<!-- ── Hero ──────────────────────────────────────────────────── -->
<section style="position:relative;overflow:hidden;padding:7rem 0 6rem;background:#ffffff;border-bottom:1px solid rgba(0,0,0,0.07);">
  <div style="position:absolute;inset:0;pointer-events:none;background-image:linear-gradient(rgba(0,0,0,0.018) 1px,transparent 1px),linear-gradient(90deg,rgba(0,0,0,0.018) 1px,transparent 1px);background-size:72px 72px;"></div>
  <div style="position:absolute;inset:0;pointer-events:none;background:radial-gradient(ellipse 50% 40% at 50% 0%,rgba(224,100,28,0.04) 0%,transparent 65%);"></div>
  <div class="container" style="position:relative;z-index:1;">

    <div class="stag stag-o fade-up" data-delay="0" style="margin-bottom:1.5rem;">Starling AIX · Cognitive Design</div>

    <h1 class="fade-up" data-delay="0.08"
        style="font-family:'Bitter',Georgia,serif;font-weight:700;font-size:clamp(3rem,8vw,5.5rem);margin:0 0 1.5rem;max-width:820px;letter-spacing:-0.04em;line-height:1;color:#0c0c0c;">
      9 weeks to your working <em style="color:#e0641c;font-style:italic;">Org Brain.</em>
    </h1>

    <p class="fade-up" data-delay="0.15"
       style="font-family:'Inter Tight',system-ui,sans-serif;font-size:1.05rem;color:#4a4a4a;line-height:1.75;max-width:560px;margin:0 0 0.5rem;">
      Build your cognitive AI system and get certified as the dataset administrator every AI-native company needs.
    </p>
    <p class="fade-up" data-delay="0.17"
       style="font-family:'Inter Tight',system-ui,sans-serif;font-size:0.875rem;color:#888;margin:0 0 2.5rem;">
      A drip-learning system undertaken in natural conversation with AI.
    </p>

    <div class="fade-up" data-delay="0.2" style="display:flex;gap:0.75rem;flex-wrap:wrap;">
      <a href="#pricing" class="btn btn-org">Enroll Now →</a>
      <a href="#curriculum" class="btn-ghost-light">See the Curriculum</a>
    </div>

  </div>
</section>

<!-- ── Core Insight ───────────────────────────────────────────── -->
<section style="background:#f2f1ee;padding:5rem 0;border-top:1px solid rgba(0,0,0,0.07);">
  <div class="container">
    <div class="feat-header">
      <div>
        <div class="stag stag-o fade-up" data-delay="0" style="margin-bottom:1.25rem;">1.0 · The Problem</div>
        <h2 class="feat-h2 fade-up" data-delay="0.06">
          Stop renting your business intelligence.
        </h2>
      </div>
      <div>
        <p class="feat-body fade-up" data-delay="0.1">
          Every AI conversation you have disappears when the session ends. Every workflow you build inside a platform belongs to that platform. Switch tools, lose everything.
        </p>
        <p class="feat-body fade-up" data-delay="0.13" style="margin-bottom:0;">
          An Org Brain changes that. It's yours — sovereign, portable, structured in plain language that any LLM can read. Claude today, something else tomorrow. The knowledge travels because it lives in your infrastructure, not theirs.
        </p>
      </div>
    </div>
  </div>
</section>

<!-- ── Memory Architecture ────────────────────────────────────── -->
<section style="background:#ffffff;padding:5rem 0;border-top:1px solid rgba(0,0,0,0.07);">
  <div class="container">
    <div class="feat-header">
      <div>
        <div class="stag stag-g fade-up" data-delay="0" style="margin-bottom:1.25rem;">2.0 · What You Build</div>
        <h2 class="feat-h2 fade-up" data-delay="0.06">
          A complete organisational memory system.
        </h2>
      </div>
      <div>
        <p class="feat-body fade-up" data-delay="0.1">
          Four memory tiers. Semantic addressing. Governed knowledge that your AI reads by name. This is the architecture that makes session-based AI remember your business — not just the world.
        </p>
      </div>
    </div>

    <!-- Memory architecture wide mockup — dark for contrast -->
    <div class="wide-mock fade-up" data-delay="0.16">
      <div class="mock-bar">
        <span class="mock-dot r"></span><span class="mock-dot y"></span><span class="mock-dot g"></span>
        <span style="font-family:'JetBrains Mono',monospace;font-size:0.7rem;color:#3f3f46;margin-left:0.75rem;">Org Brain — Memory Architecture</span>
        <span style="margin-left:auto;font-family:'JetBrains Mono',monospace;font-size:0.68rem;color:#28c840;display:flex;align-items:center;gap:0.35rem;">
          <span style="width:6px;height:6px;border-radius:50%;background:#28c840;"></span>
          28 Memories Active
        </span>
      </div>
      <div style="display:flex;flex-direction:column;gap:0;">
        {[
          { tier:'System', range:'00–19', desc:'Operating logic and architecture', items:['Operating Prompt','Cognitive Architecture','Semantic Addressing'], color:'#52525b' },
          { tier:'Constitutional', range:'20–23', desc:'Core identity and strategy', items:['Cultural Values','Competitive Position','Product Roadmap'], color:'#60a5fa' },
          { tier:'Persistent', range:'24–49', desc:'Extended strategic depth', items:['IP Strategy','Brand Nomenclature','Remote Work Protocols'], color:'#a78bfa' },
          { tier:'Active', range:'50–79', desc:'Daily work as addressable memory', items:['Q2 Campaign Brief','Enterprise Page Copy','Board Deck'], color:'#2dd4bf' },
          { tier:'Learned', range:'80–99', desc:'Extracted patterns from operations', items:['Direct outreach converts 3× cold email','Q1 retro → async works'], color:'#34d399' },
        ].map(({ tier, range, desc, items, color }, i, arr) => (
          <div style={`padding:1.25rem 2rem;display:flex;gap:2rem;align-items:flex-start;flex-wrap:wrap;${i < arr.length - 1 ? 'border-bottom:1px solid rgba(255,255,255,0.05);' : ''}`}>
            <div style="min-width:160px;">
              <span style={`font-family:'JetBrains Mono',monospace;font-size:0.7rem;color:${color};`}>{tier} <span style="color:#3f3f46;">{range}</span></span>
              <p style="font-size:0.78rem;color:#3f3f46;margin:0.2rem 0 0;">{desc}</p>
            </div>
            <div style="display:flex;gap:0.4rem;flex-wrap:wrap;flex:1;">
              {items.map(t => (
                <span style="font-family:'JetBrains Mono',monospace;font-size:0.65rem;padding:0.2rem 0.55rem;border-radius:999px;border:1px solid rgba(255,255,255,0.1);color:#71717a;">{t}</span>
              ))}
            </div>
          </div>
        ))}
      </div>
      <div style="padding:1.25rem 2rem;border-top:1px solid rgba(255,255,255,0.06);display:flex;flex-wrap:wrap;gap:0.75rem;align-items:center;">
        <span style="font-size:0.8rem;color:#52525b;">11 Cognates · 4 Memory Tiers · Semantic Addressing</span>
        <span class="badge" style="margin-left:auto;">UCA Free Standard</span>
      </div>
    </div>

  </div>
</section>

<!-- ── Image Split: What You Build ────────────────────────────── -->
<div class="img-split" style="border-top:1px solid rgba(0,0,0,0.07);">
  <div class="img-split-photo">
    <img src="/images/women-teal.png" alt="Building your Org Brain" loading="lazy" />
    <div class="img-split-overlay">
      <div style="display:flex;gap:0.75rem;flex-wrap:wrap;">
        <div style="padding:0.65rem 1rem;border:1px solid rgba(96,165,250,0.3);border-radius:8px;background:rgba(0,0,0,0.6);backdrop-filter:blur(8px);">
          <div style="font-family:'Bitter',Georgia,serif;font-size:1.5rem;font-weight:700;color:#60a5fa;line-height:1;letter-spacing:-0.03em;">9</div>
          <div style="font-family:'JetBrains Mono',monospace;font-size:0.58rem;color:#71717a;text-transform:uppercase;letter-spacing:0.08em;margin-top:0.25rem;">Weeks</div>
        </div>
        <div style="padding:0.65rem 1rem;border:1px solid rgba(167,139,250,0.3);border-radius:8px;background:rgba(0,0,0,0.6);backdrop-filter:blur(8px);">
          <div style="font-family:'Bitter',Georgia,serif;font-size:1.5rem;font-weight:700;color:#a78bfa;line-height:1;letter-spacing:-0.03em;">28</div>
          <div style="font-family:'JetBrains Mono',monospace;font-size:0.58rem;color:#71717a;text-transform:uppercase;letter-spacing:0.08em;margin-top:0.25rem;">Memories</div>
        </div>
        <div style="padding:0.65rem 1rem;border:1px solid rgba(45,212,191,0.3);border-radius:8px;background:rgba(0,0,0,0.6);backdrop-filter:blur(8px);">
          <div style="font-family:'Bitter',Georgia,serif;font-size:1.5rem;font-weight:700;color:#2dd4bf;line-height:1;letter-spacing:-0.03em;">4</div>
          <div style="font-family:'JetBrains Mono',monospace;font-size:0.58rem;color:#71717a;text-transform:uppercase;letter-spacing:0.08em;margin-top:0.25rem;">Tiers</div>
        </div>
      </div>
    </div>
  </div>
  <div class="img-split-content" style="background:#f2f1ee;padding:4rem 2.5rem;">
    <p class="feat-num" style="margin-bottom:1rem;">What you build</p>
    <h2 class="feat-h2" style="margin-bottom:1.25rem;">
      Sovereign memory.<br/>Built in weeks.
    </h2>
    <p style="font-family:'Inter Tight',system-ui,sans-serif;font-size:0.95rem;color:#4a4a4a;line-height:1.75;margin:0 0 2rem;">
      Every iPub you complete produces a real, working memory node — governed, addressed, and ready for any LLM. You don't finish with a certification and a PDF. You finish with a functioning AI system that knows your business.
    </p>
    <div style="display:flex;flex-direction:column;gap:0.85rem;">
      {[
        { color:'#60a5fa', label:'Constitutional Layer', desc:'15+ identity and strategy memories codified by week 5' },
        { color:'#a78bfa', label:'Persistent Layer', desc:'11 operational memories extending your strategic depth' },
        { color:'#2dd4bf', label:'Active + Learned Layers', desc:'Live work and extracted patterns that compound over time' },
      ].map(({ color, label, desc }) => (
        <div style={`display:flex;gap:0.85rem;align-items:flex-start;padding:0.85rem 1rem;border-radius:8px;background:rgba(0,0,0,0.025);border-left:2px solid ${color};`}>
          <div>
            <p style={`font-family:'Inter Tight',sans-serif;font-size:0.82rem;font-weight:600;color:${color};margin:0 0 0.2rem;letter-spacing:-0.01em;`}>{label}</p>
            <p style="font-family:'Inter Tight',sans-serif;font-size:0.8rem;color:#4a4a4a;margin:0;line-height:1.5;">{desc}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</div>

<!-- ── Curriculum ─────────────────────────────────────────────── -->
<section id="curriculum" style="background:#ffffff;padding:5rem 0;border-top:1px solid rgba(0,0,0,0.07);">
  <div class="container">
    <div class="feat-header" style="margin-bottom:3rem;">
      <div>
        <div class="stag stag-o fade-up" data-delay="0" style="margin-bottom:1.25rem;">3.0 · The Program</div>
        <h2 class="feat-h2 fade-up" data-delay="0.06">
          Your business canon,<br/>built week by week.
        </h2>
      </div>
      <div>
        <p class="feat-body fade-up" data-delay="0.1">
          Each week we ship an iPub — a training framework that doubles as a dataset plug-in. You read the narrative. Your AI runs the framework. As you establish your business fundamentals, Cognitive Design codifies organisational knowledge into sovereign, governed, architecturally complete memory.
        </p>
      </div>
    </div>

    <div style="display:flex;flex-direction:column;gap:1px;border:1px solid rgba(0,0,0,0.08);border-radius:12px;overflow:hidden;">
      {weeks.map((w, i) => (
        <div class="fade-up" data-delay={String(i*0.04)}
             style="padding:2rem;border-radius:0;border:none;border-bottom:1px solid rgba(0,0,0,0.06);background:#ffffff;">
          <div style="display:grid;grid-template-columns:1fr;gap:1.25rem;" class="week-inner">
            <div>
              <div style="display:flex;align-items:center;gap:0.75rem;margin-bottom:0.75rem;flex-wrap:wrap;">
                <span class="week-num" style="color:#60a5fa;">Week {w.n}</span>
                <span class="badge badge-accent">{w.badge}</span>
              </div>
              <h3 style="font-family:'Bitter',Georgia,serif;font-size:1rem;font-weight:600;color:#0c0c0c;margin:0 0 0.4rem;letter-spacing:-0.01em;">{w.title}</h3>
              <p style="font-family:'Inter Tight',sans-serif;font-size:0.85rem;color:#60a5fa;margin:0 0 0.75rem;">{w.one}</p>
              <p style="font-family:'Inter Tight',sans-serif;font-size:0.875rem;color:#4a4a4a;line-height:1.7;margin:0 0 1rem;white-space:pre-line;">{w.body}</p>
              <div style="display:flex;gap:0.4rem;flex-wrap:wrap;">
                {w.tags.map(t => <span style="font-family:'JetBrains Mono',monospace;font-size:0.63rem;padding:0.18rem 0.55rem;border-radius:999px;border:1px solid rgba(0,0,0,0.1);color:#888;">{t}</span>)}
              </div>
            </div>
          </div>
          {w.milestone && (
            <div style="margin-top:1.5rem;padding:1rem 1.25rem;border:1px solid rgba(96,165,250,0.25);border-radius:8px;background:rgba(96,165,250,0.05);">
              <p style="font-size:0.82rem;color:#60a5fa;margin:0;font-family:'JetBrains Mono',monospace;">Milestone — {w.milestone}</p>
            </div>
          )}
          {w.cert && (
            <div style="margin-top:1.5rem;padding:1rem 1.25rem;border:1px solid rgba(45,212,191,0.3);border-radius:8px;background:rgba(45,212,191,0.05);">
              <p style="font-size:0.82rem;color:#2dd4bf;margin:0;font-family:'JetBrains Mono',monospace;">All 9 weeks complete. You've built your Innovation System. Complete a mastery walkthrough for System Librarian certification.</p>
            </div>
          )}
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ── How It Works ───────────────────────────────────────────── -->
<section style="background:#f2f1ee;padding:5rem 0;border-top:1px solid rgba(0,0,0,0.07);">
  <div class="container">
    <div class="feat-header">
      <div>
        <div class="stag stag-o fade-up" data-delay="0" style="margin-bottom:1.25rem;">4.0 · How It Works</div>
        <h2 class="feat-h2 fade-up" data-delay="0.06">
          iPubs + Claude + Office Hours + Mastery Gate.
        </h2>
      </div>
      <div>
        <p class="feat-body fade-up" data-delay="0.1">
          Each iPub produces real organisational memory: governed, addressable, and sovereign. This program requires Claude by Anthropic. Starling OS runs as a Claude Project — the free tier works for discovery, but Claude Max ($99/mo) is recommended for extended daily use.
        </p>
      </div>
    </div>

    <div style="display:grid;grid-template-columns:1fr;gap:1.25rem;" class="how-grid">
      {[
        ['📚','iPubs','Read along to understand the proprietary business frameworks. Run the installer to produce real organisational memory. Kindle + Machine-Ready MD Edition.'],
        ['💬','Office Hours','Weekly group sessions with guided discovery. AI summaries available to all subscribers. Not required for certification — but the fastest path to mastery.'],
        ['🏆','Mastery Gate','Certification requires a recorded Loom walkthrough — demonstrating you can build, explain, and defend the work. The gate is competence, not seat time.'],
        ['⏱','9-Week Drip','One module per week. Focused enough to build momentum, paced enough to absorb. Your working Org Brain in eight weeks; certification in nine.'],
      ].map(([icon, title, body]) => (
        <div class="card-light fade-up" data-delay="0.05" style="padding:1.75rem;">
          <div style="font-size:1.5rem;margin-bottom:0.75rem;">{icon}</div>
          <h3 style="font-family:'Inter Tight',sans-serif;font-size:0.95rem;font-weight:600;color:#0c0c0c;margin:0 0 0.5rem;">{title}</h3>
          <p style="font-family:'Inter Tight',sans-serif;font-size:0.875rem;color:#4a4a4a;line-height:1.7;margin:0;">{body}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ── Pricing ────────────────────────────────────────────────── -->
<section id="pricing" style="background:#ffffff;padding:5rem 0;border-top:1px solid rgba(0,0,0,0.07);">
  <div class="container">
    <div class="cta-row">

      <!-- Left: pricing card -->
      <div class="card-light fade-up" data-delay="0" style="padding:2.5rem;border-top:2px solid rgba(96,165,250,0.4);">
        <div style="display:flex;align-items:flex-start;justify-content:space-between;flex-wrap:wrap;gap:1rem;margin-bottom:1.5rem;">
          <div>
            <span class="badge badge-accent" style="margin-bottom:0.75rem;display:inline-flex;">Program 1</span>
            <h3 style="font-family:'Bitter',Georgia,serif;font-size:1.4rem;margin:0.5rem 0 0.25rem;color:#0c0c0c;letter-spacing:-0.02em;font-weight:700;">Build Your Org Brain</h3>
            <p style="font-family:'Inter Tight',sans-serif;font-size:0.8rem;color:#888;margin:0;">From Innovation to Applied Intelligence</p>
          </div>
          <div style="text-align:right;">
            <div style="font-family:'Bitter',Georgia,serif;font-size:2.8rem;color:#0c0c0c;line-height:1;font-weight:700;letter-spacing:-0.04em;">$999</div>
            <p style="font-family:'Inter Tight',sans-serif;font-size:0.8rem;color:#888;margin:0.25rem 0 0;">or 3 × $333/mo</p>
          </div>
        </div>

        <hr style="border:none;border-top:1px solid rgba(0,0,0,0.08);margin:1.5rem 0;" />

        <p style="font-family:'Inter',sans-serif;font-size:0.62rem;color:#888;text-transform:uppercase;letter-spacing:0.1em;margin:0 0 0.75rem;font-weight:600;">What's In the Box</p>
        <div style="display:flex;flex-direction:column;gap:0.55rem;margin-bottom:1.75rem;">
          {[
            '9 iPubs — the training frameworks that are also your AI plug-ins',
            'Starling OS — the operating logic that powers every session',
            'Office Hours access — weekly guided discovery sessions',
            'System Librarian Certification Exam',
          ].map(t => <div class="check-item">{t}</div>)}
        </div>

        <hr style="border:none;border-top:1px solid rgba(0,0,0,0.08);margin:1.5rem 0;" />
        <a href="https://calendly.com/starlingaix" target="_blank" rel="noopener" class="btn btn-org" style="width:100%;justify-content:center;padding:0.8rem;font-size:0.95rem;">
          Get Started →
        </a>
      </div>

      <!-- Right: what you'll produce -->
      <div class="fade-up" data-delay="0.1">
        <div class="stag stag-o" style="margin-bottom:1.25rem;">4.0 · Pricing</div>
        <h2 class="feat-h2" style="margin-bottom:1rem;">
          Mach 1 business.<br/>A career-defining credential.
        </h2>
