<script is:inline>
/* ========================================================
   SCROLL REVEAL
   ======================================================== */
(function(){
    const io = new IntersectionObserver((entries) => {
        entries.forEach(e => { if(e.isIntersecting){ e.target.classList.add('is-visible'); io.unobserve(e.target); }});
    }, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' });
    document.querySelectorAll('.reveal').forEach(el => io.observe(el));
})();

/* ========================================================
   ANIMATED COUNTERS
   ======================================================== */
(function(){
    const counters = document.querySelectorAll('.counter');
    const cio = new IntersectionObserver((entries) => {
        entries.forEach(e => {
            if(!e.isIntersecting) return;
            const el = e.target;
            const target = +el.dataset.target;
            const suffix = el.dataset.suffix || '';
            let current = 0;
            const step = Math.max(1, Math.floor(target / 30));
            const timer = setInterval(() => {
                current += step;
                if(current >= target){ current = target; clearInterval(timer); }
                el.textContent = current + suffix;
            }, 40);
            cio.unobserve(el);
        });
    }, { threshold: 0.5 });
    counters.forEach(c => cio.observe(c));
})();

/* ========================================================
   MODULE ACCORDION
   ======================================================== */
(function(){
    document.querySelectorAll('.module__header').forEach(header => {
        header.addEventListener('click', () => {
            const mod = header.parentElement;
            const wasOpen = mod.classList.contains('is-open');
            document.querySelectorAll('.module').forEach(m => m.classList.remove('is-open'));
            if(!wasOpen) mod.classList.add('is-open');
        });
    });
})();

/* ========================================================
   TIER EXPLORER — Tab switching
   ======================================================== */
(function(){
    const tabs = document.querySelectorAll('.tier-explorer__tab');
    const panels = document.querySelectorAll('.tier-explorer__panel');
    tabs.forEach(tab => {
        tab.addEventListener('click', () => {
            tabs.forEach(t => t.classList.remove('is-active'));
            panels.forEach(p => p.classList.remove('is-active'));
            tab.classList.add('is-active');
            const tier = tab.dataset.tier;
            document.querySelector(`[data-tier-panel="${tier}"]`).classList.add('is-active');
        });
    });
    // Auto-cycle every 4s
    let tierIdx = 0;
    const tierKeys = ['system','constitutional','persistent','active','learned'];
    setInterval(() => {
        const explorer = document.getElementById('tierExplorer');
        if(!explorer) return;
        const rect = explorer.getBoundingClientRect();
        if(rect.top > window.innerHeight || rect.bottom < 0) return;
        tierIdx = (tierIdx + 1) % tierKeys.length;
        tabs.forEach(t => t.classList.remove('is-active'));
        panels.forEach(p => p.classList.remove('is-active'));
        const key = tierKeys[tierIdx];
        document.querySelector(`[data-tier="${key}"]`).classList.add('is-active');
        document.querySelector(`[data-tier-panel="${key}"]`).classList.add('is-active');
    }, 4000);
})();

/* ========================================================
   BRAIN BUILDER — Hero mockup auto-cycling
   ======================================================== */
(function(){
    const weeks = document.querySelectorAll('.bb-week');
    if(!weeks.length) return;
    let idx = 0;
    const memoryMap = [3,5,2,2,3,5,4,4,2]; // memories produced each week
    const dots = [document.getElementById('bbDot1'),document.getElementById('bbDot2'),document.getElementById('bbDot3')];
    const memEl = document.getElementById('bbMemories');
    const weekEl = document.getElementById('bbWeek');
    const progEl = document.getElementById('bbProgress');

    function activate(i){
        weeks.forEach((w,wi) => {
            w.classList.remove('is-active');
            w.classList.toggle('is-done', wi < i);
            const fill = w.querySelector('.bb-week__fill');
            fill.style.width = wi < i ? '100%' : wi === i ? '0%' : '0%';
        });
        const w = weeks[i];
        w.classList.add('is-active');
        setTimeout(() => {
            w.querySelector('.bb-week__fill').style.width = '100%';
        }, 100);

        // Update stats
        let totalMem = 0;
        for(let j = 0; j <= i; j++) totalMem += memoryMap[j];
        memEl.textContent = totalMem;
        weekEl.textContent = (i + 1);
        progEl.textContent = Math.round(((i + 1) / 9) * 100) + '%';

        // Dot colors
        dots[0].classList.add('is-red');
        dots[1].classList.add('is-yellow');
        dots[2].classList.add('is-green');
    }

    activate(0);

    setInterval(() => {
        const mockup = document.getElementById('brainBuilder');
        const rect = mockup.getBoundingClientRect();
        if(rect.top < window.innerHeight && rect.bottom > 0){
            idx = (idx + 1) % weeks.length;
            activate(idx);
        }
    }, 2500);

    weeks.forEach((w, i) => {
        w.addEventListener('click', () => { idx = i; activate(i); });
    });
})();

/* Hero canvas removed — clean white background */

/* ── Flow Simulator (How It Works) ── */
const flowStages = document.querySelectorAll('.flow-sim__stage');
const flowDots   = document.querySelectorAll('.flow-sim__progress-dot');
const flowWeek   = document.getElementById('flowWeekBadge');
const flowOut    = document.getElementById('flowOutputText');
const flowTag    = document.getElementById('flowOutputTag');
let flowIdx = 0;

const flowData = [
    {step:0, output:'Output: 3 memory artifacts installed into your working Org Brain', tag:'Memory Stored'},
    {step:1, output:'Output: Constitutional alignment verified, persistent layer updated', tag:'AI Validated'},
    {step:2, output:'Output: Session summary + peer insights distributed to all participants', tag:'Cycle Complete'}
];
const flowWeeks = [
    {badge:'Week 3', label:'Persistent Memory & Constitutional Layers'},
    {badge:'Week 5', label:'Decision Engines & Governance Protocols'},
    {badge:'Week 8', label:'Integration Testing & Certification Prep'}
];
let flowWeekIdx = 0;

function setFlowStage(i){
    flowIdx = i;
    flowStages.forEach((s,idx) => s.classList.toggle('is-active', idx === i));
    flowDots.forEach((d,idx) => d.classList.toggle('is-active', idx === i));
    flowOut.textContent = flowData[i].output;
    flowTag.textContent = flowData[i].tag;
}
window.setFlowStage = setFlowStage;

setInterval(() => {
    const sim = document.querySelector('.flow-sim');
    if(!sim) return;
    const rect = sim.getBoundingClientRect();
    if(rect.top < window.innerHeight && rect.bottom > 0){
        flowIdx = (flowIdx + 1) % 3;
        setFlowStage(flowIdx);
        if(flowIdx === 0){
            flowWeekIdx = (flowWeekIdx + 1) % flowWeeks.length;
            flowWeek.textContent = flowWeeks[flowWeekIdx].badge;
            document.querySelector('.flow-sim__week-label').textContent = flowWeeks[flowWeekIdx].label;
        }
    }
}, 3000);
</script>
