.cd-hero__bg{position:absolute;inset:0;z-index:0;pointer-events:none}
.cd-hero__bg canvas{width:100%;height:100%}
.cd-hero__inner{
    position:relative;z-index:2;max-width:var(--max-w);margin:0 auto;
    padding:calc(var(--nav-h) + var(--hero-pad)) var(--pad-x) var(--hero-pad);
    display:grid;grid-template-columns:1fr;gap:48px;align-items:center;
}
@media(min-width:768px){.cd-hero__inner{grid-template-columns:1fr 1fr;gap:64px}}
.cd-hero__badge{
    display:inline-flex;align-items:center;gap:8px;
    padding:6px 16px;border-radius:var(--radius-pill);
    background:var(--brand-pale);border:1px solid rgba(212,112,44,0.15);
    font-size:12px;font-weight:600;color:var(--brand);text-transform:uppercase;letter-spacing:0.06em;
    margin-bottom:28px;
}
.cd-hero__badge-dot{width:6px;height:6px;border-radius:50%;background:var(--brand);animation:badgePulse 2s ease infinite}
@keyframes badgePulse{0%,100%{opacity:1;box-shadow:0 0 0 0 rgba(212,112,44,0.4)}50%{opacity:0.7;box-shadow:0 0 0 6px rgba(212,112,44,0)}}
.cd-hero__title{
    font-size:clamp(2rem,4.5vw,50px);font-weight:400;line-height:1.1;letter-spacing:-0.025em;
    color:var(--text-secondary);margin-bottom:20px;
}
.cd-hero__title strong{font-weight:500;color:var(--text-primary)}
.cd-hero__desc{font-size:clamp(1rem,1.4vw,1.125rem);color:var(--text-secondary);line-height:1.7;margin-bottom:32px;max-width:540px}

/* ── Hero: Org Brain Builder mockup ── */
.cd-hero__visual{display:flex;align-items:center;justify-content:center}
.brain-builder{
    width:100%;max-width:440px;border:1px solid var(--border);border-radius:var(--radius-lg);
    background:var(--bg-white);box-shadow:var(--shadow-lg);overflow:hidden;
}
.brain-builder__bar{
    display:flex;align-items:center;gap:8px;padding:10px 16px;
    background:var(--bg-gray);border-bottom:1px solid var(--border);
}
.brain-builder__dots{display:flex;gap:5px}
.brain-builder__dot{width:8px;height:8px;border-radius:50%;background:var(--border);transition:background 0.4s}
.brain-builder__dot.is-green{background:#34d399}
.brain-builder__dot.is-yellow{background:#fbbf24}
.brain-builder__dot.is-red{background:#f87171}
.brain-builder__bar-title{
    margin-left:auto;font-size:11px;font-weight:600;color:var(--text-muted);
    text-transform:uppercase;letter-spacing:0.06em;display:flex;align-items:center;gap:6px;
}
.brain-builder__bar-status{width:6px;height:6px;border-radius:50%;background:var(--accent-teal);animation:bbStatusPulse 2s ease infinite}
@keyframes bbStatusPulse{0%,100%{opacity:1}50%{opacity:0.3}}

.brain-builder__body{padding:16px;display:flex;flex-direction:column;gap:10px}

/* Week rows */
.bb-week{
    display:grid;grid-template-columns:32px 1fr 56px;gap:10px;align-items:center;
    padding:8px 10px;border-radius:var(--radius);transition:all 0.35s ease;cursor:default;
    border:1px solid transparent;
}
.bb-week:hover{background:var(--bg-gray)}
.bb-week.is-active{background:var(--brand-pale);border-color:rgba(212,112,44,0.12)}
.bb-week.is-done{opacity:0.85}
.bb-week__num{
    width:28px;height:28px;border-radius:8px;display:flex;align-items:center;justify-content:center;
    font-size:10px;font-weight:800;color:#fff;flex-shrink:0;
    transition:transform 0.3s,box-shadow 0.3s;
}
.bb-week.is-active .bb-week__num{transform:scale(1.1);box-shadow:0 2px 8px rgba(0,0,0,0.15)}
.bb-week__info{min-width:0}
.bb-week__name{font-size:12px;font-weight:600;color:var(--text-primary);white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.bb-week__tag{font-size:9px;font-weight:700;color:var(--text-muted);text-transform:uppercase;letter-spacing:0.04em}
.bb-week__progress{width:56px;height:4px;border-radius:2px;background:var(--border);overflow:hidden}
.bb-week__fill{height:100%;border-radius:2px;width:0;transition:width 1.2s cubic-bezier(0.16,1,0.3,1)}

/* Milestone line inside builder */
.bb-milestone{
    display:flex;align-items:center;gap:8px;padding:4px 10px;
    font-size:9px;font-weight:700;color:#1a9e82;text-transform:uppercase;letter-spacing:0.04em;
}
.bb-milestone__dot{width:5px;height:5px;border-radius:50%;background:#1a9e82}
.bb-milestone__line{flex:1;height:1px;background:rgba(54,209,183,0.2)}

/* Builder footer with live stats */
.brain-builder__footer{
    display:flex;justify-content:space-between;align-items:center;
    padding:12px 16px;border-top:1px solid var(--border);background:var(--bg-gray);
}
.bb-stat{text-align:center}
.bb-stat__val{font-size:16px;font-weight:700;color:var(--text-primary);font-family:var(--font-mono);line-height:1}
.bb-stat__label{font-size:9px;font-weight:600;color:var(--text-muted);text-transform:uppercase;letter-spacing:0.04em}

/* ========================================================
   SECTION 2: CORE INSIGHT — Before/After cards
   ======================================================== */
.insight-cards{display:grid;grid-template-columns:1fr;gap:24px;margin-top:16px}
@media(min-width:768px){.insight-cards{grid-template-columns:1fr 1fr}}
.insight-card{
    padding:36px 32px;border-radius:var(--radius-lg);border:1px solid var(--border);
    position:relative;overflow:hidden;transition:all 0.35s ease;
}
.insight-card:hover{transform:translateY(-3px);box-shadow:var(--shadow-md)}
.insight-card--before{background:var(--bg-gray)}
.insight-card--after{background:var(--bg-white)}
.insight-card__tag{
    display:inline-flex;align-items:center;gap:6px;
    font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:0.08em;
    padding:4px 12px;border-radius:20px;margin-bottom:20px;
}
.insight-card__tag--before{color:var(--accent-pink);background:rgba(245,100,147,0.06);border:1px solid rgba(245,100,147,0.15)}
.insight-card__tag--after{color:#1a9e82;background:rgba(54,209,183,0.06);border:1px solid rgba(54,209,183,0.15)}
.insight-card__tag-dot{width:6px;height:6px;border-radius:50%}
.insight-card__title{font-size:20px;font-weight:600;color:var(--text-primary);margin-bottom:12px;letter-spacing:-0.01em}
.insight-card__list{display:flex;flex-direction:column;gap:12px}
.insight-card__item{display:flex;align-items:flex-start;gap:10px;font-size:14px;color:var(--text-secondary);line-height:1.6}
.insight-card__item-icon{flex-shrink:0;font-size:16px;line-height:1.6}
.insight-card__item strong{color:var(--text-primary);font-weight:500}
/* Animated data stream (before card) */
.insight-card__stream{position:absolute;bottom:0;left:0;right:0;height:3px;overflow:hidden}
.insight-card__stream-line{
    position:absolute;height:100%;width:40px;border-radius:2px;
    animation:streamFlow 3s linear infinite;
}
@keyframes streamFlow{0%{left:-40px;opacity:0}10%{opacity:1}90%{opacity:1}100%{left:100%;opacity:0}}
/* Animated pulse ring (after card) */
.insight-card__pulse{
    position:absolute;top:20px;right:20px;width:40px;height:40px;
}
.insight-card__pulse::before,.insight-card__pulse::after{
    content:'';position:absolute;inset:0;border-radius:50%;
    border:2px solid rgba(54,209,183,0.2);
}
.insight-card__pulse::before{animation:insightPulse 2s ease infinite}
.insight-card__pulse::after{animation:insightPulse 2s ease infinite 1s}
@keyframes insightPulse{0%{transform:scale(0.5);opacity:1}100%{transform:scale(1.5);opacity:0}}

/* Stats bar between sections */
.stat-bar{
    display:grid;grid-template-columns:repeat(2,1fr);gap:16px;margin-top:48px;
}
@media(min-width:768px){.stat-bar{grid-template-columns:repeat(4,1fr)}}
.stat-item{
    text-align:center;padding:20px 16px;border-radius:var(--radius-lg);
    background:var(--bg-white);border:1px solid var(--border);transition:all 0.25s ease;
}
.stat-item:hover{border-color:rgba(212,112,44,0.15);box-shadow:var(--shadow-sm)}
.stat-item__val{font-size:clamp(1.5rem,3vw,2rem);font-weight:600;color:var(--text-primary);line-height:1;margin-bottom:4px;font-family:var(--font-mono)}
.stat-item__label{font-size:12px;color:var(--text-muted);line-height:1.4}

/* ========================================================
   SECTION 3: MEMORY TIERS — Interactive explorer
   ======================================================== */
.tier-explorer{
    border:1px solid var(--border);border-radius:var(--radius-lg);overflow:hidden;
    display:grid;grid-template-columns:1fr;background:var(--bg-white);
    box-shadow:var(--shadow-lg);
}
@media(min-width:768px){.tier-explorer{grid-template-columns:200px 1fr}}
.tier-explorer__sidebar{
    background:var(--bg-gray);border-right:1px solid var(--border);
    padding:16px 0;display:flex;flex-direction:column;
}
@media(max-width:767px){.tier-explorer__sidebar{border-right:none;border-bottom:1px solid var(--border);flex-direction:row;overflow-x:auto;padding:12px 8px;gap:4px}}
.tier-explorer__sidebar-title{
    font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:0.08em;
    color:var(--text-muted);padding:0 16px 12px;border-bottom:1px solid var(--border);margin-bottom:8px;
}
@media(max-width:767px){.tier-explorer__sidebar-title{display:none}}
.tier-explorer__tab{
    display:flex;align-items:center;gap:8px;padding:8px 16px;
    font-size:13px;font-weight:500;color:var(--text-muted);cursor:pointer;
    transition:all 0.2s ease;border-radius:0;white-space:nowrap;
}
@media(max-width:767px){.tier-explorer__tab{border-radius:var(--radius);padding:6px 12px;font-size:12px}}
.tier-explorer__tab:hover{color:var(--text-primary);background:rgba(212,112,44,0.03)}
.tier-explorer__tab.is-active{color:var(--text-primary);background:rgba(212,112,44,0.06);font-weight:600}
.tier-explorer__tab-dot{width:8px;height:8px;border-radius:50%;flex-shrink:0}
.tier-explorer__tab-range{font-family:var(--font-mono);font-size:10px;color:var(--text-muted);margin-left:auto}
@media(max-width:767px){.tier-explorer__tab-range{display:none}}

.tier-explorer__content{padding:32px;display:flex;flex-direction:column;gap:20px;min-height:280px}
.tier-explorer__panel{display:none;flex-direction:column;gap:16px;animation:tierFadeIn 0.3s ease}
.tier-explorer__panel.is-active{display:flex}
@keyframes tierFadeIn{from{opacity:0;transform:translateY(6px)}to{opacity:1;transform:translateY(0)}}
.tier-explorer__panel-header{display:flex;align-items:center;gap:12px}
.tier-explorer__panel-badge{
    font-family:var(--font-mono);font-size:14px;font-weight:700;color:#fff;
    padding:6px 14px;border-radius:var(--radius);
}
.tier-explorer__panel-name{font-size:20px;font-weight:600;color:var(--text-primary)}
.tier-explorer__panel-range{font-family:var(--font-mono);font-size:13px;color:var(--text-muted)}
.tier-explorer__panel-desc{font-size:15px;color:var(--text-secondary);line-height:1.7;max-width:600px}
.tier-explorer__examples{display:flex;flex-wrap:wrap;gap:6px;margin-top:4px}
.tier-explorer__example{
    font-size:12px;font-weight:500;padding:5px 14px;border-radius:var(--radius-pill);
    background:var(--bg-gray);color:var(--text-secondary);border:1px solid var(--border);
}

/* ========================================================
   SECTION 4: CURRICULUM — Module accordion with progress
   ======================================================== */
.module-list{display:flex;flex-direction:column;gap:12px}
.module{
    border:1px solid var(--border);border-radius:var(--radius-lg);overflow:hidden;
    background:var(--bg-white);transition:all 0.3s ease;
}
.module:hover{box-shadow:var(--shadow-md)}
.module__header{
    display:flex;align-items:center;gap:14px;padding:20px 24px;cursor:pointer;
    transition:background 0.2s;user-select:none;
}
.module__header:hover{background:rgba(212,112,44,0.02)}
.module__icon{
    width:36px;height:36px;border-radius:10px;display:flex;align-items:center;justify-content:center;
    font-size:12px;font-weight:800;color:#fff;flex-shrink:0;
}
.module__info{flex:1;min-width:0}
.module__week{font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.06em;color:var(--text-muted);margin-bottom:2px}
.module__name{font-size:16px;font-weight:600;color:var(--text-primary);letter-spacing:-0.01em}
.module__badge{
    font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.04em;
    padding:4px 12px;border-radius:var(--radius-pill);background:var(--bg-gray);
    color:var(--text-secondary);flex-shrink:0;white-space:nowrap;
}
.module__chevron{
    width:20px;height:20px;color:var(--text-muted);flex-shrink:0;
    transition:transform 0.3s cubic-bezier(0.34,1.56,0.64,1);
}
.module.is-open .module__chevron{transform:rotate(180deg)}
.module__body{max-height:0;overflow:hidden;transition:max-height 0.4s cubic-bezier(0.16,1,0.3,1)}
.module.is-open .module__body{max-height:400px}
.module__content{padding:0 24px 24px;border-top:1px solid var(--border);padding-top:20px}
.module__content p{font-size:14px;color:var(--text-muted);line-height:1.7;max-width:700px}
.module__content p + p{margin-top:12px}
.module__outputs{display:flex;flex-wrap:wrap;gap:6px;margin-top:16px}
.module__output-tag{
    font-size:11px;font-weight:600;padding:4px 12px;border-radius:var(--radius-pill);
    background:var(--bg-gray);color:var(--text-secondary);
}

/* Milestone marker */
.milestone{
    display:flex;align-items:center;gap:12px;padding:16px 20px;
    background:rgba(54,209,183,0.06);border-radius:var(--radius-lg);
    border:1px solid rgba(54,209,183,0.12);margin:8px 0;
}
.milestone__dot{width:10px;height:10px;border-radius:50%;background:var(--accent-teal);flex-shrink:0;animation:milestonePulse 2s ease infinite}
@keyframes milestonePulse{0%,100%{box-shadow:0 0 0 0 rgba(54,209,183,0.3)}50%{box-shadow:0 0 0 6px rgba(54,209,183,0)}}
.milestone__text{font-size:14px;color:var(--text-primary);line-height:1.5}
.milestone__text strong{font-weight:600}

/* Certification callout */
.cert-callout{
    display:flex;align-items:center;gap:16px;padding:20px 24px;
    background:var(--brand-pale);border-radius:var(--radius-lg);
    border:1px solid rgba(212,112,44,0.12);margin-top:8px;
}
.cert-callout__icon{font-size:20px;flex-shrink:0}
.cert-callout__text{flex:1}
.cert-callout__title{font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:0.06em;color:var(--brand);margin-bottom:4px}
.cert-callout__desc{font-size:14px;color:var(--text-secondary);line-height:1.6}
.cert-callout__desc strong{color:var(--text-primary);font-weight:600}

/* ========================================================
   SECTION 5: HOW IT WORKS — Dark
   ======================================================== */
.section--dark{background:#0d0f14;color:#fff}
.format-grid{display:grid;grid-template-columns:1fr;gap:20px;margin-top:48px}
@media(min-width:640px){.format-grid{grid-template-columns:1fr 1fr}}
@media(min-width:1024px){.format-grid{grid-template-columns:1fr 1fr 1fr 1fr}}
.format-card{
    padding:28px 24px;border-radius:var(--radius-lg);
    border:1px solid rgba(255,255,255,0.06);background:rgba(255,255,255,0.03);
    transition:all 0.3s ease;
}
.format-card:hover{border-color:rgba(255,255,255,0.12);background:rgba(255,255,255,0.05);transform:translateY(-2px)}
.format-card__icon{
    width:44px;height:44px;border-radius:12px;display:flex;align-items:center;justify-content:center;
    font-size:20px;margin-bottom:16px;
    background:rgba(255,255,255,0.06);border:1px solid rgba(255,255,255,0.08);
}
.format-card__title{font-size:17px;font-weight:600;color:#fff;margin-bottom:8px}
.format-card__desc{font-size:14px;color:rgba(255,255,255,0.55);line-height:1.65}

/* Equation pills */
.equation{display:flex;flex-wrap:wrap;align-items:center;justify-content:center;gap:12px;margin-top:56px}
.equation__pill{
    font-weight:600;font-size:14px;padding:10px 22px;border-radius:var(--radius-pill);
    border:1.5px solid rgba(255,255,255,0.12);background:rgba(255,255,255,0.04);
    color:rgba(255,255,255,0.8);transition:all 0.35s cubic-bezier(0.34,1.56,0.64,1);cursor:default;
}
.equation__pill:hover{border-color:rgba(255,255,255,0.25);transform:translateY(-2px);background:rgba(255,255,255,0.07)}
.equation__op{font-size:1rem;font-weight:600;color:rgba(255,255,255,0.3)}
.equation__result{
    background:linear-gradient(135deg,var(--brand) 0%,var(--brand-dark) 100%);
    color:#fff;border-color:var(--brand);
    box-shadow:0 4px 20px rgba(212,112,44,0.3),inset 0 1px 0 rgba(255,255,255,0.15);
}
.equation__result:hover{
    box-shadow:0 8px 30px rgba(212,112,44,0.4),0 0 0 4px rgba(212,112,44,0.1);
    border-color:var(--brand);
}

/* Flow Simulator Mockup */
.flow-sim{
    margin-top:56px;border-radius:var(--radius-lg);overflow:hidden;
    border:1px solid rgba(255,255,255,0.08);background:rgba(255,255,255,0.02);
}
.flow-sim__header{
    display:flex;align-items:center;gap:10px;padding:14px 20px;
    background:rgba(255,255,255,0.04);border-bottom:1px solid rgba(255,255,255,0.06);
}
.flow-sim__dots{display:flex;gap:6px}
.flow-sim__dots span{width:10px;height:10px;border-radius:50%;background:rgba(255,255,255,0.12)}
.flow-sim__dots span:first-child{background:#ff5f57}
.flow-sim__dots span:nth-child(2){background:#febc2e}
.flow-sim__dots span:nth-child(3){background:#28c840}
.flow-sim__title{font-size:12px;color:rgba(255,255,255,0.4);font-family:'Source Code Pro',monospace;margin-left:auto}
.flow-sim__body{padding:32px 28px}
.flow-sim__week{
    display:flex;align-items:center;gap:12px;margin-bottom:24px;
}
.flow-sim__week-badge{
    font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:0.08em;
    padding:5px 14px;border-radius:var(--radius-pill);
    background:linear-gradient(135deg,var(--accent-teal),#5BE4CC);color:#0d0f14;
}
.flow-sim__week-label{font-size:13px;color:rgba(255,255,255,0.5);font-family:'Source Code Pro',monospace}

/* 3-stage pipeline */
.flow-sim__pipeline{display:flex;gap:0;align-items:stretch;margin-bottom:28px}
@media(max-width:768px){.flow-sim__pipeline{flex-direction:column}}
.flow-sim__stage{
    flex:1;padding:24px 20px;position:relative;
    border:1px solid rgba(255,255,255,0.06);
    transition:all 0.5s cubic-bezier(0.4,0,0.2,1);cursor:pointer;
}
.flow-sim__stage:first-child{border-radius:var(--radius-lg) 0 0 var(--radius-lg)}
.flow-sim__stage:last-child{border-radius:0 var(--radius-lg) var(--radius-lg) 0}
@media(max-width:768px){
    .flow-sim__stage:first-child{border-radius:var(--radius-lg) var(--radius-lg) 0 0}
    .flow-sim__stage:last-child{border-radius:0 0 var(--radius-lg) var(--radius-lg)}
}
.flow-sim__stage.is-active{
    background:rgba(255,255,255,0.06);border-color:rgba(255,255,255,0.15);
}
.flow-sim__stage-num{
    font-size:11px;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;
    color:rgba(255,255,255,0.25);margin-bottom:10px;
    transition:color 0.4s ease;
}
.flow-sim__stage.is-active .flow-sim__stage-num{color:var(--accent-teal)}
.flow-sim__stage-title{font-size:15px;font-weight:600;color:#fff;margin-bottom:6px}
.flow-sim__stage-sub{font-size:12px;color:rgba(255,255,255,0.4);line-height:1.5}

/* Animated content area inside stage */
.flow-sim__content{
    margin-top:14px;min-height:48px;overflow:hidden;
    opacity:0;max-height:0;transition:all 0.5s cubic-bezier(0.4,0,0.2,1);
}
.flow-sim__stage.is-active .flow-sim__content{opacity:1;max-height:200px}
.flow-sim__line{
    display:flex;align-items:center;gap:8px;font-size:12px;
    font-family:'Source Code Pro',monospace;color:rgba(255,255,255,0.5);
    margin-bottom:6px;opacity:0;transform:translateX(-8px);
    transition:all 0.3s ease;
}
.flow-sim__stage.is-active .flow-sim__line{opacity:1;transform:translateX(0)}
.flow-sim__stage.is-active .flow-sim__line:nth-child(2){transition-delay:0.15s}
.flow-sim__stage.is-active .flow-sim__line:nth-child(3){transition-delay:0.3s}
.flow-sim__line-dot{
    width:6px;height:6px;border-radius:50%;flex-shrink:0;
}

/* Connector arrows between stages */
.flow-sim__arrow{
    display:flex;align-items:center;justify-content:center;
    width:32px;flex-shrink:0;color:rgba(255,255,255,0.15);font-size:16px;
}
@media(max-width:768px){
    .flow-sim__arrow{width:auto;height:28px;transform:rotate(90deg)}
}

/* Output bar */
.flow-sim__output{
    display:flex;align-items:center;gap:16px;padding:16px 20px;
    border-radius:var(--radius-md);background:rgba(255,255,255,0.03);
    border:1px solid rgba(255,255,255,0.06);
}
.flow-sim__output-icon{font-size:18px;flex-shrink:0}
.flow-sim__output-text{font-size:13px;color:rgba(255,255,255,0.5);flex:1}
