---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---
<BaseLayout title="Starling AIX | About — The Breakthrough" description="Starling AI Systems creates a classification system for business knowledge that lives in natural language, not machine code.">
<Nav currentPage="about" />
<main>

<!-- ===== HERO ===== -->
<section class="ab-hero" id="hero">
    <div class="ab-hero__bg"></div>
    <div class="ab-hero__inner">
        <div class="ab-hero__text">
            <div class="ab-hero__badge">
                <span class="ab-hero__badge-dot"></span>
                The Breakthrough
            </div>
            <h1 class="ab-hero__title"><strong>Your business,</strong> <em>now fluent in AI</em></h1>
            <p class="ab-hero__sub">Starling AI Systems creates a classification system for business knowledge that lives in natural language, not machine code. Our six progressive systems establish governing protocols where AI operates by human rules — transforming generic LLMs into contextualized Intelligence Agents.</p>
            <div class="ab-hero__cta">
                <a href="#get-started" class="btn btn--primary btn--large">
                    Get Started
                    <svg class="arrow" width="10" height="10" fill="none" stroke="currentColor" stroke-width="2"><path d="M0.5 5.5h7"/><path d="M5.5 1.5l4 4-4 4"/></svg>
                </a>
            </div>
        </div>

        <div class="ab-hero__illo">
            <div class="ab-hero__card">
                <div class="ab-hero__card-bar">
                    <div class="ab-hero__card-dots"><span class="ab-hero__card-dot"></span><span class="ab-hero__card-dot"></span><span class="ab-hero__card-dot"></span></div>
                    <div class="ab-hero__card-title">Semantic Coordinates</div>
                </div>
                <div class="ab-hero__card-body" id="heroCoords">
                    <div class="ab-hero__coord" data-coord="0">
                        <span class="ab-hero__coord-code">MA20</span>
                        <span class="ab-hero__coord-label">Competitive Position</span>
                        <span class="ab-hero__coord-status" style="background:var(--brand)"></span>
                    </div>
                    <div class="ab-hero__coord" data-coord="1">
                        <span class="ab-hero__coord-code">VL01</span>
                        <span class="ab-hero__coord-label">Product Offering</span>
                        <span class="ab-hero__coord-status" style="background:var(--accent-teal)"></span>
                    </div>
                    <div class="ab-hero__coord" data-coord="2">
                        <span class="ab-hero__coord-code">ID10</span>
                        <span class="ab-hero__coord-label">Value-Centric Design</span>
                        <span class="ab-hero__coord-status" style="background:var(--accent-pink)"></span>
                    </div>
                    <div class="ab-hero__coord" data-coord="3">
                        <span class="ab-hero__coord-code">SY10</span>
                        <span class="ab-hero__coord-label">Smart Orgs</span>
                        <span class="ab-hero__coord-status" style="background:var(--accent-blue)"></span>
                    </div>
                    <div class="ab-hero__coord" data-coord="4">
                        <span class="ab-hero__coord-code">BR10</span>
                        <span class="ab-hero__coord-label">Impact Branding</span>
                        <span class="ab-hero__coord-status" style="background:var(--accent-yellow)"></span>
                    </div>
                    <div class="ab-hero__coord" data-coord="5">
                        <span class="ab-hero__coord-code">LA10</span>
                        <span class="ab-hero__coord-label">Organizational Intelligence</span>
                        <span class="ab-hero__coord-status" style="background:var(--accent-teal)"></span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- ===== SECTION 2: APPLICATION INTELLIGENCE ===== -->
<section class="ai2" id="ai2">
    <div class="ai2__inner">
        <div class="section__header reveal">
            <h2 class="section__h"><strong>Your knowledge. Machine speed.</strong> Exponential power.</h2>
            <div class="section__header-right">
                <p class="body-lg">Starling transforms generic LLMs into AI&sup2; advisors that understand your specific business context. We provide the operating logic that codifies and continually refines your unique approach to innovation.</p>
                <p class="body-lg">The AI provides raw processing power. You provide structured expertise. Together they produce Cross Intelligence — cognitive systems that learn and evolve through memory training and daily conversation.</p>
            </div>
        </div>

        <div class="ai2__illo reveal" id="ai2Illo">
            <div class="ai2__illo-bar">
                <div class="ai2__illo-dots"><span class="ai2__illo-dot"></span><span class="ai2__illo-dot"></span><span class="ai2__illo-dot"></span></div>
                <div class="ai2__illo-title">Cross Intelligence Engine</div>
            </div>
            <div class="ai2__illo-body">
                <div class="ai2__nodes">
                    <div class="ai2__node ai2__node--ai1" id="ai2Node1">
                        <div class="ai2__node-badge">AI1</div>
                        <div class="ai2__node-value">AI</div>
                        <div class="ai2__node-name">Artificial Intelligence</div>
                        <div class="ai2__node-desc">Raw processing power and pattern recognition (LLMs)</div>
                    </div>
                    <div class="ai2__node ai2__node--ai2" id="ai2Node2">
                        <div class="ai2__node-badge">AI2</div>
                        <div class="ai2__node-value">AI</div>
                        <div class="ai2__node-name">Application Intelligence</div>
                        <div class="ai2__node-desc">Human expertise structured for machine processing</div>
                    </div>
                </div>
                <div class="ai2__flow" id="ai2Flow">
                    <span class="ai2__flow-line"></span>
                    <span class="ai2__flow-op">&times;</span>
                    <span class="ai2__flow-line"></span>
                </div>
                <div class="ai2__result" id="ai2Result">
                    <div class="ai2__result-badge">Cross Intelligence</div>
                    <div class="ai2__result-value">AI&sup2;</div>
                    <div class="ai2__result-name">Cognitive systems that learn and evolve</div>
                    <div class="ai2__result-desc">Memory training + daily conversation = compounding organizational intelligence</div>
                </div>
            </div>
            <div class="ai2__illo-footer">
                <span class="ai2__illo-footer-dot" id="ai2StatusDot"></span>
                <span class="ai2__illo-footer-text" id="ai2StatusText">Synthesis complete — AI&sup2; active</span>
            </div>
        </div>
    </div>
</section>

<!-- ===== SECTION 3: AI-NATIVE ORG DESIGN ===== -->
<section class="orgdesign" id="org-design">
    <div class="orgdesign__inner">
        <div class="section__header reveal">
            <h2 class="section__h"><strong>Design your AI agent</strong> with our Industry 5.0 innovation framework</h2>
            <div class="section__header-right">
                <p class="body-lg">Starling AIX is built on Cognitive Design — a comprehensive approach to business design and transformation that synthesizes systematic efficiency with human values.</p>
            </div>
        </div>

        <div class="orgdesign__highlight reveal">
            <div class="orgdesign__highlight-title">The first business methodology designed specifically for the AI era</div>
            <div class="orgdesign__highlight-desc">Powering your AI&sup2; Chief of Staff. This isn't AI trained on the Internet. It's AI trained on Cognitive Design — the methodology of Smart Orgs.</div>
        </div>

        <div class="orgdesign__grid">
            <div class="orgdesign__card reveal reveal-d1">
                <div class="orgdesign__card-icon">&hearts;</div>
                <div class="orgdesign__card-title">Combines the efficiency of Lean</div>
                <div class="orgdesign__card-desc">With the human-centered problem-solving of Design Thinking — now machine-executable.</div>
            </div>
            <div class="orgdesign__card reveal reveal-d2">
                <div class="orgdesign__card-icon">&cir;</div>
                <div class="orgdesign__card-title">Makes business knowledge machine-executable</div>
                <div class="orgdesign__card-desc">While codifying your Hierarchy of Organizational Values through six progressive systems.</div>
            </div>
            <div class="orgdesign__card reveal reveal-d3">
                <div class="orgdesign__card-icon">&equiv;</div>
                <div class="orgdesign__card-title">Creates self-improving knowledge systems</div>
                <div class="orgdesign__card-desc">Build intelligence through natural conversation that compounds with every session.</div>
            </div>
            <div class="orgdesign__card reveal reveal-d4">
                <div class="orgdesign__card-icon">&diams;</div>
                <div class="orgdesign__card-title">Enables a systematic enterprise asset</div>
                <div class="orgdesign__card-desc">That gets smarter and more valuable over time — not a subscription that resets.</div>
            </div>
        </div>
    </div>
</section>

<!-- ===== SECTION 4: PROVEN METHODS ===== -->
<section class="methods" id="methods">
    <div class="methods__inner">
        <div class="section__header reveal">
            <h2 class="section__h"><strong>Built from real business frameworks,</strong> not research labs</h2>
            <div class="section__header-right">
                <p class="body-lg">Most AI platforms start with technology and try to fit business into it. Starling AIX started with Chris Kincade and Ari Meisel's frameworks for business design, optimization, and transformation — then made them machine-executable.</p>
                <p class="body-lg">The sound barrier didn't stop aviation. It defined the engineering required to go faster. We designed the airframe for Industry 5.0.</p>
            </div>
        </div>

        <div class="methods__stats reveal">
            <div class="methods__stat">
                <div class="methods__stat-num"><span class="counter" data-target="25" data-suffix="">0</span></div>
                <div class="methods__stat-label">Years of methodology</div>
            </div>
            <div class="methods__stat">
                <div class="methods__stat-num"><span class="counter" data-target="12" data-suffix="K">0</span></div>
                <div class="methods__stat-label">Hours of interface design</div>
            </div>
            <div class="methods__stat">
                <div class="methods__stat-num"><span class="counter" data-target="12" data-suffix="">0</span></div>
                <div class="methods__stat-label">Installer frameworks</div>
            </div>
            <div class="methods__stat">
                <div class="methods__stat-num"><span class="counter" data-target="28" data-suffix="">0</span></div>
                <div class="methods__stat-label">Constitutional memories</div>
            </div>
        </div>

