                        <div class="methods__arch-layer" data-layer="1">Logic + Routing</div>
                        <div class="methods__arch-layer" data-layer="2">Value Design</div>
                        <div class="methods__arch-layer" data-layer="3">Process Design</div>
                        <div class="methods__arch-layer" data-layer="4">Autonomic Design</div>
                        <div class="methods__arch-layer" data-layer="5">Semantic Design</div>
                    </div>
                    <div class="methods__arch-detail" id="archDetail">
