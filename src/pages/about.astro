---
import Layout from '../layouts/Layout.astro';
---

<Layout title="About — Starling AIX" description="Starling AIX creates a classification system for business knowledge that lives in natural language. Our methodology transforms generic LLMs into contextualized Intelligence Agents.">

<!-- ── Hero ──────────────────────────────────────────────────── -->
<section style="position:relative;overflow:hidden;padding:7rem 0 5rem;" class="grid-bg">
  <div class="hero-glow"></div>
  <span class="corner-mark cm-tl">+</span>
  <span class="corner-mark cm-tr">+</span>
  <div class="container" style="position:relative;z-index:1;">
    <div class="about-hero-grid">
      <div>
        <p class="feat-num fade-up" data-delay="0">Starling AIX · The Breakthrough</p>
        <h1 class="heading-display fade-up" data-delay="0.08"
            style="font-size:clamp(3rem,8vw,5rem);margin:0 0 1.5rem;max-width:580px;">
          Your business,<br/>now fluent in AI.
        </h1>
        <p class="fade-up" data-delay="0.15"
           style="font-size:1.05rem;color:#71717a;line-height:1.75;max-width:480px;margin:0 0 2.5rem;">
          We create a classification system for business knowledge that lives in natural language — not machine code. Our systems establish governing protocols where AI operates by human rules.
        </p>
        <div class="fade-up" data-delay="0.2" style="display:flex;gap:0.75rem;flex-wrap:wrap;">
          <a href="/cognitive-design" class="btn btn-primary">Enroll Now →</a>
          <a href="/ai-guide" class="btn btn-ghost">Get Free AI Guide</a>
        </div>
      </div>
      <!-- Metric cluster -->
      <div class="fade-up about-metrics" data-delay="0.14">
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:0.75rem;">
          {[
            ['25', 'Years of methodology'],
            ['12K', 'Design hours'],
            ['47%', 'Faster decisions'],
            ['28', 'Constitutional memories'],
          ].map(([num, label]) => (
            <div class="metric-pill">
              <span class="metric-pill-num">{num}</span>
              <span class="metric-pill-label">{label}</span>
            </div>
          ))}
        </div>
        <div class="glass" style="padding:1.25rem;margin-top:0.75rem;display:flex;align-items:flex-start;gap:0.75rem;">
          <span style="font-size:1rem;">💬</span>
          <p style="font-size:0.82rem;color:#71717a;line-height:1.65;margin:0;font-style:italic;">
            "In 20 minutes, it took me from being overwhelmed with information to only 53 attachments unattached. That huge mental burden on recall — gone."
          </p>
        </div>
      </div>
    </div>
  </div>
</section>

<div class="divider"></div>

<!-- ── Application Intelligence ──────────────────────────────── -->
<section class="feat-section">
  <div class="container">
    <div class="feat-header">
      <div>
        <p class="feat-num fade-up" data-delay="0">1.0 · Application Intelligence</p>
        <h2 class="feat-h2 heading-display fade-up" data-delay="0.06">
          Raw power meets structured expertise.
        </h2>
      </div>
      <div>
        <p class="feat-body fade-up" data-delay="0.1">
          Starling transforms generic LLMs into AI² advisors that understand your specific business context. We provide the operating logic that codifies and continually refines your unique approach to innovation.
        </p>
        <p class="feat-body fade-up" data-delay="0.13" style="margin-bottom:0;">
          The AI provides raw processing power. You provide structured expertise. Together they produce Cross Intelligence — cognitive systems that learn and evolve through memory training and daily conversation.
        </p>
      </div>
    </div>

    <!-- AI² equation — colorful -->
    <div class="wide-mock fade-up" data-delay="0.18">
      <div class="mock-bar">
        <span class="mock-dot r"></span><span class="mock-dot y"></span><span class="mock-dot g"></span>
        <span style="font-family:'JetBrains Mono',monospace;font-size:0.7rem;color:#3f3f46;margin-left:0.75rem;">AI² — Cross Intelligence Formula</span>
      </div>
      <div style="display:grid;grid-template-columns:1fr;gap:1px;background:rgba(255,255,255,0.05);" class="ai2-grid">
        {[
          { label: 'AI¹', accent: '#60a5fa', bg: 'rgba(96,165,250,0.05)', border: 'rgba(96,165,250,0.15)', title: 'Artificial Intelligence', desc: 'Raw processing power and pattern recognition from Large Language Models — generalised, context-free, infinitely scalable.' },
          { label: 'AI²', accent: '#a78bfa', bg: 'rgba(167,139,250,0.05)', border: 'rgba(167,139,250,0.15)', title: 'Application Intelligence', desc: 'Human expertise structured for machine processing — your unique genius, your values, your decision frameworks, made machine-executable.' },
          { label: 'AI²', accent: '#fff', bg: 'rgba(255,255,255,0.025)', border: 'rgba(255,255,255,0.08)', title: 'Cross Intelligence', desc: 'The product of both: cognitive systems that learn and evolve through memory training, natural conversation, and organisational feedback loops.' },
        ].map(({ label, accent, bg, border, title, desc }) => (
          <div style={`background:#050505;padding:1.75rem 2rem;display:flex;gap:1.5rem;align-items:flex-start;border-left:2px solid ${border};`}>
            <div style={`font-family:'Space Grotesk',sans-serif;font-size:1.9rem;font-weight:700;color:${accent};min-width:52px;line-height:1;`}>{label}</div>
            <div>
              <p style={`font-size:0.9rem;font-weight:600;margin:0 0 0.35rem;color:${accent};`}>{title}</p>
              <p style="font-size:0.825rem;color:#52525b;line-height:1.7;margin:0;">{desc}</p>
            </div>
          </div>
        ))}
      </div>
      <div style="padding:1.25rem 2rem;border-top:1px solid rgba(255,255,255,0.06);display:flex;align-items:center;gap:1rem;">
        <span class="badge badge-accent">AI¹ × AI² = AI²</span>
        <span style="font-family:'JetBrains Mono',monospace;font-size:0.68rem;color:#3f3f46;">Cross Intelligence · Starling AIX</span>
      </div>
    </div>

  </div>
</section>

<!-- ── Image Split: Leader ────────────────────────────────────── -->
<section style="border-top:1px solid rgba(255,255,255,0.07);overflow:hidden;">
  <div class="img-split">
    <div class="img-split-photo">
      <img src="/images/women-teal.png" alt="AI-native leader with organizational intelligence system" />
      <div class="img-split-overlay">
        <div class="glass-dark" style="padding:1rem 1.25rem;border-radius:10px;max-width:260px;">
          <p style="font-family:'JetBrains Mono',monospace;font-size:0.6rem;color:#60a5fa;margin:0 0 0.25rem;text-transform:uppercase;letter-spacing:0.08em;">Live session</p>
          <p style="font-size:0.82rem;color:#e4e4e7;margin:0;line-height:1.5;">AI Chief of Staff loaded with full organizational context — every session, from day one.</p>
        </div>
      </div>
    </div>
    <div class="img-split-content">
      <p class="feat-num" style="margin-bottom:0.75rem;">2.0 · AI-Native Org Design</p>
      <h2 class="feat-h2 heading-display" style="margin-bottom:1.25rem;">The first methodology built<br/>for the AI era.</h2>
      <p style="font-size:0.95rem;color:#71717a;line-height:1.8;margin:0 0 2rem;">
        Starling AIX is built on <strong style="color:#e4e4e7;">Cognitive Design</strong> — a comprehensive approach to business transformation that synthesises systematic efficiency with human values. This isn't AI trained on the Internet. It's AI trained on your methodology.
      </p>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:0.75rem;margin-bottom:2rem;">
        {[
          ['Lean + Design Thinking', 'Human-centered, now machine-executable'],
          ['Self-improving systems', 'Intelligence compounds every session'],
          ['Sovereign architecture', 'You own every memory, forever'],
          ['No code required', 'Conversation as configuration'],
        ].map(([title, body]) => (
          <div style="padding:0.875rem 1rem;border:1px solid rgba(255,255,255,0.07);border-radius:8px;background:rgba(255,255,255,0.02);">
            <p style="font-size:0.82rem;color:#e4e4e7;font-weight:600;margin:0 0 0.2rem;">{title}</p>
            <p style="font-size:0.75rem;color:#52525b;line-height:1.5;margin:0;">{body}</p>
          </div>
        ))}
      </div>
      <a href="/cognitive-design" class="btn btn-primary" style="align-self:flex-start;">See the Curriculum →</a>
    </div>
  </div>
</section>

<!-- ── Proven Methods ─────────────────────────────────────────── -->
<section class="feat-section" style="position:relative;overflow:hidden;border-top:1px solid rgba(255,255,255,0.07);">
  <div class="section-grid-accent"></div>
  <div class="container" style="position:relative;z-index:1;">
    <div class="feat-header">
      <div>
        <p class="feat-num fade-up" data-delay="0">3.0 · Proven Methods</p>
        <h2 class="feat-h2 heading-display fade-up" data-delay="0.06">
          Built from real frameworks,<br/>not research labs.
        </h2>
      </div>
      <div>
        <p class="feat-body fade-up" data-delay="0.1">
          Most AI platforms start with technology and try to fit business into it. Starling AIX started with <strong style="color:#e4e4e7;">Chris Kincade</strong> and <strong style="color:#e4e4e7;">Ari Meisel's</strong> frameworks for business design, optimisation, and transformation — then made them machine-executable.
        </p>
        <p class="feat-body fade-up" data-delay="0.13" style="font-style:italic;color:#3f3f46;margin-bottom:0;">
          The sound barrier didn't stop aviation. It defined the engineering required to go faster. We designed the airframe for Industry 5.0.
        </p>
      </div>
    </div>

    <!-- Stats strip -->
    <div class="fade-up" data-delay="0.15" style="display:grid;grid-template-columns:repeat(2,1fr);border:1px solid rgba(255,255,255,0.07);border-radius:12px;overflow:hidden;margin-bottom:3rem;" class="stats-strip-4">
      {[
        ['25', 'Years of methodology'],
        ['12K', 'Hours of interface design'],
        ['12', 'Installer frameworks'],
        ['28', 'Constitutional memories'],
      ].map(([num, label], i) => (
        <div style={`background:#0a0a0a;padding:2rem 1.5rem;text-align:center;${i % 2 === 0 ? 'border-right:1px solid rgba(255,255,255,0.07);' : ''}${i < 2 ? 'border-bottom:1px solid rgba(255,255,255,0.07);' : ''}`}>
          <div class="stat-num">{num}</div>
          <div class="stat-label">{label}</div>
        </div>
      ))}
    </div>

    <!-- Three Systems as wide-mock — colorized -->
    <div class="wide-mock fade-up" data-delay="0.18">
      <div class="mock-bar">
        <span class="mock-dot r"></span><span class="mock-dot y"></span><span class="mock-dot g"></span>
        <span style="font-family:'JetBrains Mono',monospace;font-size:0.7rem;color:#3f3f46;margin-left:0.75rem;">Cognitive Design — 12 Installer Frameworks</span>
        <span style="font-family:'JetBrains Mono',monospace;font-size:0.62rem;color:#34d399;margin-left:auto;padding-right:0.75rem;">● All systems active</span>
      </div>
      <div style="display:grid;grid-template-columns:1fr;gap:0;" class="systems-grid">

        <div style="border-bottom:1px solid rgba(255,255,255,0.06);">
          <div style="padding:1rem 2rem;border-bottom:1px solid rgba(255,255,255,0.05);display:flex;align-items:center;gap:0.75rem;background:rgba(96,165,250,0.03);">
            <span class="badge badge-accent">Innovation System</span>
            <span style="font-family:'JetBrains Mono',monospace;font-size:0.65rem;color:#3f3f46;">Chris Kincade</span>
            <span style="margin-left:auto;font-family:'JetBrains Mono',monospace;font-size:0.6rem;color:#60a5fa;">4 frameworks</span>
          </div>
          <div style="display:grid;gap:0;" class="framework-grid">
            {[
              ['ID10', 'Value-Centric Design', 'Conversational excavation of who you are — creates Cultural, Product, Customer, and Market Values (ID20–23).'],
              ['MA10', 'Open Road Canvas', 'Strategic positioning — creates Competitive Positioning, Business Model, and Revenue Strategy (MA20–22).'],
              ['IN10', 'Value Mapping', 'Defines what you\'re building — creates Product Roadmap and Growth Strategy (IN20–21).'],
              ['BR10', 'Impact Branding', 'Transforms values into market impact — creates Brand Positioning and Stakeholder Communications (BR20–22).'],
            ].map(([code, title, body], i, arr) => (
              <div style={`padding:1.25rem 2rem;display:flex;gap:1rem;align-items:flex-start;${i < arr.length - 1 ? 'border-bottom:1px solid rgba(255,255,255,0.04);' : ''}`}>
                <span style="font-family:'JetBrains Mono',monospace;font-size:0.7rem;color:#60a5fa;min-width:36px;padding-top:1px;">{code}</span>
                <div>
                  <p style="font-size:0.875rem;color:#e4e4e7;font-weight:500;margin:0 0 0.2rem;">{title}</p>
                  <p style="font-size:0.8rem;color:#52525b;line-height:1.65;margin:0;">{body}</p>
                </div>
              </div>
            ))}
          </div>
        </div>

        <div style="border-bottom:1px solid rgba(255,255,255,0.06);">
          <div style="padding:1rem 2rem;border-bottom:1px solid rgba(255,255,255,0.05);display:flex;align-items:center;gap:0.75rem;background:rgba(167,139,250,0.03);">
            <span class="badge badge-violet">Optimisation System</span>
            <span style="font-family:'JetBrains Mono',monospace;font-size:0.65rem;color:#3f3f46;">Ari Meisel</span>
            <span style="margin-left:auto;font-family:'JetBrains Mono',monospace;font-size:0.6rem;color:#a78bfa;">4 frameworks</span>
          </div>
          <div style="display:grid;gap:0;" class="framework-grid">
            {[
              ['PD10', 'The Genius Paradigm', 'Defines your most strategic work zone — creates Innovation Zone and Task Replacement Plan (PD20–21).'],
              ['WF10', 'Smart Workflows', 'Clarifies how work flows with minimal friction — creates Signal Clarity and Delegation Standards (WF20–22).'],
              ['PR10', 'Process Perfection', 'Establishes AI-native SOPs — creates Process Clarity and Quality Standards (PR20–22).'],
              ['CU10', 'Eight Traits of Endurance', 'Cultural practices that sustain performance — creates Cultural Framework and Team Structure (CU20–22).'],
            ].map(([code, title, body], i, arr) => (
              <div style={`padding:1.25rem 2rem;display:flex;gap:1rem;align-items:flex-start;${i < arr.length - 1 ? 'border-bottom:1px solid rgba(255,255,255,0.04);' : ''}`}>
                <span style="font-family:'JetBrains Mono',monospace;font-size:0.7rem;color:#a78bfa;min-width:36px;padding-top:1px;">{code}</span>
                <div>
                  <p style="font-size:0.875rem;color:#e4e4e7;font-weight:500;margin:0 0 0.2rem;">{title}</p>
                  <p style="font-size:0.8rem;color:#52525b;line-height:1.65;margin:0;">{body}</p>
                </div>
              </div>
            ))}
          </div>
        </div>

        <div>
          <div style="padding:1rem 2rem;border-bottom:1px solid rgba(255,255,255,0.05);display:flex;align-items:center;gap:0.75rem;background:rgba(45,212,191,0.03);">
            <span class="badge badge-teal">Cognitive System</span>
            <span style="font-family:'JetBrains Mono',monospace;font-size:0.65rem;color:#3f3f46;">Chris Kincade</span>
            <span style="margin-left:auto;font-family:'JetBrains Mono',monospace;font-size:0.6rem;color:#2dd4bf;">4 frameworks</span>
          </div>
          <div style="display:grid;gap:0;" class="framework-grid">
            {[
              ['SY10', 'Smart Orgs', 'AI-native organisational design — establishes System Configuration and governance protocols (SY21).'],
              ['LA10', 'Organisational Intelligence', 'Builds the measurement layer — creates Empirical and Empathic Metrics as Autonomic Equations (LA20–21).'],
              ['IT10', 'Activating Your Smart OS', 'Connects external intelligence sources — creates Intelligence Access and Integration Standards (IT20–21).'],
              ['SY11', 'Unlocking Deep Context', 'Advanced memory enhancement — refines all Constitutional memories with Deep Context layers.'],
            ].map(([code, title, body], i, arr) => (
              <div style={`padding:1.25rem 2rem;display:flex;gap:1rem;align-items:flex-start;${i < arr.length - 1 ? 'border-bottom:1px solid rgba(255,255,255,0.04);' : ''}`}>
                <span style="font-family:'JetBrains Mono',monospace;font-size:0.7rem;color:#2dd4bf;min-width:36px;padding-top:1px;">{code}</span>
                <div>
                  <p style="font-size:0.875rem;color:#e4e4e7;font-weight:500;margin:0 0 0.2rem;">{title}</p>
                  <p style="font-size:0.8rem;color:#52525b;line-height:1.65;margin:0;">{body}</p>
                </div>
              </div>
            ))}
          </div>
        </div>

      </div>
      <div style="padding:1.25rem 2rem;border-top:1px solid rgba(255,255,255,0.06);display:flex;align-items:center;gap:1.5rem;flex-wrap:wrap;">
        <span style="font-size:0.825rem;color:#71717a;">Six successive systems. Each one builds on the last.</span>
        <span class="badge badge-neutral">No code required</span>
      </div>
    </div>

  </div>
</section>

<!-- ── Image Split: Enterprise ────────────────────────────────── -->
<section style="border-top:1px solid rgba(255,255,255,0.07);overflow:hidden;">
  <div class="img-split reverse">
    <div class="img-split-photo">
      <img src="/images/abstract-city-building-shadows.jpg" alt="Enterprise-scale organizational intelligence" />
      <div class="img-split-overlay">
        <div style="display:flex;gap:1rem;flex-wrap:wrap;">
          {[['12', 'Installers'],['28','Memories'],['9wk','Certification']].map(([n,l]) => (
            <div style="background:rgba(0,0,0,0.7);border:1px solid rgba(255,255,255,0.1);border-radius:8px;padding:0.6rem 0.9rem;">
              <div style="font-family:'Space Grotesk',sans-serif;font-size:1.2rem;font-weight:700;color:#fff;line-height:1;">{n}</div>
              <div style="font-family:'JetBrains Mono',monospace;font-size:0.55rem;color:#71717a;text-transform:uppercase;letter-spacing:0.08em;margin-top:0.2rem;">{l}</div>
            </div>
          ))}
        </div>
      </div>
    </div>
    <div class="img-split-content">
      <p class="feat-num" style="margin-bottom:0.75rem;">4.0 · Design Principles</p>
      <h2 class="feat-h2 heading-display" style="margin-bottom:1.25rem;">Three commitments.<br/>One architecture.</h2>
      <div style="display:flex;flex-direction:column;gap:1.25rem;margin-bottom:2rem;">
        {[
          { num:'01', title:'Information Sovereignty', body:'Your knowledge stays in your repository. Readable. Editable. Portable. Forever. The AI serves your data — it never owns it.' },
          { num:'02', title:'Conversation as Configuration', body:'Business knowledge shouldn\'t require a developer to encode. Guided installers extract intelligence through conversation — at machine speed.' },
          { num:'03', title:'Architecture Over Tools', body:'Tools change. Platforms sunset. Models improve. Architecture endures. UCA is a permanent free standard.' },
        ].map(({num, title, body}) => (
          <div style="display:flex;gap:1rem;align-items:flex-start;">
            <span style="font-family:'JetBrains Mono',monospace;font-size:0.65rem;color:#3f3f46;padding-top:0.15rem;flex-shrink:0;">{num}</span>
            <div>
              <p style="font-size:0.9rem;color:#e4e4e7;font-weight:600;margin:0 0 0.2rem;">{title}</p>
              <p style="font-size:0.82rem;color:#71717a;line-height:1.65;margin:0;">{body}</p>
            </div>
          </div>
        ))}
      </div>
      <a href="/ai-guide" class="btn btn-primary" style="align-self:flex-start;">Get the Free AI Guide →</a>
    </div>
  </div>
</section>

<!-- ── Final CTA ──────────────────────────────────────────────── -->
<section class="feat-section" style="border-top:1px solid rgba(255,255,255,0.07);">
  <div class="container">
    <div class="cta-row">
      <div>
        <p class="feat-num fade-up" data-delay="0">Ready to build →</p>
        <h2 class="feat-h2 heading-display fade-up" data-delay="0.06" style="margin-bottom:1rem;">
          Ready to build the airframe?
        </h2>
        <p class="feat-body fade-up" data-delay="0.1">
          Start with the free standard. See how semantic addressing works. Then decide if you want to go further.
        </p>
        <div class="feat-ctas fade-up" data-delay="0.14">
          <a href="/ai-guide" class="btn btn-primary">Get the Free AI Guide →</a>
          <a href="https://calendly.com/starlingaix" target="_blank" rel="noopener" class="btn btn-ghost">Talk to Us</a>
        </div>
      </div>
      <div class="glass fade-up" data-delay="0.12" style="padding:2.5rem;">
        <p class="feat-num" style="margin-bottom:1.25rem;">What you get on day one</p>
        <div style="display:flex;flex-direction:column;gap:0.85rem;">
          {[
            'Universal Cognitive Architecture — the free standard',
            'AI Guide: plain-language breakdown of how LLMs work',
            'Access to a 9-week Cognitive Design curriculum',
            'Your first Constitutional Memory in week one',
            'A working AI² Chief of Staff within 90 days',
          ].map(item => (
            <div class="check-item">{item}</div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>

</Layout>

<style>
  .about-hero-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
    align-items: start;
  }
  .about-metrics { display: none; }

  @media(min-width: 768px) {
    .about-hero-grid    { grid-template-columns: 1fr 1fr; align-items: center; }
    .about-metrics      { display: block; }
    .principles-grid    { grid-template-columns: repeat(2, 1fr) !important; }
    .framework-grid     { grid-template-columns: repeat(2, 1fr) !important; }
    .stats-strip-4      { grid-template-columns: repeat(4, 1fr) !important; }
    .systems-grid       { grid-template-columns: repeat(3, 1fr) !important; }
  }
  @media(min-width: 768px) {
    .systems-grid > div { border-right: 1px solid rgba(255,255,255,0.06); border-bottom: none !important; }
    .systems-grid > div:last-child { border-right: none; }
    .stats-strip-4 > div { border-right: 1px solid rgba(255,255,255,0.07) !important; border-bottom: none !important; }
    .stats-strip-4 > div:last-child { border-right: none !important; }
  }
</style>
