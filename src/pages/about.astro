    </div>
</section>

<!-- ===== SECTION 7: DESIGN PRINCIPLES ===== -->
<section class="principles" id="principles">
    <div class="principles__inner">
        <div class="section__header reveal">
            <h2 class="section__h"><strong>What we believe</strong></h2>
            <div class="section__header-right">
                <p class="body-lg">Every design decision in Starling traces back to three principles. They aren't marketing copy. They're engineering constraints.</p>
            </div>
        </div>

        <div class="principles__grid">
            <div class="principle reveal">
                <span class="principle__num">01</span>
                <div class="principle__title">Information Sovereignty</div>
                <div class="principle__desc">Your knowledge stays in your repository. Readable. Editable. Portable. Forever. The AI serves your data — it never owns it. No vendor lock-in. No proprietary formats. Natural language, stored where you control it.</div>
            </div>
            <div class="principle reveal reveal-d1">
                <span class="principle__num">02</span>
                <div class="principle__title">Conversation as Configuration</div>
                <div class="principle__desc">Business knowledge shouldn't require a developer to encode. Starling installers extract organizational intelligence through guided conversation — the same way a great consultant would, at machine speed, with permanent output.</div>
            </div>
            <div class="principle reveal reveal-d2">
                <span class="principle__num">03</span>
                <div class="principle__title">Architecture Over Tools</div>
                <div class="principle__desc">Tools change. Platforms sunset. Models improve. Architecture endures. UCA is a permanent free standard because the classification system for business knowledge shouldn't belong to any single vendor — including us.</div>
            </div>
        </div>
    </div>
</section>

<!-- ===== FINAL CTA ===== -->
<section class="final-cta" id="contact">
    <div class="final-cta__inner reveal">
        <h2 class="final-cta__title"><strong>Ready to build the airframe?</strong></h2>
        <p class="final-cta__desc">Start with the free standard. See how semantic addressing works. Then decide if you want to go further.</p>
        <div class="btn-group" style="justify-content:center">
            <a href="#" class="btn btn--primary btn--large">
                Get UCA Free
                <svg class="arrow" width="10" height="10" fill="none" stroke="currentColor" stroke-width="2"><path d="M0.5 5.5h7"/><path d="M5.5 1.5l4 4-4 4"/></svg>
            </a>
            <a href="#contact" class="btn btn--secondary btn--large">Talk to Us</a>
        </div>
    </div>
</section>

</main>
<Footer />
<script is:inline>
/* ========================================================
   HERO — Entrance + Coordinate Animation
   ======================================================== */
(function(){
    const hero = document.querySelector('.ab-hero');
    if (!hero) return;
    setTimeout(() => hero.classList.add('is-loaded'), 100);

    const coords = document.querySelectorAll('.ab-hero__coord');
    if (!coords.length) return;

    let activeIdx = 0;
    let cycleTimer = null;

    // Stagger entrance
    coords.forEach((c, i) => {
        setTimeout(() => c.classList.add('is-visible'), 600 + i * 150);
    });

    // Activate cycling
    function activate(idx) {
        coords.forEach((c, i) => c.classList.toggle('is-active', i === idx));
        activeIdx = idx;
    }

    function startCycle() {
        cycleTimer = setInterval(() => {
            activate((activeIdx + 1) % coords.length);
        }, 2500);
    }

    setTimeout(() => {
        activate(0);
        startCycle();
    }, coords.length * 150 + 800);

    coords.forEach((c, i) => {
        c.addEventListener('click', () => {
            clearInterval(cycleTimer);
            activate(i);
            setTimeout(startCycle, 5000);
        });
    });
})();

/* ========================================================
   AI² — Interactive Convergence Illustration
   ======================================================== */
(function(){
    const illo = document.getElementById('ai2Illo');
    if (!illo) return;
    const node1 = document.getElementById('ai2Node1');
    const node2 = document.getElementById('ai2Node2');
    const flow = document.getElementById('ai2Flow');
    const result = document.getElementById('ai2Result');
    const statusDot = document.getElementById('ai2StatusDot');
    const statusText = document.getElementById('ai2StatusText');
    const lines = flow.querySelectorAll('.ai2__flow-line');
    const op = flow.querySelector('.ai2__flow-op');

    let played = false;

    function animate() {
        if (played) return;
        played = true;
        // Step 1: Show nodes
        setTimeout(() => { node1.classList.add('is-visible'); }, 200);
        setTimeout(() => { node2.classList.add('is-visible'); }, 400);
        // Step 2: Activate nodes
        setTimeout(() => { node1.classList.add('is-active'); }, 800);
        setTimeout(() => { node2.classList.add('is-active'); }, 1100);
        // Step 3: Flow lines converge
        setTimeout(() => { lines.forEach(l => l.classList.add('is-visible')); op.classList.add('is-visible'); }, 1500);
        // Step 4: Result appears
        setTimeout(() => { result.classList.add('is-visible'); }, 2100);
        setTimeout(() => { result.classList.add('is-active'); }, 2500);
        // Step 5: Status
        setTimeout(() => { statusDot.classList.add('is-visible'); statusText.classList.add('is-visible'); }, 2800);
    }

    const observer = new IntersectionObserver(entries => {
        entries.forEach(e => {
            if (e.isIntersecting) { animate(); observer.unobserve(e.target); }
        });
    }, { threshold: 0.3 });
    observer.observe(illo);
})();

/* ========================================================
   METHODS — Tab switching
   ======================================================== */
(function(){
    const tabs = document.querySelectorAll('.methods__tab');
    const panels = document.querySelectorAll('.methods__system');
    if (!tabs.length) return;

    tabs.forEach(tab => {
        tab.addEventListener('click', () => {
            const key = tab.dataset.system;
            tabs.forEach(t => t.classList.toggle('is-active', t === tab));
            panels.forEach(p => {
                const isMatch = p.dataset.panel === key;
                p.classList.toggle('is-active', isMatch);
                // Re-trigger reveal animations
                if (isMatch) {
                    p.querySelectorAll('.reveal').forEach(el => {
                        el.classList.remove('is-visible');
                        setTimeout(() => el.classList.add('is-visible'), 50);
                    });
                }
            });
        });
    });
})();

/* ========================================================
   METHODS — Architecture Interactive Mockup
   ======================================================== */
(function(){
    const arch = document.getElementById('methodsArch');
    if (!arch) return;
    const layers = arch.querySelectorAll('.methods__arch-layer');
    const detail = document.getElementById('archDetail');
    const fill = document.getElementById('archFill');
    const pct = document.getElementById('archPct');

    const LAYERS = [
        { name:'Cognitive Architecture', num:'System 01', desc:'The foundational UCA addressing system. Gives every piece of business knowledge a permanent semantic coordinate — making your organization\'s intelligence speakable to AI.', tags:['UCA Standard','Semantic Addressing','28 Cognates'] },
        { name:'Logic + Routing', num:'System 02', desc:'Operating logic and governance protocols that determine how AI processes requests, routes information, and maintains constitutional compliance across all interactions.', tags:['AI00 Logic','Governance','Routing Rules'] },
        { name:'Value Design', num:'System 03', desc:'The Innovation System. Excavates organizational identity, competitive positioning, and market strategy through guided conversation — creating the first 12 constitutional memories.', tags:['ID10','MA10','IN10','BR10'] },
        { name:'Process Design', num:'System 04', desc:'The Optimization System. Defines how work flows, how genius is deployed, and how processes self-improve — creating 11 operational memories that make your AI understand how you work.', tags:['PD10','WF10','PR10','CU10'] },
        { name:'Autonomic Design', num:'System 05', desc:'The Cognitive System. Activates Smart OS, builds measurement layers, and connects intelligence sources — the final 5 memories that unlock your AI as an autonomous advisor.', tags:['SY10','LA10','IT10','SY11'] },
        { name:'Semantic Design', num:'System 06', desc:'The Translation System. Bridges your Org Brain to external systems, enabling enterprise-wide integration where every tool speaks your organization\'s language natively.', tags:['IT11–14','Semantic Bridge','Integration'] },
    ];

    let activeIdx = 0;
    let cycleTimer = null;

    function renderDetail(idx) {
        const l = LAYERS[idx];
        detail.innerHTML = `
            <div class="methods__arch-detail-num">${l.num}</div>
            <div class="methods__arch-detail-name">${l.name}</div>
            <div class="methods__arch-detail-desc">${l.desc}</div>
            <div class="methods__arch-detail-tags">${l.tags.map(t => `<span class="methods__arch-detail-tag">${t}</span>`).join('')}</div>
        `;
        fill.style.width = Math.round(((idx + 1) / 6) * 100) + '%';
        pct.textContent = (idx + 1) + ' / 6';
    }

    function activate(idx) {
        layers.forEach((l, i) => l.classList.toggle('is-active', i === idx));
        activeIdx = idx;
        renderDetail(idx);
    }

    function startCycle() {
        clearInterval(cycleTimer);
        cycleTimer = setInterval(() => {
            activate((activeIdx + 1) % 6);
        }, 3500);
    }

    // Entrance
    const observer = new IntersectionObserver(entries => {
        entries.forEach(e => {
            if (e.isIntersecting) {
                layers.forEach((l, i) => {
                    setTimeout(() => l.classList.add('is-visible'), i * 120);
                });
                setTimeout(() => { activate(0); startCycle(); }, layers.length * 120 + 300);
                observer.unobserve(e.target);
            }
        });
    }, { threshold: 0.2 });
    observer.observe(arch);

    // Click interaction
    layers.forEach((l, i) => {
        l.addEventListener('click', () => {
            clearInterval(cycleTimer);
            activate(i);
            setTimeout(startCycle, 6000);
        });
    });
})();

/* ========================================================
   SCROLL REVEAL + ANIMATED COUNTERS
   ======================================================== */
const io = new IntersectionObserver((entries) => {
    entries.forEach(e => {
        if (e.isIntersecting) {
            e.target.classList.add('is-visible');
            e.target.querySelectorAll('.counter').forEach(el => {
                if (el.dataset.counted) return;
                el.dataset.counted = '1';
                const target = parseInt(el.dataset.target);
                const suffix = el.dataset.suffix || '';
                const duration = 2000;
                const start = performance.now();
                function tick(now) {
                    const elapsed = now - start;
                    const progress = Math.min(elapsed / duration, 1);
                    const eased = 1 - Math.pow(1 - progress, 3);
                    el.textContent = Math.floor(eased * target) + suffix;
                    if (progress < 1) requestAnimationFrame(tick);
                }
                requestAnimationFrame(tick);
            });
        }
    });
}, { threshold: 0.08, rootMargin: '0px 0px -60px 0px' });
document.querySelectorAll('.reveal').forEach(el => io.observe(el));

/* ========================================================
   SMOOTH SCROLL
   ======================================================== */
document.querySelectorAll('a[href^="#"]').forEach(a => {
    a.addEventListener('click', function(e) {
        const t = document.querySelector(this.getAttribute('href'));
        if (t) { e.preventDefault(); t.scrollIntoView({ behavior: 'smooth', block: 'start' }); }
    });
});
</script>
</BaseLayout>

