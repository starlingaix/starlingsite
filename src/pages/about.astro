---
import Layout from '../layouts/Layout.astro';
---

<Layout title="About — Starling AIX" description="Starling AIX creates a classification system for business knowledge that lives in natural language. Our methodology transforms generic LLMs into contextualized Intelligence Agents.">

<!-- ── Hero ──────────────────────────────────────────────────── -->
<section style="position:relative;overflow:hidden;padding:7rem 0 6rem;" class="grid-bg">
  <div class="hero-glow"></div>
  <span class="corner-mark cm-tl">+</span>
  <span class="corner-mark cm-tr">+</span>
  <div class="container" style="position:relative;z-index:1;">

    <p class="feat-num fade-up" data-delay="0">Starling AIX · The Breakthrough</p>

    <h1 class="heading-display fade-up" data-delay="0.08"
        style="font-size:clamp(3rem,8vw,5.5rem);margin:0 0 1.5rem;max-width:820px;letter-spacing:-0.04em;">
      Your business, now <em>fluent in AI</em>
    </h1>

    <p class="fade-up" data-delay="0.15"
       style="font-size:1.05rem;color:#71717a;line-height:1.75;max-width:580px;margin:0 0 2.5rem;">
      We create a classification system for business knowledge that lives in natural language — not machine code. Our systems establish governing protocols where AI operates by human rules, transforming generic LLMs into contextualized Intelligence Agents.
    </p>

    <div class="fade-up" data-delay="0.2" style="display:flex;gap:0.75rem;flex-wrap:wrap;">
      <a href="/cognitive-design" class="btn btn-primary">Enroll Now →</a>
      <a href="/ai-guide" class="btn btn-ghost">Get Free AI Guide</a>
    </div>

  </div>
</section>

<div class="divider"></div>

<!-- ── Application Intelligence ──────────────────────────────── -->
<section class="feat-section">
  <div class="container">
    <div class="feat-header">
      <!-- Left -->
      <div>
        <p class="feat-num fade-up" data-delay="0">1.0 · Application Intelligence</p>
        <h2 class="feat-h2 heading-display fade-up" data-delay="0.06">
          Raw power meets structured expertise.
        </h2>
      </div>
      <!-- Right -->
      <div>
        <p class="feat-body fade-up" data-delay="0.1">
          Starling transforms generic LLMs into AI² advisors that understand your specific business context. We provide the operating logic that codifies and continually refines your unique approach to innovation.
        </p>
        <p class="feat-body fade-up" data-delay="0.13" style="margin-bottom:0;">
          The AI provides raw processing power. You provide structured expertise. Together they produce Cross Intelligence — cognitive systems that learn and evolve through memory training and daily conversation.
        </p>
      </div>
    </div>

    <!-- AI² equation card -->
    <div class="wide-mock fade-up" data-delay="0.18">
      <div class="mock-bar">
        <span class="mock-dot r"></span><span class="mock-dot y"></span><span class="mock-dot g"></span>
        <span style="font-family:'JetBrains Mono',monospace;font-size:0.7rem;color:#3f3f46;margin-left:0.75rem;">AI² — Cross Intelligence Formula</span>
      </div>
      <div style="padding:2.5rem;display:grid;grid-template-columns:1fr;gap:1px;background:rgba(255,255,255,0.06);" class="ai2-grid">
        {[
          { label: 'AI¹', color: '#a1a1aa', title: 'Artificial Intelligence', desc: 'Raw processing power and pattern recognition from Large Language Models — generalised, context-free, infinitely scalable.' },
          { label: 'AI²', color: '#f97316', title: 'Application Intelligence', desc: 'Human expertise structured for machine processing — your unique genius, your values, your decision frameworks, made machine-executable.' },
          { label: 'AI²', color: '#fff', title: 'Cross Intelligence', desc: 'The product of both: cognitive systems that learn and evolve through memory training, natural conversation, and organisational feedback loops.' },
        ].map(({ label, color, title, desc }) => (
          <div style="background:#050505;padding:1.75rem 2rem;display:flex;gap:1.5rem;align-items:flex-start;">
            <div style={`font-family:'Instrument Serif',Georgia,serif;font-size:1.8rem;font-style:italic;color:${color};min-width:48px;line-height:1;`}>{label}</div>
            <div>
              <p style="font-size:0.9rem;color:#e4e4e7;font-weight:500;margin:0 0 0.35rem;">{title}</p>
              <p style="font-size:0.825rem;color:#52525b;line-height:1.7;margin:0;">{desc}</p>
            </div>
          </div>
        ))}
      </div>
      <div style="padding:1.25rem 2rem;border-top:1px solid rgba(255,255,255,0.06);display:flex;align-items:center;gap:1rem;">
        <span class="badge">AI¹ × AI² = AI²</span>
        <span style="font-family:'JetBrains Mono',monospace;font-size:0.68rem;color:#3f3f46;">Cross Intelligence · Starling AIX</span>
      </div>
    </div>

  </div>
</section>

<div class="divider"></div>

<!-- ── AI-Native Org Design ───────────────────────────────────── -->
<section class="feat-section" style="background:#030303;">
  <div class="container">
    <div class="feat-header">
      <!-- Left -->
      <div>
        <p class="feat-num fade-up" data-delay="0">2.0 · AI-Native Org Design</p>
        <h2 class="feat-h2 heading-display fade-up" data-delay="0.06">
          The first methodology built for the AI era.
        </h2>
      </div>
      <!-- Right -->
      <div>
        <p class="feat-body fade-up" data-delay="0.1">
          Starling AIX is built on <strong style="color:#e4e4e7;">Cognitive Design</strong> — a comprehensive approach to business transformation that synthesises systematic efficiency with human values. This isn't AI trained on the Internet. It's AI trained on Cognitive Design — the methodology of Smart Orgs.
        </p>
        <div class="feat-ctas fade-up" data-delay="0.14">
          <a href="/cognitive-design" class="btn btn-primary">See the Curriculum →</a>
        </div>
      </div>
    </div>

    <div style="display:grid;grid-template-columns:1fr;gap:1rem;" class="principles-grid">
      {[
        ['Combines Lean + Design Thinking', 'With the human-centered problem-solving of Design Thinking — now machine-executable.'],
        ['Makes knowledge machine-executable', 'Codifies your Hierarchy of Organisational Values through six progressive systems.'],
        ['Creates self-improving systems', 'Build intelligence through natural conversation that compounds with every session.'],
        ['Enables a systematic enterprise asset', 'Gets smarter and more valuable over time — not a subscription that resets.'],
      ].map(([title, body], i) => (
        <div class="card fade-up" data-delay={`${i * 0.05}`} style="padding:1.5rem 1.75rem;display:flex;gap:1rem;align-items:flex-start;">
          <div style="width:6px;height:6px;border-radius:50%;background:#f97316;flex-shrink:0;margin-top:0.6rem;"></div>
          <div>
            <p style="font-size:0.95rem;color:#e4e4e7;margin:0 0 0.25rem;font-weight:500;">{title}</p>
            <p style="font-size:0.875rem;color:#71717a;line-height:1.7;margin:0;">{body}</p>
          </div>
        </div>
      ))}
    </div>

  </div>
</section>

<div class="divider"></div>

<!-- ── Proven Methods ─────────────────────────────────────────── -->
<section class="feat-section" style="position:relative;" class="grid-bg">
  <div class="container">
    <div class="feat-header">
      <!-- Left -->
      <div>
        <p class="feat-num fade-up" data-delay="0">3.0 · Proven Methods</p>
        <h2 class="feat-h2 heading-display fade-up" data-delay="0.06">
          Built from real frameworks, not research labs.
        </h2>
      </div>
      <!-- Right -->
      <div>
        <p class="feat-body fade-up" data-delay="0.1">
          Most AI platforms start with technology and try to fit business into it. Starling AIX started with <strong style="color:#e4e4e7;">Chris Kincade</strong> and <strong style="color:#e4e4e7;">Ari Meisel's</strong> frameworks for business design, optimisation, and transformation — then made them machine-executable.
        </p>
        <p class="feat-body fade-up" data-delay="0.13" style="font-style:italic;color:#3f3f46;margin-bottom:0;">
          The sound barrier didn't stop aviation. It defined the engineering required to go faster. We designed the airframe for Industry 5.0.
        </p>
      </div>
    </div>

    <!-- Stats strip -->
    <div class="fade-up" data-delay="0.15" style="display:grid;grid-template-columns:repeat(2,1fr);border:1px solid rgba(255,255,255,0.07);border-radius:12px;overflow:hidden;margin-bottom:3rem;" class="stats-strip-4">
      {[
        ['25', 'Years of methodology'],
        ['12K', 'Hours of interface design'],
        ['12', 'Installer frameworks'],
        ['28', 'Constitutional memories'],
      ].map(([num, label], i) => (
        <div style={`background:#0a0a0a;padding:2rem 1.5rem;text-align:center;${i % 2 === 0 ? 'border-right:1px solid rgba(255,255,255,0.07);' : ''}${i < 2 ? 'border-bottom:1px solid rgba(255,255,255,0.07);' : ''}`}>
          <div class="stat-num">{num}</div>
          <div class="stat-label">{label}</div>
        </div>
      ))}
    </div>

    <!-- Three Systems as wide-mock -->
    <div class="wide-mock fade-up" data-delay="0.18">
      <div class="mock-bar">
        <span class="mock-dot r"></span><span class="mock-dot y"></span><span class="mock-dot g"></span>
        <span style="font-family:'JetBrains Mono',monospace;font-size:0.7rem;color:#3f3f46;margin-left:0.75rem;">Cognitive Design — 12 Installer Frameworks</span>
      </div>
      <div style="display:grid;grid-template-columns:1fr;gap:0;" class="systems-grid">

        <!-- Innovation System -->
        <div style="border-bottom:1px solid rgba(255,255,255,0.06);">
          <div style="padding:1.25rem 2rem;border-bottom:1px solid rgba(255,255,255,0.05);display:flex;align-items:center;gap:0.75rem;">
            <span class="badge">Innovation System</span>
            <span style="font-family:'JetBrains Mono',monospace;font-size:0.65rem;color:#3f3f46;">Chris Kincade</span>
          </div>
          <div style="display:grid;gap:0;" class="framework-grid">
            {[
              ['ID10', 'Value-Centric Design', 'Conversational excavation of who you are — creates Cultural, Product, Customer, and Market Values (ID20–23).'],
              ['MA10', 'Open Road Canvas', 'Strategic positioning — creates Competitive Positioning, Business Model, and Revenue Strategy (MA20–22).'],
              ['IN10', 'Value Mapping', 'Defines what you\'re building — creates Product Roadmap and Growth Strategy (IN20–21).'],
              ['BR10', 'Impact Branding', 'Transforms values into market impact — creates Brand Positioning and Stakeholder Communications (BR20–22).'],
            ].map(([code, title, body], i, arr) => (
              <div style={`padding:1.25rem 2rem;display:flex;gap:1rem;align-items:flex-start;${i < arr.length - 1 ? 'border-bottom:1px solid rgba(255,255,255,0.04);' : ''}`}>
                <span style="font-family:'JetBrains Mono',monospace;font-size:0.7rem;color:#f97316;min-width:36px;padding-top:1px;">{code}</span>
                <div>
                  <p style="font-size:0.875rem;color:#e4e4e7;font-weight:500;margin:0 0 0.2rem;">{title}</p>
                  <p style="font-size:0.8rem;color:#52525b;line-height:1.65;margin:0;">{body}</p>
                </div>
              </div>
            ))}
          </div>
        </div>

        <!-- Optimisation System -->
        <div style="border-bottom:1px solid rgba(255,255,255,0.06);">
          <div style="padding:1.25rem 2rem;border-bottom:1px solid rgba(255,255,255,0.05);display:flex;align-items:center;gap:0.75rem;">
            <span class="badge">Optimisation System</span>
            <span style="font-family:'JetBrains Mono',monospace;font-size:0.65rem;color:#3f3f46;">Ari Meisel</span>
          </div>
          <div style="display:grid;gap:0;" class="framework-grid">
            {[
              ['PD10', 'The Genius Paradigm', 'Defines your most strategic work zone — creates Innovation Zone and Task Replacement Plan (PD20–21).'],
              ['WF10', 'Smart Workflows', 'Clarifies how work flows with minimal friction — creates Signal Clarity and Delegation Standards (WF20–22).'],
              ['PR10', 'Process Perfection', 'Establishes AI-native SOPs — creates Process Clarity and Quality Standards (PR20–22).'],
              ['CU10', 'Eight Traits of Endurance', 'Cultural practices that sustain performance — creates Cultural Framework and Team Structure (CU20–22).'],
            ].map(([code, title, body], i, arr) => (
              <div style={`padding:1.25rem 2rem;display:flex;gap:1rem;align-items:flex-start;${i < arr.length - 1 ? 'border-bottom:1px solid rgba(255,255,255,0.04);' : ''}`}>
                <span style="font-family:'JetBrains Mono',monospace;font-size:0.7rem;color:#f97316;min-width:36px;padding-top:1px;">{code}</span>
                <div>
                  <p style="font-size:0.875rem;color:#e4e4e7;font-weight:500;margin:0 0 0.2rem;">{title}</p>
                  <p style="font-size:0.8rem;color:#52525b;line-height:1.65;margin:0;">{body}</p>
                </div>
              </div>
            ))}
          </div>
        </div>

        <!-- Cognitive System -->
        <div>
          <div style="padding:1.25rem 2rem;border-bottom:1px solid rgba(255,255,255,0.05);display:flex;align-items:center;gap:0.75rem;">
            <span class="badge">Cognitive System</span>
            <span style="font-family:'JetBrains Mono',monospace;font-size:0.65rem;color:#3f3f46;">Chris Kincade</span>
          </div>
          <div style="display:grid;gap:0;" class="framework-grid">
            {[
              ['SY10', 'Smart Orgs', 'AI-native organisational design — establishes System Configuration and governance protocols (SY21).'],
              ['LA10', 'Organisational Intelligence', 'Builds the measurement layer — creates Empirical and Empathic Metrics as Autonomic Equations (LA20–21).'],
              ['IT10', 'Activating Your Smart OS', 'Connects external intelligence sources — creates Intelligence Access and Integration Standards (IT20–21).'],
              ['SY11', 'Unlocking Deep Context', 'Advanced memory enhancement — refines all Constitutional memories with Deep Context layers.'],
            ].map(([code, title, body], i, arr) => (
              <div style={`padding:1.25rem 2rem;display:flex;gap:1rem;align-items:flex-start;${i < arr.length - 1 ? 'border-bottom:1px solid rgba(255,255,255,0.04);' : ''}`}>
                <span style="font-family:'JetBrains Mono',monospace;font-size:0.7rem;color:#f97316;min-width:36px;padding-top:1px;">{code}</span>
                <div>
                  <p style="font-size:0.875rem;color:#e4e4e7;font-weight:500;margin:0 0 0.2rem;">{title}</p>
                  <p style="font-size:0.8rem;color:#52525b;line-height:1.65;margin:0;">{body}</p>
                </div>
              </div>
            ))}
          </div>
        </div>

      </div>
      <div style="padding:1.25rem 2rem;border-top:1px solid rgba(255,255,255,0.06);display:flex;align-items:center;gap:1.5rem;flex-wrap:wrap;">
        <span style="font-size:0.825rem;color:#71717a;">Six successive systems. Each one builds on the last.</span>
        <span class="badge badge-neutral">No code required</span>
      </div>
    </div>

  </div>
</section>

<div class="divider"></div>

<!-- ── Design Principles ──────────────────────────────────────── -->
<section class="feat-section">
  <div class="container">
    <div class="feat-header">
      <!-- Left -->
      <div>
        <p class="feat-num fade-up" data-delay="0">4.0 · Design Principles</p>
        <h2 class="feat-h2 heading-display fade-up" data-delay="0.06">
          What we believe.
        </h2>
      </div>
      <!-- Right -->
      <div>
        <p class="feat-body fade-up" data-delay="0.1">
          Every design decision in Starling traces back to three principles. They aren't marketing copy. They're engineering constraints — the architectural commitments that shape every feature we build.
        </p>
      </div>
    </div>

    <div style="display:grid;grid-template-columns:1fr;gap:1.5rem;" class="dp-grid">

      <div class="card fade-up" data-delay="0" style="padding:2.5rem;">
        <div style="font-family:'JetBrains Mono',monospace;font-size:0.72rem;color:#f97316;margin-bottom:1rem;">01</div>
        <h3 style="font-size:1.2rem;color:#fff;margin:0 0 0.75rem;letter-spacing:-0.02em;">Information Sovereignty</h3>
        <p style="color:#71717a;font-size:0.9rem;line-height:1.8;margin:0;">
          Your knowledge stays in your repository. Readable. Editable. Portable. Forever. The AI serves your data — it never owns it. No vendor lock-in. No proprietary formats.
        </p>
      </div>

      <div class="card fade-up" data-delay="0.06" style="padding:2.5rem;">
        <div style="font-family:'JetBrains Mono',monospace;font-size:0.72rem;color:#f97316;margin-bottom:1rem;">02</div>
        <h3 style="font-size:1.2rem;color:#fff;margin:0 0 0.75rem;letter-spacing:-0.02em;">Conversation as Configuration</h3>
        <p style="color:#71717a;font-size:0.9rem;line-height:1.8;margin:0;">
          Business knowledge shouldn't require a developer to encode. Starling installers extract organisational intelligence through guided conversation — at machine speed, with permanent output.
        </p>
      </div>

      <div class="card fade-up" data-delay="0.12" style="padding:2.5rem;">
        <div style="font-family:'JetBrains Mono',monospace;font-size:0.72rem;color:#f97316;margin-bottom:1rem;">03</div>
        <h3 style="font-size:1.2rem;color:#fff;margin:0 0 0.75rem;letter-spacing:-0.02em;">Architecture Over Tools</h3>
        <p style="color:#71717a;font-size:0.9rem;line-height:1.8;margin:0;">
          Tools change. Platforms sunset. Models improve. Architecture endures. UCA is a permanent free standard because the classification system for business knowledge shouldn't belong to any single vendor — including us.
        </p>
      </div>

    </div>
  </div>
</section>

<div class="divider"></div>

<!-- ── Final CTA ──────────────────────────────────────────────── -->
<section class="feat-section">
  <div class="container">
    <div class="cta-row">
      <div>
        <p class="feat-num fade-up" data-delay="0">Ready to build →</p>
        <h2 class="feat-h2 heading-display fade-up" data-delay="0.06" style="margin-bottom:1rem;">
          Ready to build the airframe?
        </h2>
        <p class="feat-body fade-up" data-delay="0.1">
          Start with the free standard. See how semantic addressing works. Then decide if you want to go further.
        </p>
        <div class="feat-ctas fade-up" data-delay="0.14">
          <a href="/ai-guide" class="btn btn-primary">Get the Free AI Guide →</a>
          <a href="https://calendly.com/starlingaix" target="_blank" rel="noopener" class="btn btn-ghost">Talk to Us</a>
        </div>
      </div>
      <div class="glass fade-up" data-delay="0.12" style="padding:2.5rem;">
        <p class="feat-num" style="margin-bottom:1.25rem;">What you get on day one</p>
        <div style="display:flex;flex-direction:column;gap:0.85rem;">
          {[
            'Universal Cognitive Architecture — the free standard',
            'AI Guide: plain-language breakdown of how LLMs work',
            'Access to a 9-week Cognitive Design curriculum',
            'Your first Constitutional Memory in week one',
            'A working AI² Chief of Staff within 90 days',
          ].map(item => (
            <div class="check-item">{item}</div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>

</Layout>

<style>
  @media(min-width:768px) {
    .principles-grid { grid-template-columns: repeat(2, 1fr) !important; }
    .dp-grid         { grid-template-columns: repeat(3, 1fr) !important; }
    .framework-grid  { grid-template-columns: repeat(2, 1fr) !important; }
    .stats-strip-4   { grid-template-columns: repeat(4, 1fr) !important; }
    .systems-grid    { grid-template-columns: repeat(3, 1fr) !important; }
  }
  @media(min-width:768px) {
    .systems-grid > div { border-right: 1px solid rgba(255,255,255,0.06); border-bottom: none !important; }
    .systems-grid > div:last-child { border-right: none; }
    .stats-strip-4 > div { border-right: 1px solid rgba(255,255,255,0.07) !important; border-bottom: none !important; }
    .stats-strip-4 > div:last-child { border-right: none !important; }
  }
</style>
