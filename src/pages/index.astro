<script>
  // ── Tab switcher
  const tabData: Record<string, {label: string, status: string, color: string}> = {
    '0': { label: 'starling.workspace — UCA · Cognate Library', status: 'MA20 active', color: '#60a5fa' },
    '1': { label: 'starling.workspace — Org Brain · Architecture View', status: '● 28 memories indexed', color: '#a78bfa' },
    '2': { label: 'starling.dlm — Organizational Query Interface', status: '● DLM Active', color: '#2dd4bf' },
  };

  const barLabel  = document.getElementById('mock-bar-label');
  const barStatus = document.getElementById('mock-bar-status');

  document.getElementById('tab-cards')?.querySelectorAll('.tab-card').forEach(card => {
    card.addEventListener('click', () => {
      const tab = (card as HTMLElement).dataset.tab ?? '0';

      // Update panels
      document.querySelectorAll('.tab-panel').forEach(p => p.classList.remove('active'));
      document.getElementById(`panel-${tab}`)?.classList.add('active');

      // Update tab cards
      document.querySelectorAll('.tab-card').forEach(c => c.classList.remove('active'));
      card.classList.add('active');

      // Update mock bar
      const d = tabData[tab];
      if (barLabel) barLabel.textContent = d.label;
      if (barStatus) { barStatus.textContent = d.status; barStatus.style.color = d.color; }
    });
  });

  // ── Newsletter form
  document.getElementById('nl-form')?.addEventListener('submit', e => {
    e.preventDefault();
    const btn = (e.target as HTMLFormElement).querySelector('button') as HTMLButtonElement;
    btn.textContent = "You're in!";
    btn.disabled = true;
    setTimeout(() => { btn.textContent = 'Subscribe'; btn.disabled = false; (e.target as HTMLFormElement).reset(); }, 3500);
  });
</script>
