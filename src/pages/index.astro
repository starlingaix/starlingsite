  .brain-hem-optim .brain-hem-label { color: #c87b45; }
  .brain-sys { margin-bottom: 0.65rem; padding: 0.55rem 0.75rem; border: 1px solid rgba(255,255,255,0.05); border-radius: 7px; background: rgba(255,255,255,0.02); }
