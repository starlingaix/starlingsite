---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---
<BaseLayout title="Starling AIX | Enterprise Organizational Intelligence" description="Starling builds organizational intelligence systems — then makes sure someone in your organization can run them.">
<Nav currentPage="index" />
<main>

<section class="hero">
    <div class="hero__bg"></div>
    <div class="hero__content">
        <div class="hero__text">
            <p class="hero__eyebrow">Introducing</p>
            <div class="hero__title">
                <em><span style="color:var(--brand);display:inline">Mach 1</span> Business</em>
                <span>The sound barrier didn't stop aviation. It defined the engineering required to go faster. Your business has a similar barrier. We built the airframe.</span>
            </div>
            <div class="hero__cta-wrap">
                <a href="#barrier" class="btn btn--primary btn--large">
                    Start Here
                    <svg class="arrow" width="10" height="10" fill="none" stroke="currentColor" stroke-width="2"><path d="M0.5 5.5h7"/><path d="M5.5 1.5l4 4-4 4"/></svg>
                </a>
            </div>
        </div>
    </div>

    <!-- Full-width DLM Intelligence Engine Mockup -->
    <div class="hero-mock" id="heroMock">
        <div class="hero-mock__card">
            <div class="hero-mock__bar">
                <div class="hero-mock__dots"><span class="hero-mock__dot"></span><span class="hero-mock__dot"></span><span class="hero-mock__dot"></span></div>
                <div class="hero-mock__bar-title">Starling Intelligence Engine</div>
            </div>
            <div class="hero-mock__body">
                <!-- Left: 4 Pillar Modules -->
                <div class="hero-mock__modules">
                    <div class="hero-mock__module" data-mod="llm" style="color:var(--accent-pink)">
                        <div class="hero-mock__module-icon hero-mock__module-icon--llm">LLM</div>
                        <div class="hero-mock__module-info">
                            <div class="hero-mock__module-name">Language Model</div>
                            <div class="hero-mock__module-desc">Stateless processing engine</div>
                        </div>
                        <div class="hero-mock__module-pulse" style="background:var(--accent-pink)"></div>
                    </div>
                    <div class="hero-mock__module" data-mod="mcp" style="color:var(--accent-teal)">
                        <div class="hero-mock__module-icon hero-mock__module-icon--mcp">MCP</div>
                        <div class="hero-mock__module-info">
                            <div class="hero-mock__module-name">Context Protocol</div>
                            <div class="hero-mock__module-desc">Universal connector layer</div>
                        </div>
                        <div class="hero-mock__module-pulse" style="background:var(--accent-teal)"></div>
                    </div>
                    <div class="hero-mock__module" data-mod="uca" style="color:var(--brand)">
                        <div class="hero-mock__module-icon hero-mock__module-icon--uca">UCA</div>
                        <div class="hero-mock__module-info">
                            <div class="hero-mock__module-name">Cognitive Architecture</div>
                            <div class="hero-mock__module-desc">Semantic address system</div>
                        </div>
                        <div class="hero-mock__module-pulse" style="background:var(--brand)"></div>
                    </div>
                    <div class="hero-mock__module" data-mod="org" style="color:var(--accent-blue)">
                        <div class="hero-mock__module-icon hero-mock__module-icon--org">ORG</div>
                        <div class="hero-mock__module-info">
                            <div class="hero-mock__module-name">Org Brain</div>
                            <div class="hero-mock__module-desc">Sovereign knowledge store</div>
                        </div>
                        <div class="hero-mock__module-pulse" style="background:var(--accent-blue)"></div>
                    </div>
                </div>

                <!-- Right: Live Resolution -->
                <div class="hero-mock__live">
                    <div class="hero-mock__live-header">
                        <span class="hero-mock__live-label">Live Resolution</span>
                        <span class="hero-mock__live-status" id="mockStatus"><span class="hero-mock__live-status-dot"></span> Connected</span>
                    </div>
                    <div class="hero-mock__query" id="mockQuery">
                        <span class="hero-mock__query-icon">resolve&gt;</span>
                        <span class="hero-mock__query-text" id="mockQueryText"></span>
                        <span class="hero-mock__query-cursor" id="mockCursor"></span>
                    </div>
                    <div class="hero-mock__pipeline" id="mockPipeline"></div>
                    <div class="hero-mock__result" id="mockResult"></div>
                </div>
            </div>
            <div class="hero-mock__footer">
                <div class="hero-mock__footer-left">
                    <div class="hero-mock__footer-stat">
                        <span class="hero-mock__footer-dot" style="background:var(--accent-teal)"></span>
                        Canonical Coverage
                        <div class="hero-mock__footer-bar"><div class="hero-mock__footer-fill" id="mockFill"></div></div>
                    </div>
                    <div class="hero-mock__footer-stat">
                        <span class="hero-mock__footer-dot" style="background:var(--brand)"></span>
                        <span id="mockCognates">0</span> / 28 Cognates Mapped
                    </div>
                </div>
                <button class="hero-mock__replay" id="mockReplay">&#x21bb; Replay</button>
            </div>
        </div>
        <div class="hero-mock__spacer"></div>
    </div>
</section>

<!-- ===== THE COGNITION BARRIER ===== -->
<section class="barrier" id="barrier">
    <div class="barrier__inner">
        <div class="barrier__header reveal">
            <div class="barrier__header-left">
                <h2 class="barrier__h"><strong>More AI won't make you faster.</strong> Better architecture will.</h2>
            </div>
            <div class="barrier__header-right">
                <p class="body-lg">Every organization hits the same wall. You add AI tools, solutions, and specialists — but instead of accelerating, you hit turbulence. Information fragments. Context evaporates. Your AI is out of sync. Your team resists.</p>
                <p class="body-lg">That's the cognition barrier. The answer isn't more power. It's better infrastructure.</p>
            </div>
        </div>

        <div class="barrier__visual reveal">
            <div class="barrier-mockup">
                <div class="barrier-toggle">
                    <div class="barrier-toggle__bar">
                        <button class="barrier-toggle__btn is-active" data-panel="without">Without DLM</button>
                        <button class="barrier-toggle__btn" data-panel="with">With DLM</button>
                    </div>
                </div>
                <div class="barrier-panels">
                    <!-- Without DLM: messy chat -->
                    <div class="barrier-panel is-active" id="barrierWithout">
                        <div class="barrier-chat">
                            <div class="barrier-chat__msg barrier-chat__msg--user">
                                <div class="barrier-chat__avatar barrier-chat__avatar--user">You</div>
                                <div class="barrier-chat__bubble barrier-chat__bubble--user">What's our competitive positioning strategy?</div>
                            </div>
                            <div class="barrier-chat__msg">
                                <div class="barrier-chat__avatar barrier-chat__avatar--ai">AI</div>
                                <div class="barrier-chat__bubble barrier-chat__bubble--ai">
                                    <span class="vague">Based on various sources, here are some general thoughts on competitive positioning...</span>
                                    <div class="barrier-chat__results">
                                        <div class="barrier-chat__result"><span class="url">drive.google.com/doc/47x...</span> Marketing deck v3 (outdated)</div>
                                        <div class="barrier-chat__result"><span class="url">notion.so/strategy-q2...</span> Q2 notes (partial)</div>
                                        <div class="barrier-chat__result"><span class="url">slack.com/archive/c-strat...</span> Thread from 6 months ago</div>
                                    </div>
                                </div>
                            </div>
                            <div class="barrier-chat__msg barrier-chat__msg--user">
                                <div class="barrier-chat__avatar barrier-chat__avatar--user">You</div>
                                <div class="barrier-chat__bubble barrier-chat__bubble--user">Which one is the actual current strategy?</div>
                            </div>
                            <div class="barrier-chat__msg">
                                <div class="barrier-chat__avatar barrier-chat__avatar--ai">AI</div>
                                <div class="barrier-chat__bubble barrier-chat__bubble--ai"><span class="vague">I'm not sure which document is the most up-to-date. You may want to check with your strategy team...</span></div>
                            </div>
                            <div class="barrier-chat__noise">Scattered context. No authority. No single source of truth.</div>
                        </div>
                    </div>
                    <!-- With DLM: clean retrieval -->
                    <div class="barrier-panel" id="barrierWith">
                        <div class="barrier-retrieval">
                            <div class="barrier-retrieval__prompt">
                                <div class="barrier-retrieval__prompt-icon"><svg viewBox="0 0 24 24"><path d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg></div>
                                <div class="barrier-retrieval__prompt-text">Resolve: <strong>MA20</strong> — Competitive Position</div>
                            </div>
                            <div class="barrier-retrieval__arrow">&#8595;</div>
                            <div class="barrier-retrieval__card">
                                <div class="barrier-retrieval__addr">
                                    <span class="barrier-retrieval__code">MA20</span>
                                    <span class="barrier-retrieval__status"><span class="barrier-retrieval__status-dot"></span> Canonical</span>
                                </div>
                                <div class="barrier-retrieval__title">Competitive Position &amp; Market Strategy</div>
                                <div class="barrier-retrieval__meta">
                                    <span class="barrier-retrieval__tag barrier-retrieval__tag--type">Persistent Memory</span>
                                    <span class="barrier-retrieval__tag barrier-retrieval__tag--canon">Single Source of Truth</span>
                                </div>
                                <div class="barrier-retrieval__excerpt">The organization competes on cognitive infrastructure — not features. Our moat is the architecture itself: UCA addressing + sovereign Org Brain + DLM synthesis. Updated Q1 2026.</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

    </div>
</section>

<!-- ===== FROM SCOPE TO AUTHORITY ===== -->
<section class="scope" id="scope">
    <div class="scope__inner">
        <div class="cognates reveal">
            <div class="cognates__header">
                <p class="overline">11 Organizational Cognates</p>
                <h3 class="h3" style="color:var(--text-secondary)"><strong style="color:var(--text-primary);font-weight:500">The Neural System</strong> for Business</h3>
            </div>
        </div>

        <div class="brain-mockup reveal" id="brainMockup">
            <div class="brain-mockup__canvas-wrap">
                <div class="brain-orbit brain-orbit--1"></div>
                <div class="brain-orbit brain-orbit--2"></div>
                <svg class="brain-pulse" id="brainPulse"></svg>
                <div class="brain-hub">
                    <span class="brain-hub__label">Brain</span>
                    <span class="brain-hub__count" id="brainCount">0</span>
                </div>
                <div class="brain-node" data-brain="identity" style="color:#D4702C">
                    <span class="brain-node__dot" style="background:#D4702C"></span>
                    <span class="brain-node__label">Identity</span>
                </div>
                <div class="brain-node" data-brain="strategy" style="color:#1a9e82">
                    <span class="brain-node__dot" style="background:#1a9e82"></span>
                    <span class="brain-node__label">Strategy</span>
                </div>
                <div class="brain-node" data-brain="operations" style="color:#635bff">
                    <span class="brain-node__dot" style="background:#635bff"></span>
                    <span class="brain-node__label">Operations</span>
                </div>
                <div class="brain-node" data-brain="culture" style="color:#e06090">
                    <span class="brain-node__dot" style="background:#e06090"></span>
                    <span class="brain-node__label">Culture</span>
                </div>
                <div class="brain-node" data-brain="innovation" style="color:#e8945a">
                    <span class="brain-node__dot" style="background:#e8945a"></span>
                    <span class="brain-node__label">Innovation</span>
                </div>
                <div class="brain-node" data-brain="compliance" style="color:#36d1b7">
                    <span class="brain-node__dot" style="background:#36d1b7"></span>
                    <span class="brain-node__label">Compliance</span>
                </div>
            </div>
            <div class="brain-sidebar">
                <div class="brain-sidebar__title">Memory Systems</div>
                <div class="brain-sidebar__list" id="brainSidebarList">
                    <div class="brain-sidebar__item" data-brain-side="identity">
                        <div class="brain-sidebar__item-row">
                            <span class="brain-sidebar__item-dot" style="background:#D4702C"></span>
                            <span class="brain-sidebar__item-name">Identity</span>
                        </div>
                        <span class="brain-sidebar__item-status">6 memories trained</span>
                        <div class="brain-sidebar__item-bar"><div class="brain-sidebar__item-fill" style="background:#D4702C" data-width="100%"></div></div>
                    </div>
                    <div class="brain-sidebar__item" data-brain-side="strategy">
                        <div class="brain-sidebar__item-row">
                            <span class="brain-sidebar__item-dot" style="background:#1a9e82"></span>
                            <span class="brain-sidebar__item-name">Strategy</span>
                        </div>
                        <span class="brain-sidebar__item-status">4 memories trained</span>
                        <div class="brain-sidebar__item-bar"><div class="brain-sidebar__item-fill" style="background:#1a9e82" data-width="72%"></div></div>
                    </div>
                    <div class="brain-sidebar__item" data-brain-side="operations">
                        <div class="brain-sidebar__item-row">
                            <span class="brain-sidebar__item-dot" style="background:#635bff"></span>
                            <span class="brain-sidebar__item-name">Operations</span>
                        </div>
                        <span class="brain-sidebar__item-status">3 memories training</span>
                        <div class="brain-sidebar__item-bar"><div class="brain-sidebar__item-fill" style="background:#635bff" data-width="55%"></div></div>
                    </div>
                    <div class="brain-sidebar__item" data-brain-side="culture">
                        <div class="brain-sidebar__item-row">
                            <span class="brain-sidebar__item-dot" style="background:#e06090"></span>
                            <span class="brain-sidebar__item-name">Culture</span>
                        </div>
                        <span class="brain-sidebar__item-status">2 memories pending</span>
                        <div class="brain-sidebar__item-bar"><div class="brain-sidebar__item-fill" style="background:#e06090" data-width="35%"></div></div>
                    </div>
                </div>
                <div class="brain-complete">
                    <div class="brain-complete__pct" id="brainPct">0%</div>
                    <div class="brain-complete__label">Brain completeness</div>
                    <div class="brain-complete__bar"><div class="brain-complete__fill" id="brainFill"></div></div>
                </div>
            </div>
        </div>

        <div class="scope-block reveal">
            <div class="scope-block__text">
                <h3 class="h3" style="color:var(--text-secondary)"><strong style="color:var(--text-primary);font-weight:500">From Scope</strong> to Authority</h3>
                <p class="body">Most AI strategies chase coverage — more data, more integrations, more compute.</p>
                <p class="body">We invert this. Every piece of organizational knowledge gets a permanent semantic address — a Single Source of Truth your AI reads by name. <strong style="color:var(--text-primary)">MA20 is always your competitive position.</strong></p>
                <p class="body">That's <em>canon</em> — the governing truth your entire organization, but especially your AI works from. Not a search result. Not a best guess. The final authority, at a permanent coordinate, operating as head code for every downstream agent, workflow, and session.</p>
                <div class="memory-types">
                    <div class="memory-type">
                        <span class="memory-type__dot memory-type__dot--persistent"></span>
                        <span class="memory-type__label">Persistent Memory</span>
                        <span class="memory-type__desc">— guides growth</span>
                    </div>
                    <div class="memory-type">
                        <span class="memory-type__dot memory-type__dot--active"></span>
                        <span class="memory-type__label">Active Memory</span>
                        <span class="memory-type__desc">— powers daily work</span>
                    </div>
                    <div class="memory-type">
                        <span class="memory-type__dot memory-type__dot--learned"></span>
                        <span class="memory-type__label">Learned Memory</span>
                        <span class="memory-type__desc">— memorializes what worked</span>
                    </div>
                </div>
                <div style="margin-top:12px">
                    <a href="services.html" class="btn btn--primary">
                        See how it's built
                        <svg class="arrow" width="10" height="10" fill="none" stroke="currentColor" stroke-width="2"><path d="M0.5 5.5h7"/><path d="M5.5 1.5l4 4-4 4"/></svg>
                    </a>
                </div>
            </div>
            <div class="scope-block__visual" style="background:none;min-height:0">
                <div class="uca-browser" id="ucaBrowser">
                    <div class="uca-browser__sidebar">
                        <div class="uca-browser__sidebar-title">Addresses</div>
                        <div class="uca-browser__item" data-code="MA01">MA01</div>
                        <div class="uca-browser__item" data-code="MA05">MA05</div>
                        <div class="uca-browser__item" data-code="MA10">MA10</div>
                        <div class="uca-browser__item" data-code="MA15">MA15</div>
                        <div class="uca-browser__item is-active" data-code="MA20">MA20</div>
                        <div class="uca-browser__item" data-code="VL01">VL01</div>
                        <div class="uca-browser__item" data-code="VL05">VL05</div>
                    </div>
                    <div class="uca-browser__detail" id="ucaDetail">
                        <!-- populated by JS -->
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- ===== THE AIRFRAME ===== -->
<section class="airframe" id="airframe">
    <div class="airframe__inner">
        <div class="airframe__header reveal">
            <div class="airframe__header-left">
                <h2 class="airframe__h"><strong>Three breakthroughs.</strong> One architecture.</h2>
            </div>
            <div class="airframe__header-right">
                <p class="body-lg">The X-1 didn't break the sound barrier with a bigger engine. It broke it with a better airframe. Starling AIX is powered by three interlocking breakthroughs that change how your organization works with AI.</p>
            </div>
        </div>

        <div class="airframe__cards">
            <div class="af-card reveal reveal-d1">
                <div class="af-card__visual af-card__visual--uca">
                    <span class="af-card__badge af-card__badge--uca">UCA</span>
                    <div class="uca-tree" id="ucaTree">
                        <div class="uca-tree__node uca-tree__node--root" data-toggle="org">
                            <span class="uca-tree__caret">&#9654;</span>
                            <span class="uca-tree__icon">&#128194;</span>
                            Organization
                        </div>
                        <div class="uca-tree__children" data-parent="org">
                            <div class="uca-tree__node uca-tree__node--child" data-toggle="mission">
                                <span class="uca-tree__caret">&#9654;</span>
                                <span class="uca-tree__icon">&#127919;</span>
                                Mission
                            </div>
                            <div class="uca-tree__children" data-parent="mission">
                                <div class="uca-tree__node uca-tree__node--grandchild">&#8226; MA01 Purpose</div>
                                <div class="uca-tree__node uca-tree__node--grandchild">&#8226; MA05 Vision</div>
                                <div class="uca-tree__node uca-tree__node--grandchild">&#8226; MA10 Values</div>
                                <div class="uca-tree__node uca-tree__node--grandchild">&#8226; MA15 Strategy</div>
                                <div class="uca-tree__node uca-tree__node--grandchild">&#8226; MA20 Position</div>
                                <div class="uca-tree__node uca-tree__node--grandchild">&#8226; MA25 Culture</div>
                                <div class="uca-tree__node uca-tree__node--grandchild">&#8226; MA28 Identity</div>
                            </div>
                            <div class="uca-tree__node uca-tree__node--child" data-toggle="value">
                                <span class="uca-tree__caret">&#9654;</span>
                                <span class="uca-tree__icon">&#128176;</span>
                                Value Chain
                            </div>
                            <div class="uca-tree__children" data-parent="value">
                                <div class="uca-tree__node uca-tree__node--grandchild">&#8226; VL01 Offering</div>
                                <div class="uca-tree__node uca-tree__node--grandchild">&#8226; VL05 Market</div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="af-card__body">
                    <h4 class="af-card__title">Universal Cognitive Architecture</h4>
                    <p class="af-card__desc">UCA is the Dewey Decimal System for business knowledge — a free standard that gives every piece of organizational knowledge a semantic address. UCA makes your business addressable, retrievable, and speakable to AI.</p>
                    <div class="af-card__links">
                        <a href="#" class="af-card__link">
                            Get the Free AI Guide
                            <svg width="12" height="12" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 6h8"/><path d="M6 2l4 4-4 4"/></svg>
                        </a>
                    </div>
                </div>
            </div>
            <div class="af-card reveal reveal-d2">
                <div class="af-card__visual af-card__visual--org">
                    <span class="af-card__badge af-card__badge--org">ORG BRAIN</span>
                    <div class="org-brain" id="orgBrain">
                        <div class="org-brain__hemi org-brain__hemi--left" data-side="left">
                            <span class="org-brain__hemi-label">Innovation</span>
                            <span class="org-brain__hemi-sub">Strategy, Vision,<br>Culture</span>
                        </div>
                        <span class="org-brain__bridge">Cognitive Bridge</span>
                        <div class="org-brain__hemi org-brain__hemi--right" data-side="right">
                            <span class="org-brain__hemi-label">Optimization</span>
                            <span class="org-brain__hemi-sub">Workflow, Systems,<br>Delivery</span>
                        </div>
                        <div class="org-brain__cognates">
                            <span class="org-brain__cognate" data-hemi="left">Purpose</span>
                            <span class="org-brain__cognate" data-hemi="left">Vision</span>
                            <span class="org-brain__cognate" data-hemi="left">Strategy</span>
                            <span class="org-brain__cognate" data-hemi="left">Culture</span>
                            <span class="org-brain__cognate" data-hemi="left">Identity</span>
                            <span class="org-brain__cognate" data-hemi="right">Workflow</span>
                            <span class="org-brain__cognate" data-hemi="right">Delivery</span>
                            <span class="org-brain__cognate" data-hemi="right">Systems</span>
                            <span class="org-brain__cognate" data-hemi="right">Capital</span>
                            <span class="org-brain__cognate" data-hemi="right">Scale</span>
                            <span class="org-brain__cognate" data-hemi="both">Position</span>
                        </div>
                    </div>
                </div>
                <div class="af-card__body">
                    <h4 class="af-card__title">Organizational Intelligence</h4>
                    <p class="af-card__desc">The first architecture that models business as a neural system. Two hemispheres — Innovation and Optimization — bridged by a Cognitive layer that synthesizes across the whole brain. 11 Organizational Cognates, 28 Constitutional Memories, four tiers of intelligence.</p>
                    <div class="af-card__links">
                        <a href="#" class="af-card__link">
                            Build It Yourself
                            <svg width="12" height="12" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 6h8"/><path d="M6 2l4 4-4 4"/></svg>
                        </a>
                        <a href="services.html" class="af-card__link">
                            Build It With Us
                            <svg width="12" height="12" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 6h8"/><path d="M6 2l4 4-4 4"/></svg>
                        </a>
                    </div>
                </div>
            </div>
            <div class="af-card reveal reveal-d3">
                <div class="af-card__visual af-card__visual--dlm">
                    <span class="af-card__badge af-card__badge--dlm">DLM</span>
                    <div class="dlm-equation" id="dlmEquation">
                        <span class="dlm-equation__part dlm-equation__part--llm">LLM</span>
                        <span class="dlm-equation__op">+</span>
                        <span class="dlm-equation__part dlm-equation__part--mcp">MCP</span>
                        <span class="dlm-equation__op">+</span>
                        <span class="dlm-equation__part dlm-equation__part--uca">UCA</span>
                        <span class="dlm-equation__op">+</span>
                        <span class="dlm-equation__part dlm-equation__part--org">Org Brain</span>
                        <span class="dlm-equation__op">=</span>
                        <span class="dlm-equation__result">DLM</span>
                    </div>
                </div>
                <div class="af-card__body">
                    <h4 class="af-card__title">Domain Language Model</h4>
                    <p class="af-card__desc">The equation that provides information sovereignty: LLM &times; MCP &times; UCA &times; Org Brain = DLM. A stateless model combined with a sovereign knowledge base, universally accessible through semantic retrieval. The model processes. The domain remembers.</p>
                    <div class="af-card__links">
                        <a href="#" class="af-card__link">
                            Request Beta Invite
