---
import Layout from '../layouts/Layout.astro';
const CDN = 'https://cdn.prod.website-files.com/68a8c21bc88f17902fc14981';
const usaTodayLogo = `${CDN}/697d0d971e75e603938c8e02_usa-today-seeklogo.svg`;
const ibtLogo      = `${CDN}/697d0da1b283dc95eb1d53a5_international-business-times-logo-vector.svg`;
const chrisImg     = `${CDN}/69336097cd299f5bc5e0f762_Chris%20Smiling%20_Silo.png`;
---

<Layout title="Starling AIX — Mach 1 Business" description="The sound barrier didn't stop aviation. It defined the engineering required to go faster. Your business has a similar barrier. We built the airframe to safely surpass it.">

<!-- ── Hero ──────────────────────────────────────────────────── -->
<section style="position:relative;overflow:hidden;padding:7rem 0 6rem;text-align:center;" class="grid-bg">
  <div class="hero-glow"></div>
  <span class="corner-mark cm-tl">+</span>
  <span class="corner-mark cm-tr">+</span>
  <span class="corner-mark cm-bl">+</span>
  <span class="corner-mark cm-br">+</span>
  <div class="container" style="position:relative;z-index:1;">
    <div class="badge fade-up" data-delay="0" style="margin-bottom:1.75rem;">Introducing Mach 1 Business</div>
    <h1 class="heading-display fade-up" data-delay="0.06"
        style="font-size:clamp(3.5rem,9vw,6.5rem);margin:0 0 1.5rem;letter-spacing:-0.04em;max-width:820px;margin-inline:auto;">
      Your business,<br/>now <em style="color:#f97316;">fluent in AI.</em>
    </h1>
    <p class="fade-up" data-delay="0.12"
       style="font-size:1.1rem;color:#71717a;line-height:1.75;max-width:500px;margin:0 auto 2.5rem;">
      The sound barrier didn't stop aviation. It defined the engineering required to go faster. We built the airframe.
    </p>
    <div class="fade-up" data-delay="0.18" style="display:flex;gap:0.75rem;flex-wrap:wrap;justify-content:center;margin-bottom:4rem;">
      <a href="/ai-guide" class="btn btn-primary" style="font-size:0.95rem;padding:0.75rem 1.75rem;">Start Here →</a>
      <a href="#architecture" class="btn btn-ghost" style="font-size:0.95rem;padding:0.75rem 1.75rem;">See the Architecture</a>
    </div>
    <!-- DLM equation -->
    <div class="fade-up" data-delay="0.24" style="display:flex;align-items:center;justify-content:center;gap:0.5rem;flex-wrap:wrap;">
      {[
        ['LLM','Stateless\nProcessing'],['×',null],
        ['MCP','Connection\nProtocol'],['×',null],
        ['UCA','Semantic\nAddressing'],['×',null],
        ['ORG\nBRAIN','Sovereign\nRepository'],['=',null],
        ['DLM','Domain\nLanguage Model'],
      ].map(([label,sub]) =>
        (label==='×'||label==='=')
          ? <span style="color:#3f3f46;font-family:'JetBrains Mono',monospace;font-size:0.9rem;">{label}</span>
          : <div style="display:flex;flex-direction:column;align-items:center;gap:0.3rem;">
              <div class="dlm-box" style={label==='DLM'?'border-color:rgba(249,115,22,0.5);background:rgba(249,115,22,0.12);box-shadow:0 0 24px rgba(249,115,22,0.15)':''}>{label}</div>
              {sub&&<span style="font-family:'JetBrains Mono',monospace;font-size:0.58rem;color:#3f3f46;text-align:center;line-height:1.4;white-space:pre-line;">{sub}</span>}
            </div>
      )}
    </div>
  </div>
</section>

<!-- ── Press ─────────────────────────────────────────────────── -->
<section style="padding:1.75rem 0;border-top:1px solid rgba(255,255,255,0.07);border-bottom:1px solid rgba(255,255,255,0.07);opacity:0.55;">
  <div class="container" style="text-align:center;">
    <p class="section-label" style="margin-bottom:1rem;">As Featured In</p>
    <div class="marquee-wrap" style="overflow:hidden;">
      <div class="marquee-track">
        {[usaTodayLogo,ibtLogo,usaTodayLogo,ibtLogo,usaTodayLogo,ibtLogo,usaTodayLogo,ibtLogo].map(src=>(
          <img src={src} alt="press" class="press-logo"/>
        ))}
      </div>
    </div>
  </div>
</section>

<!-- ── Bento: The Airframe ────────────────────────────────────── -->
<section id="architecture" style="padding:6rem 0;">
  <div class="container">
    <div style="text-align:center;margin-bottom:3rem;">
      <p class="section-label fade-up" data-delay="0" style="margin-bottom:0.75rem;">The Airframe</p>
      <h2 class="heading-display fade-up" data-delay="0.06" style="font-size:clamp(2rem,5vw,3.5rem);margin:0;">
        Three breakthroughs. One architecture.
      </h2>
    </div>

    <!-- Row 1 -->
    <div class="bento fade-up" data-delay="0.1" id="bento-r1" style="grid-template-columns:1fr;">

      <!-- UCA cell -->
      <div class="bento-cell">
        <div style="display:flex;align-items:center;gap:0.75rem;margin-bottom:1rem;">
          <span class="badge">UCA</span>
          <span style="font-family:'JetBrains Mono',monospace;font-size:0.68rem;color:#3f3f46;">Universal Cognitive Architecture</span>
        </div>
        <h3 style="font-size:1.3rem;font-weight:700;letter-spacing:-0.025em;color:#fff;margin:0 0 0.6rem;">Every idea, permanently addressed.</h3>
        <p style="font-size:0.875rem;color:#71717a;line-height:1.75;margin:0 0 1.25rem;max-width:340px;">
          The Dewey Decimal System for business knowledge. Eleven cognates, four memory tiers, semantic coordinates your AI reads by name — not by search.
        </p>
        <a href="/ai-guide" class="btn btn-ghost" style="font-size:0.8rem;padding:0.45rem 1rem;">Get the Free Standard →</a>
        <div class="mock-window">
          <div class="mock-bar">
            <span class="mock-dot r"></span><span class="mock-dot y"></span><span class="mock-dot g"></span>
            <span style="font-family:'JetBrains Mono',monospace;font-size:0.65rem;color:#3f3f46;margin-left:0.5rem;">uca.semantic</span>
          </div>
          <div class="mock-body">
            {[['MA20','Competitive Position'],['ID20','Cultural Values'],['BR20','Brand Positioning']].map(([code,label])=>(
              <div class="mock-chip">
                <span>{code}</span>
                <span style="color:#a1a1aa;margin-left:0.25rem;">{label}</span>
                <span style="color:#22c55e;margin-left:0.5rem;font-size:0.6rem;">✓</span>
              </div>
            ))}
            <div class="mock-chip dim"><span>IN20</span><span style="margin-left:0.25rem;">Product Roadmap</span><span style="margin-left:0.5rem;color:#3f3f46;">—</span></div>
          </div>
        </div>
      </div>

      <!-- Org Brain cell -->
      <div class="bento-cell no-right" id="orgcell">
        <div style="display:flex;align-items:center;gap:0.75rem;margin-bottom:1rem;">
          <span class="badge">Org Brain</span>
          <span style="font-family:'JetBrains Mono',monospace;font-size:0.68rem;color:#3f3f46;">Organizational Intelligence</span>
        </div>
        <h3 style="font-size:1.3rem;font-weight:700;letter-spacing:-0.025em;color:#fff;margin:0 0 0.6rem;">Your company's neural system.</h3>
        <p style="font-size:0.875rem;color:#71717a;line-height:1.75;margin:0 0 1.25rem;max-width:340px;">
          Two hemispheres — Innovation and Optimization — bridged by a Cognitive layer. 28 Constitutional Memories. One sovereign repository you own forever.
        </p>
        <div style="display:flex;gap:0.5rem;flex-wrap:wrap;">
          <a href="/cognitive-design" class="btn btn-ghost" style="font-size:0.8rem;padding:0.45rem 1rem;">Build It →</a>
          <a href="/services" class="btn btn-ghost" style="font-size:0.8rem;padding:0.45rem 1rem;">With Us →</a>
        </div>
        <div class="mock-window">
          <div class="mock-bar">
            <span class="mock-dot r"></span><span class="mock-dot y"></span><span class="mock-dot g"></span>
            <span style="font-family:'JetBrains Mono',monospace;font-size:0.65rem;color:#3f3f46;margin-left:0.5rem;">org.brain / memory</span>
          </div>
          <div class="mock-body">
            {[['SY','System Memory','00–19'],['ID–IT','Constitutional Memory','20–23'],['PM','Persistent Memory','Always on'],['AM','Active Memory','Per project'],['LM','Learned Memory','Compounding']].map(([code,label,note])=>(
              <div class="mock-tier">
                <span style="display:flex;align-items:center;gap:0.5rem;"><span class="tc">{code}</span><span>{label}</span></span>
                <span style="color:#3f3f46;font-size:0.6rem;">{note}</span>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>

    <!-- Row 2 -->
    <div class="bento fade-up" data-delay="0.16" id="bento-r2" style="grid-template-columns:1fr;margin-top:1px;">

      <!-- DLM cell -->
      <div class="bento-cell" style="border-top:none;">
        <div style="display:flex;align-items:center;gap:0.75rem;margin-bottom:1rem;">
          <span class="badge">DLM</span>
          <span style="font-family:'JetBrains Mono',monospace;font-size:0.68rem;color:#3f3f46;">Domain Language Model</span>
        </div>
        <h3 style="font-size:1.3rem;font-weight:700;letter-spacing:-0.025em;color:#fff;margin:0 0 0.6rem;">Intelligence that compounds.</h3>
        <p style="font-size:0.875rem;color:#71717a;line-height:1.75;margin:0 0 1.25rem;max-width:400px;">
          A general-purpose model with your complete organizational context loaded on every request. The know-how is the asset. The processing is the commodity.
        </p>
        <a href="/platform" class="btn btn-ghost" style="font-size:0.8rem;padding:0.45rem 1rem;">Request Beta Invite →</a>
        <div class="mock-window">
          <div class="mock-bar">
            <span class="mock-dot r"></span><span class="mock-dot y"></span><span class="mock-dot g"></span>
            <span style="font-family:'JetBrains Mono',monospace;font-size:0.65rem;color:#3f3f46;margin-left:0.5rem;">dlm.equation</span>
          </div>
          <div class="mock-body" style="padding:1rem;">
            <div style="font-family:'JetBrains Mono',monospace;font-size:0.8rem;color:#f97316;letter-spacing:0.03em;background:rgba(249,115,22,0.06);border:1px solid rgba(249,115,22,0.15);border-radius:8px;padding:0.75rem 1rem;">
              LLM × MCP × UCA × Org Brain = DLM
            </div>
            <div style="display:grid;grid-template-columns:repeat(2,1fr);gap:0.4rem;margin-top:0.5rem;">
              {[['LLM','Stateless processing'],['MCP','Connection protocol'],['UCA','Semantic addressing'],['ORG','Sovereign repository']].map(([k,v])=>(
                <div style="font-family:'JetBrains Mono',monospace;font-size:0.62rem;padding:0.45rem 0.65rem;border-radius:6px;border:1px solid rgba(255,255,255,0.06);background:rgba(255,255,255,0.02);">
                  <span style="color:#f97316;">{k}</span>
                  <span style="color:#3f3f46;display:block;margin-top:0.1rem;">{v}</span>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>

      <!-- Stats cell -->
      <div class="bento-cell no-right no-bottom" style="border-top:none;display:flex;flex-direction:column;justify-content:center;">
        <p class="section-label" style="margin-bottom:1.5rem;">By the numbers</p>
        <div style="display:grid;grid-template-columns:1fr 1fr;border:1px solid rgba(255,255,255,0.07);border-radius:12px;overflow:hidden;">
          {[['11','Org\nCognates'],['28','Constitutional\nMemories'],['4','Memory\nTiers'],['9wk','Certification\nProgram']].map(([num,label],i)=>(
            <div style={`padding:1.5rem 1.25rem;background:#0a0a0a;${i%2===0?'border-right:1px solid rgba(255,255,255,0.07);':''}${i<2?'border-bottom:1px solid rgba(255,255,255,0.07);':''}`}>
              <div class="stat-num">{num}</div>
              <div class="stat-label" style="white-space:pre-line;">{label}</div>
            </div>
          ))}
        </div>
        <a href="/cognitive-design" class="btn btn-orange" style="margin-top:1.5rem;justify-content:center;">Enroll in Cognitive Design →</a>
      </div>

    </div>
  </div>
</section>

<div class="divider"></div>

<!-- ── Cognition Barrier ──────────────────────────────────────── -->
<section style="padding:6rem 0;position:relative;overflow:hidden;" class="grid-bg">
  <div class="hero-glow-wide"></div>
  <span class="corner-mark cm-tl">+</span>
  <span class="corner-mark cm-tr">+</span>
  <div class="container" style="position:relative;z-index:1;">
    <div style="max-width:780px;margin-inline:auto;">
      <p class="section-label fade-up" data-delay="0" style="margin-bottom:1rem;text-align:center;">The Cognition Barrier</p>
      <h2 class="heading-display fade-up" data-delay="0.06"
          style="font-size:clamp(2rem,5vw,3.5rem);margin:0 0 1.5rem;text-align:center;">
        More AI won't make you faster.<br/>Better architecture will.
      </h2>
      <div class="glass fade-up" data-delay="0.12" style="padding:2.5rem;margin-bottom:1rem;">
        <p style="font-size:1rem;color:#a1a1aa;line-height:1.85;margin:0 0 1.25rem;">
          Every organization hits the same wall. You add AI tools, solutions, and specialists — but instead of accelerating, you hit turbulence. Information fragments. Context evaporates. Your AI is out of sync.
        </p>
        <p style="font-size:1rem;color:#a1a1aa;line-height:1.85;margin:0 0 1.75rem;">
          The answer isn't more power. It's better infrastructure.
          <span style="color:#fff;"> MA20 is always your competitive position.</span> That's canon — the governing truth your entire organization, especially your AI, works from.
        </p>
        <div style="display:flex;gap:0.75rem;align-items:center;flex-wrap:wrap;">
          <a href="/cognitive-design" class="btn btn-primary" style="font-size:0.875rem;padding:0.65rem 1.5rem;">Enroll Now →</a>
          <a href="/about" class="btn btn-ghost" style="font-size:0.875rem;padding:0.65rem 1.5rem;">How It Works</a>
        </div>
      </div>
      <div style="display:flex;flex-direction:column;gap:0.5rem;">
        {[
          ['Persistent Memory','guides growth and strategic direction across every session'],
          ['Active Memory','powers daily work and in-flight projects with full context'],
          ['Learned Memory','memorializes what worked and compounds intelligence over time'],
        ].map(([title,body],i)=>(
          <div class="glass fade-up" data-delay={`${0.16+i*0.04}`} style="padding:1rem 1.25rem;display:flex;align-items:center;gap:0.75rem;flex-wrap:wrap;">
            <span style="width:6px;height:6px;border-radius:50%;background:#f97316;flex-shrink:0;"></span>
            <span style="font-size:0.875rem;color:#e4e4e7;font-weight:600;">{title}</span>
            <span style="font-size:0.875rem;color:#52525b;">{body}</span>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<div class="divider"></div>

<!-- ── Newsletter ─────────────────────────────────────────────── -->
<section id="newsletter" style="padding:6rem 0;">
  <div class="container">
    <div style="display:grid;grid-template-columns:1fr;gap:3rem;align-items:center;max-width:820px;margin-inline:auto;" class="nl-grid">
      <div>
        <p class="section-label fade-up" data-delay="0" style="margin-bottom:0.75rem;">On Cognitive Design</p>
        <h2 class="heading-display fade-up" data-delay="0.06" style="font-size:clamp(1.8rem,4vw,2.8rem);margin:0 0 1rem;">
          The weekly deep dive.
        </h2>
        <p class="fade-up" data-delay="0.1" style="font-size:0.95rem;color:#71717a;line-height:1.75;margin:0 0 2rem;">
          Each issue unpacks a piece of the methodology in a free, in-depth essay. From Chris Kincade, Starling CEO and creator of Cognitive Design.
        </p>
        <form id="nl-form" class="fade-up" data-delay="0.14" style="display:flex;gap:0.75rem;flex-wrap:wrap;">
          <input type="email" name="email" placeholder="your@email.com" required class="input" style="flex:1;min-width:220px;" />
          <button type="submit" class="btn btn-orange" style="padding:0.65rem 1.5rem;">Subscribe</button>
        </form>
        <p style="font-size:0.75rem;color:#3f3f46;margin-top:0.75rem;">Weekly. No spam. Unsubscribe anytime.</p>
      </div>
      <div class="fade-up" data-delay="0.1" style="display:flex;justify-content:center;">
        <div style="position:relative;width:180px;">
          <img src={chrisImg} alt="Chris Kincade"
               style="width:100%;border-radius:16px;border:1px solid rgba(255,255,255,0.08);display:block;" />
          <div class="glass-dark" style="position:absolute;bottom:-10px;left:-10px;padding:0.4rem 0.75rem;border-radius:8px;">
            <span style="font-family:'JetBrains Mono',monospace;font-size:0.62rem;color:#a1a1aa;">Chris Kincade</span>
            <div style="font-family:'JetBrains Mono',monospace;font-size:0.58rem;color:#f97316;margin-top:0.1rem;">CEO, Starling AIX</div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

</Layout>

<style>
  @media(min-width:768px) {
    #bento-r1 { grid-template-columns: 1fr 1fr !important; }
    #bento-r2 { grid-template-columns: 1fr 1fr !important; }
    .nl-grid  { grid-template-columns: 1fr 200px !important; }
    #orgcell  { border-bottom: 1px solid rgba(255,255,255,0.08) !important; }
  }
</style>

<script>
  document.getElementById('nl-form')?.addEventListener('submit', e => {
    e.preventDefault();
    const btn = (e.target as HTMLFormElement).querySelector('button') as HTMLButtonElement;
    btn.textContent = "You're in!";
    btn.disabled = true;
    setTimeout(() => { btn.textContent = 'Subscribe'; btn.disabled = false; (e.target as HTMLFormElement).reset(); }, 3500);
  });
</script>
