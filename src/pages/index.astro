</style>

<script>
  // ── Tab switcher
  const tabData: Record<string, {label: string, status: string}> = {
    '0': { label: 'starling.workspace — UCA · Cognate Library', status: 'MA20 active' },
    '1': { label: 'starling.workspace — Org Brain · Architecture View', status: '● 28 memories indexed' },
    '2': { label: 'starling.dlm — Organizational Query Interface', status: '● DLM Active' },
  };
  const barLabel  = document.getElementById('mock-bar-label');
  const barStatus = document.getElementById('mock-bar-status');

  document.getElementById('tab-cards')?.querySelectorAll('.tab-card-lt').forEach(card => {
    card.addEventListener('click', () => {
      const tab = (card as HTMLElement).dataset.tab ?? '0';
      document.querySelectorAll('.tab-panel').forEach(p => p.classList.remove('active'));
      document.getElementById(`panel-${tab}`)?.classList.add('active');
      document.querySelectorAll('.tab-card-lt').forEach(c => c.classList.remove('active'));
      card.classList.add('active');
      const d = tabData[tab];
      if (barLabel) barLabel.textContent = d.label;
      if (barStatus) barStatus.textContent = d.status;
    });
  });

  // ── Newsletter form
  document.getElementById('nl-form')?.addEventListener('submit', e => {
    e.preventDefault();
    const btn = (e.target as HTMLFormElement).querySelector('button') as HTMLButtonElement;
    btn.textContent = "You're in!";
    btn.disabled = true;
    setTimeout(() => { btn.textContent = 'Subscribe'; btn.disabled = false; (e.target as HTMLFormElement).reset(); }, 3500);
  });
</script>
