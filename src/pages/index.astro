<script is:inline>
(function () {
  'use strict';

  const canvas = document.getElementById('brain-canvas');
  if (!canvas) return;
  const ctx = canvas.getContext('2d');

  let W = 0, H = 0, dpr = 1, raf = 0;

  /* ── 1. Geometry: Fibonacci-sphere brain ─────────────────── */
  const N = 115;

  function makeBrain(n) {
    const pts = [];
    for (let i = 0; i < n; i++) {
      // Evenly-spaced Fibonacci sphere
      const phi   = Math.acos(1 - 2 * (i + 0.5) / n);
      const theta = Math.PI * (1 + Math.sqrt(5)) * i;

      let x = Math.sin(phi) * Math.cos(theta);
      let y = Math.cos(phi);
      let z = Math.sin(phi) * Math.sin(theta);

      // Ellipsoid scaling — wider (X) than tall (Y), shallow (Z)
      x *= 1.42;
      y *= 0.96;
      z *= 1.06;

      // Medial sulcus: groove down the top-centre
      const topFactor     = Math.max(0, y / 1.1);
      const centralFactor = Math.exp(-(x * x) / 0.32);
      y -= 0.38 * topFactor * centralFactor;

      // Organic surface wrinkle noise
      const amp = 0.10;
      x += amp * Math.sin(x * 5.3 + z * 3.7) * Math.cos(y * 4.1);
      y += amp * Math.sin(y * 4.7 + x * 6.1) * Math.cos(z * 3.3);
      z += amp * Math.sin(z * 5.1 + y * 3.9) * Math.cos(x * 4.7);

      pts.push({ x, y, z });
    }
    return pts;
  }

  const pts = makeBrain(N);

  /* ── 2. Edges: connect closest neighbours ────────────────── */
  const MAX_EDGES_PER_NODE = 6;
  const DIST_THRESHOLD     = 0.90;
  const degree  = new Array(N).fill(0);
  const edges   = [];

  const cands = [];
  for (let i = 0; i < N; i++) {
    for (let j = i + 1; j < N; j++) {
      const dx = pts[i].x - pts[j].x;
      const dy = pts[i].y - pts[j].y;
      const dz = pts[i].z - pts[j].z;
      const d  = Math.sqrt(dx*dx + dy*dy + dz*dz);
      if (d < DIST_THRESHOLD) cands.push([i, j, d]);
    }
  }
  cands.sort((a, b) => a[2] - b[2]);

  for (const [i, j] of cands) {
    if (degree[i] < MAX_EDGES_PER_NODE && degree[j] < MAX_EDGES_PER_NODE) {
      edges.push([i, j]);
      degree[i]++;
      degree[j]++;
    }
  }

  const maxDeg = Math.max(...degree);

  /* ── 3. Resize ───────────────────────────────────────────── */
  function resize() {
    dpr = window.devicePixelRatio || 1;
    const rect = canvas.getBoundingClientRect();
    W = rect.width  || 500;
    H = rect.height || 600;
    canvas.width  = Math.round(W * dpr);
    canvas.height = Math.round(H * dpr);
    ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
  }

  /* ── 4. 3-D math ─────────────────────────────────────────── */
  function rotY(p, a) {
    const c = Math.cos(a), s = Math.sin(a);
    return { x: p.x * c - p.z * s, y: p.y, z: p.x * s + p.z * c };
  }
  function rotX(p, a) {
    const c = Math.cos(a), s = Math.sin(a);
    return { x: p.x, y: p.y * c - p.z * s, z: p.y * s + p.z * c };
  }
  function project(p) {
    const fov   = Math.min(W, H) * 0.36;
    const depth = 4.2;
    const sc    = fov / (depth + p.z);
    return { sx: W * 0.5 + p.x * sc, sy: H * 0.5 - p.y * sc, z: p.z };
  }

  /* ── 5. Draw loop ────────────────────────────────────────── */
  const TILT = 0.18;   // static X-tilt for depth
  let   angle = 0;

  function draw() {
    ctx.clearRect(0, 0, W, H);
    angle += 0.004;

    // Transform
    const t    = pts.map(p => rotX(rotY(p, angle), TILT));
    const proj = t.map(p => project(p));

    // Depth normalisation helper (approx z range -1.8 … 1.8)
    const depth = z => Math.max(0, Math.min(1, (z + 1.9) / 3.8));

    // Edges
    ctx.lineWidth = 0.8;
    for (const [i, j] of edges) {
      const d = depth((t[i].z + t[j].z) * 0.5);
      ctx.beginPath();
      ctx.moveTo(proj[i].sx, proj[i].sy);
      ctx.lineTo(proj[j].sx, proj[j].sy);
      ctx.strokeStyle = `rgba(160,150,140,${(0.10 + d * 0.30).toFixed(2)})`;
      ctx.stroke();
    }

    // Nodes — back-to-front
    const sorted = proj.map((p, i) => ({ ...p, i })).sort((a, b) => a.z - b.z);
    for (const { sx, sy, z, i } of sorted) {
      const d    = depth(z);
      const hub  = degree[i] / maxDeg;            // 0 = leaf, 1 = hub
      const r    = 1.6 + hub * 2.8 + d * 2.4;    // bigger if hub and closer
      const alpha = 0.30 + d * 0.70;

      ctx.beginPath();
      ctx.arc(sx, sy, r, 0, Math.PI * 2);
      ctx.fillStyle = `rgba(202,80,18,${alpha.toFixed(2)})`;
      ctx.fill();
    }

    raf = requestAnimationFrame(draw);
  }

  /* ── 6. Start / stop with visibility ────────────────────── */
  const io = new IntersectionObserver(entries => {
    if (entries[0].isIntersecting) {
      cancelAnimationFrame(raf);
      resize();
      draw();
    } else {
      cancelAnimationFrame(raf);
    }
  }, { threshold: 0.05 });

  io.observe(canvas);

  window.addEventListener('resize', () => {
    cancelAnimationFrame(raf);
    resize();
    draw();
  }, { passive: true });
})();
</script>
