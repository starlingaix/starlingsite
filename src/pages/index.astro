---
import Layout from '../layouts/Layout.astro';
const CDN = 'https://cdn.prod.website-files.com/68a8c21bc88f17902fc14981';
const usaTodayLogo = `${CDN}/697d0d971e75e603938c8e02_usa-today-seeklogo.svg`;
const ibtLogo      = `${CDN}/697d0da1b283dc95eb1d53a5_international-business-times-logo-vector.svg`;
const chrisImg     = `${CDN}/69336097cd299f5bc5e0f762_Chris%20Smiling%20_Silo.png`;

const cognates = [
  ['MA','Market Analysis',true],
  ['ID','Identity & Culture',false],
  ['BR','Brand & Story',false],
  ['IN','Innovation',false],
  ['FN','Finance',false],
  ['OP','Operations',false],
  ['HR','People & Talent',false],
  ['IT','Technology',false],
  ['CN','Compliance',false],
  ['CS','Customer Success',false],
  ['PM','Product & Market',false],
];

const ucaFields = [
  ['Market Position','Mid-market B2B leader with enterprise migration path. AI-native architecture advantage in all segments.'],
  ['Primary Competitors','Salesforce, HubSpot, Monday.com — each lacking a sovereign knowledge layer. No competitor has DLM.'],
  ['Competitive Moat','The Org Brain architecture. Once installed, switching costs approach 100% — knowledge compounds in your system, not ours.'],
  ['Strategic Evidence','47% faster decision cycles post-implementation. 12 enterprise pilots. Zero churn at 18 months.'],
];

const innovationSystems = [
  { name: 'Innovation System',  mems: ['Corporate Vision', 'Innovation Charter', 'R&D Roadmap'] },
  { name: 'Disruption System',  mems: ['Market Signals',   'Competitive Intel',  'Opportunity Map'] },
  { name: 'Discovery System',   mems: ['Research Vault',   'Prototype Log',      'Learning Ledger'] },
];
const optimizationSystems = [
  { name: 'Revenue Intelligence', mems: ['Pipeline Memory', 'Pricing Matrix',    'Win/Loss Archive'] },
  { name: 'Process Intelligence', mems: ['SOP Library',     'Quality Standards', 'Efficiency Log'] },
  { name: 'Risk Intelligence',    mems: ['Compliance Vault','Risk Register',     'Incident Archive'] },
];

const ctxChips  = ['28 memories loaded','11 cognates indexed','MA20 · BR20 · PM20 active','Org Brain v2.4'];
const dlmRefs   = ['MA20','BR20','PM20','FN20'];
const stats     = [['11','Org Cognates'],['28','Constitutional Memories'],['4','Memory Tiers'],['9 wk','Certification Program']];
const memTypes  = [
  ['Persistent Memory','guides growth and strategic direction across every session'],
  ['Active Memory','powers daily work and in-flight projects with full context'],
  ['Learned Memory','memorializes what worked and compounds intelligence over time'],
];
---

<Layout
  title="Starling AIX — Mach 1 Business"
  description="The sound barrier didn't stop aviation. It defined the engineering required to go faster. Your business has a similar barrier. We built the airframe to safely surpass it."
>

<!-- ══════════════════════════════════════════════════════════════
     HERO — Stripe-style left/right split
     ══════════════════════════════════════════════════════════════ -->
<section style="position:relative;overflow:hidden;background:#ffffff;border-bottom:1px solid rgba(0,0,0,0.07);">

  <div class="container" style="position:relative;z-index:1;">
    <div class="hero-split">

      <!-- ── Left: copy ── -->
      <div style="padding:7rem 0 6rem;">
        <div class="stag stag-o fade-up" data-delay="0" style="margin-bottom:1.5rem;">Introducing Mach 1 Business</div>

        <h1 class="fade-up" data-delay="0.06"
            style="font-family:'Bitter',Georgia,serif;font-weight:700;line-height:1.02;letter-spacing:-0.04em;font-size:clamp(3rem,7vw,5.5rem);margin:0 0 1.5rem;color:#0c0c0c;">
          Organisational intelligence<br/><em style="color:#e0641c;font-style:italic;">that compounds.</em>
        </h1>

        <p class="fade-up" data-delay="0.12"
           style="font-family:'Inter Tight',system-ui,sans-serif;font-size:1.05rem;color:#4a4a4a;line-height:1.7;max-width:440px;margin:0 0 2.25rem;">
          Your AI is a brilliant consultant, not a contextualised Chief of Staff. The Org Brain changes that — sovereign knowledge architecture that speaks the language of your specific business.
        </p>

        <div class="fade-up" data-delay="0.17" style="display:flex;gap:0.75rem;flex-wrap:wrap;margin-bottom:3rem;">
          <a href="/ai-guide" class="btn btn-org" style="font-size:0.95rem;padding:0.75rem 1.75rem;">Get the Free Book →</a>
          <a href="#architecture" class="btn-ghost-light" style="font-size:0.95rem;padding:0.75rem 1.75rem;">See the Architecture</a>
        </div>

        <!-- DLM equation — compact chips -->
        <div class="fade-up" data-delay="0.23" style="display:flex;align-items:center;gap:0.45rem;flex-wrap:wrap;">
          {[
            ['LLM','Stateless\nProcessing'],['×',null],
            ['MCP','Connection\nProtocol'],['×',null],
            ['UCA','Semantic\nAddressing'],['×',null],
            ['ORG\nBRAIN','Sovereign\nRepository'],['=',null],
            ['DLM','Domain\nLanguage Model'],
          ].map(([label,sub]) =>
            (label==='×'||label==='=')
              ? <span style="color:#bbb;font-family:'JetBrains Mono',monospace;font-size:0.85rem;">{label}</span>
              : <div style="display:flex;flex-direction:column;align-items:center;gap:0.25rem;">
                  <div class="dlm-box-lt" style={label==='DLM'?'border-color:rgba(224,100,28,0.55);background:rgba(224,100,28,0.1);color:#c05010;':''}>
                    {label}
                  </div>
                  {sub&&<span style="font-family:'JetBrains Mono',monospace;font-size:0.52rem;color:#aaa;text-align:center;line-height:1.3;white-space:pre-line;">{sub}</span>}
                </div>
          )}
        </div>

        <p style="font-family:'Inter',sans-serif;font-size:0.72rem;color:#aaa;letter-spacing:0.03em;margin-top:0.75rem;">The Domain Language Model equation</p>
      </div>

      <!-- ── Right: 3D brain canvas ── -->
      <div class="hero-right-col">
        <canvas id="brain-canvas" style="width:100%;height:100%;min-height:600px;display:block;"></canvas>
      </div>

    </div>
  </div>
</section>

<!-- ══════════════════════════════════════════════════════════════
     PRESS — light paper band
     ══════════════════════════════════════════════════════════════ -->
<section style="background:#f8f7f5;padding:1.75rem 0;overflow:hidden;border-top:1px solid rgba(0,0,0,0.07);border-bottom:1px solid rgba(0,0,0,0.07);">
  <div class="container" style="text-align:center;">
    <p style="font-family:'Inter',sans-serif;font-size:0.6rem;font-weight:600;letter-spacing:0.13em;text-transform:uppercase;color:rgba(0,0,0,0.3);margin-bottom:1.1rem;">As Featured In</p>
    <div class="marquee-wrap marquee-outer">
      <div class="marquee-track">
        {[usaTodayLogo,ibtLogo,usaTodayLogo,ibtLogo,usaTodayLogo,ibtLogo,usaTodayLogo,ibtLogo,usaTodayLogo,ibtLogo].map(src=>(
          <img src={src} alt="press" style="height:22px;width:auto;filter:grayscale(1) brightness(0) opacity(0.22);"/>
        ))}
      </div>
    </div>
  </div>
</section>

<!-- ══════════════════════════════════════════════════════════════
     BENTO PRODUCTS — Stripe-style product cards
     ══════════════════════════════════════════════════════════════ -->
<section style="background:#f8f7f5;padding:6rem 0;border-bottom:1px solid rgba(0,0,0,0.07);">
  <div class="container">

    <div class="arch-header fade-up" data-delay="0" style="margin-bottom:3.5rem;">
      <div>
        <div class="stag stag-o" style="margin-bottom:1.25rem;">1.0 · The Products</div>
        <h2 style="font-family:'Bitter',Georgia,serif;font-weight:700;font-size:clamp(1.9rem,4vw,2.9rem);line-height:1.1;letter-spacing:-0.03em;margin:0;color:#0c0c0c;">
          Three breakthroughs.<br/>One system.
        </h2>
      </div>
      <div>
        <p style="font-family:'Inter Tight',system-ui,sans-serif;font-size:1rem;color:#4a4a4a;line-height:1.75;margin:0 0 1.5rem;">
          UCA semantically addresses every idea your company produces. The Org Brain stores it all in a sovereign knowledge repository you own. The DLM fuses them into an AI that speaks the language of your specific business.
        </p>
        <div style="display:flex;gap:0.75rem;flex-wrap:wrap;">
          <a href="/cognitive-design" class="btn btn-org">Enroll Now →</a>
          <a href="/platform" class="btn-ghost-light">Explore the Workspace</a>
        </div>
      </div>
    </div>

    <!-- Row 1: 3 equal bento cards -->
    <div class="bento-row3 fade-up" data-delay="0.06">

      <!-- Card 1: UCA -->
      <div class="bento-card">
        <div class="bento-card-head">
          <div>
            <span style="display:inline-flex;font-family:'JetBrains Mono',monospace;font-size:0.6rem;padding:0.18rem 0.55rem;border-radius:4px;border:1px solid rgba(224,100,28,0.25);color:#e0641c;background:rgba(224,100,28,0.06);margin-bottom:0.65rem;">UCA</span>
            <h3 style="font-family:'Bitter',Georgia,serif;font-size:1.15rem;font-weight:700;color:#0c0c0c;margin:0 0 0.4rem;letter-spacing:-0.02em;line-height:1.2;">Every idea, permanently addressed</h3>
            <p style="font-family:'Inter Tight',system-ui,sans-serif;font-size:0.82rem;color:#4a4a4a;margin:0;line-height:1.6;">Semantic coordinates your AI reads by name — not by search. O(1) lookup at any scale.</p>
          </div>
          <a href="/cognitive-design" style="font-family:'JetBrains Mono',monospace;font-size:0.62rem;color:#aaa;text-decoration:none;flex-shrink:0;">↗</a>
        </div>
        <!-- Mini UCA visual -->
        <div class="bento-mock">
          <div style="font-family:'JetBrains Mono',monospace;font-size:0.6rem;color:#aaa;margin-bottom:0.75rem;letter-spacing:0.06em;text-transform:uppercase;">Cognate Library · 11 addresses</div>
          {[
            ['MA20','Market Analysis','#e0641c',true],
            ['ID20','Identity & Culture','#888',false],
            ['BR20','Brand & Story','#e0641c',true],
            ['FN20','Finance','#888',false],
            ['PM20','Product & Market','#e0641c',true],
            ['OP20','Operations','#888',false],
          ].map(([code,label,col,active])=>(
            <div style={`display:flex;align-items:center;gap:0.65rem;padding:0.35rem 0.5rem;border-radius:5px;margin-bottom:0.2rem;${active?'background:rgba(224,100,28,0.05);':''}`}>
              <span style={`font-family:'JetBrains Mono',monospace;font-size:0.65rem;font-weight:500;color:${col};min-width:30px;`}>{code}</span>
              <span style={`font-family:'Inter Tight',system-ui,sans-serif;font-size:0.75rem;color:${active?'#1e1e1e':'#aaa'};`}>{label}</span>
              {active && <span style="margin-left:auto;width:5px;height:5px;border-radius:50%;background:#e0641c;flex-shrink:0;"></span>}
            </div>
          ))}
        </div>
      </div>

      <!-- Card 2: Org Brain -->
      <div class="bento-card">
        <div class="bento-card-head">
          <div>
            <span style="display:inline-flex;font-family:'JetBrains Mono',monospace;font-size:0.6rem;padding:0.18rem 0.55rem;border-radius:4px;border:1px solid rgba(224,100,28,0.25);color:#e0641c;background:rgba(224,100,28,0.06);margin-bottom:0.65rem;">Org Brain</span>
            <h3 style="font-family:'Bitter',Georgia,serif;font-size:1.15rem;font-weight:700;color:#0c0c0c;margin:0 0 0.4rem;letter-spacing:-0.02em;line-height:1.2;">Your company's neural system</h3>
            <p style="font-family:'Inter Tight',system-ui,sans-serif;font-size:0.82rem;color:#4a4a4a;margin:0;line-height:1.6;">28 Constitutional Memories in a sovereign repository you own forever. Intelligence compounds weekly.</p>
          </div>
          <a href="/platform" style="font-family:'JetBrains Mono',monospace;font-size:0.62rem;color:#aaa;text-decoration:none;flex-shrink:0;">↗</a>
        </div>
        <!-- Mini tier stack visual -->
        <div class="bento-mock">
          <div style="font-family:'JetBrains Mono',monospace;font-size:0.6rem;color:#aaa;margin-bottom:0.75rem;letter-spacing:0.06em;text-transform:uppercase;">Memory Architecture · 4 Tiers</div>
          {[
            ['Persistent','Strategic direction · 4 memories','#e0641c','100%'],
            ['Active','In-flight projects · 8 memories','#f97316','75%'],
            ['Learned','Compounded wins · 12 memories','#fb923c','90%'],
            ['Ephemeral','Live session · 4 memories','#fcd34d','40%'],
          ].map(([tier,desc,col,width])=>(
            <div style="margin-bottom:0.75rem;">
              <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:0.25rem;">
                <span style={`font-family:'Inter Tight',system-ui,sans-serif;font-size:0.72rem;font-weight:600;color:#0c0c0c;`}>{tier}</span>
                <span style="font-family:'JetBrains Mono',monospace;font-size:0.58rem;color:#aaa;">{desc.split('·')[1]?.trim()}</span>
              </div>
              <div style="height:4px;background:rgba(0,0,0,0.07);border-radius:999px;overflow:hidden;">
                <div style={`height:100%;width:${width};background:${col};border-radius:999px;`}></div>
              </div>
            </div>
          ))}
          <div style="display:flex;align-items:center;gap:0.4rem;margin-top:0.85rem;">
            <span style="width:5px;height:5px;border-radius:50%;background:#34d399;"></span>
            <span style="font-family:'JetBrains Mono',monospace;font-size:0.6rem;color:#34d399;">All systems nominal · 28/28 indexed</span>
          </div>
        </div>
      </div>

      <!-- Card 3: DLM -->
      <div class="bento-card">
        <div class="bento-card-head">
          <div>
            <span style="display:inline-flex;font-family:'JetBrains Mono',monospace;font-size:0.6rem;padding:0.18rem 0.55rem;border-radius:4px;border:1px solid rgba(224,100,28,0.25);color:#e0641c;background:rgba(224,100,28,0.06);margin-bottom:0.65rem;">DLM</span>
            <h3 style="font-family:'Bitter',Georgia,serif;font-size:1.15rem;font-weight:700;color:#0c0c0c;margin:0 0 0.4rem;letter-spacing:-0.02em;line-height:1.2;">Intelligence that compounds</h3>
            <p style="font-family:'Inter Tight',system-ui,sans-serif;font-size:0.82rem;color:#4a4a4a;margin:0;line-height:1.6;">A general-purpose LLM loaded with your complete organisational context on every request.</p>
          </div>
          <a href="/about" style="font-family:'JetBrains Mono',monospace;font-size:0.62rem;color:#aaa;text-decoration:none;flex-shrink:0;">↗</a>
        </div>
        <!-- Mini DLM chat -->
        <div class="bento-mock" style="padding:0.85rem;">
          <div style="display:flex;flex-direction:column;gap:0.65rem;">
            <div style="display:flex;gap:0.5rem;align-items:flex-start;">
              <span style="width:18px;height:18px;border-radius:50%;background:#f2f1ee;border:1px solid rgba(0,0,0,0.1);font-family:'JetBrains Mono',monospace;font-size:0.48rem;color:#888;display:flex;align-items:center;justify-content:center;flex-shrink:0;">You</span>
              <div style="background:#f2f1ee;border-radius:4px 8px 8px 4px;padding:0.45rem 0.65rem;font-size:0.75rem;color:#0c0c0c;font-family:'Inter Tight',system-ui,sans-serif;line-height:1.4;">Draft the exec summary for our Series A deck.</div>
            </div>
            <div style="display:flex;gap:0.5rem;align-items:flex-start;">
              <span style="width:18px;height:18px;border-radius:50%;background:rgba(224,100,28,0.1);border:1px solid rgba(224,100,28,0.25);font-family:'JetBrains Mono',monospace;font-size:0.44rem;color:#e0641c;display:flex;align-items:center;justify-content:center;flex-shrink:0;">DLM</span>
              <div style="flex:1;">
                <div style="font-family:'JetBrains Mono',monospace;font-size:0.55rem;color:#aaa;margin-bottom:0.3rem;">MA20 · BR20 · FN20 · ID20</div>
                <div style="background:#fffaf7;border:1px solid rgba(224,100,28,0.1);border-radius:4px 8px 8px 4px;padding:0.45rem 0.65rem;font-size:0.75rem;color:#1e1e1e;font-family:'Inter Tight',system-ui,sans-serif;line-height:1.45;">Starling AIX is redefining enterprise AI through sovereign knowledge architecture — the only platform where organisational intelligence compounds in infrastructure <em>you own</em>.</div>
              </div>
            </div>
            <div style="display:flex;gap:0.3rem;flex-wrap:wrap;padding-left:22px;">
              {['MA20','BR20','FN20','ID20'].map(r=>(
                <span style="font-family:'JetBrains Mono',monospace;font-size:0.55rem;color:#e0641c;background:rgba(224,100,28,0.06);border:1px solid rgba(224,100,28,0.15);border-radius:3px;padding:0.1rem 0.35rem;">{r}</span>
              ))}
            </div>
          </div>
        </div>
      </div>

    </div>

    <!-- Row 2: 2/3 + 1/3 wide cards -->
    <div class="bento-row2 fade-up" data-delay="0.12" style="margin-top:1.25rem;">

      <!-- Wide left: The Barrier -->
      <div class="bento-card" style="background:#0c0c0c;border-color:rgba(255,255,255,0.08);">
        <div class="bento-card-head">
          <div>
            <span style="display:inline-flex;font-family:'JetBrains Mono',monospace;font-size:0.6rem;padding:0.18rem 0.55rem;border-radius:4px;border:1px solid rgba(224,100,28,0.3);color:#e0641c;background:rgba(224,100,28,0.08);margin-bottom:0.65rem;">The Problem</span>
            <h3 style="font-family:'Bitter',Georgia,serif;font-size:1.15rem;font-weight:700;color:#fff;margin:0 0 0.5rem;letter-spacing:-0.02em;line-height:1.2;">More AI won't make you faster.<br/><em style="color:#e0641c;">Better architecture will.</em></h3>
            <p style="font-family:'Inter Tight',system-ui,sans-serif;font-size:0.82rem;color:rgba(255,255,255,0.5);margin:0 0 1.25rem;line-height:1.65;max-width:380px;">You've deployed AI and still get generic outputs. You've built custom GPTs. Deployed agents that don't understand your business. The intelligence is generic. The memory is theirs.</p>
            <a href="/about" class="btn btn-org" style="font-size:0.8rem;padding:0.5rem 1.1rem;">How It Works →</a>
          </div>
          <a href="/about" style="font-family:'JetBrains Mono',monospace;font-size:0.62rem;color:rgba(255,255,255,0.2);text-decoration:none;flex-shrink:0;">↗</a>
        </div>
        <!-- 3 memory types inline -->
        <div style="display:flex;flex-direction:column;gap:0.6rem;margin-top:1.25rem;padding-top:1.25rem;border-top:1px solid rgba(255,255,255,0.06);">
          {memTypes.map(([title,body])=>(
            <div style="display:flex;align-items:flex-start;gap:0.65rem;">
              <span style="display:block;width:5px;height:5px;border-radius:50%;background:#e0641c;flex-shrink:0;margin-top:0.55rem;"></span>
              <p style="font-family:'Inter Tight',system-ui,sans-serif;font-size:0.8rem;color:rgba(255,255,255,0.45);margin:0;line-height:1.55;"><strong style="color:rgba(255,255,255,0.75);">{title}</strong> — {body}</p>
            </div>
          ))}
        </div>
      </div>

      <!-- Right: Key stats -->
      <div class="bento-card" style="display:flex;flex-direction:column;justify-content:space-between;">
        <div>
          <span style="display:inline-flex;font-family:'JetBrains Mono',monospace;font-size:0.6rem;padding:0.18rem 0.55rem;border-radius:4px;border:1px solid rgba(0,0,0,0.1);color:#888;background:rgba(0,0,0,0.03);margin-bottom:0.65rem;">By the numbers</span>
          <h3 style="font-family:'Bitter',Georgia,serif;font-size:1.15rem;font-weight:700;color:#0c0c0c;margin:0 0 0.5rem;letter-spacing:-0.02em;line-height:1.2;">The architecture behind the results.</h3>
        </div>
        <div class="stats-2x2">
          {stats.map(([num,label])=>(
            <div style="padding:1.25rem 1rem;border:1px solid rgba(0,0,0,0.07);border-radius:10px;background:#fff;">
              <div style="font-family:'Bitter',Georgia,serif;font-size:2.2rem;font-weight:700;color:#e0641c;line-height:0.9;letter-spacing:-0.04em;">{num}</div>
              <div style="font-family:'Inter',sans-serif;font-size:0.58rem;font-weight:600;letter-spacing:0.1em;text-transform:uppercase;color:#888;margin-top:0.5rem;">{label}</div>
            </div>
          ))}
        </div>
      </div>

    </div>
  </div>
</section>

<!-- ══════════════════════════════════════════════════════════════
     ARCHITECTURE — silk background, dark mock window
     ══════════════════════════════════════════════════════════════ -->
<section style="background:#f2f1ee;padding:6rem 0;" id="architecture">
  <div class="container">

    <div class="arch-header fade-up" data-delay="0" style="margin-bottom:3rem;">
      <div>
        <div class="stag stag-o" style="margin-bottom:1.25rem;">2.0 · Deep Dive</div>
        <h2 style="font-family:'Bitter',Georgia,serif;font-weight:700;font-size:clamp(1.9rem,4vw,2.9rem);line-height:1.1;letter-spacing:-0.03em;margin:0;color:#0c0c0c;">
          Inside the Org Brain.
        </h2>
      </div>
      <div>
        <p style="font-family:'Inter Tight',system-ui,sans-serif;font-size:1rem;color:#4a4a4a;line-height:1.75;margin:0 0 1.5rem;">
          Switch between the UCA cognate library, the full Org Brain architecture, and the DLM query interface. This is what organisational intelligence actually looks like when it's running.
        </p>
        <div style="display:flex;gap:0.75rem;flex-wrap:wrap;">
          <a href="/platform" class="btn btn-org">Request Beta Access →</a>
          <a href="/about" class="btn-ghost-light">Learn How It Works</a>
        </div>
      </div>
    </div>

    <!-- Tabbed wide mock -->
    <div class="wide-mock fade-up" data-delay="0.08" id="arch-mock">
      <div class="mock-bar">
        <span class="mock-dot r"></span><span class="mock-dot y"></span><span class="mock-dot g"></span>
        <span id="mock-bar-label" style="font-family:'JetBrains Mono',monospace;font-size:0.65rem;color:#3f3f46;margin-left:0.5rem;">starling.workspace — UCA · Cognate Library</span>
        <span id="mock-bar-status" style="font-family:'JetBrains Mono',monospace;font-size:0.62rem;color:#e0641c;margin-left:auto;padding-right:0.75rem;">MA20 active</span>
      </div>

      <!-- Panel 0: UCA -->
      <div class="tab-panel active" id="panel-0">
        <div class="mock-split">
          <div class="mock-side">
            <div class="mock-side-head">All Cognates <span style="color:#e0641c;">11</span></div>
            {cognates.map(([code,label,active]) => (
              <div class={`mock-side-row${active ? ' is-active' : ''}`}>
                <span class="msr-code">{code}</span>
                <span class="msr-label">{label}</span>
                {active && <span class="msr-dot"></span>}
              </div>
            ))}
          </div>
