---
import Layout from '../layouts/Layout.astro';
const CDN = 'https://cdn.prod.website-files.com/68a8c21bc88f17902fc14981';
const usaTodayLogo = `${CDN}/697d0d971e75e603938c8e02_usa-today-seeklogo.svg`;
const ibtLogo      = `${CDN}/697d0da1b283dc95eb1d53a5_international-business-times-logo-vector.svg`;
const chrisImg     = `${CDN}/69336097cd299f5bc5e0f762_Chris%20Smiling%20_Silo.png`;

const cognates = [
  ['MA','Market Analysis',true],
  ['ID','Identity & Culture',false],
  ['BR','Brand & Story',false],
  ['IN','Innovation',false],
  ['FN','Finance',false],
  ['OP','Operations',false],
  ['HR','People & Talent',false],
  ['IT','Technology',false],
  ['CN','Compliance',false],
  ['CS','Customer Success',false],
  ['PM','Product & Market',false],
];

const ucaFields = [
  ['Market Position','Mid-market B2B leader with enterprise migration path. AI-native architecture advantage in all segments.'],
  ['Primary Competitors','Salesforce, HubSpot, Monday.com — each lacking a sovereign knowledge layer. No competitor has DLM.'],
  ['Competitive Moat','The Org Brain architecture. Once installed, switching costs approach 100% — knowledge compounds in your system, not ours.'],
  ['Strategic Evidence','47% faster decision cycles post-implementation. 12 enterprise pilots. Zero churn at 18 months.'],
];

const innovationSystems = [
  { name: 'Innovation System',  mems: ['Corporate Vision', 'Innovation Charter', 'R&D Roadmap'] },
  { name: 'Disruption System',  mems: ['Market Signals',   'Competitive Intel',  'Opportunity Map'] },
  { name: 'Discovery System',   mems: ['Research Vault',   'Prototype Log',      'Learning Ledger'] },
];
const optimizationSystems = [
  { name: 'Revenue Intelligence', mems: ['Pipeline Memory', 'Pricing Matrix',    'Win/Loss Archive'] },
  { name: 'Process Intelligence', mems: ['SOP Library',     'Quality Standards', 'Efficiency Log'] },
  { name: 'Risk Intelligence',    mems: ['Compliance Vault','Risk Register',     'Incident Archive'] },
];

const ctxChips  = ['28 memories loaded','11 cognates indexed','MA20 · BR20 · PM20 active','Org Brain v2.4'];
const dlmRefs   = ['MA20','BR20','PM20','FN20'];
const stats     = [['11','Org Cognates'],['28','Constitutional Memories'],['4','Memory Tiers'],['9 wk','Certification Program']];
const memTypes  = [
  ['Persistent Memory','guides growth and strategic direction across every session'],
  ['Active Memory','powers daily work and in-flight projects with full context'],
  ['Learned Memory','memorializes what worked and compounds intelligence over time'],
];
---

<Layout
  title="Starling AIX — Mach 1 Business"
  description="The sound barrier didn't stop aviation. It defined the engineering required to go faster. Your business has a similar barrier. We built the airframe to safely surpass it."
>

<!-- ── Hero ──────────────────────────────────────────────────────────── -->
<section style="position:relative;overflow:hidden;padding:7rem 0 6rem;text-align:center;" class="grid-bg">
  <div class="hero-glow"></div>
  <span class="corner-mark cm-tl">+</span>
  <span class="corner-mark cm-tr">+</span>
  <span class="corner-mark cm-bl">+</span>
  <span class="corner-mark cm-br">+</span>
  <div class="container" style="position:relative;z-index:1;">
    <div class="badge fade-up" data-delay="0" style="margin-bottom:1.75rem;">Introducing Mach 1 Business</div>
    <h1 class="heading-display fade-up" data-delay="0.06"
        style="font-size:clamp(3.5rem,9vw,6.5rem);margin:0 0 1.5rem;letter-spacing:-0.04em;max-width:820px;margin-inline:auto;">
      Your business,<br/>now <em style="color:#f97316;">fluent in AI.</em>
    </h1>
    <p class="fade-up" data-delay="0.12"
       style="font-size:1.1rem;color:#71717a;line-height:1.75;max-width:500px;margin:0 auto 2.5rem;">
      The sound barrier didn't stop aviation. It defined the engineering required to go faster. We built the airframe.
    </p>
    <div class="fade-up" data-delay="0.18" style="display:flex;gap:0.75rem;flex-wrap:wrap;justify-content:center;margin-bottom:4rem;">
      <a href="/ai-guide" class="btn btn-primary" style="font-size:0.95rem;padding:0.75rem 1.75rem;">Start Here →</a>
      <a href="#architecture" class="btn btn-ghost" style="font-size:0.95rem;padding:0.75rem 1.75rem;">See the Architecture</a>
    </div>
    <!-- DLM equation -->
    <div class="fade-up" data-delay="0.24" style="display:flex;align-items:center;justify-content:center;gap:0.5rem;flex-wrap:wrap;">
      {[
        ['LLM','Stateless\nProcessing'],['×',null],
        ['MCP','Connection\nProtocol'],['×',null],
        ['UCA','Semantic\nAddressing'],['×',null],
        ['ORG\nBRAIN','Sovereign\nRepository'],['=',null],
        ['DLM','Domain\nLanguage Model'],
      ].map(([label,sub]) =>
        (label==='×'||label==='=')
          ? <span style="color:#3f3f46;font-family:'JetBrains Mono',monospace;font-size:0.9rem;">{label}</span>
          : <div style="display:flex;flex-direction:column;align-items:center;gap:0.3rem;">
              <div class="dlm-box" style={label==='DLM'?'border-color:rgba(249,115,22,0.5);background:rgba(249,115,22,0.12);box-shadow:0 0 24px rgba(249,115,22,0.15)':''}>{label}</div>
              {sub&&<span style="font-family:'JetBrains Mono',monospace;font-size:0.58rem;color:#3f3f46;text-align:center;line-height:1.4;white-space:pre-line;">{sub}</span>}
            </div>
      )}
    </div>
  </div>
</section>

<!-- ── Press ─────────────────────────────────────────────────────────── -->
<section style="padding:1.75rem 0;border-top:1px solid rgba(255,255,255,0.07);border-bottom:1px solid rgba(255,255,255,0.07);opacity:0.55;">
  <div class="container" style="text-align:center;">
    <p class="section-label" style="margin-bottom:1rem;">As Featured In</p>
    <div class="marquee-wrap" style="overflow:hidden;">
      <div class="marquee-track">
        {[usaTodayLogo,ibtLogo,usaTodayLogo,ibtLogo,usaTodayLogo,ibtLogo,usaTodayLogo,ibtLogo].map(src=>(
          <img src={src} alt="press" class="press-logo"/>
        ))}
      </div>
    </div>
  </div>
</section>

<!-- ══════════════════════════════════════════════════════════════════════
     1.0  UCA — Every idea, permanently addressed
     ══════════════════════════════════════════════════════════════════════ -->
<section class="feat-section" id="architecture">
  <div class="container">

    <div class="feat-header fade-up" data-delay="0">
      <div>
        <p class="feat-num">1.0 · Universal Cognitive Architecture</p>
        <h2 class="feat-h2 heading-bold">Every idea,<br/>permanently addressed.</h2>
      </div>
      <div>
        <p class="feat-body">The Dewey Decimal System for business knowledge. Eleven cognates, four memory tiers — semantic coordinates your AI reads by name, not by search. Every strategic position, cultural value, and decision your company has ever made: instantly addressable.</p>
        <div class="feat-ctas">
          <a href="/ai-guide" class="btn btn-primary">Get the Free Standard →</a>
          <a href="/platform" class="btn btn-ghost">See the Platform</a>
        </div>
      </div>
    </div>

    <!-- Wide app mockup -->
    <div class="wide-mock fade-up" data-delay="0.1">
      <div class="mock-bar">
        <span class="mock-dot r"></span><span class="mock-dot y"></span><span class="mock-dot g"></span>
        <span style="font-family:'JetBrains Mono',monospace;font-size:0.65rem;color:#3f3f46;margin-left:0.5rem;">starling.workspace — UCA · Cognate Library</span>
        <span style="font-family:'JetBrains Mono',monospace;font-size:0.62rem;color:#3f3f46;margin-left:auto;padding-right:0.75rem;">MA20 active</span>
      </div>
      <div class="mock-split">
        <!-- Sidebar -->
        <div class="mock-side">
          <div class="mock-side-head">All Cognates <span style="color:#f97316;">11</span></div>
          {cognates.map(([code,label,active]) => (
            <div class={`mock-side-row${active ? ' is-active' : ''}`}>
              <span class="msr-code">{code}</span>
              <span class="msr-label">{label}</span>
              {active && <span class="msr-dot"></span>}
            </div>
          ))}
        </div>
        <!-- Main panel -->
        <div class="mock-content">
          <div style="display:flex;align-items:center;gap:0.75rem;flex-wrap:wrap;margin-bottom:0.75rem;">
            <span style="font-family:'JetBrains Mono',monospace;font-size:0.78rem;color:#f97316;font-weight:500;">MA20</span>
            <h3 style="font-size:1.15rem;font-weight:600;letter-spacing:-0.02em;color:#fff;margin:0;">Competitive Position</h3>
            <span class="badge" style="font-size:0.58rem;padding:0.12rem 0.5rem;">Active</span>
            <span style="margin-left:auto;font-family:'JetBrains Mono',monospace;font-size:0.6rem;color:#3f3f46;">Persistent · Tier 3</span>
          </div>
          <div style="height:1px;background:rgba(255,255,255,0.06);margin-bottom:1.25rem;"></div>
          <div class="mock-fields">
            {ucaFields.map(([label,val]) => (
              <div class="mock-field">
                <p class="mf-label">{label}</p>
                <p class="mf-val">{val}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>

  </div>
</section>

<!-- ══════════════════════════════════════════════════════════════════════
     2.0  Org Brain — Your company's neural system
     ══════════════════════════════════════════════════════════════════════ -->
<section class="feat-section" style="border-top:1px solid rgba(255,255,255,0.07);">
  <div class="container">

    <div class="feat-header fade-up" data-delay="0">
      <div>
        <p class="feat-num">2.0 · Organizational Intelligence</p>
        <h2 class="feat-h2 heading-bold">Your company's<br/>neural system.</h2>
      </div>
      <div>
        <p class="feat-body">Two hemispheres — Innovation and Optimization — bridged by a Cognitive layer. 28 Constitutional Memories. One sovereign repository that compounds knowledge with every decision your team makes. You own it forever.</p>
        <div class="feat-ctas">
          <a href="/cognitive-design" class="btn btn-primary">Build Your Org Brain →</a>
          <a href="/services" class="btn btn-ghost">Enterprise Licensing</a>
        </div>
      </div>
    </div>

    <!-- Wide architecture mockup -->
    <div class="wide-mock fade-up" data-delay="0.1">
      <div class="mock-bar">
        <span class="mock-dot r"></span><span class="mock-dot y"></span><span class="mock-dot g"></span>
        <span style="font-family:'JetBrains Mono',monospace;font-size:0.65rem;color:#3f3f46;margin-left:0.5rem;">starling.workspace — Org Brain · Architecture View</span>
        <span style="font-family:'JetBrains Mono',monospace;font-size:0.62rem;color:#22c55e;margin-left:auto;padding-right:0.75rem;">● 28 memories indexed</span>
      </div>
      <div class="brain-grid">
        <!-- Left: Innovation Hemisphere -->
        <div class="brain-hem">
          <div class="brain-hem-label">Innovation Hemisphere</div>
          {innovationSystems.map(sys => (
            <div class="brain-sys">
              <div class="brain-sys-name">{sys.name}</div>
              {sys.mems.map(m => <div class="brain-mem">{m}</div>)}
            </div>
          ))}
        </div>
        <!-- Center: Cognitive Layer -->
        <div class="brain-center">
          <div class="brain-center-label">Cognitive<br/>Layer</div>
          {['Memory Router','Context Engine','DLM Gateway','Semantic Index'].map(c => (
            <div class="brain-chip">{c}</div>
          ))}
        </div>
        <!-- Right: Optimization Hemisphere -->
        <div class="brain-hem">
          <div class="brain-hem-label">Optimization Hemisphere</div>
          {optimizationSystems.map(sys => (
            <div class="brain-sys">
              <div class="brain-sys-name">{sys.name}</div>
              {sys.mems.map(m => <div class="brain-mem">{m}</div>)}
            </div>
          ))}
        </div>
      </div>
    </div>

  </div>
</section>

<!-- ══════════════════════════════════════════════════════════════════════
     3.0  DLM — Intelligence that compounds
     ══════════════════════════════════════════════════════════════════════ -->
<section class="feat-section grid-bg" style="border-top:1px solid rgba(255,255,255,0.07);position:relative;">
  <div class="container" style="position:relative;z-index:1;">

    <div class="feat-header fade-up" data-delay="0">
      <div>
        <p class="feat-num">3.0 · Domain Language Model</p>
        <h2 class="feat-h2 heading-bold">Intelligence<br/>that compounds.</h2>
      </div>
      <div>
        <p class="feat-body">A general-purpose LLM loaded with your complete organizational context on every request. The know-how is the asset. The processing is the commodity. Your DLM gets measurably smarter every week you use it.</p>
        <div class="feat-ctas">
          <a href="/platform" class="btn btn-primary">Request Beta Invite →</a>
          <a href="/about" class="btn btn-ghost">How It Works</a>
        </div>
      </div>
    </div>

    <!-- Wide DLM query mockup -->
    <div class="wide-mock fade-up" data-delay="0.1">
      <div class="mock-bar">
        <span class="mock-dot r"></span><span class="mock-dot y"></span><span class="mock-dot g"></span>
        <span style="font-family:'JetBrains Mono',monospace;font-size:0.65rem;color:#3f3f46;margin-left:0.5rem;">starling.dlm — Organizational Query Interface</span>
        <span style="font-family:'JetBrains Mono',monospace;font-size:0.62rem;color:#f97316;margin-left:auto;padding-right:0.75rem;">● DLM Active</span>
      </div>
      <!-- Context bar -->
      <div style="padding:0.75rem 1.25rem;border-bottom:1px solid rgba(255,255,255,0.06);display:flex;gap:0.4rem;flex-wrap:wrap;background:rgba(249,115,22,0.02);">
        {ctxChips.map(t => (
          <span class="mock-chip" style="font-size:0.62rem;padding:0.2rem 0.6rem;">{t}</span>
        ))}
      </div>
      <!-- Thread -->
      <div class="dlm-thread">
        <div class="dlm-msg">
          <div class="dlm-avatar dlm-avatar-user">You</div>
          <div class="dlm-bubble-user">
            What's our competitive positioning narrative for the Q2 board presentation?
          </div>
        </div>
        <div class="dlm-msg">
          <div class="dlm-avatar dlm-avatar-ai">DLM</div>
          <div style="flex:1;">
            <div class="dlm-ref-line">Referencing MA20 · BR20 · PM20 · FN20 — 4 memories active</div>
            <div class="dlm-bubble-ai">
              Your Q2 narrative should center on <span style="color:#fff;font-weight:500;">the sovereignty advantage</span>: no competitor offers a system where organizational knowledge compounds in an architecture the client permanently owns. Lead with the 47% decision-cycle improvement from persistent memory, then position DLM as infrastructure — not software. Close with the Exit Guarantee as the risk-reversal that eliminates every procurement objection.
            </div>
            <div style="display:flex;gap:0.4rem;margin-top:0.5rem;flex-wrap:wrap;">
              {dlmRefs.map(ref => (
                <span class="dlm-ref-tag">{ref}</span>
              ))}
            </div>
          </div>
        </div>
      </div>
    </div>

  </div>
</section>

<!-- ── Stats Strip ────────────────────────────────────────────────────── -->
<div style="border-top:1px solid rgba(255,255,255,0.07);border-bottom:1px solid rgba(255,255,255,0.07);">
  <div class="container" style="padding-inline:0;">
    <div class="stats-strip">
      {stats.map(([num,label]) => (
        <div class="stat-cell">
          <div class="stat-num">{num}</div>
          <div class="stat-label">{label}</div>
        </div>
      ))}
    </div>
  </div>
</div>

<!-- ── Cognition Barrier ──────────────────────────────────────────────── -->
<section class="feat-section grid-bg" style="position:relative;overflow:hidden;border-top:1px solid rgba(255,255,255,0.07);">
  <div class="hero-glow-wide"></div>
  <span class="corner-mark cm-tl">+</span>
  <span class="corner-mark cm-tr">+</span>
  <div class="container" style="position:relative;z-index:1;">
    <div class="barrier-row">

      <div class="fade-up" data-delay="0">
        <p class="feat-num">The Cognition Barrier</p>
        <h2 class="feat-h2 heading-bold" style="max-width:360px;">More AI won't make you faster.<br/>Better architecture will.</h2>
        <div style="margin-top:2.5rem;display:flex;flex-direction:column;gap:1.25rem;">
          {memTypes.map(([title,body]) => (
            <div style="display:flex;align-items:flex-start;gap:0.75rem;">
              <span style="width:6px;height:6px;border-radius:50%;background:#f97316;flex-shrink:0;margin-top:0.55rem;"></span>
              <div>
                <span style="font-size:0.9rem;color:#e4e4e7;font-weight:600;">{title}</span>
                <span style="font-size:0.9rem;color:#52525b;"> — {body}</span>
              </div>
            </div>
          ))}
        </div>
      </div>

      <div class="glass fade-up" data-delay="0.12" style="padding:2.5rem;align-self:start;">
        <p style="font-size:1rem;color:#a1a1aa;line-height:1.85;margin:0 0 1.25rem;">
          Every organization hits the same wall. You add AI tools, solutions, and specialists — but instead of accelerating, you hit turbulence. Information fragments. Context evaporates. Your AI is out of sync.
        </p>
        <p style="font-size:1rem;color:#a1a1aa;line-height:1.85;margin:0 0 1.75rem;">
          The answer isn't more power. It's better infrastructure.
          <span style="color:#fff;font-weight:500;"> MA20 is always your competitive position.</span> That's canon — the governing truth your entire organization, especially your AI, works from.
        </p>
        <div style="display:flex;gap:0.75rem;align-items:center;flex-wrap:wrap;">
          <a href="/cognitive-design" class="btn btn-primary" style="font-size:0.875rem;padding:0.65rem 1.5rem;">Enroll Now →</a>
          <a href="/about" class="btn btn-ghost" style="font-size:0.875rem;padding:0.65rem 1.5rem;">How It Works</a>
        </div>
      </div>

    </div>
  </div>
</section>

<!-- ── Newsletter ─────────────────────────────────────────────────────── -->
<section id="newsletter" style="padding:6rem 0;border-top:1px solid rgba(255,255,255,0.07);">
  <div class="container">
    <div class="nl-grid">
      <div>
        <p class="section-label fade-up" data-delay="0" style="margin-bottom:0.75rem;">On Cognitive Design</p>
        <h2 class="heading-display fade-up" data-delay="0.06" style="font-size:clamp(1.8rem,4vw,2.8rem);margin:0 0 1rem;">
          The weekly deep dive.
        </h2>
        <p class="fade-up" data-delay="0.1" style="font-size:0.95rem;color:#71717a;line-height:1.75;margin:0 0 2rem;">
          Each issue unpacks a piece of the methodology in a free, in-depth essay. From Chris Kincade, Starling CEO and creator of Cognitive Design.
        </p>
        <form id="nl-form" class="fade-up" data-delay="0.14" style="display:flex;gap:0.75rem;flex-wrap:wrap;">
          <input type="email" name="email" placeholder="your@email.com" required class="input" style="flex:1;min-width:220px;" />
          <button type="submit" class="btn btn-orange" style="padding:0.65rem 1.5rem;">Subscribe</button>
        </form>
        <p style="font-size:0.75rem;color:#3f3f46;margin-top:0.75rem;">Weekly. No spam. Unsubscribe anytime.</p>
      </div>
      <div class="fade-up" data-delay="0.1" style="display:flex;justify-content:center;">
        <div style="position:relative;width:180px;">
          <img src={chrisImg} alt="Chris Kincade"
               style="width:100%;border-radius:16px;border:1px solid rgba(255,255,255,0.08);display:block;" />
          <div class="glass-dark" style="position:absolute;bottom:-10px;left:-10px;padding:0.4rem 0.75rem;border-radius:8px;">
            <span style="font-family:'JetBrains Mono',monospace;font-size:0.62rem;color:#a1a1aa;">Chris Kincade</span>
            <div style="font-family:'JetBrains Mono',monospace;font-size:0.58rem;color:#f97316;margin-top:0.1rem;">CEO, Starling AIX</div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

</Layout>

<style>
  /* ── Feature section layout ──────────────────────────── */
  .feat-section { padding: 5rem 0; }

  .feat-num {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.72rem;
    color: #52525b;
    letter-spacing: 0.05em;
    margin: 0 0 1.25rem;
  }
  .feat-h2 {
    font-size: clamp(1.8rem, 4vw, 2.8rem);
    letter-spacing: -0.035em;
    margin: 0;
    color: #fff;
    line-height: 1.1;
  }
  .feat-header {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
    margin-bottom: 3rem;
    align-items: start;
  }
  .feat-body {
    font-size: 1rem;
    color: #71717a;
    line-height: 1.8;
    margin: 0 0 1.5rem;
  }
  .feat-ctas { display: flex; gap: 0.75rem; flex-wrap: wrap; }

  /* ── Wide mock window ────────────────────────────────── */
  .wide-mock {
    background: #0a0a0a;
    border: 1px solid rgba(255,255,255,0.09);
    border-radius: 10px;
    overflow: hidden;
  }

  /* ── UCA sidebar split ───────────────────────────────── */
  .mock-split { display: grid; grid-template-columns: 1fr; }

  .mock-side {
    border-right: 1px solid rgba(255,255,255,0.06);
    padding: 0.5rem 0 1rem;
    background: #070707;
    display: none; /* show on desktop */
  }
  .mock-side-head {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.6rem;
    color: #3f3f46;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    padding: 0.5rem 1rem 0.75rem;
    border-bottom: 1px solid rgba(255,255,255,0.05);
    margin-bottom: 0.35rem;
  }
  .mock-side-row {
    padding: 0.35rem 1rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    cursor: default;
  }
  .mock-side-row.is-active { background: rgba(249,115,22,0.06); }
  .msr-code {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.62rem;
    font-weight: 500;
    color: #3f3f46;
    min-width: 22px;
  }
  .mock-side-row.is-active .msr-code { color: #f97316; }
  .msr-label { font-size: 0.78rem; color: #3f3f46; }
  .mock-side-row.is-active .msr-label { color: #e4e4e7; }
  .msr-dot { margin-left: auto; width: 5px; height: 5px; border-radius: 50%; background: #f97316; flex-shrink: 0; }

  .mock-content { padding: 1.5rem; min-height: 340px; overflow: hidden; }

  .mock-fields { display: grid; grid-template-columns: 1fr; gap: 0.75rem; }
  .mock-field {
    border: 1px solid rgba(255,255,255,0.06);
    border-radius: 8px;
    padding: 0.75rem 1rem;
    background: rgba(255,255,255,0.015);
  }
  .mf-label {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.6rem;
    color: #52525b;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin: 0 0 0.4rem;
  }
  .mf-val { font-size: 0.82rem; color: #a1a1aa; margin: 0; line-height: 1.6; }

  /* ── Org Brain grid ──────────────────────────────────── */
  .brain-grid {
    display: grid;
    grid-template-columns: 1fr;
