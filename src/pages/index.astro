    .mock-fields     { grid-template-columns: 1fr 1fr; }
    .brain-grid      { grid-template-columns: 1fr auto 1fr; }
    .brain-center    { order: 0; }
    .tab-cards-row   { grid-template-columns: repeat(3,1fr); }
    .stats-strip     { grid-template-columns: repeat(4,1fr); }
    .stat-cell       { border-bottom: none; }
    .stat-cell:nth-child(2n)  { border-right: 1px solid rgba(0,0,0,0.08); }
    .stat-cell:last-child     { border-right: none; }
    .nl-grid         { grid-template-columns: 1fr 200px; }
