/* SECTION HEADER */
.section__header{display:grid;grid-template-columns:1fr;gap:16px;margin-bottom:32px;align-items:start}
@media(min-width:768px){.section__header{grid-template-columns:1.2fr 1fr;gap:60px;margin-bottom:72px}}
.section__h{font-size:clamp(1.75rem,3.5vw,40px);font-weight:400;line-height:1.15;letter-spacing:-0.025em;color:var(--text-secondary)}
