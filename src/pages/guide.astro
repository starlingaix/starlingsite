<script is:inline>
/* ========================================================
   HERO — Ambient Particle Canvas
   ======================================================== */
(function(){
    const c = document.getElementById('heroCanvas');
    if(!c) return;
    const ctx = c.getContext('2d');
    let W, H, particles = [], raf;
    const colors = ['rgba(212,112,44,0.4)','rgba(54,209,183,0.35)','rgba(99,91,255,0.35)','rgba(245,100,147,0.3)','rgba(232,147,79,0.3)'];

    function resize(){
        const r = window.devicePixelRatio || 1;
        W = c.parentElement.clientWidth;
        H = c.parentElement.clientHeight;
        c.width = W * r; c.height = H * r;
        c.style.width = W + 'px'; c.style.height = H + 'px';
        ctx.setTransform(r,0,0,r,0,0);
    }
    function init(){
        resize(); particles = [];
        const count = Math.min(80, Math.floor(W*H/8000));
        for(let i=0;i<count;i++){
            particles.push({x:Math.random()*W,y:Math.random()*H,r:Math.random()*2.5+0.8,
                vx:(Math.random()-0.5)*0.3,vy:(Math.random()-0.5)*0.3,
                color:colors[Math.floor(Math.random()*colors.length)],phase:Math.random()*Math.PI*2});
        }
    }
    function draw(t){
        ctx.clearRect(0,0,W,H);
        const time=t*0.001;
        for(let i=0;i<particles.length;i++){
            for(let j=i+1;j<particles.length;j++){
                const dx=particles[i].x-particles[j].x,dy=particles[i].y-particles[j].y,dist=Math.sqrt(dx*dx+dy*dy);
                if(dist<120){ctx.beginPath();ctx.moveTo(particles[i].x,particles[i].y);ctx.lineTo(particles[j].x,particles[j].y);ctx.strokeStyle=`rgba(212,112,44,${0.06*(1-dist/120)})`;ctx.lineWidth=0.5;ctx.stroke();}
            }
        }
        for(const p of particles){
            const pulse=0.3+0.7*(0.5+0.5*Math.sin(time+p.phase));
            ctx.beginPath();ctx.arc(p.x,p.y,p.r*pulse,0,Math.PI*2);ctx.fillStyle=p.color;ctx.fill();
            ctx.beginPath();ctx.arc(p.x,p.y,p.r*3*pulse,0,Math.PI*2);ctx.fillStyle=p.color.replace(/[\d.]+\)$/,(0.08*pulse).toFixed(3)+')');ctx.fill();
            p.x+=p.vx+Math.sin(time*0.5+p.phase)*0.1;p.y+=p.vy+Math.cos(time*0.4+p.phase)*0.1;
            if(p.x<-10)p.x=W+10;if(p.x>W+10)p.x=-10;if(p.y<-10)p.y=H+10;if(p.y>H+10)p.y=-10;
        }
        raf=requestAnimationFrame(draw);
    }
    init(); raf=requestAnimationFrame(draw);
    window.addEventListener('resize',()=>{init();});
    setTimeout(()=>document.querySelector('.guide-hero').classList.add('is-loaded'),100);
})();

/* ========================================================
   HERO — Summon Starling Terminal Animation (Dynamic)
   ======================================================== */
(function(){
    const $ = id => document.getElementById(id);
    const upload=$('htUpload'), check=$('htCheck'), progress=$('htProgress'),
          uploadStatus=$('htUploadStatus'),
          cmd=$('htCmd'), cmdText=$('htCmdText'), cursor=$('htCursor'),
          step1=$('htStep1'), step2=$('htStep2'), step3=$('htStep3'),
          fill1=$('htFill1'), fill2=$('htFill2'), fill3=$('htFill3'),
          count1=$('htCount1'), count2=$('htCount2'), count3=$('htCount3'),
          result=$('htResult'), replay=$('htReplay'),
          pill1=$('htPill1'), pill2=$('htPill2'), pill3=$('htPill3'),
          barStatus=$('htBarStatus'),
          dot1=$('htDot1'), dot2=$('htDot2'), dot3=$('htDot3');
    if(!upload) return;

    let timers = [];
    function delay(fn, ms){ const t = setTimeout(fn, ms); timers.push(t); return t; }

    function reset(){
        timers.forEach(clearTimeout); timers = [];
        [upload,cmd,step1,step2,step3,result].forEach(el => {
            el.classList.remove('is-visible','is-done','is-loading','is-active');
        });
        [check,pill1,pill2,pill3].forEach(el => el.classList.remove('is-visible'));
        barStatus.classList.remove('is-active');
        replay.classList.remove('is-visible');
        cmdText.textContent = '';
        cursor.style.display = 'inline-block';
        cmd.classList.remove('is-active');
        progress.style.width = '0%';
        fill1.style.width = '0%'; fill2.style.width = '0%'; fill3.style.width = '0%';
        count1.textContent = ''; count2.textContent = ''; count3.textContent = '';
        uploadStatus.textContent = 'iPub · 2.4 MB · Uploading...';
        dot1.style.background = dot2.style.background = dot3.style.background = '';
    }

    function typeText(el, text, speed, cb){
        let i = 0;
        function tick(){
            if(i < text.length){ el.textContent += text[i]; i++; delay(tick, speed + Math.random()*40); }
            else if(cb) cb();
        }
        tick();
    }

    function animateProgress(el, duration, cb){
        const start = performance.now();
        function tick(now){
            const p = Math.min((now - start) / duration, 1);
            const eased = 1 - Math.pow(1 - p, 3); // ease-out cubic
            el.style.width = (eased * 100).toFixed(1) + '%';
            if(p < 1) requestAnimationFrame(tick);
            else if(cb) cb();
        }
        requestAnimationFrame(tick);
    }

    function countUp(el, from, to, duration, suffix){
        const start = performance.now();
        function tick(now){
            const p = Math.min((now - start) / duration, 1);
            const val = Math.floor(from + (to - from) * p);
            el.textContent = val + (suffix || '');
            if(p < 1) requestAnimationFrame(tick);
        }
        requestAnimationFrame(tick);
    }

    function runSequence(){
        reset();
        const d = 500;

        // Phase 1: Upload with animated progress bar
        delay(() => {
            upload.classList.add('is-visible');
            delay(() => animateProgress(progress, 1200, () => {
                upload.classList.add('is-done');
                uploadStatus.textContent = 'iPub · 2.4 MB · Uploaded as project knowledge';
                check.classList.add('is-visible');
            }), 200);
        }, d);

        // Phase 2: Command input with active glow
        delay(() => {
            cmd.classList.add('is-visible');
            delay(() => {
                cmd.classList.add('is-active');
                typeText(cmdText, 'Starling', 100, () => {
                    cursor.style.display = 'none';
                    cmd.classList.remove('is-active');
                });
            }, 250);
        }, d + 1800);

        // Phase 3: Resolution step 1 — UCA (loading → progress → done)
        delay(() => {
            step1.classList.add('is-visible','is-loading');
            countUp(count1, 0, 11, 800, ' cognates');
            delay(() => animateProgress(fill1, 700, () => {
                step1.classList.remove('is-loading');
                step1.classList.add('is-done');
            }), 300);
        }, d + 3200);

        // Phase 3b: Resolution step 2 — DLM
        delay(() => {
            step2.classList.add('is-visible','is-loading');
            countUp(count2, 0, 28, 600, ' nodes');
            delay(() => animateProgress(fill2, 600, () => {
                step2.classList.remove('is-loading');
                step2.classList.add('is-done');
            }), 250);
        }, d + 4400);

        // Phase 3c: Resolution step 3 — Smart OS
        delay(() => {
            step3.classList.add('is-visible','is-loading');
            countUp(count3, 0, 100, 500, '%');
            delay(() => animateProgress(fill3, 500, () => {
                step3.classList.remove('is-loading');
                step3.classList.add('is-done');
            }), 200);
        }, d + 5400);

        // Phase 4: Result card with staggered pills
        delay(() => {
            result.classList.add('is-visible');
            barStatus.classList.add('is-active');
            dot1.style.background = '#F56493';
            dot2.style.background = '#FBBF24';
            dot3.style.background = '#36D1B7';
            delay(() => pill1.classList.add('is-visible'), 200);
            delay(() => pill2.classList.add('is-visible'), 400);
            delay(() => pill3.classList.add('is-visible'), 600);
        }, d + 6400);

        // Replay
        delay(() => replay.classList.add('is-visible'), d + 7400);
    }

    // Auto-start on load
    runSequence();

    // Replay click
    replay.addEventListener('click', runSequence);
})();

/* ========================================================
   SCROLL REVEAL — IntersectionObserver
   ======================================================== */
(function(){
    const io = new IntersectionObserver((entries) => {
        entries.forEach(e => { if(e.isIntersecting){ e.target.classList.add('is-visible'); io.unobserve(e.target); }});
    }, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' });
    document.querySelectorAll('.reveal').forEach(el => io.observe(el));
})();

/* ========================================================
   LOCK-CHAIN — Animate on scroll
   ======================================================== */
(function(){
    const chain = document.querySelector('.lock-chain');
    if(!chain) return;
    const io = new IntersectionObserver((entries) => {
        entries.forEach(e => {
            if(e.isIntersecting){
                chain.classList.add('is-visible');
                const links = chain.querySelectorAll('.lock-chain__link');
                links.forEach((l, i) => { l.style.transitionDelay = (i * 0.08) + 's'; });
                io.unobserve(chain);
            }
        });
    }, { threshold: 0.3 });
    io.observe(chain);
})();

/* ========================================================
   SOLUTION TOGGLE — Search / Address / Compare
   ======================================================== */
(function(){
    const bar = document.getElementById('solToggleBar');
    const pill = document.getElementById('solPill');
    const btns = document.querySelectorAll('.solution-toggle__btn');
    const panels = document.querySelectorAll('.solution-panel');
    const wrapper = document.getElementById('solPanels');
    if(!bar || !btns.length) return;

    // Position the sliding pill
    function movePill(btn){
        const barRect = bar.getBoundingClientRect();
        const btnRect = btn.getBoundingClientRect();
        pill.style.left = (btnRect.left - barRect.left) + 'px';
        pill.style.width = btnRect.width + 'px';
    }

    // Initialize pill on first active
    const firstActive = bar.querySelector('.solution-toggle__btn.is-active');
    if(firstActive) requestAnimationFrame(() => movePill(firstActive));
    window.addEventListener('resize', () => {
        const cur = bar.querySelector('.solution-toggle__btn.is-active');
        if(cur) movePill(cur);
    });

    // Animate items in a panel
    function animatePanel(panelId){
        const panel = document.getElementById('panel-' + panelId);
        if(!panel) return;

        if(panelId === 'search') animateSearch(panel);
        else if(panelId === 'address') animateAddress(panel);
        else if(panelId === 'compare') animateCompare(panel);
    }

    // Measure wrapper height for smooth transition
    function updateHeight(activePanel){
        // Let browser calculate, then set explicit height for transition
        wrapper.style.height = wrapper.offsetHeight + 'px';
        requestAnimationFrame(() => {
            wrapper.style.height = activePanel.offsetHeight + 'px';
            setTimeout(() => { wrapper.style.height = 'auto'; }, 450);
        });
    }

    btns.forEach(btn => {
        btn.addEventListener('click', () => {
            const target = btn.dataset.panel;
            const current = document.querySelector('.solution-panel.is-active');
            const next = document.getElementById('panel-' + target);
            if(current === next) return;

            btns.forEach(b => b.classList.remove('is-active'));
            btn.classList.add('is-active');
            movePill(btn);

            // Transition panels
            if(current) current.classList.remove('is-active');
            next.classList.add('is-active');
            updateHeight(next);

            // Reset and re-animate items
            animatePanel(target);

            // Draw graph for new panel
            if(target === 'search') triggerGraph('searchViz', 'search');
            else if(target === 'address') triggerGraph('addressViz', 'address');
            else if(target === 'compare') triggerGraph('compareViz', 'compare');
        });
    });

    // Initial animation for search panel
    setTimeout(() => animatePanel('search'), 300);
    setTimeout(() => triggerGraph('searchViz', 'search'), 600);

    /* ----- Search panel animation ----- */
    let searchHighlightTimer = null;
    function animateSearch(panel){
        clearInterval(searchHighlightTimer);
        const items = panel.querySelectorAll('.search-item');
        const counter = document.getElementById('searchTokenCounter');
        // Reset
        items.forEach(i => { i.classList.remove('is-visible','is-highlight'); });
        if(counter) counter.textContent = '0';

        // Stagger entrance
        items.forEach((item, i) => {
            setTimeout(() => item.classList.add('is-visible'), i * 120);
        });

        // Animate token counter
        if(counter){
            setTimeout(() => {
                const target = 4200;
                const duration = 1800;
                const start = performance.now();
                function tick(now){
                    const p = Math.min((now - start) / duration, 1);
                    const eased = 1 - Math.pow(1 - p, 3);
                    counter.textContent = Math.floor(eased * target).toLocaleString();
                    if(p < 1) requestAnimationFrame(tick);
                }
                requestAnimationFrame(tick);
            }, items.length * 120 + 200);
        }

        // Highlight cycling
        let hlIdx = 0;
        setTimeout(() => {
            searchHighlightTimer = setInterval(() => {
                items.forEach(i => i.classList.remove('is-highlight'));
                items[hlIdx].classList.add('is-highlight');
                hlIdx = (hlIdx + 1) % items.length;
            }, 2000);
        }, items.length * 120 + 400);
    }

    /* ----- Address panel animation ----- */
    let addressHighlightTimer = null;
    function animateAddress(panel){
        clearInterval(addressHighlightTimer);
        const items = panel.querySelectorAll('.address-item');
        const counter = document.getElementById('addressTokenCounter');
        items.forEach(i => { i.classList.remove('is-visible','is-highlight','is-checked'); });
        if(counter) counter.textContent = '0';

        // Stagger entrance
        items.forEach((item, i) => {
            setTimeout(() => item.classList.add('is-visible'), i * 120);
            setTimeout(() => item.classList.add('is-checked'), i * 120 + 400);
        });

        // Counter
        if(counter){
            setTimeout(() => {
                const target = 80;
                const duration = 800;
                const start = performance.now();
                function tick(now){
                    const p = Math.min((now - start) / duration, 1);
                    const eased = 1 - Math.pow(1 - p, 3);
                    counter.textContent = Math.floor(eased * target);
                    if(p < 1) requestAnimationFrame(tick);
                }
                requestAnimationFrame(tick);
            }, items.length * 120 + 200);
        }

        // Highlight cycling
        let hlIdx = 0;
        setTimeout(() => {
            addressHighlightTimer = setInterval(() => {
                items.forEach(i => i.classList.remove('is-highlight'));
                items[hlIdx].classList.add('is-highlight');
                hlIdx = (hlIdx + 1) % items.length;
            }, 2000);
        }, items.length * 120 + 600);
    }

    /* ----- Compare panel animation ----- */
    function animateCompare(panel){
        // Animate metrics
        const vals = panel.querySelectorAll('.sol-metric__val');
        vals.forEach(v => v.classList.remove('is-visible'));
        vals.forEach((v, i) => {
            setTimeout(() => {
                v.classList.add('is-visible');
                const target = parseInt(v.dataset.target);
                const suffix = v.dataset.suffix || '';
                const duration = 1200;
                const start = performance.now();
                function tick(now){
                    const p = Math.min((now - start) / duration, 1);
                    const eased = 1 - Math.pow(1 - p, 3);
                    v.textContent = Math.floor(eased * target).toLocaleString() + suffix;
                    if(p < 1) requestAnimationFrame(tick);
                }
                requestAnimationFrame(tick);
            }, i * 150);
        });

        // Animate compare items
        const items = panel.querySelectorAll('.sol-compare__item');
        items.forEach(i => i.classList.remove('is-visible'));
        items.forEach((item, i) => {
            setTimeout(() => item.classList.add('is-visible'), 600 + i * 100);
        });

        // Verdict
        const verdict = document.getElementById('compareVerdict');
        if(verdict){
            verdict.classList.remove('is-visible');
            setTimeout(() => verdict.classList.add('is-visible'), 1400);
        }
    }

    /* ========================================================
       GRAPH DRAWING — Shared renderer
       ======================================================== */
    const graphStates = {};

    function triggerGraph(canvasId, type){
        const c = document.getElementById(canvasId);
        if(!c) return;

        if(graphStates[canvasId]) graphStates[canvasId].cancel = true;

        const ctx = c.getContext('2d');
        const r = window.devicePixelRatio || 1;
        const state = { progress: 0, cancel: false };
        graphStates[canvasId] = state;

        function resize(){
            const W = c.parentElement.clientWidth;
            const H = c.parentElement.clientHeight;
            c.width = W * r; c.height = H * r;
            c.style.width = W + 'px'; c.style.height = H + 'px';
            ctx.setTransform(r,0,0,r,0,0);
            return { W, H };
        }

        function draw(){
            if(state.cancel) return;
            const { W, H } = resize();
            ctx.clearRect(0,0,W,H);
            const pad = { top:20, right:20, bottom:30, left:40 };
            const gW = W - pad.left - pad.right;
            const gH = H - pad.top - pad.bottom;

            // Grid lines
            ctx.strokeStyle = 'rgba(227,232,238,0.6)';
            ctx.lineWidth = 1;
            for(let i = 0; i <= 4; i++){
                const y = pad.top + (gH / 4) * i;
                ctx.beginPath(); ctx.moveTo(pad.left, y); ctx.lineTo(pad.left + gW, y); ctx.stroke();
            }

            // Axes
            ctx.strokeStyle = '#e3e8ee';
            ctx.lineWidth = 1.5;
            ctx.beginPath();
            ctx.moveTo(pad.left, pad.top);
            ctx.lineTo(pad.left, pad.top + gH);
            ctx.lineTo(pad.left + gW, pad.top + gH);
            ctx.stroke();

            // Labels
            ctx.fillStyle = '#8792a2';
            ctx.font = '500 10px Inter, sans-serif';
            ctx.fillText('Cost', pad.left + 4, pad.top - 6);
            ctx.textAlign = 'right';
            ctx.fillText('Scale →', pad.left + gW, pad.top + gH + 18);
            ctx.textAlign = 'left';

            const steps = Math.floor(100 * state.progress);

            if(type === 'compare'){
                // Draw both curves (pass isCompare=true for label positioning)
                drawCurve(ctx, 'address', pad, gW, gH, steps, true);
                drawCurve(ctx, 'search', pad, gW, gH, steps, true);

                // Shaded gap between curves
                if(steps > 20){
                    ctx.globalAlpha = 0.05;
                    ctx.beginPath();
                    for(let i = 0; i <= steps; i++){
                        const t = i / 100;
                        const x = pad.left + t * gW;
                        if(i === 0) ctx.moveTo(x, searchY(t, pad, gH));
                        else ctx.lineTo(x, searchY(t, pad, gH));
                    }
                    for(let i = steps; i >= 0; i--){
                        const t = i / 100;
                        ctx.lineTo(pad.left + t * gW, addressY(pad, gH));
                    }
                    ctx.closePath();
                    ctx.fillStyle = '#F56493';
                    ctx.fill();
                    ctx.globalAlpha = 1;
                }

                // Savings label — centered in the gap at 70% along x
                if(state.progress > 0.65){
                    const lx = pad.left + gW * 0.7;
                    const sY = searchY(0.7, pad, gH);
                    const aY = addressY(pad, gH);
                    const midY = (sY + aY) / 2 + 4;
                    ctx.globalAlpha = Math.min((state.progress - 0.65) * 3, 1);
                    ctx.font = '700 12px Inter, sans-serif';
                    ctx.fillStyle = '#F56493';
                    ctx.textAlign = 'center';
                    ctx.fillText('98% savings', lx, midY);
                    ctx.textAlign = 'left';
                    ctx.globalAlpha = 1;
                }
            } else {
                drawCurve(ctx, type, pad, gW, gH, steps, false);
            }

            // Dot at leading edge
            if(steps > 0 && type !== 'compare'){
                const t = steps / 100;
                const x = pad.left + t * gW;
                let y;
                if(type === 'search'){
                    y = searchY(t, pad, gH);
                    ctx.fillStyle = '#F56493';
                } else {
                    y = addressY(pad, gH);
                    ctx.fillStyle = '#1a9e82';
                }
                ctx.beginPath(); ctx.arc(x, y, 4, 0, Math.PI * 2); ctx.fill();
            }

            if(state.progress < 1){
                state.progress += 0.018;
                if(state.progress > 1) state.progress = 1;
                requestAnimationFrame(draw);
            }
        }

        /* Curve math helpers — address line sits at 88% down (low cost) */
        function searchY(t, pad, gH){ return pad.top + gH - (t * t * 0.85 + t * 0.1) * gH; }
        function addressY(pad, gH){ return pad.top + gH * 0.88; }

        function drawCurve(ctx, curveType, pad, gW, gH, steps, isCompare){
            const color = curveType === 'search' ? '#F56493' : '#1a9e82';
            const yFn = curveType === 'search'
                ? (t) => searchY(t, pad, gH)
                : () => addressY(pad, gH);

            // Line
            ctx.lineWidth = 2.5;
            ctx.strokeStyle = color;
            ctx.beginPath();
            for(let i = 0; i <= steps; i++){
                const t = i / 100;
                const x = pad.left + t * gW;
                const y = yFn(t);
                if(i === 0) ctx.moveTo(x, y); else ctx.lineTo(x, y);
            }
            ctx.stroke();

            // Area fill
            if(steps > 0){
                ctx.globalAlpha = 0.06;
                ctx.beginPath();
                for(let i = 0; i <= steps; i++){
                    const t = i / 100;
                    const x = pad.left + t * gW;
                    if(i === 0) ctx.moveTo(x, yFn(t)); else ctx.lineTo(x, yFn(t));
                }
                ctx.lineTo(pad.left + (steps/100) * gW, pad.top + gH);
                ctx.lineTo(pad.left, pad.top + gH);
                ctx.closePath();
                ctx.fillStyle = color;
                ctx.fill();
                ctx.globalAlpha = 1;
            }

            // Label — position differently in compare mode to avoid overlap
            if(steps > 50){
                ctx.font = '600 11px Inter, sans-serif';
                ctx.fillStyle = color;
                if(curveType === 'search'){
                    // Place label above the curve at ~40% along x
                    const lx = pad.left + gW * 0.35;
                    const ly = searchY(0.35, pad, gH) - 12;
                    ctx.fillText('O(n) — scales with size', lx, isCompare ? ly : ly);
                } else {
                    // Place label just above the flat line at ~55% along x
                    const lx = pad.left + gW * 0.45;
                    const ly = addressY(pad, gH) - 10;
                    ctx.fillText('O(1) — constant cost', lx, ly);
                }
            }
        }

        draw();
        window.addEventListener('resize', () => { if(state.progress >= 1){ state.progress = 1; draw(); } });
    }
})();

/* ========================================================
   TOC — Expandable sections
   ======================================================== */
(function(){
    document.querySelectorAll('.toc-section__header').forEach(header => {
        header.addEventListener('click', () => {
            const section = header.parentElement;
            const wasOpen = section.classList.contains('is-open');
            // Close all
            document.querySelectorAll('.toc-section').forEach(s => s.classList.remove('is-open'));
            // Toggle
            if(!wasOpen) section.classList.add('is-open');
        });
    });

    // Auto-open first on scroll
    const tocMockup = document.querySelector('.toc-mockup');
    if(tocMockup){
        const io = new IntersectionObserver((entries) => {
            entries.forEach(e => {
                if(e.isIntersecting){
                    setTimeout(() => {
                        const first = document.querySelector('.toc-section');
                        if(first) first.classList.add('is-open');
                    }, 600);
                    io.unobserve(tocMockup);
                }
            });
        }, { threshold: 0.2 });
        io.observe(tocMockup);
    }

    // Auto-cycle through TOC sections
    let tocCycleIdx = 0;
    const tocSections = document.querySelectorAll('.toc-section');
    if(tocSections.length > 0){
        setInterval(() => {
            // Only cycle if mockup is in viewport
            const rect = tocMockup.getBoundingClientRect();
            if(rect.top < window.innerHeight && rect.bottom > 0){
                tocCycleIdx = (tocCycleIdx + 1) % tocSections.length;
                tocSections.forEach(s => s.classList.remove('is-open'));
                tocSections[tocCycleIdx].classList.add('is-open');
            }
        }, 4000);
    }
})();

/* ========================================================
   iPUB ANATOMY — Interactive sidebar
   ======================================================== */
(function(){
    const data = {
        'chapters': {
            label: 'Chapters',
            title: 'Narrative + Framework',
            desc: 'The argument. Proprietary business frameworks taught through guided discovery. You read to understand — your AI reads to process. Each chapter builds on the last, creating a compounding knowledge architecture.'
        },
        'appendix-a': {
            label: 'Appendix A — Always Included',
            title: 'The Standard',
            desc: 'The open specification. Machine-readable architecture your AI uses to classify, address, and govern organizational knowledge. In Mach 1 Business, this is the complete Universal Cognitive Architecture Standard.'
        },
        'appendix-b': {
            label: 'Appendix B — Always Included',
            title: 'The Installer or Wake Word',
            desc: 'Machine-executable logic. In the full library, this is the guided extraction sequence. In Mach 1 Business, it\'s the Summon Starling protocol — upload the book, type "Starling," and activate your AI Chief of Staff.'
        },
        'appendix-c': {
            label: 'Appendix C — When Applicable',
            title: 'The Worked Example',
            desc: 'A complete reference implementation. Shows what the output looks like when the installer runs against real organizational data. Not every iPub includes one — but when it does, it\'s the fastest path to understanding.'
        }
    };

    const items = document.querySelectorAll('.ipub-sidebar__item');
    const content = document.getElementById('ipubContent');
    let cycleTimer;

    function show(key){
        items.forEach(i => i.classList.remove('is-active'));
        document.querySelector(`[data-ipub="${key}"]`).classList.add('is-active');
        const d = data[key];
        content.innerHTML = `
            <span class="ipub-content__label">${d.label}</span>
            <h3 class="ipub-content__title">${d.title}</h3>
            <p class="ipub-content__desc">${d.desc}</p>
            <div class="ipub-format">
                <span class="ipub-format__icon">📚</span>
                <span class="ipub-format__text">Format: <span>iPub</span> — read it, load it, run it</span>
            </div>
        `;
    }

    items.forEach(item => {
        item.addEventListener('click', () => {
            show(item.dataset.ipub);
            clearInterval(cycleTimer);
            startCycle();
        });
    });

    // Initial
    show('chapters');

    // Auto-cycle
    const keys = Object.keys(data);
    let idx = 0;
    function startCycle(){
        cycleTimer = setInterval(() => {
            const mockup = document.querySelector('.ipub-mockup');
            const rect = mockup.getBoundingClientRect();
            if(rect.top < window.innerHeight && rect.bottom > 0){
                idx = (idx + 1) % keys.length;
                show(keys[idx]);
            }
        }, 4000);
    }
    startCycle();
})();

</script>
