---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Starling Workspace — Starling AIX" description="Starling Workspace is where your Domain Language Model lives. An AI work surface with your entire Org Brain behind it.">

<!-- ── Hero ──────────────────────────────────────────────────── -->
<section style="position:relative;overflow:hidden;padding:7rem 0 5rem;background:#ffffff;border-bottom:1px solid rgba(0,0,0,0.07);">
  <div style="position:absolute;inset:0;pointer-events:none;background-image:linear-gradient(rgba(0,0,0,0.018) 1px,transparent 1px),linear-gradient(90deg,rgba(0,0,0,0.018) 1px,transparent 1px);background-size:72px 72px;"></div>
  <div style="position:absolute;inset:0;pointer-events:none;background:radial-gradient(ellipse 50% 40% at 50% 0%,rgba(224,100,28,0.04) 0%,transparent 65%);"></div>
  <div class="container" style="position:relative;z-index:1;">
    <div style="display:grid;grid-template-columns:1fr;gap:3rem;align-items:center;" class="platform-hero-grid">
      <div>
        <div class="stag stag-o fade-up" data-delay="0" style="margin-bottom:1.5rem;">Starling AIX · Workspace</div>
        <h1 class="fade-up" data-delay="0.08"
            style="font-family:'Bitter',Georgia,serif;font-weight:700;font-size:clamp(3rem,8vw,5rem);margin:0 0 1.5rem;max-width:620px;line-height:1;letter-spacing:-0.04em;color:#0c0c0c;">
          Work that<br/><em style="color:#e0641c;font-style:italic;">remembers.</em>
        </h1>
        <p class="fade-up" data-delay="0.15"
           style="font-family:'Inter Tight',system-ui,sans-serif;font-size:1.05rem;color:#4a4a4a;line-height:1.75;max-width:480px;margin:0 0 2.5rem;">
          Starling Workspace is where your Domain Language Model lives — an AI work surface with your entire Org Brain behind it. Every deliverable you produce makes the next one better.
        </p>
        <div class="fade-up" data-delay="0.2" style="display:flex;gap:0.75rem;flex-wrap:wrap;align-items:center;">
          <a href="#beta" class="btn btn-org">Request Beta Access →</a>
          <span style="font-family:'Inter Tight',sans-serif;font-size:0.85rem;color:#888;">Beta opens March 2026. Free for 14 days.</span>
        </div>
      </div>
      <!-- Platform status panel -->
      <div class="fade-up platform-status-panel" data-delay="0.14">
        <div class="wide-mock" style="margin-top:0;">
          <div class="mock-bar">
            <span class="mock-dot r"></span><span class="mock-dot y"></span><span class="mock-dot g"></span>
            <span style="font-family:'JetBrains Mono',monospace;font-size:0.65rem;color:#3f3f46;margin-left:0.6rem;">starling.workspace — status</span>
            <span style="font-family:'JetBrains Mono',monospace;font-size:0.6rem;color:#34d399;margin-left:auto;padding-right:0.75rem;">● All systems</span>
          </div>
          <div style="padding:1.25rem;">
            {[
              { label: 'Org Brain', val: '28 memories loaded', color: '#60a5fa', dot: '#60a5fa' },
              { label: 'DLM', val: 'Active · Claude 3.7', color: '#a78bfa', dot: '#a78bfa' },
              { label: 'UCA', val: '11 cognates indexed', color: '#2dd4bf', dot: '#2dd4bf' },
              { label: 'MCP', val: 'Connected', color: '#34d399', dot: '#34d399' },
            ].map(({ label, val, color, dot }) => (
              <div style="display:flex;align-items:center;gap:0.75rem;padding:0.55rem 0;border-bottom:1px solid rgba(255,255,255,0.04);">
                <span style={`width:6px;height:6px;border-radius:50%;background:${dot};flex-shrink:0;box-shadow:0 0 6px ${dot}66;`}></span>
                <span style="font-family:'JetBrains Mono',monospace;font-size:0.68rem;color:#71717a;min-width:72px;">{label}</span>
                <span style={`font-family:'JetBrains Mono',monospace;font-size:0.68rem;color:${color};`}>{val}</span>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ── DLM Pipeline Section ───────────────────────────────────── -->
<section style="background:#f2f1ee;padding:5rem 0;border-top:1px solid rgba(0,0,0,0.07);">
  <div class="container">
    <div class="feat-header">
      <div>
        <div class="stag stag-o fade-up" data-delay="0" style="margin-bottom:1.25rem;">1.0 · Your Domain Language Model</div>
        <h2 class="feat-h2 fade-up" data-delay="0.06">
          The model processes.<br/>The domain remembers.
        </h2>
      </div>
      <div>
        <p class="feat-body fade-up" data-delay="0.1">
          Workspace assembles your DLM on every request. It loads the right organisational context from your Org Brain, routes it through semantic addressing, and delivers intelligence no general-purpose AI can match.
        </p>
        <p class="feat-body fade-up" data-delay="0.13" style="margin-bottom:0;">
          Four multiplicative factors. Remove any one and the product is zero.
        </p>
      </div>
    </div>

    <!-- DLM pipeline mock — dark for contrast -->
    <div class="wide-mock fade-up" data-delay="0.18">
      <div class="mock-bar">
        <span class="mock-dot r"></span><span class="mock-dot y"></span><span class="mock-dot g"></span>
        <span style="font-family:'JetBrains Mono',monospace;font-size:0.7rem;color:#3f3f46;margin-left:0.75rem;">DLM Assembly — Request Pipeline</span>
      </div>
      <div style="display:grid;grid-template-columns:1fr;gap:1px;background:rgba(255,255,255,0.05);" class="dlm-pipeline-grid">
        {[
          { badge: 'LLM',      color:'#60a5fa', bg:'rgba(96,165,250,0.04)',   border:'rgba(96,165,250,0.15)',  title: 'Large Language Model',       desc: 'Stateless processing. Reads, reasons, advises — then forgets. Powerful, but starts from zero every time.', status: 'Claude 3.7', statusColor:'#34d399' },
          { badge: 'MCP',      color:'#a78bfa', bg:'rgba(167,139,250,0.04)',  border:'rgba(167,139,250,0.15)', title: 'Model Context Protocol',     desc: "Anthropic's open standard for connecting AI to external data. The pipe — not the water. Makes the model swappable.", status: 'Connected', statusColor:'#34d399' },
          { badge: 'UCA',      color:'#2dd4bf', bg:'rgba(45,212,191,0.04)',   border:'rgba(45,212,191,0.15)',  title: 'Universal Cognitive Architecture', desc: 'Eleven cognates. Four memory tiers. Semantic addressing gives business knowledge permanent coordinates — O(1) lookup, not O(n) search.', status: 'Active', statusColor:'#2dd4bf' },
          { badge: 'ORG BRAIN',color:'#34d399', bg:'rgba(52,211,153,0.04)',   border:'rgba(52,211,153,0.15)',  title: 'Sovereign Repository',       desc: 'Values, strategy, positioning, operations, culture — governed in Notion. You own it. It travels with you. No vendor lock-in.', status: '28 Memories', statusColor:'#34d399' },
        ].map(({ badge, color, bg, border, title, desc, status, statusColor }) => (
          <div style={`background:#050505;padding:1.5rem 2rem;border-left:3px solid ${border};`}>
            <div style="display:flex;align-items:center;gap:1rem;margin-bottom:0.5rem;">
              <span style={`font-family:'JetBrains Mono',monospace;font-size:0.72rem;font-weight:600;color:${color};min-width:80px;`}>{badge}</span>
              <span style="font-size:0.875rem;color:#e4e4e7;font-weight:500;flex:1;">{title}</span>
              <span style={`margin-left:auto;font-family:'JetBrains Mono',monospace;font-size:0.65rem;color:${statusColor};display:flex;align-items:center;gap:0.35rem;flex-shrink:0;`}>
                <span style={`width:5px;height:5px;border-radius:50%;background:${statusColor};`}></span>
                {status}
              </span>
            </div>
            <p style="font-size:0.82rem;color:#52525b;line-height:1.65;margin:0;">{desc}</p>
          </div>
        ))}
      </div>
      <div style="padding:1.25rem 2rem;border-top:1px solid rgba(255,255,255,0.06);display:flex;align-items:center;gap:1rem;flex-wrap:wrap;">
        <span style="font-size:0.8rem;color:#71717a;">LLM × MCP × UCA × Org Brain</span>
        <span class="badge badge-accent" style="margin-left:auto;">= Your DLM</span>
      </div>
    </div>

  </div>
</section>

<!-- ── Image Split: Architecture ──────────────────────────────── -->
<section style="border-top:1px solid rgba(0,0,0,0.07);overflow:hidden;">
  <div class="img-split reverse">
    <div class="img-split-photo">
      <img src="/images/abstract-city-building-shadows.jpg" alt="Enterprise-scale organizational intelligence architecture" />
      <div class="img-split-overlay">
        <div style="display:flex;gap:0.5rem;flex-wrap:wrap;">
          {[['Build once','Deploy anywhere'],['Your data','Your repo'],['Any LLM','Swappable']].map(([a,b]) => (
            <div style="background:rgba(0,0,0,0.75);border:1px solid rgba(255,255,255,0.1);border-radius:8px;padding:0.5rem 0.75rem;">
              <p style="font-size:0.78rem;color:#fff;font-weight:600;margin:0;line-height:1.2;">{a}</p>
              <p style="font-family:'JetBrains Mono',monospace;font-size:0.58rem;color:#71717a;margin:0.1rem 0 0;">{b}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
    <div class="img-split-content" style="padding:4rem 2.5rem;">
      <p class="feat-num" style="margin-bottom:0.75rem;">2.0 · Architecture</p>
      <h2 class="feat-h2" style="margin-bottom:1.25rem;">Build once.<br/>Deploy anywhere.</h2>
      <p style="font-family:'Inter Tight',system-ui,sans-serif;font-size:0.95rem;color:#4a4a4a;line-height:1.8;margin:0 0 2rem;">
        Three layers. One stores. One translates. One thinks. You own the first two. The third is stateless and swappable. Claude today. GPT tomorrow. Gemini next week. The intelligence isn't in the model — it's in your Org Brain.
      </p>
      <div style="display:flex;flex-direction:column;gap:0.75rem;margin-bottom:2rem;">
        {[
          { num:'01', label:'Store', sub:'Org Brain · Notion', color:'#60a5fa', body:'Your sovereign knowledge repository. PMNs, AMNs, and LMNs — governed, versioned, and human-owned.' },
          { num:'02', label:'Translate', sub:'MCP Server · Starling', color:'#a78bfa', body:'Reads your Org Brain, assembles context, injects it into any LLM. Automatic memory management.' },
          { num:'03', label:'Think', sub:'Any LLM · Your Choice', color:'#2dd4bf', body:'Switch providers without losing a single memory. The intelligence is yours.' },
        ].map(({ num, label, sub, color, body }) => (
          <div style={`display:flex;gap:1rem;align-items:flex-start;padding:0.875rem 1rem;border:1px solid rgba(0,0,0,0.08);border-left:3px solid ${color};border-radius:0 8px 8px 0;background:rgba(0,0,0,0.02);`}>
            <span style={`font-family:'JetBrains Mono',monospace;font-size:0.62rem;color:${color};flex-shrink:0;padding-top:0.2rem;`}>{num}</span>
            <div>
              <div style="display:flex;align-items:center;gap:0.5rem;margin-bottom:0.2rem;">
                <span style={`font-family:'JetBrains Mono',monospace;font-size:0.72rem;color:${color};font-weight:600;text-transform:uppercase;letter-spacing:0.06em;`}>{label}</span>
                <span style="font-family:'JetBrains Mono',monospace;font-size:0.62rem;color:#888;">{sub}</span>
              </div>
              <p style="font-family:'Inter Tight',sans-serif;font-size:0.82rem;color:#4a4a4a;line-height:1.6;margin:0;">{body}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<!-- ── Platform Features ──────────────────────────────────────── -->
<section style="background:#ffffff;padding:5rem 0;position:relative;overflow:hidden;border-top:1px solid rgba(0,0,0,0.07);">
  <div class="section-grid-accent"></div>
  <div class="container" style="position:relative;z-index:1;">
    <div class="feat-header">
      <div>
        <div class="stag stag-g fade-up" data-delay="0" style="margin-bottom:1.25rem;">3.0 · Inside the Platform</div>
        <h2 class="feat-h2 fade-up" data-delay="0.06">
          Two modes.<br/>One intelligence layer.
        </h2>
      </div>
      <div>
        <p class="feat-body fade-up" data-delay="0.1">
          Workspace operates in two modes — Excavation for building the Org Brain, Document for putting it to work. Both connect to the same memory system through the same AI Chief of Staff.
        </p>
      </div>
    </div>

    <!-- Feature mockup — dark for contrast -->
    <div class="wide-mock fade-up" data-delay="0.16">
      <div class="mock-bar">
        <span class="mock-dot r"></span><span class="mock-dot y"></span><span class="mock-dot g"></span>
        <span style="font-family:'JetBrains Mono',monospace;font-size:0.7rem;color:#3f3f46;margin-left:0.75rem;">Starling Workspace</span>
        <div style="margin-left:auto;display:flex;gap:0.5rem;">
          <span class="mock-chip teal">Document Mode</span>
          <span class="mock-chip dim">Excavation Mode</span>
        </div>
      </div>
      <div style="display:grid;grid-template-columns:1fr;gap:0;" class="feature-panels">

        <div style="padding:1.75rem 2rem;border-bottom:1px solid rgba(255,255,255,0.05);background:rgba(96,165,250,0.02);">
          <div style="display:flex;align-items:center;gap:0.75rem;margin-bottom:1rem;">
            <span class="badge badge-accent">Excavation Mode</span>
            <span style="font-family:'JetBrains Mono',monospace;font-size:0.62rem;color:#3f3f46;">12 guided installers</span>
          </div>
          <p style="font-size:0.875rem;color:#71717a;line-height:1.75;margin:0 0 1rem;">
            Guided installers excavate organisational knowledge through structured conversation. Your answers become governed memory — permanently addressed, sovereign, and versioned.
          </p>
          <div style="display:flex;flex-direction:column;gap:0.4rem;">
            {['ID10 → Value-Centric Design', 'MA10 → Open Road Canvas', 'IN10 → Value Mapping', 'BR10 → Impact Branding'].map(item => (
              <div class="mock-chip" style="font-size:0.68rem;">{item}</div>
            ))}
          </div>
        </div>

        <div style="padding:1.75rem 2rem;background:rgba(45,212,191,0.02);">
          <div style="display:flex;align-items:center;gap:0.75rem;margin-bottom:1rem;">
            <span class="badge badge-teal">Document Mode</span>
            <span style="font-family:'JetBrains Mono',monospace;font-size:0.62rem;color:#3f3f46;">Full Org Brain context</span>
          </div>
          <p style="font-size:0.875rem;color:#71717a;line-height:1.75;margin:0 0 1rem;">
            Work on deliverables with your entire Org Brain as context. Semantic addresses appear as clickable chips — tap{' '}
            <span style="font-family:'JetBrains Mono',monospace;font-size:0.75rem;color:#60a5fa;background:rgba(96,165,250,0.1);padding:0.15rem 0.4rem;border-radius:4px;">MA20</span>
            {' '}mid-thread to see your Competitive Position without leaving the session.
          </p>
          <div style="padding:1rem;background:rgba(255,255,255,0.02);border:1px solid rgba(255,255,255,0.06);border-radius:8px;font-size:0.8rem;color:#52525b;line-height:1.7;">
            Referenced:{' '}
            <span class="mock-chip" style="display:inline-flex;font-size:0.65rem;">MA20</span>{' '}
            <span class="mock-chip violet" style="display:inline-flex;font-size:0.65rem;">ID20</span>{' '}
            <span class="mock-chip teal" style="display:inline-flex;font-size:0.65rem;">BR20</span>
          </div>
        </div>

      </div>
    </div>

  </div>
</section>

<!-- ── Compounding Loop ───────────────────────────────────────── -->
<section style="background:#f2f1ee;padding:5rem 0;border-top:1px solid rgba(0,0,0,0.07);">
  <div class="container">
    <div class="feat-header">
      <div>
        <div class="stag stag-o fade-up" data-delay="0" style="margin-bottom:1.25rem;">4.0 · The Compounding Loop</div>
        <h2 class="feat-h2 fade-up" data-delay="0.06">
          Work is your best memory.
        </h2>
      </div>
      <div>
        <p class="feat-body fade-up" data-delay="0.1">
          The page you just shipped is better context than the strategy doc it came from. Workspace treats every deliverable as memory. The campaign brief that shipped becomes context for the next one. That's the compounding asset — not the AI.
        </p>
      </div>
    </div>

    <div style="display:grid;grid-template-columns:1fr;gap:0;border:1px solid rgba(0,0,0,0.08);border-radius:12px;overflow:hidden;background:#ffffff;" class="fade-up loop-grid" data-delay="0.16">
      {[
        { num:'01', title:'Create a Session', body:'Open a project, create a session. The system already knows you. Your Org Brain loads automatically.', color:'#60a5fa' },
        { num:'02', title:'Add Context', body:'The right knowledge loads. Persistent memory, active work, and learned patterns — all through semantic addressing.', color:'#a78bfa' },
        { num:'03', title:'Generate Artifact', body:'Super content, from the jump. Every artifact becomes memory for the next one. The system gets smarter with each deliverable.', color:'#2dd4bf' },
      ].map(({ num, title, body, color }, i) => (
        <div style={`padding:2rem;background:#ffffff;border-left:3px solid ${color}55;${i < 2 ? 'border-bottom:1px solid rgba(0,0,0,0.08);' : ''}`}>
          <div style="display:flex;align-items:flex-start;gap:1.25rem;">
            <span style={`font-family:'JetBrains Mono',monospace;font-size:1rem;color:${color};flex-shrink:0;font-weight:700;`}>{num}</span>
            <div>
              <h3 style="font-family:'Inter Tight',sans-serif;font-size:1rem;font-weight:600;color:#0c0c0c;margin:0 0 0.35rem;letter-spacing:-0.01em;">{title}</h3>
              <p style="font-family:'Inter Tight',sans-serif;font-size:0.875rem;color:#4a4a4a;line-height:1.7;margin:0;">{body}</p>
            </div>
          </div>
        </div>
      ))}
    </div>

  </div>
</section>

<hr style="border:none;border-top:1px solid rgba(0,0,0,0.08);" />

<!-- ── Beta CTA ───────────────────────────────────────────────── -->
<section id="beta" style="background:#ffffff;padding:5rem 0;">
  <div class="container">
    <div class="cta-row">
      <div>
        <div class="stag stag-o fade-up" data-delay="0" style="margin-bottom:1.25rem;">Beta · March 2026</div>
        <h2 class="feat-h2 fade-up" data-delay="0.06" style="margin-bottom:1rem;">
          Be first in the door.
        </h2>
        <p class="feat-body fade-up" data-delay="0.1">
          Beta opens March 2026. Free for 14 days, $99/month after that. Early access includes full Org Brain setup support and direct access to the Starling team.
        </p>
        <div class="feat-ctas fade-up" data-delay="0.14">
          <form id="beta-form" style="display:flex;gap:0.75rem;flex-wrap:wrap;">
            <input type="email" name="email" placeholder="Email address" required class="input-light" style="flex:1;min-width:220px;max-width:300px;" />
            <button type="submit" class="btn btn-org">Request Invite</button>
          </form>
          <p style="font-family:'Inter',sans-serif;font-size:0.78rem;color:#888;margin:0.5rem 0 0;">We'll email when it's ready. No spam.</p>
        </div>
      </div>
      <div class="card-light fade-up" data-delay="0.12" style="padding:2.5rem;">
        <p class="feat-num" style="margin-bottom:1.25rem;">What's included in beta</p>
        <div style="display:flex;flex-direction:column;gap:0.85rem;">
          {[
            'Full Starling Workspace — both modes',
            'Org Brain setup guide + 9-week curriculum access',
            'Starling OS prompt templates for Claude/ChatGPT',
            'Your first 15 Constitutional Memories in week one',
            '1-on-1 onboarding session with the Starling team',
          ].map(item => (
            <div class="check-item">{item}</div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>

</Layout>

<style>
  .platform-status-panel { display: none; }
  @media(min-width: 768px) {
    .platform-hero-grid    { grid-template-columns: 1fr 1fr !important; align-items: center; }
    .platform-status-panel { display: block; }
    .dlm-pipeline-grid     { grid-template-columns: repeat(2, 1fr) !important; }
    .feature-panels        { grid-template-columns: repeat(2, 1fr) !important; }
    .loop-grid             { grid-template-columns: repeat(3, 1fr) !important; }
  }
  @media(min-width: 768px) {
    .feature-panels > div { border-bottom: none !important; border-right: 1px solid rgba(255,255,255,0.05); }
    .feature-panels > div:last-child { border-right: none; }
    .loop-grid > div { border-bottom: none !important; border-right: 1px solid rgba(0,0,0,0.08); }
    .loop-grid > div:last-child { border-right: none; }
    .img-split-content { padding: 5rem 4rem !important; }
  }
</style>

<script>
  document.getElementById('beta-form')?.addEventListener('submit', e => {
    e.preventDefault();
    const btn = (e.target as HTMLFormElement).querySelector('button') as HTMLButtonElement;
    btn.textContent = 'You\'re on the list!';
    btn.disabled = true;
    setTimeout(() => { btn.textContent = 'Request Invite'; btn.disabled = false; (e.target as HTMLFormElement).reset(); }, 3500);
  });
</script>
