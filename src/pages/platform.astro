---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Starling Workspace — Starling AIX" description="Starling Workspace is where your Domain Language Model lives. An AI work surface with your entire Org Brain behind it.">

<!-- ── Hero ──────────────────────────────────────────────────── -->
<section style="position:relative;overflow:hidden;padding:7rem 0 6rem;" class="grid-bg">
  <div class="hero-glow"></div>
  <span class="corner-mark cm-tl">+</span>
  <span class="corner-mark cm-tr">+</span>
  <div class="container" style="position:relative;z-index:1;">

    <p class="feat-num fade-up" data-delay="0">Starling AIX · Workspace</p>

    <h1 class="heading-display fade-up" data-delay="0.08"
        style="font-size:clamp(3rem,8vw,5.5rem);margin:0 0 1.5rem;max-width:820px;letter-spacing:-0.04em;">
      Work that <em>remembers.</em>
    </h1>

    <p class="fade-up" data-delay="0.15"
       style="font-size:1.05rem;color:#71717a;line-height:1.75;max-width:540px;margin:0 0 2.5rem;">
      Starling Workspace is where your Domain Language Model lives — an AI work surface with your entire Org Brain behind it. Every deliverable you produce makes the next one better.
    </p>

    <div class="fade-up" data-delay="0.2" style="display:flex;gap:0.75rem;flex-wrap:wrap;align-items:center;">
      <a href="#beta" class="btn btn-primary">Request Beta Access →</a>
      <span style="font-size:0.85rem;color:#3f3f46;">Beta opens March 2026. Free for 14 days.</span>
    </div>

  </div>
</section>

<div class="divider"></div>

<!-- ── DLM Section ───────────────────────────────────────────── -->
<section class="feat-section">
  <div class="container">
    <div class="feat-header">
      <!-- Left -->
      <div>
        <p class="feat-num fade-up" data-delay="0">1.0 · Your Domain Language Model</p>
        <h2 class="feat-h2 heading-display fade-up" data-delay="0.06">
          The model processes. The domain remembers.
        </h2>
      </div>
      <!-- Right -->
      <div>
        <p class="feat-body fade-up" data-delay="0.1">
          Workspace assembles your DLM on every request. It loads the right organisational context from your Org Brain, routes it through semantic addressing, and delivers intelligence no general-purpose AI can match.
        </p>
        <p class="feat-body fade-up" data-delay="0.13" style="margin-bottom:0;">
          Four multiplicative factors. Remove any one and the product is zero.
        </p>
      </div>
    </div>

    <!-- DLM wide mockup -->
    <div class="wide-mock fade-up" data-delay="0.18">
      <div class="mock-bar">
        <span class="mock-dot r"></span><span class="mock-dot y"></span><span class="mock-dot g"></span>
        <span style="font-family:'JetBrains Mono',monospace;font-size:0.7rem;color:#3f3f46;margin-left:0.75rem;">DLM Assembly — Request Pipeline</span>
      </div>
      <div style="padding:2rem;display:grid;grid-template-columns:1fr;gap:1px;background:rgba(255,255,255,0.05);" class="dlm-pipeline-grid">
        {[
          { badge: 'LLM', title: 'Large Language Model', desc: 'Stateless processing. Reads, reasons, advises — then forgets. Powerful, but starts from zero every time.', status: 'Claude 3.7', dot: '#28c840' },
          { badge: 'MCP', title: 'Model Context Protocol', desc: 'Anthropic\'s open standard for connecting AI to external data. The pipe — not the water. Makes the model swappable.', status: 'Connected', dot: '#28c840' },
          { badge: 'UCA', title: 'Universal Cognitive Architecture', desc: 'Eleven cognates. Four memory tiers. Semantic addressing gives business knowledge permanent coordinates — O(1) lookup, not O(n) search.', status: 'Active', dot: '#f97316' },
          { badge: 'ORG BRAIN', title: 'Sovereign Repository', desc: 'Values, strategy, positioning, operations, culture — governed in Notion. You own it. It travels with you. No vendor lock-in.', status: '28 Memories', dot: '#f97316' },
        ].map(({ badge, title, desc, status, dot }) => (
          <div style="background:#050505;padding:1.5rem 2rem;display:grid;gap:0;" class="dlm-row-inner">
            <div style="display:flex;align-items:center;gap:1rem;margin-bottom:0.5rem;">
              <span class="badge" style="flex-shrink:0;">{badge}</span>
              <span style="font-size:0.875rem;color:#e4e4e7;font-weight:500;">{title}</span>
              <span style={`margin-left:auto;font-family:'JetBrains Mono',monospace;font-size:0.68rem;color:${dot};display:flex;align-items:center;gap:0.35rem;`}>
                <span style={`width:6px;height:6px;border-radius:50%;background:${dot};flex-shrink:0;`}></span>
                {status}
              </span>
            </div>
            <p style="font-size:0.825rem;color:#52525b;line-height:1.65;margin:0;padding-left:0;">{desc}</p>
          </div>
        ))}
      </div>
      <div style="padding:1.25rem 2rem;border-top:1px solid rgba(255,255,255,0.06);display:flex;align-items:center;gap:1rem;">
        <span style="font-size:0.8rem;color:#71717a;">LLM × MCP × UCA × Org Brain</span>
        <span class="badge" style="margin-left:auto;">= Your DLM</span>
      </div>
    </div>

  </div>
</section>

<div class="divider"></div>

<!-- ── Architecture ───────────────────────────────────────────── -->
<section class="feat-section" style="background:#030303;">
  <div class="container">
    <div class="feat-header">
      <!-- Left -->
      <div>
        <p class="feat-num fade-up" data-delay="0">2.0 · Architecture</p>
        <h2 class="feat-h2 heading-display fade-up" data-delay="0.06">
          Build once. Deploy anywhere.
        </h2>
      </div>
      <!-- Right -->
      <div>
        <p class="feat-body fade-up" data-delay="0.1">
          Three layers. One stores. One translates. One thinks. You own the first two. The third is stateless and swappable. Claude today. GPT tomorrow. Gemini next week.
        </p>
      </div>
    </div>

    <div style="display:grid;grid-template-columns:1fr;gap:1.5rem;" class="layers-grid">

      {[
        { num: '01', label: 'Store', sub: 'Org Brain · Notion', body: 'Your sovereign knowledge repository. Structured memories with semantic addresses. PMNs, AMNs, and LMNs — governed, versioned, and human-owned.' },
        { num: '02', label: 'Translate', sub: 'MCP Server · Starling', body: 'The orchestration layer. Reads your Org Brain, assembles context, injects it into any LLM. Automatic memory management and token budgeting.' },
        { num: '03', label: 'Think', sub: 'Any LLM · Your Choice', body: 'Claude today. GPT tomorrow. Gemini next week. The intelligence isn\'t in the model — it\'s in your Org Brain. Switch providers without losing a single memory.' },
      ].map(({ num, label, sub, body }, i) => (
        <div class="card fade-up" data-delay={`${i * 0.06}`} style="padding:2rem;display:flex;gap:1.5rem;align-items:flex-start;">
          <div style="flex-shrink:0;width:40px;height:40px;border-radius:8px;background:rgba(249,115,22,0.1);border:1px solid rgba(249,115,22,0.2);display:flex;align-items:center;justify-content:center;">
            <span style="font-family:'JetBrains Mono',monospace;font-size:0.65rem;color:#f97316;font-weight:600;">{num}</span>
          </div>
          <div>
            <div style="display:flex;align-items:center;gap:0.75rem;margin-bottom:0.5rem;">
              <h3 style="font-family:'JetBrains Mono',monospace;font-size:0.72rem;color:#f97316;letter-spacing:0.08em;text-transform:uppercase;margin:0;">{label}</h3>
              <span style="font-family:'JetBrains Mono',monospace;font-size:0.68rem;color:#3f3f46;">{sub}</span>
            </div>
            <p style="color:#a1a1aa;font-size:0.9rem;line-height:1.75;margin:0;">{body}</p>
          </div>
        </div>
      ))}

    </div>
  </div>
</section>

<div class="divider"></div>

<!-- ── Platform Features ──────────────────────────────────────── -->
<section class="feat-section" style="position:relative;" class="grid-bg">
  <div class="container">
    <div class="feat-header">
      <!-- Left -->
      <div>
        <p class="feat-num fade-up" data-delay="0">3.0 · Inside the Platform</p>
        <h2 class="feat-h2 heading-display fade-up" data-delay="0.06">
          Two modes. One intelligence layer.
        </h2>
      </div>
      <!-- Right -->
      <div>
        <p class="feat-body fade-up" data-delay="0.1">
          Workspace operates in two modes — Excavation for building the Org Brain, Document for putting it to work. Both connect to the same memory system through the same AI Chief of Staff.
        </p>
      </div>
    </div>

    <!-- Feature mockup -->
    <div class="wide-mock fade-up" data-delay="0.16">
      <div class="mock-bar">
        <span class="mock-dot r"></span><span class="mock-dot y"></span><span class="mock-dot g"></span>
        <span style="font-family:'JetBrains Mono',monospace;font-size:0.7rem;color:#3f3f46;margin-left:0.75rem;">Starling Workspace — Document Mode</span>
        <div style="margin-left:auto;display:flex;gap:0.5rem;">
          <span class="mock-chip">Document Mode</span>
          <span class="mock-chip dim">Excavation Mode</span>
        </div>
      </div>
      <div style="display:grid;grid-template-columns:1fr;gap:0;" class="feature-panels">

        <!-- Left panel: editor -->
        <div style="padding:1.75rem 2rem;border-bottom:1px solid rgba(255,255,255,0.05);">
          <div style="display:flex;align-items:center;gap:0.75rem;margin-bottom:1rem;">
            <span class="badge">Excavation Mode</span>
          </div>
          <p style="font-size:0.875rem;color:#71717a;line-height:1.75;margin:0 0 1rem;">
            Guided installers excavate organisational knowledge through structured conversation. Your answers become governed memory — permanently addressed, sovereign, and versioned.
          </p>
          <div style="display:flex;flex-direction:column;gap:0.5rem;">
            {['ID10 → Value-Centric Design', 'MA10 → Open Road Canvas', 'IN10 → Value Mapping', 'BR10 → Impact Branding'].map(item => (
              <div class="mock-chip" style="font-size:0.68rem;">{item}</div>
            ))}
          </div>
        </div>

        <!-- Right panel: inline refs -->
        <div style="padding:1.75rem 2rem;">
          <div style="display:flex;align-items:center;gap:0.75rem;margin-bottom:1rem;">
            <span class="badge">Document Mode</span>
          </div>
          <p style="font-size:0.875rem;color:#71717a;line-height:1.75;margin:0 0 1rem;">
            Work on deliverables with your entire Org Brain as context. Semantic addresses appear as clickable chips — tap{' '}
            <span style="font-family:'JetBrains Mono',monospace;font-size:0.75rem;color:#f97316;background:rgba(249,115,22,0.1);padding:0.15rem 0.4rem;border-radius:4px;">MA20</span>
            {' '}mid-thread to see your Competitive Position without leaving the session.
          </p>
          <div style="padding:1rem;background:rgba(255,255,255,0.02);border:1px solid rgba(255,255,255,0.06);border-radius:8px;font-size:0.8rem;color:#52525b;line-height:1.7;">
            Referenced: <span class="mock-chip" style="display:inline-flex;font-size:0.65rem;">MA20</span>{' '}
            <span class="mock-chip" style="display:inline-flex;font-size:0.65rem;">ID20</span>{' '}
            <span class="mock-chip" style="display:inline-flex;font-size:0.65rem;">BR20</span>
          </div>
        </div>

      </div>
    </div>

    <div style="display:grid;grid-template-columns:1fr;gap:1.25rem;margin-top:1.5rem;" class="features-grid">
      {[
        ['Inline References', 'Semantic addresses appear as clickable chips inline. Click to see the full memory without leaving the conversation.'],
        ['Capture Learning', 'Extract patterns from every project. Lessons learned become Learning Memories that compound over time.'],
      ].map(([title, body], i) => (
        <div class="card fade-up" data-delay={`${i * 0.06}`} style="padding:1.75rem;">
          <h3 style="font-size:0.95rem;color:#e4e4e7;font-weight:600;margin:0 0 0.5rem;">{title}</h3>
          <p style="color:#71717a;font-size:0.875rem;line-height:1.75;margin:0;">{body}</p>
        </div>
      ))}
    </div>

  </div>
</section>

<div class="divider"></div>

<!-- ── Workflow ───────────────────────────────────────────────── -->
<section class="feat-section">
  <div class="container">
    <div class="feat-header">
      <!-- Left -->
      <div>
        <p class="feat-num fade-up" data-delay="0">4.0 · The Compounding Loop</p>
        <h2 class="feat-h2 heading-display fade-up" data-delay="0.06">
          Work is your best <em>memory.</em>
        </h2>
      </div>
      <!-- Right -->
      <div>
        <p class="feat-body fade-up" data-delay="0.1">
          The page you just shipped is better context than the strategy doc it came from. Workspace treats every deliverable as memory. The campaign brief that shipped becomes context for the next one. That's the compounding asset — not the AI.
        </p>
      </div>
    </div>

    <div style="display:flex;flex-direction:column;gap:0;border:1px solid rgba(255,255,255,0.08);border-radius:12px;overflow:hidden;" class="fade-up" data-delay="0.16">
      {[
        ['01', 'Create a Session', 'Open a project, create a session. The system already knows you. Your Org Brain loads automatically.'],
        ['02', 'Add Context', 'The right knowledge loads. Persistent memory, active work, and learned patterns — all through semantic addressing.'],
        ['03', 'Generate Artifact', 'Super content, from the jump. Every artifact becomes memory for the next one. The system gets smarter with each deliverable.'],
      ].map(([num, title, body], i) => (
        <div style={`padding:1.75rem 2rem;background:#0a0a0a;${i < 2 ? 'border-bottom:1px solid rgba(255,255,255,0.06);' : ''}`}>
          <div style="display:flex;align-items:flex-start;gap:1.25rem;">
            <span style="font-family:'JetBrains Mono',monospace;font-size:0.75rem;color:#f97316;flex-shrink:0;padding-top:0.2rem;">{num}</span>
            <div>
              <h3 style="font-size:1rem;font-weight:600;color:#fff;margin:0 0 0.35rem;letter-spacing:-0.01em;">{title}</h3>
              <p style="font-size:0.875rem;color:#71717a;line-height:1.7;margin:0;">{body}</p>
            </div>
          </div>
        </div>
      ))}
    </div>

  </div>
</section>

<div class="divider"></div>

<!-- ── Beta CTA ───────────────────────────────────────────────── -->
<section id="beta" class="feat-section">
  <div class="container">
    <div class="cta-row">
      <div>
        <p class="feat-num fade-up" data-delay="0">Beta · March 2026</p>
        <h2 class="feat-h2 heading-display fade-up" data-delay="0.06" style="margin-bottom:1rem;">
          Be first in the door.
        </h2>
        <p class="feat-body fade-up" data-delay="0.1">
          Beta opens March 2026. Free for 14 days, $99/month after that. Early access includes full Org Brain setup support and direct access to the Starling team.
        </p>
        <div class="feat-ctas fade-up" data-delay="0.14">
          <form id="beta-form" style="display:flex;gap:0.75rem;flex-wrap:wrap;">
            <input type="email" name="email" placeholder="Email address" required class="input" style="flex:1;min-width:220px;max-width:300px;" />
            <button type="submit" class="btn btn-primary">Request Invite</button>
          </form>
          <p style="font-size:0.78rem;color:#3f3f46;margin:0.5rem 0 0;">We'll email when it's ready. No spam.</p>
        </div>
      </div>
      <div class="glass fade-up" data-delay="0.12" style="padding:2.5rem;">
        <p class="feat-num" style="margin-bottom:1.25rem;">What's included in beta</p>
        <div style="display:flex;flex-direction:column;gap:0.85rem;">
          {[
            'Full Starling Workspace — both modes',
            'Org Brain setup guide + 9-week curriculum access',
            'Starling OS prompt templates for Claude/ChatGPT',
            'Your first 15 Constitutional Memories in week one',
            '1-on-1 onboarding session with the Starling team',
          ].map(item => (
            <div class="check-item">{item}</div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>

</Layout>

<style>
  @media(min-width:768px) {
    .dlm-pipeline-grid { grid-template-columns: repeat(2, 1fr) !important; }
    .layers-grid       { grid-template-columns: repeat(3, 1fr) !important; }
    .features-grid     { grid-template-columns: repeat(2, 1fr) !important; }
    .feature-panels    { grid-template-columns: repeat(2, 1fr) !important; }
  }
  @media(min-width:768px) {
    .feature-panels > div { border-bottom: none !important; border-right: 1px solid rgba(255,255,255,0.05); }
    .feature-panels > div:last-child { border-right: none; }
  }
</style>

<script>
  document.getElementById('beta-form')?.addEventListener('submit', e => {
    e.preventDefault();
    const btn = (e.target as HTMLFormElement).querySelector('button') as HTMLButtonElement;
    btn.textContent = 'You\'re on the list!';
    btn.disabled = true;
    setTimeout(() => { btn.textContent = 'Request Invite'; btn.disabled = false; (e.target as HTMLFormElement).reset(); }, 3500);
  });
</script>
