---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Starling Workspace — Starling AIX" description="Starling Workspace is where your Domain Language Model lives. An AI work surface with your entire Org Brain behind it.">

<!-- ── Hero ──────────────────────────────────────────────────── -->
<section style="position:relative;overflow:hidden;padding:6rem 0 5rem;text-align:center;" class="grid-bg">
  <div class="hero-glow"></div>
  <div class="container" style="position:relative;z-index:1;">

    <div class="badge fade-up" data-delay="0" style="margin-bottom:1.5rem;">
      Workspace
    </div>

    <h1 class="heading-display fade-up" data-delay="0.08"
        style="font-size:clamp(3rem,8vw,5.5rem);margin:0 0 1.5rem;max-width:700px;margin-inline:auto;">
      Work that <em>remembers.</em>
    </h1>

    <p class="fade-up" data-delay="0.15"
       style="font-size:1.05rem;color:#71717a;line-height:1.75;max-width:540px;margin:0 auto 2.5rem;">
      Starling Workspace is where your Domain Language Model lives. An AI work surface with your entire Org Brain behind it — every deliverable you produce makes the next one better.
    </p>

    <div class="fade-up" data-delay="0.22" style="display:flex;gap:1rem;flex-wrap:wrap;justify-content:center;align-items:center;">
      <a href="#beta" class="btn btn-primary" style="font-size:0.95rem;padding:0.7rem 1.75rem;">
        Request Beta Access
      </a>
      <p style="font-size:0.85rem;color:#52525b;margin:0;">Beta opens March 2026. Free for 14 days.</p>
    </div>

  </div>
</section>

<div class="divider"></div>

<!-- ── DLM Section ───────────────────────────────────────────── -->
<section style="padding:5rem 0;">
  <div class="container">
    <div style="max-width:760px;margin-inline:auto;text-align:center;margin-bottom:3.5rem;">
      <p class="section-label fade-up" data-delay="0" style="margin-bottom:0.75rem;">Your Domain Language Model</p>
      <h2 class="heading-display fade-up" data-delay="0.06"
          style="font-size:clamp(2rem,5vw,3rem);margin:0 0 1.25rem;">
        The model processes.<br/>The domain remembers.
      </h2>
      <p class="fade-up" data-delay="0.12"
         style="font-size:1rem;color:#71717a;line-height:1.75;">
        Workspace assembles your DLM on every request. It loads the right organizational context from your Org Brain, routes it through semantic addressing, and delivers intelligence no general-purpose AI can match.
      </p>
    </div>

    <!-- DLM breakdown cards -->
    <div style="display:grid;grid-template-columns:1fr;gap:1.25rem;" class="dlm-grid">

      <div class="card fade-up" data-delay="0" style="padding:1.75rem;">
        <div style="display:flex;align-items:center;gap:0.75rem;margin-bottom:1rem;">
          <span class="badge">LLM</span>
          <span style="color:#e4e4e7;font-size:0.9rem;font-weight:500;">Large Language Model</span>
        </div>
        <p style="color:#71717a;font-size:0.9rem;line-height:1.7;margin:0;">
          Stateless processing. Reads, reasons, advises — then forgets. Powerful, but starts from zero every time.
        </p>
      </div>

      <div class="card fade-up" data-delay="0.04" style="padding:1.75rem;">
        <div style="display:flex;align-items:center;gap:0.75rem;margin-bottom:1rem;">
          <span class="badge">MCP</span>
          <span style="color:#e4e4e7;font-size:0.9rem;font-weight:500;">Model Context Protocol</span>
        </div>
        <p style="color:#71717a;font-size:0.9rem;line-height:1.7;margin:0;">
          Anthropic's open standard for connecting AI to external data. The pipe — not the water.
        </p>
      </div>

      <div class="card fade-up" data-delay="0.08" style="padding:1.75rem;">
        <div style="display:flex;align-items:center;gap:0.75rem;margin-bottom:1rem;">
          <span class="badge">UCA</span>
          <span style="color:#e4e4e7;font-size:0.9rem;font-weight:500;">Universal Cognitive Architecture</span>
        </div>
        <p style="color:#71717a;font-size:0.9rem;line-height:1.7;margin:0;">
          Eleven cognates. Four memory tiers. Semantic addressing that gives business knowledge permanent coordinates. O(1) lookup, not O(n) search.
        </p>
      </div>

      <div class="card fade-up" data-delay="0.12" style="padding:1.75rem;">
        <div style="display:flex;align-items:center;gap:0.75rem;margin-bottom:1rem;">
          <span class="badge">ORG BRAIN</span>
          <span style="color:#e4e4e7;font-size:0.9rem;font-weight:500;">Your Sovereign Repository</span>
        </div>
        <p style="color:#71717a;font-size:0.9rem;line-height:1.7;margin:0;">
          Values, strategy, positioning, operations, culture — governed and addressable in Notion. You own it. It travels with you.
        </p>
      </div>

      <div class="card fade-up" data-delay="0.16" style="padding:1.75rem;border-color:rgba(249,115,22,0.25);background:rgba(249,115,22,0.04);">
        <div style="display:flex;align-items:center;gap:0.75rem;margin-bottom:1rem;">
          <span class="badge">DLM</span>
          <span style="color:#e4e4e7;font-size:0.9rem;font-weight:500;">Domain Language Model</span>
        </div>
        <p style="color:#71717a;font-size:0.9rem;line-height:1.7;margin:0;">
          Not a fine-tuned model. A general-purpose model with your complete organizational context loaded on every request.
        </p>
      </div>

    </div>
  </div>
</section>

<div class="divider"></div>

<!-- ── How It Works ───────────────────────────────────────────── -->
<section style="padding:5rem 0;">
  <div class="container">
    <div style="text-align:center;margin-bottom:3rem;">
      <p class="section-label fade-up" data-delay="0" style="margin-bottom:0.75rem;">Architecture</p>
      <h2 class="heading-display fade-up" data-delay="0.06"
          style="font-size:clamp(2rem,5vw,3rem);margin:0 0 1rem;">
        Build once. Deploy anywhere.
      </h2>
      <p class="fade-up" data-delay="0.12"
         style="font-size:1rem;color:#71717a;line-height:1.75;max-width:560px;margin-inline:auto;">
        Three layers. One stores. One translates. One thinks. You own the first two. The third is stateless and swappable.
      </p>
    </div>

    <div style="display:grid;grid-template-columns:1fr;gap:1.5rem;max-width:900px;margin-inline:auto;" class="layers-grid">

      <div class="card fade-up" data-delay="0" style="padding:2rem;display:flex;gap:1.5rem;align-items:flex-start;">
        <div style="flex-shrink:0;width:40px;height:40px;border-radius:8px;background:rgba(249,115,22,0.1);border:1px solid rgba(249,115,22,0.2);display:flex;align-items:center;justify-content:center;">
          <span style="font-family:'JetBrains Mono',monospace;font-size:0.65rem;color:#f97316;font-weight:600;">01</span>
        </div>
        <div>
          <div style="display:flex;align-items:center;gap:0.75rem;margin-bottom:0.5rem;">
            <h3 style="font-family:'JetBrains Mono',monospace;font-size:0.75rem;color:#f97316;letter-spacing:0.08em;text-transform:uppercase;margin:0;">Store</h3>
            <span style="font-family:'JetBrains Mono',monospace;font-size:0.7rem;color:#3f3f46;">Org Brain · Notion</span>
          </div>
          <p style="color:#a1a1aa;font-size:0.95rem;line-height:1.75;margin:0;">
            Your sovereign knowledge repository. Structured memories with semantic addresses. PMNs, AMNs, and LMNs — governed, versioned, and human-owned.
          </p>
        </div>
      </div>

      <div class="card fade-up" data-delay="0.06" style="padding:2rem;display:flex;gap:1.5rem;align-items:flex-start;">
        <div style="flex-shrink:0;width:40px;height:40px;border-radius:8px;background:rgba(249,115,22,0.1);border:1px solid rgba(249,115,22,0.2);display:flex;align-items:center;justify-content:center;">
          <span style="font-family:'JetBrains Mono',monospace;font-size:0.65rem;color:#f97316;font-weight:600;">02</span>
        </div>
        <div>
          <div style="display:flex;align-items:center;gap:0.75rem;margin-bottom:0.5rem;">
            <h3 style="font-family:'JetBrains Mono',monospace;font-size:0.75rem;color:#f97316;letter-spacing:0.08em;text-transform:uppercase;margin:0;">Translate</h3>
            <span style="font-family:'JetBrains Mono',monospace;font-size:0.7rem;color:#3f3f46;">MCP Server · Starling</span>
          </div>
          <p style="color:#a1a1aa;font-size:0.95rem;line-height:1.75;margin:0;">
            The orchestration layer. Reads your Org Brain, assembles context, injects it into any LLM. Automatic memory management and token budgeting.
          </p>
        </div>
      </div>

      <div class="card fade-up" data-delay="0.12" style="padding:2rem;display:flex;gap:1.5rem;align-items:flex-start;">
        <div style="flex-shrink:0;width:40px;height:40px;border-radius:8px;background:rgba(249,115,22,0.1);border:1px solid rgba(249,115,22,0.2);display:flex;align-items:center;justify-content:center;">
          <span style="font-family:'JetBrains Mono',monospace;font-size:0.65rem;color:#f97316;font-weight:600;">03</span>
        </div>
        <div>
          <div style="display:flex;align-items:center;gap:0.75rem;margin-bottom:0.5rem;">
            <h3 style="font-family:'JetBrains Mono',monospace;font-size:0.75rem;color:#f97316;letter-spacing:0.08em;text-transform:uppercase;margin:0;">Think</h3>
            <span style="font-family:'JetBrains Mono',monospace;font-size:0.7rem;color:#3f3f46;">Any LLM · Your Choice</span>
          </div>
          <p style="color:#a1a1aa;font-size:0.95rem;line-height:1.75;margin:0;">
            Claude today. GPT tomorrow. Gemini next week. The intelligence isn't in the model — it's in your Org Brain. Switch providers without losing a single memory.
          </p>
        </div>
      </div>

    </div>
  </div>
</section>

<div class="divider"></div>

<!-- ── Platform Features ──────────────────────────────────────── -->
<section style="padding:5rem 0;">
  <div class="container">
    <div style="text-align:center;margin-bottom:3rem;">
      <p class="section-label fade-up" data-delay="0" style="margin-bottom:0.75rem;">Inside the Platform</p>
      <h2 class="heading-display fade-up" data-delay="0.06"
          style="font-size:clamp(2rem,5vw,3rem);margin:0 0 1rem;">
        Two modes. One intelligence layer.
      </h2>
      <p class="fade-up" data-delay="0.12"
         style="font-size:1rem;color:#71717a;line-height:1.75;max-width:580px;margin-inline:auto;">
        Workspace operates in two modes — Excavation for building the Org Brain, Document for putting it to work. Both connect to the same memory system through the same AI Chief of Staff.
      </p>
    </div>

    <div style="display:grid;grid-template-columns:1fr;gap:1.25rem;max-width:900px;margin-inline:auto;" class="features-grid">

      <div class="card fade-up" data-delay="0" style="padding:2rem;">
        <div style="display:flex;align-items:center;gap:0.75rem;margin-bottom:1rem;">
          <span class="badge">Excavation Mode</span>
        </div>
        <p style="color:#a1a1aa;font-size:0.95rem;line-height:1.75;margin:0;">
          Guided installers excavate organizational knowledge through structured conversation. Your answers become governed memory.
        </p>
      </div>

      <div class="card fade-up" data-delay="0.05" style="padding:2rem;">
        <div style="display:flex;align-items:center;gap:0.75rem;margin-bottom:1rem;">
          <span class="badge">Document Mode</span>
        </div>
        <p style="color:#a1a1aa;font-size:0.95rem;line-height:1.75;margin:0;">
          Work on project deliverables with your entire Org Brain loaded as context. Web copy, proposals, reports — all in your organization's voice.
        </p>
      </div>

      <div class="card fade-up" data-delay="0.1" style="padding:2rem;">
        <div style="display:flex;align-items:center;gap:0.75rem;margin-bottom:1rem;">
          <span class="badge">Inline References</span>
        </div>
        <p style="color:#a1a1aa;font-size:0.95rem;line-height:1.75;margin:0;">
          Semantic addresses appear as clickable chips. Click <span style="font-family:'JetBrains Mono',monospace;font-size:0.8rem;color:#f97316;background:rgba(249,115,22,0.08);padding:0.15rem 0.4rem;border-radius:4px;">MA20</span> mid-conversation to see your Competitive Position without leaving the thread.
        </p>
      </div>

      <div class="card fade-up" data-delay="0.15" style="padding:2rem;">
        <div style="display:flex;align-items:center;gap:0.75rem;margin-bottom:1rem;">
          <span class="badge">Capture Learning</span>
        </div>
        <p style="color:#a1a1aa;font-size:0.95rem;line-height:1.75;margin:0;">
          Extract patterns from every project. Lessons learned and process improvements become Learning Memories that compound over time.
        </p>
      </div>

    </div>
  </div>
</section>

<div class="divider"></div>

<!-- ── Workflow ───────────────────────────────────────────────── -->
<section style="padding:5rem 0;">
  <div class="container" style="max-width:820px;">
    <div style="text-align:center;margin-bottom:3rem;">
      <h2 class="heading-display fade-up" data-delay="0"
          style="font-size:clamp(2rem,5vw,3rem);margin:0 0 1rem;">
        Work is your best <em>memory.</em>
      </h2>
      <p class="fade-up" data-delay="0.08"
         style="font-size:1rem;color:#71717a;line-height:1.75;max-width:560px;margin-inline:auto;">
        The page you just shipped is better context than the strategy doc it came from. <strong style="color:#e4e4e7;">Workspace</strong> treats every deliverable as memory. The campaign brief that shipped becomes context for the next one. That's the compounding asset — not the AI.
      </p>
    </div>

    <div style="display:flex;flex-direction:column;gap:0;border:1px solid rgba(255,255,255,0.08);border-radius:12px;overflow:hidden;" class="fade-up" data-delay="0.12">

      {[
        ['01', 'Create a Session', 'Open a project, create a session. The system already knows you. Your Org Brain loads automatically.'],
        ['02', 'Add Context', 'The right knowledge loads. Persistent memory, active work, and learned patterns — all through semantic addressing.'],
        ['03', 'Generate Artifact', 'Super content, from the jump. The output knows you. Every artifact becomes memory for the next one.'],
      ].map(([num, title, body], i) => (
        <div style={`padding:1.75rem 2rem;background:#0d0d0d;${i < 2 ? 'border-bottom:1px solid rgba(255,255,255,0.06);' : ''}`}>
          <div style="display:flex;align-items:flex-start;gap:1.25rem;">
            <span style="font-family:'JetBrains Mono',monospace;font-size:0.75rem;color:#f97316;flex-shrink:0;padding-top:0.2rem;">{num}</span>
            <div>
              <h3 style="font-size:1rem;font-weight:600;color:#fff;margin:0 0 0.4rem;">{title}</h3>
              <p style="font-size:0.9rem;color:#71717a;line-height:1.7;margin:0;">{body}</p>
            </div>
          </div>
        </div>
      ))}

    </div>
  </div>
</section>

<div class="divider"></div>

<!-- ── Beta CTA ───────────────────────────────────────────────── -->
<section id="beta" style="padding:5rem 0;">
  <div class="container">
    <div class="card fade-up" data-delay="0" style="padding:3rem 2.5rem;max-width:620px;margin-inline:auto;text-align:center;border-color:rgba(249,115,22,0.2);background:rgba(249,115,22,0.03);">

      <div class="badge" style="margin-bottom:1.5rem;">Beta Access</div>

      <h2 class="heading-display" style="font-size:clamp(1.8rem,4vw,2.5rem);margin:0 0 1rem;">
        Beta opens March 2026.
      </h2>
      <p style="font-size:1rem;color:#71717a;line-height:1.75;margin:0 0 0.5rem;">
        Free for 14 days. $99/mo after that.
      </p>

      <form id="beta-form" style="display:flex;gap:0.75rem;flex-wrap:wrap;margin-top:2rem;justify-content:center;">
        <input type="email" name="email" placeholder="Email address" required class="input" style="flex:1;min-width:220px;max-width:320px;" />
        <button type="submit" class="btn btn-primary">Request Invite</button>
      </form>
      <p style="font-size:0.78rem;color:#3f3f46;margin-top:0.75rem;">We'll email when it's ready.</p>

    </div>
  </div>
</section>

</Layout>

<style>
  @media(min-width:768px) {
    .dlm-grid      { grid-template-columns: repeat(3, 1fr) !important; }
    .layers-grid   { grid-template-columns: repeat(3, 1fr) !important; }
    .features-grid { grid-template-columns: repeat(2, 1fr) !important; }
  }
</style>

<script>
  document.getElementById('beta-form')?.addEventListener('submit', e => {
    e.preventDefault();
    const btn = (e.target as HTMLFormElement).querySelector('button') as HTMLButtonElement;
    btn.textContent = 'You\'re on the list!';
    btn.disabled = true;
    setTimeout(() => { btn.textContent = 'Request Invite'; btn.disabled = false; (e.target as HTMLFormElement).reset(); }, 3500);
  });
</script>
