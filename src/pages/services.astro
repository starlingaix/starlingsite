            prompt: 'Review this facilitator guide draft for compliance.',
            response: 'Cross-checking against your <strong>Standards</strong> memory — 2 issues: Section 3 uses "AI assistant" (your terminology standard is "Domain Language Model"), and the assessment rubric is missing the constitutional memory validation step from your <strong>Workflows</strong>...',
            refs: [
                { name: 'Standards', color: '#9B5DE5' },
                { name: 'Workflows', color: '#9B5DE5' },
                { name: 'Voice', color: '#D4702C' }
            ]
        },
        culture: {
            prompt: 'Write an internal memo about our new remote-first policy.',
            response: 'Drawing from your <strong>Culture</strong> memory — "trust-default, async-first, documentation over meetings." I\'ll write this in your internal <strong>Voice</strong> (warmer, more personal than external) and reference the <strong>Decisions</strong> log from the Q2 offsite...',
            refs: [
                { name: 'Culture', color: '#F56493' },
                { name: 'Voice', color: '#D4702C' },
                { name: 'Decisions', color: '#36D1B7' }
            ]
        }
    };

    function renderChat(key) {
        const data = conversations[key];
        if (!data) return;
        const refsHtml = data.refs.map(r =>
            '<span class="dlm-mock__ref"><span class="dlm-mock__ref-dot" style="background:' + r.color + '"></span>' + r.name + '</span>'
        ).join('');
        msgs.innerHTML =
            '<div class="dlm-mock__msg dlm-mock__msg--user">' +
                '<div class="dlm-mock__msg-avatar dlm-mock__msg-avatar--user">U</div>' +
                '<div class="dlm-mock__msg-body">' +
                    '<div class="dlm-mock__msg-name">You <span>just now</span></div>' +
                    '<p>' + data.prompt + '</p>' +
                '</div>' +
            '</div>' +
            '<div class="dlm-mock__msg dlm-mock__msg--ai">' +
                '<div class="dlm-mock__msg-avatar dlm-mock__msg-avatar--ai">' +
                    '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M8 12l3 3 5-5"/></svg>' +
                '</div>' +
                '<div class="dlm-mock__msg-body">' +
                    '<div class="dlm-mock__msg-name">DLM <span>typing...</span></div>' +
                    '<p class="dlm-mock__typing">' + data.response + '</p>' +
                    '<div class="dlm-mock__msg-refs">' + refsHtml + '</div>' +
                '</div>' +
            '</div>';
    }

    // Initial render
    renderChat('mission');

    // Click handler
    list.addEventListener('click', function(e) {
        const mem = e.target.closest('.dlm-mock__memory');
        if (!mem || mem.classList.contains('is-active')) return;

        // Update active tab
        list.querySelectorAll('.dlm-mock__memory').forEach(m => m.classList.remove('is-active'));
        mem.classList.add('is-active');

        const key = mem.getAttribute('data-dlm');
        const memName = mem.textContent.replace(/[0-9]/g, '').trim();

        // Update status bar
        status.textContent = 'Loading ' + memName + ' memories...';

        // Fade out
        msgs.classList.add('is-fading');

        setTimeout(function() {
            renderChat(key);
            msgs.classList.remove('is-fading');
            // Restore status after animation
            setTimeout(function() {
                status.textContent = 'Connected · 28 memories loaded';
            }, 800);
        }, 250);
    });

    // Auto-cycle through tabs every 5s if user hasn't interacted
    let autoTimer;
    let userClicked = false;
    const keys = Object.keys(conversations);
    let currentIndex = 0;

    function autoCycle() {
        if (userClicked) return;
        currentIndex = (currentIndex + 1) % keys.length;
        const nextMem = list.querySelector('[data-dlm="' + keys[currentIndex] + '"]');
        if (nextMem) {
            list.querySelectorAll('.dlm-mock__memory').forEach(m => m.classList.remove('is-active'));
            nextMem.classList.add('is-active');
            status.textContent = 'Loading ' + keys[currentIndex].charAt(0).toUpperCase() + keys[currentIndex].slice(1) + ' memories...';
            msgs.classList.add('is-fading');
            setTimeout(function() {
                renderChat(keys[currentIndex]);
                msgs.classList.remove('is-fading');
                setTimeout(function() { status.textContent = 'Connected · 28 memories loaded'; }, 800);
            }, 250);
        }
        autoTimer = setTimeout(autoCycle, 5000);
    }
    autoTimer = setTimeout(autoCycle, 4000);

    // Stop auto-cycle on first user click
    list.addEventListener('click', function() {
        userClicked = true;
        clearTimeout(autoTimer);
    }, { once: true });
})();
</script>
</BaseLayout>

<style is:global>
/* ========================================================
   DESIGN TOKENS
   ======================================================== */
:root {
    --font: "Inter Variable", "Inter", "SF Pro Display", -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Oxygen, Ubuntu, Cantarell, "Open Sans", "Helvetica Neue", sans-serif;
    --text-light: rgb(138, 143, 152);
    --font-mono: 'Source Code Pro', 'SFMono-Regular', monospace;
    --brand: #D4702C;
    --brand-dark: #B85E22;
    --brand-light: #E8934F;
    --brand-pale: #FDF3EB;
    --brand-glow: rgba(212,112,44,0.15);
    --accent-teal: #36D1B7;
    --accent-pink: #F56493;
    --accent-yellow: #FBBF24;
    --accent-blue: #635bff;
    --text-primary: rgb(45, 37, 100);
    --text-secondary: #4f566b;
    --text-muted: #8792a2;
    --bg-white: #ffffff;
    --bg-gray: #f6f9fc;
    --bg-cream: #FDF8F4;
    --border: #e3e8ee;
    --radius: 8px;
    --radius-lg: 12px;
    --radius-pill: 100px;
    --shadow-sm: 0 2px 4px rgba(0,0,0,0.04);
    --shadow-md: 0 4px 12px rgba(0,0,0,0.06);
    --shadow-lg: 0 15px 35px rgba(0,0,0,0.06), 0 5px 15px rgba(0,0,0,0.04);
    --shadow-brand: 0 8px 30px rgba(212,112,44,0.18);
    --max-w: 1440px;
    --pad-x: 20px;
    --nav-h: 64px;
    --col-gap: 24px;
    --section-pad: 60px;
    --section-pad-lg: 60px;
    --hero-pad: 60px;
}
@media (min-width: 768px) {
    :root { --section-pad: 110px; --section-pad-lg: 110px; --hero-pad: 130px; --pad-x: 32px; }
}
@media (min-width: 1024px) {
    :root { --section-pad: 140px; --section-pad-lg: 140px; --hero-pad: 160px; --pad-x: 40px; }
}

/* RESET */
*,*::before,*::after{margin:0;padding:0;box-sizing:border-box}
html{scroll-behavior:smooth;-webkit-text-size-adjust:100%}
body{font-family:var(--font);font-weight:400;color:var(--text-primary);background:var(--bg-white);line-height:1.6;-webkit-font-smoothing:antialiased;-moz-osx-font-smoothing:grayscale;overflow-x:hidden;font-size:16px}
a{color:inherit;text-decoration:none}
ul,ol{list-style:none}
img{max-width:100%;display:block}
button{font-family:inherit;cursor:pointer;border:none;background:none}

/* GRID */
.container{max-width:var(--max-w);margin:0 auto;padding:0 var(--pad-x)}
.grid{display:grid;grid-template-columns:repeat(12,1fr);gap:var(--col-gap)}
.section{padding:var(--section-pad) 0;position:relative;overflow:hidden}
.section--lg{padding:var(--section-pad-lg) 0}
.section--white{background:var(--bg-white)}
.section--gray{background:var(--bg-gray)}
.section--cream{background:var(--bg-cream)}

/* ── Shape dividers ── */
.divider-wave{position:relative;z-index:3;margin-top:-1px;line-height:0}
.divider-wave svg{display:block;width:100%;height:auto}
.divider-wave--flip{transform:scaleY(-1);margin-top:0;margin-bottom:-1px}

/* ── Per-section unique backgrounds ── */

/* ========================================================
   HOW WE WORK — Linear-style split heading + panels
   ======================================================== */
.hww{
    padding:var(--section-pad-lg) 0;
    background:var(--bg-white);
    position:relative;overflow:hidden;
    border-top:1px solid var(--border);
    border-bottom:1px solid var(--border);
}
.hww__inner{max-width:var(--max-w);margin:0 auto;padding:0 var(--pad-x)}

/* Split heading: bold left, description right */
.hww__header{
    display:grid;grid-template-columns:1fr;gap:24px;
    margin-bottom:80px;align-items:start;
}
@media(min-width:768px){
    .hww__header{grid-template-columns:1.2fr 1fr;gap:60px;margin-bottom:100px}
}
.hww__h{
    font-size:clamp(1.75rem,3.5vw,40px);font-weight:400;line-height:1.15;
    letter-spacing:-0.025em;color:var(--text-secondary);
}
.hww__h strong{font-weight:500;color:var(--text-primary)}
.hww__header-right{display:flex;flex-direction:column;gap:24px}
@media(min-width:768px){.hww__header-right{padding-top:8px}}
.hww__link{
    display:inline-flex;align-items:center;gap:6px;
    font-size:15px;font-weight:600;color:var(--brand);
    transition:gap 0.25s ease;
}
.hww__link:hover{gap:10px}
.hww__link svg{transition:transform 0.25s}
.hww__link:hover svg{transform:translateX(3px)}

/* 3-column panels — Stripe-style with particle splash backgrounds */
.hww__panels{
    display:grid;grid-template-columns:1fr;gap:24px;
}
@media(min-width:768px){.hww__panels{grid-template-columns:repeat(3,1fr)}}

.hww__panel{
    background:var(--bg-white);
    border:1px solid var(--border);border-radius:20px;
    display:flex;flex-direction:column;
    transition:all 0.4s cubic-bezier(0.4,0,0.2,1);
    cursor:default;overflow:hidden;
    box-shadow:0 4px 24px rgba(0,0,0,0.03);
}
.hww__panel:hover{
    transform:translateY(-4px);
    box-shadow:0 20px 60px rgba(0,0,0,0.08);
    border-color:transparent;
}
.hww__panel-canvas{width:100%;height:100%;position:relative;z-index:2}
.hww__panel .hww__panel-canvas{transition:transform 0.5s cubic-bezier(0.34,1.56,0.64,1)}
.hww__panel:hover .hww__panel-canvas{transform:scale(1.06) translateY(-2px)}

.hww__panel-visual{
    position:relative;padding:40px 24px 20px;
    height:280px;display:flex;align-items:center;justify-content:center;
    overflow:hidden;
}
@media(min-width:768px){.hww__panel-visual{height:320px;padding:48px 32px 20px}}

/* Particle splash background per panel */
.hww__panel-visual::before{
    content:'';position:absolute;inset:0;z-index:0;
    opacity:0.85;transition:opacity 0.4s ease,transform 0.6s ease;
}
.hww__panel:hover .hww__panel-visual::before{opacity:1;transform:scale(1.03)}

/* Build — warm orange/coral radial burst */
.hww__panel--build .hww__panel-visual::before{
    background:
        radial-gradient(ellipse at 55% 45%,rgba(212,112,44,0.18) 0%,transparent 50%),
        radial-gradient(ellipse at 30% 70%,rgba(245,100,147,0.12) 0%,transparent 40%),
        radial-gradient(ellipse at 80% 25%,rgba(212,112,44,0.08) 0%,transparent 35%),
        radial-gradient(circle at 65% 80%,rgba(245,158,11,0.1) 0%,transparent 30%);
}
.hww__panel--build .hww__panel-visual{
    background:linear-gradient(145deg,#FFF8F3 0%,#FFF1E8 40%,#FFECE0 100%);
}

/* License — cool teal/mint flowing waves */
.hww__panel--license .hww__panel-visual::before{
    background:
        radial-gradient(ellipse at 45% 50%,rgba(54,209,183,0.2) 0%,transparent 50%),
        radial-gradient(ellipse at 75% 30%,rgba(54,209,183,0.1) 0%,transparent 35%),
        radial-gradient(ellipse at 20% 80%,rgba(0,178,97,0.08) 0%,transparent 30%),
        radial-gradient(circle at 85% 70%,rgba(54,209,183,0.12) 0%,transparent 35%);
}
.hww__panel--license .hww__panel-visual{
    background:linear-gradient(145deg,#F0FFFE 0%,#E4FBF6 40%,#D9F7F0 100%);
}

/* Certify — electric purple/violet bursts */
.hww__panel--certify .hww__panel-visual::before{
    background:
        radial-gradient(ellipse at 50% 40%,rgba(155,93,229,0.18) 0%,transparent 50%),
        radial-gradient(ellipse at 25% 65%,rgba(139,92,246,0.1) 0%,transparent 35%),
        radial-gradient(ellipse at 80% 75%,rgba(245,100,147,0.08) 0%,transparent 30%),
        radial-gradient(circle at 70% 20%,rgba(155,93,229,0.12) 0%,transparent 35%);
}
.hww__panel--certify .hww__panel-visual{
    background:linear-gradient(145deg,#F9F5FF 0%,#F3EDFF 40%,#EDE5FF 100%);
}

/* Animated particle dots overlay — CSS only */
.hww__panel-visual::after{
    content:'';position:absolute;inset:0;z-index:1;pointer-events:none;
    background-image:
        radial-gradient(circle 2px,currentColor 100%,transparent 100%),
        radial-gradient(circle 1.5px,currentColor 100%,transparent 100%),
        radial-gradient(circle 2.5px,currentColor 100%,transparent 100%),
        radial-gradient(circle 1px,currentColor 100%,transparent 100%),
        radial-gradient(circle 2px,currentColor 100%,transparent 100%),
        radial-gradient(circle 1.5px,currentColor 100%,transparent 100%),
        radial-gradient(circle 1px,currentColor 100%,transparent 100%),
        radial-gradient(circle 2px,currentColor 100%,transparent 100%),
        radial-gradient(circle 1.5px,currentColor 100%,transparent 100%),
        radial-gradient(circle 2.5px,currentColor 100%,transparent 100%),
        radial-gradient(circle 1px,currentColor 100%,transparent 100%),
        radial-gradient(circle 2px,currentColor 100%,transparent 100%);
    background-size:4px 4px,3px 3px,5px 5px,2px 2px,4px 4px,3px 3px,2px 2px,4px 4px,3px 3px,5px 5px,2px 2px,4px 4px;
    background-position:
        10% 15%,25% 80%,45% 10%,60% 60%,75% 25%,85% 75%,
        15% 50%,35% 35%,55% 85%,70% 45%,90% 15%,50% 70%;
    background-repeat:no-repeat;
    opacity:0.15;
    animation:hww-dots-drift 8s ease-in-out infinite alternate;
}
.hww__panel--build .hww__panel-visual::after{color:var(--brand)}
.hww__panel--license .hww__panel-visual::after{color:var(--accent-teal)}
.hww__panel--certify .hww__panel-visual::after{color:#9B5DE5}
@keyframes hww-dots-drift{
    0%{transform:translate(0,0) scale(1)}
    100%{transform:translate(3px,-3px) scale(1.02)}
}

.hww__fig-label{
    position:absolute;top:20px;left:24px;z-index:3;
    font-family:var(--font-mono);font-size:11px;font-weight:500;
    text-transform:uppercase;letter-spacing:0.08em;color:var(--text-muted);
    transition:color 0.3s;
    background:rgba(255,255,255,0.7);padding:3px 8px;border-radius:6px;
    backdrop-filter:blur(4px);-webkit-backdrop-filter:blur(4px);
}
@media(min-width:768px){.hww__fig-label{left:32px}}
.hww__panel:hover .hww__fig-label{color:var(--text-primary)}

.hww__iso{width:100%;max-width:220px;height:auto}

.hww__panel-text{
    padding:24px 24px 36px;display:flex;flex-direction:column;gap:10px;
}
@media(min-width:768px){.hww__panel-text{padding:24px 32px 44px}}
.hww__panel-text strong{font-size:17px;font-weight:600;color:var(--text-primary)}
.hww__panel-text span{font-size:15px;line-height:1.6;color:var(--text-secondary)}

/* Curriculum: topographic/contour lines */
.section--topo{
    background:
        radial-gradient(circle at 50% 0%,rgba(212,112,44,0.03),transparent 40%),
        var(--bg-gray);
}
.section--topo::after{
    content:'';position:absolute;inset:0;pointer-events:none;opacity:0.025;
    background-image:
        repeating-radial-gradient(circle at 50% 50%,transparent,transparent 40px,rgba(45,37,100,1) 40px,rgba(45,37,100,1) 41px,transparent 41px);
}

/* Licensing: diagonal fine stripes */
.section--stripes{
    background:
        radial-gradient(ellipse at 80% 20%,rgba(54,209,183,0.04),transparent 50%),
        repeating-linear-gradient(135deg,transparent,transparent 30px,rgba(45,37,100,0.012) 30px,rgba(45,37,100,0.012) 31px);
    background-color:var(--bg-white);
}

/* Exit Guarantee: warm gradient wash */
.section--warm{
