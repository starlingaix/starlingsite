<script is:inline>
/* ========================================================
   HERO — Interactive AI Network Canvas
   Mouse attracts nodes, click sends ripples, drag creates trails
   ======================================================== */
(function() {
    const canvas = document.getElementById('heroAiCanvas');
    if (!canvas) return;
    const ctx = canvas.getContext('2d');
    let w, h, nodes = [], pulses = [], ripples = [], t = 0;
    let mx = -999, my = -999, mouseIn = false, mouseDown = false;

    const COLORS = [
        [212,112,44],[232,147,79],[54,209,183],[245,100,147],[251,191,36],[107,92,200]
    ];
    const CONNECT_DIST = 160;
    const MOUSE_RADIUS = 180;
    const NODE_COUNT = 80;

    function resize() {
        const r = window.devicePixelRatio || 1;
        w = canvas.offsetWidth; h = canvas.offsetHeight;
        canvas.width = w * r; canvas.height = h * r;
        ctx.scale(r, r);
    }

    function createNodes() {
        nodes = [];
        for (let i = 0; i < NODE_COUNT; i++) {
            const col = COLORS[Math.floor(Math.random() * COLORS.length)];
            nodes.push({
                x: Math.random() * w, y: Math.random() * h,
                vx: (Math.random() - 0.5) * 0.6,
                vy: (Math.random() - 0.5) * 0.6,
                r: 2 + Math.random() * 3,
                col: col,
                phase: Math.random() * Math.PI * 2,
                baseAlpha: 0.15 + Math.random() * 0.25
            });
        }
    }

    /* Mouse tracking */
    canvas.addEventListener('mousemove', function(e) {
        const rect = canvas.getBoundingClientRect();
        mx = e.clientX - rect.left; my = e.clientY - rect.top;
        mouseIn = true;
    });
    canvas.addEventListener('mouseleave', function() { mouseIn = false; mx = -999; my = -999; });
    canvas.addEventListener('mousedown', function() { mouseDown = true; });
    canvas.addEventListener('mouseup', function() { mouseDown = false; });

    /* Click creates a ripple burst + spawns pulses outward */
    canvas.addEventListener('click', function(e) {
        const rect = canvas.getBoundingClientRect();
        const cx = e.clientX - rect.left, cy = e.clientY - rect.top;
        ripples.push({ x: cx, y: cy, r: 0, maxR: 200 + Math.random() * 100, alpha: 0.6 });
        /* Push nearby nodes outward */
        for (const n of nodes) {
            const dx = n.x - cx, dy = n.y - cy;
            const dist = Math.sqrt(dx * dx + dy * dy);
            if (dist < 200 && dist > 0) {
                const force = (1 - dist / 200) * 8;
                n.vx += (dx / dist) * force;
                n.vy += (dy / dist) * force;
            }
        }
        /* Spawn radial pulses from click point */
        for (let a = 0; a < Math.PI * 2; a += Math.PI / 4) {
            pulses.push({
                x: cx, y: cy,
                vx: Math.cos(a) * 2.5, vy: Math.sin(a) * 2.5,
                life: 1,
                col: COLORS[Math.floor(Math.random() * COLORS.length)]
            });
        }
    });

    canvas.style.cursor = 'crosshair';

    function draw() {
        t += 0.004;
        ctx.clearRect(0, 0, w, h);

        /* Update nodes */
        for (const n of nodes) {
            /* Mouse attraction / repulsion */
            if (mouseIn) {
                const dx = mx - n.x, dy = my - n.y;
                const dist = Math.sqrt(dx * dx + dy * dy);
                if (dist < MOUSE_RADIUS && dist > 1) {
                    const force = (1 - dist / MOUSE_RADIUS) * (mouseDown ? 1.5 : 0.4);
                    /* Attract toward mouse when hovering, stronger when clicking */
                    n.vx += (dx / dist) * force;
                    n.vy += (dy / dist) * force;
                }
            }

            /* Gentle ambient drift */
            n.vx += Math.sin(t + n.phase) * 0.005;
            n.vy += Math.cos(t * 0.7 + n.phase) * 0.005;

            /* Damping */
            n.vx *= 0.97;
            n.vy *= 0.97;

            n.x += n.vx;
            n.y += n.vy;

            /* Wrap edges */
            if (n.x < -20) n.x = w + 20;
            if (n.x > w + 20) n.x = -20;
            if (n.y < -20) n.y = h + 20;
            if (n.y > h + 20) n.y = -20;
        }

        /* Draw connections */
        for (let i = 0; i < nodes.length; i++) {
            for (let j = i + 1; j < nodes.length; j++) {
                const a = nodes[i], b = nodes[j];
                const dx = a.x - b.x, dy = a.y - b.y;
                const dist = Math.sqrt(dx * dx + dy * dy);
                if (dist > CONNECT_DIST) continue;

                const alpha = 0.08 * (1 - dist / CONNECT_DIST);
                /* Brighter lines near mouse */
                let boost = 1;
                if (mouseIn) {
                    const midX = (a.x + b.x) / 2, midY = (a.y + b.y) / 2;
                    const md = Math.sqrt((mx - midX) ** 2 + (my - midY) ** 2);
                    if (md < MOUSE_RADIUS) boost = 1 + (1 - md / MOUSE_RADIUS) * 3;
                }
                ctx.beginPath();
                ctx.moveTo(a.x, a.y);
                ctx.lineTo(b.x, b.y);
                ctx.strokeStyle = 'rgba(' + a.col.join(',') + ',' + Math.min(alpha * boost, 0.35) + ')';
                ctx.lineWidth = 0.7;
                ctx.stroke();
            }
        }

        /* Draw ripples */
        for (let i = ripples.length - 1; i >= 0; i--) {
            const rp = ripples[i];
            rp.r += 4;
            rp.alpha *= 0.96;
            if (rp.alpha < 0.01 || rp.r > rp.maxR) { ripples.splice(i, 1); continue; }
            ctx.beginPath();
            ctx.arc(rp.x, rp.y, rp.r, 0, Math.PI * 2);
            ctx.strokeStyle = 'rgba(212,112,44,' + rp.alpha * 0.3 + ')';
            ctx.lineWidth = 2;
            ctx.stroke();
        }

        /* Draw click pulses */
        for (let i = pulses.length - 1; i >= 0; i--) {
            const p = pulses[i];
            p.x += p.vx; p.y += p.vy;
            p.life -= 0.015;
            if (p.life <= 0) { pulses.splice(i, 1); continue; }
            ctx.beginPath();
            ctx.arc(p.x, p.y, 3 * p.life, 0, Math.PI * 2);
            ctx.fillStyle = 'rgba(' + p.col.join(',') + ',' + (p.life * 0.6) + ')';
            ctx.fill();
        }

        /* Draw nodes */
        for (const n of nodes) {
            const pulse = (Math.sin(t * 2.5 + n.phase) + 1) / 2;
            let alpha = n.baseAlpha + pulse * 0.15;
            let r = n.r + pulse * 0.8;

            /* Highlight near mouse */
            if (mouseIn) {
                const md = Math.sqrt((mx - n.x) ** 2 + (my - n.y) ** 2);
                if (md < MOUSE_RADIUS) {
                    const prox = 1 - md / MOUSE_RADIUS;
                    alpha = Math.min(alpha + prox * 0.5, 0.9);
                    r += prox * 3;
                }
            }

            /* Outer glow */
            ctx.beginPath();
            ctx.arc(n.x, n.y, r + 6, 0, Math.PI * 2);
            ctx.fillStyle = 'rgba(' + n.col.join(',') + ',' + (alpha * 0.08) + ')';
            ctx.fill();
            /* Core */
            ctx.beginPath();
            ctx.arc(n.x, n.y, r, 0, Math.PI * 2);
            ctx.fillStyle = 'rgba(' + n.col.join(',') + ',' + alpha + ')';
            ctx.fill();
        }

        /* Mouse glow cursor */
        if (mouseIn) {
            ctx.beginPath();
            ctx.arc(mx, my, 40, 0, Math.PI * 2);
            const g = ctx.createRadialGradient(mx, my, 0, mx, my, 40);
            g.addColorStop(0, 'rgba(212,112,44,0.06)');
            g.addColorStop(1, 'rgba(212,112,44,0)');
            ctx.fillStyle = g;
            ctx.fill();
        }

        requestAnimationFrame(draw);
    }

    resize();
    createNodes();
    draw();
    window.addEventListener('resize', () => { resize(); createNodes(); });
})();

/* ========================================================
   MACH 1 — Morphing chaos→order canvas
   ======================================================== */
(function() {
    const canvas = document.getElementById('mach1MorphCanvas');
    if (!canvas) return;
    const ctx = canvas.getContext('2d');
    const slider = document.getElementById('mach1Slider');
    const tag = document.getElementById('mach1Tag');
    const desc = document.getElementById('mach1Desc');
    const bar = canvas.parentElement.querySelector('.mach1__morph-bar');
    const opts = bar.querySelectorAll('.mach1__morph-opt');
    let w, h, particles = [], pulses = [], t = 0;
    let mode = 'chaos'; // 'chaos' or 'order'
    let morph = 0; // 0=chaos, 1=order — lerps smoothly
    const N = 30;
    const COLORS = [
        [212,112,44],[54,209,183],[155,93,229],[245,100,147],
        [200,60,60],[150,150,150]
    ];

    function resize() {
        const r = window.devicePixelRatio || 1;
        const p = canvas.parentElement;
        w = p.offsetWidth; h = p.offsetHeight;
        canvas.width = w * r; canvas.height = h * r;
        ctx.scale(r, r);
        computeTargets();
    }

    function computeTargets() {
        const cx = w / 2, cy = h / 2;
        const maxR = Math.min(w, h - 80) * 0.38;
        const rings = [
            { count: 6, dist: 0.35, cols: [0,0,0,0,0,0] },
            { count: 8, dist: 0.6, cols: [1,1,1,1,2,2,2,2] },
            { count: 8, dist: 0.85, cols: [3,3,1,2,0,3,2,1] },
            { count: 8, dist: 1.0, cols: [0,1,2,3,0,1,2,3] }
        ];
        let idx = 0;
        rings.forEach(function(ring) {
            for (let i = 0; i < ring.count; i++) {
                if (idx >= N) return;
                const a = (i / ring.count) * Math.PI * 2 - Math.PI / 2;
                const p = particles[idx];
                if (p) {
                    p.tx = cx + Math.cos(a) * maxR * ring.dist;
                    p.ty = cy + Math.sin(a) * maxR * ring.dist;
                    p.col = COLORS[ring.cols[i]];
                }
                idx++;
            }
        });
    }

    function init() {
        particles = []; pulses = [];
        for (let i = 0; i < N; i++) {
            particles.push({
                // Chaos positions
                cx: 30 + Math.random() * (w - 60),
                cy: 50 + Math.random() * (h - 120),
                vx: (Math.random() - 0.5) * 2,
                vy: (Math.random() - 0.5) * 2,
                // Order target (computed by computeTargets)
                tx: w / 2, ty: h / 2,
                // Current render position
                x: 0, y: 0,
                r: 2.5 + Math.random() * 2.5,
                col: COLORS[Math.floor(Math.random() * COLORS.length)],
                phase: Math.random() * Math.PI * 2
            });
        }
        computeTargets();
    }

    function lerp(a, b, t) { return a + (b - a) * t; }

    function draw() {
        t += 0.004;
        // Smoothly lerp morph toward target
        var target = mode === 'order' ? 1 : 0;
        morph += (target - morph) * 0.04;

        ctx.clearRect(0, 0, w, h);
        var cx = w / 2, cy = h / 2;

        // Update chaos positions (always running for smooth transitions)
        for (var i = 0; i < particles.length; i++) {
            var p = particles[i];
            p.cx += p.vx + Math.sin(t * 3 + p.phase) * 0.3;
            p.cy += p.vy + Math.cos(t * 2 + p.phase) * 0.3;
            if (p.cx < 20 || p.cx > w - 20) p.vx *= -1;
            if (p.cy < 50 || p.cy > h - 70) p.vy *= -1;
            p.cx = Math.max(15, Math.min(w - 15, p.cx));
            p.cy = Math.max(45, Math.min(h - 65, p.cy));

            // Blend between chaos and order positions
            var ox = p.tx + Math.sin(t + p.phase) * 4;
            var oy = p.ty + Math.cos(t * 0.7 + p.phase) * 3;
            p.x = lerp(p.cx, ox, morph);
            p.y = lerp(p.cy, oy, morph);
        }

        // Connection lines (fade in with morph)
        if (morph > 0.05) {
            for (var i = 0; i < particles.length; i++) {
                ctx.beginPath();
                ctx.moveTo(cx, cy);
                ctx.lineTo(particles[i].x, particles[i].y);
                ctx.strokeStyle = 'rgba(' + particles[i].col.join(',') + ',' + (0.08 * morph) + ')';
                ctx.lineWidth = 0.6;
                ctx.stroke();
            }
        }

        // Chaotic tangled lines (fade out with morph)
        if (morph < 0.95) {
            for (var i = 0; i < particles.length; i++) {
                for (var j = i + 1; j < particles.length; j++) {
                    var dx = particles[i].x - particles[j].x;
                    var dy = particles[i].y - particles[j].y;
                    var dist = Math.sqrt(dx * dx + dy * dy);
                    if (dist < 90) {
                        ctx.beginPath();
                        ctx.moveTo(particles[i].x, particles[i].y);
                        ctx.lineTo(particles[j].x, particles[j].y);
                        ctx.strokeStyle = 'rgba(180,80,40,' + (0.05 * (1 - dist / 90) * (1 - morph)) + ')';
                        ctx.lineWidth = 0.5;
                        ctx.stroke();
                    }
                }
            }
        }

        // Data pulses (only in order mode)
        if (morph > 0.5 && Math.random() < 0.05) {
            var src = particles[Math.floor(Math.random() * particles.length)];
            pulses.push({
                sx: src.x, sy: src.y, dx: cx, dy: cy,
                progress: 0, speed: 0.01 + Math.random() * 0.008,
                col: src.col
            });
        }
        for (var i = pulses.length - 1; i >= 0; i--) {
            var p = pulses[i];
            p.progress += p.speed;
            if (p.progress > 1) { pulses.splice(i, 1); continue; }
            var px = p.sx + (p.dx - p.sx) * p.progress;
            var py = p.sy + (p.dy - p.sy) * p.progress;
            var a = Math.sin(p.progress * Math.PI) * 0.6 * morph;
            ctx.beginPath(); ctx.arc(px, py, 2.5, 0, Math.PI * 2);
            ctx.fillStyle = 'rgba(' + p.col.join(',') + ',' + a + ')';
            ctx.fill();
        }

        // Center hub (fades in with morph)
        if (morph > 0.1) {
            var hubR = 12 * morph;
            var hubGlow = 28 * morph;
            ctx.beginPath(); ctx.arc(cx, cy, hubGlow, 0, Math.PI * 2);
            ctx.fillStyle = 'rgba(212,112,44,' + (0.06 * morph) + ')';
            ctx.fill();
            ctx.beginPath(); ctx.arc(cx, cy, hubR, 0, Math.PI * 2);
            ctx.fillStyle = 'rgba(212,112,44,' + (0.25 * morph) + ')';
            ctx.fill();
            if (morph > 0.6) {
                ctx.font = '600 ' + Math.round(10 * morph) + 'px Inter, sans-serif';
                ctx.fillStyle = 'rgba(212,112,44,' + ((morph - 0.6) * 2) + ')';
                ctx.textAlign = 'center';
                ctx.fillText('ORG BRAIN', cx, cy + hubR + 16);
            }
        }

        // Draw particles
        for (var i = 0; i < particles.length; i++) {
            var p = particles[i];
            var pulse = (Math.sin(t * 3 + p.phase) + 1) / 2;
            // Glow (stronger in order mode)
            var glowR = p.r + lerp(2, 8, morph);
            ctx.beginPath(); ctx.arc(p.x, p.y, glowR, 0, Math.PI * 2);
            ctx.fillStyle = 'rgba(' + p.col.join(',') + ',' + lerp(0.02, 0.06, morph) + ')';
            ctx.fill();
            // Node
            ctx.beginPath(); ctx.arc(p.x, p.y, p.r + pulse * 0.5, 0, Math.PI * 2);
            ctx.fillStyle = 'rgba(' + p.col.join(',') + ',' + lerp(0.2, 0.45, morph) + ')';
            ctx.fill();
        }

        requestAnimationFrame(draw);
    }

    // Toggle handler
    bar.addEventListener('click', function(e) {
        var opt = e.target.closest('.mach1__morph-opt');
        if (!opt) return;
        var newMode = opt.getAttribute('data-mode');
        if (newMode === mode) return;
        mode = newMode;
        opts.forEach(function(o) { o.classList.remove('is-active'); });
        opt.classList.add('is-active');
        // Update slider position and color
        if (mode === 'order') {
            slider.style.left = opts[0].offsetWidth + 'px';
            slider.style.width = opts[1].offsetWidth + 'px';
            slider.className = 'mach1__morph-slider mach1__morph-slider--order';
            tag.className = 'mach1__morph-tag mach1__morph-tag--green';
            tag.textContent = 'Persistent';
            desc.textContent = '28 memories. Structured flow. Intelligence compounds.';
        } else {
            slider.style.left = '2px';
            slider.style.width = opts[0].offsetWidth + 'px';
            slider.className = 'mach1__morph-slider mach1__morph-slider--chaos';
            tag.className = 'mach1__morph-tag mach1__morph-tag--red';
            tag.textContent = 'Chaotic';
            desc.textContent = 'Fast outputs. No memory. Every prompt starts from zero.';
        }
        clearTimeout(autoTimer);
        userClicked = true;
    });

    // Position slider initially
    function positionSlider() {
        slider.style.left = '2px';
        slider.style.width = opts[0].offsetWidth + 'px';
    }

    // Auto-toggle every 4s
    var userClicked = false;
    var autoTimer;
    function autoToggle() {
        if (userClicked) return;
        var nextOpt = mode === 'chaos' ? opts[1] : opts[0];
        nextOpt.click();
        userClicked = false; // reset since auto-click
        autoTimer = setTimeout(autoToggle, 4000);
    }
    autoTimer = setTimeout(autoToggle, 3500);

    var obs = new IntersectionObserver(function(e) {
        if (e[0].isIntersecting) { resize(); init(); positionSlider(); draw(); obs.disconnect(); }
    }, { threshold: 0.1 });
    obs.observe(canvas.parentElement);
    window.addEventListener('resize', function() { resize(); });
})();

/* ========================================================
   INTERACTIVE ORG BRAIN EXPLORER — Hoverable memory network
   ======================================================== */
(function() {
    const wrap = document.getElementById('brainExplorer');
    const canvas = document.getElementById('brainCanvas');
    const tooltip = document.getElementById('brainTooltip');
    if (!canvas || !wrap) return;
    const ctx = canvas.getContext('2d');
    let w, h, memories = [], connections = [], pulses = [], t = 0, hovered = null;

    const CLUSTERS = [
        { name: 'Identity', color: [212,112,44], memories: ['Brand Voice','Market Position','Value Proposition','Origin Story','Mission','Visual Identity','Customer Promise'] },
        { name: 'Strategy', color: [54,209,183], memories: ['Innovation','Product Strategy','Pricing','Go-to-Market','Competitive Intel','Growth Model','Partnerships'] },
        { name: 'Operations', color: [155,93,229], memories: ['Workflow','Process','Tech Stack','Integration Map','Quality Standards','Vendor Relations','Decision Framework'] },
        { name: 'Culture', color: [245,100,147], memories: ['Values','Communication','Leadership','Onboarding','Learning','Governance','Social Impact'] }
    ];

    function resize() {
        const r = window.devicePixelRatio || 1;
        const parent = canvas.parentElement;
        w = parent.offsetWidth; h = parent.offsetHeight;
        canvas.width = w * r; canvas.height = h * r;
        ctx.scale(r, r);
    }

    function createMemories() {
        memories = [];
        connections = [];
        const cx = w / 2, cy = h / 2;
        const clusterRadius = Math.min(w, h) * 0.32;

        CLUSTERS.forEach((cluster, ci) => {
            const angle = (ci / CLUSTERS.length) * Math.PI * 2 - Math.PI / 2;
            const clusterCx = cx + Math.cos(angle) * clusterRadius * 0.6;
            const clusterCy = cy + Math.sin(angle) * clusterRadius * 0.6;

            cluster.memories.forEach((name, mi) => {
                const a2 = angle + ((mi - 3) / 7) * 1.2;
                const dist = clusterRadius * (0.35 + mi * 0.08) + (Math.random() - 0.5) * 30;
                const x = cx + Math.cos(a2) * dist;
                const y = cy + Math.sin(a2) * dist;
                memories.push({
                    x, y, baseX: x, baseY: y,
                    r: mi === 0 ? 7 : 4 + Math.random() * 2,
                    name, cluster: ci,
                    col: cluster.color,
                    clusterName: cluster.name,
                    phase: Math.random() * Math.PI * 2
                });
            });
        });

        // Central "Org Brain" node
        memories.push({
            x: cx, y: cy, baseX: cx, baseY: cy,
            r: 12, name: 'Org Brain', cluster: -1,
            col: [212,112,44], clusterName: 'Core',
            phase: 0
        });

        // Create connections within clusters and to center
        const center = memories[memories.length - 1];
        for (let i = 0; i < memories.length - 1; i++) {
            // Connect to center
            connections.push([i, memories.length - 1]);
            // Connect within cluster
            for (let j = i + 1; j < memories.length - 1; j++) {
                if (memories[i].cluster === memories[j].cluster) {
                    const dx = memories[i].baseX - memories[j].baseX;
                    const dy = memories[i].baseY - memories[j].baseY;
                    if (Math.sqrt(dx*dx + dy*dy) < clusterRadius * 0.6) {
                        connections.push([i, j]);
                    }
                }
            }
        }
    }

    function spawnPulse() {
        if (connections.length === 0) return;
        const c = connections[Math.floor(Math.random() * connections.length)];
        const a = memories[c[0]], b = memories[c[1]];
        const dir = Math.random() > 0.5;
        pulses.push({
            sx: dir ? a.x : b.x, sy: dir ? a.y : b.y,
            dx: dir ? b.x : a.x, dy: dir ? b.y : a.y,
            progress: 0, speed: 0.006 + Math.random() * 0.006,
            col: a.col
        });
    }

    function draw() {
        t += 0.003;
        ctx.clearRect(0, 0, w, h);

        // Float nodes
        for (const m of memories) {
            m.x = m.baseX + Math.sin(t * 0.8 + m.phase) * 4;
            m.y = m.baseY + Math.cos(t * 0.6 + m.phase) * 3;
        }

        // Connections
        for (const [ai, bi] of connections) {
            const a = memories[ai], b = memories[bi];
            const isHovered = hovered && (hovered === ai || hovered === bi);
            const alpha = isHovered ? 0.15 : 0.04;
            ctx.beginPath();
            ctx.moveTo(a.x, a.y);
            ctx.lineTo(b.x, b.y);
            ctx.strokeStyle = 'rgba(' + a.col.join(',') + ',' + alpha + ')';
            ctx.lineWidth = isHovered ? 1.2 : 0.6;
            ctx.stroke();
        }

        // Pulses
        if (Math.random() < 0.04) spawnPulse();
        for (let i = pulses.length - 1; i >= 0; i--) {
            const p = pulses[i];
            p.progress += p.speed;
            if (p.progress > 1) { pulses.splice(i, 1); continue; }
            const x = p.sx + (p.dx - p.sx) * p.progress;
            const y = p.sy + (p.dy - p.sy) * p.progress;
            const alpha = Math.sin(p.progress * Math.PI);
            ctx.beginPath();
            ctx.arc(x, y, 2, 0, Math.PI * 2);
            ctx.fillStyle = 'rgba(' + p.col.join(',') + ',' + (alpha * 0.6) + ')';
            ctx.fill();
        }

        // Nodes
        for (let i = 0; i < memories.length; i++) {
            const m = memories[i];
            const isHov = hovered === i;
            const pulse = (Math.sin(t * 3 + m.phase) + 1) / 2;
            const r = m.r + (isHov ? 3 : pulse * 1);
            const alpha = isHov ? 0.9 : (0.3 + pulse * 0.2);

            // Glow
            ctx.beginPath();
            ctx.arc(m.x, m.y, r + (isHov ? 14 : 8), 0, Math.PI * 2);
            ctx.fillStyle = 'rgba(' + m.col.join(',') + ',' + (isHov ? 0.12 : 0.04) + ')';
            ctx.fill();

            // Node
            ctx.beginPath();
            ctx.arc(m.x, m.y, r, 0, Math.PI * 2);
            ctx.fillStyle = 'rgba(' + m.col.join(',') + ',' + alpha + ')';
            ctx.fill();

            // Label for hovered or center
            if (isHov || m.cluster === -1) {
                ctx.font = (m.cluster === -1 ? '600 11px' : '500 11px') + ' Inter, sans-serif';
                ctx.fillStyle = 'rgba(' + m.col.join(',') + ',' + (isHov ? 1 : 0.5) + ')';
                ctx.textAlign = 'center';
                ctx.fillText(m.name, m.x, m.y + r + 16);
            }
        }

        requestAnimationFrame(draw);
    }

    // Mouse interaction
    canvas.parentElement.style.pointerEvents = 'auto';
    canvas.style.pointerEvents = 'auto';
    canvas.addEventListener('mousemove', function(e) {
        const rect = canvas.getBoundingClientRect();
        const scaleX = w / rect.width, scaleY = h / rect.height;
        const mx = (e.clientX - rect.left) * scaleX;
        const my = (e.clientY - rect.top) * scaleY;
        let found = null;
        for (let i = 0; i < memories.length; i++) {
            const dx = mx - memories[i].x, dy = my - memories[i].y;
            if (Math.sqrt(dx*dx + dy*dy) < memories[i].r + 12) { found = i; break; }
        }
        hovered = found;
        if (found !== null) {
            const m = memories[found];
            tooltip.textContent = m.clusterName + ' → ' + m.name;
            tooltip.classList.add('is-visible');
            tooltip.style.left = (e.clientX - rect.left) + 'px';
            tooltip.style.top = (e.clientY - rect.top) + 'px';
            canvas.style.cursor = 'pointer';
        } else {
            tooltip.classList.remove('is-visible');
            canvas.style.cursor = 'crosshair';
        }
    });
    canvas.addEventListener('mouseleave', function() {
        hovered = null;
        tooltip.classList.remove('is-visible');
    });

    const obs = new IntersectionObserver(e => {
        if (e[0].isIntersecting) { resize(); createMemories(); draw(); obs.disconnect(); }
    }, { threshold: 0.1 });
    obs.observe(wrap);
    window.addEventListener('resize', () => { resize(); createMemories(); });
})();

/* ========================================================
   GUIDE — Interactive radial diagram of 17 value systems
   ======================================================== */
(function() {
    const canvas = document.getElementById('guideCanvas');
    if (!canvas) return;
    const ctx = canvas.getContext('2d');
    let w, h, t = 0, mx = -1, my = -1, hovered = -1;

    const systems = [
        'Mission','Vision','Values','Voice','Strategy',
        'Decisions','Workflows','Standards','Policies','Roles',
        'Culture','Onboarding','Feedback','Learning','Communication',
        'Innovation','Growth'
    ];
    const rings = [
        {label:'Identity', color:'212,112,44', items:[0,1,2,3]},
        {label:'Strategy', color:'54,209,183', items:[4,5,6]},
        {label:'Operations', color:'107,92,200', items:[7,8,9,10]},
        {label:'Culture', color:'245,100,147', items:[11,12,13,14,15,16]}
    ];

    let nodes = [];

    function resize() {
        const r = window.devicePixelRatio || 1;
        w = canvas.offsetWidth; h = canvas.offsetHeight;
        canvas.width = w * r; canvas.height = h * r;
        ctx.scale(r, r);
    }
    function layout() {
        nodes = [];
        const cx = w / 2, cy = h / 2;
        const maxR = Math.min(w, h) * 0.4;
        rings.forEach((ring, ri) => {
            const ringR = maxR * (0.35 + ri * 0.22);
            ring.items.forEach((si, ni) => {
                const angle = (Math.PI * 2 / ring.items.length) * ni - Math.PI / 2 + ri * 0.3;
                nodes.push({
                    x: cx + Math.cos(angle) * ringR,
                    y: cy + Math.sin(angle) * ringR,
                    angle, ringR, ringIdx: ri,
                    label: systems[si],
                    color: ring.color,
                    r: 6,
                    phase: Math.random() * Math.PI * 2
                });
            });
        });
    }

    canvas.addEventListener('mousemove', function(e) {
        const rect = canvas.getBoundingClientRect();
        mx = e.clientX - rect.left; my = e.clientY - rect.top;
    });
    canvas.addEventListener('mouseleave', function() { mx = -1; my = -1; hovered = -1; });
    canvas.style.cursor = 'default';

    function draw() {
        t += 0.008;
        ctx.clearRect(0, 0, w, h);
        const cx = w / 2, cy = h / 2;

        /* Draw orbit rings */
        const maxR = Math.min(w, h) * 0.4;
        rings.forEach((ring, ri) => {
            const ringR = maxR * (0.35 + ri * 0.22);
            ctx.beginPath();
            ctx.arc(cx, cy, ringR, 0, Math.PI * 2);
            ctx.strokeStyle = 'rgba(' + ring.color + ',0.1)';
            ctx.lineWidth = 1;
            ctx.stroke();
        });

        /* Center hub */
        ctx.beginPath();
        ctx.arc(cx, cy, 14, 0, Math.PI * 2);
        ctx.fillStyle = 'rgba(212,112,44,0.12)';
        ctx.fill();
        ctx.beginPath();
        ctx.arc(cx, cy, 6, 0, Math.PI * 2);
        ctx.fillStyle = 'rgba(212,112,44,0.6)';
        ctx.fill();

        /* Connecting lines from center to nodes */
        hovered = -1;
        for (let i = 0; i < nodes.length; i++) {
            const n = nodes[i];
            const breathe = Math.sin(t + n.phase) * 2;
            const nx = n.x + breathe * Math.cos(n.angle);
            const ny = n.y + breathe * Math.sin(n.angle);

            /* Check hover */
            if (mx > 0) {
                const dx = mx - nx, dy = my - ny;
                if (Math.sqrt(dx * dx + dy * dy) < 18) hovered = i;
            }

            const isHov = hovered === i;

            /* Line to center */
            ctx.beginPath();
            ctx.moveTo(cx, cy);
            ctx.lineTo(nx, ny);
            ctx.strokeStyle = 'rgba(' + n.color + ',' + (isHov ? 0.3 : 0.06) + ')';
            ctx.lineWidth = 1;
            ctx.stroke();

            /* Data pulse along line */
            const pulseT = ((t * 0.5 + n.phase) % 1);
            const px = cx + (nx - cx) * pulseT;
            const py = cy + (ny - cy) * pulseT;
            ctx.beginPath();
            ctx.arc(px, py, 1.5, 0, Math.PI * 2);
            ctx.fillStyle = 'rgba(' + n.color + ',0.25)';
            ctx.fill();

            /* Node glow */
            if (isHov) {
                ctx.beginPath();
                ctx.arc(nx, ny, 18, 0, Math.PI * 2);
                ctx.fillStyle = 'rgba(' + n.color + ',0.08)';
                ctx.fill();
            }

            /* Node dot */
            ctx.beginPath();
            ctx.arc(nx, ny, isHov ? 8 : n.r, 0, Math.PI * 2);
            ctx.fillStyle = 'rgba(' + n.color + ',' + (isHov ? 0.8 : 0.4) + ')';
            ctx.fill();

            /* Label on hover */
            if (isHov) {
                canvas.style.cursor = 'pointer';
                ctx.font = '500 12px Inter, sans-serif';
                ctx.fillStyle = 'rgba(45,37,100,0.85)';
                ctx.textAlign = 'center';
                ctx.fillText(n.label, nx, ny - 16);
            }
        }
        if (hovered === -1) canvas.style.cursor = 'default';

        /* Center label */
        ctx.font = '600 10px Inter, sans-serif';
        ctx.fillStyle = 'rgba(45,37,100,0.4)';
        ctx.textAlign = 'center';
        ctx.fillText('17', cx, cy + 3.5);

        requestAnimationFrame(draw);
    }

    const obs = new IntersectionObserver(e => {
        if (e[0].isIntersecting) { resize(); layout(); draw(); obs.disconnect(); }
    }, { threshold: 0.1 });
    obs.observe(canvas.parentElement);
    window.addEventListener('resize', () => { resize(); layout(); });
})();

/* ========================================================
   FINALE — Subtle floating particles on light background
   ======================================================== */
(function() {
    const canvas = document.getElementById('ctaCanvas');
    if (!canvas) return;
    const ctx = canvas.getContext('2d');
    let w, h, particles = [];
    const colors = ['212,112,44','54,209,183','245,100,147','251,191,36'];

    function resize() {
        const r = window.devicePixelRatio || 1;
        w = canvas.offsetWidth; h = canvas.offsetHeight;
        canvas.width = w * r; canvas.height = h * r;
        ctx.scale(r, r);
    }
    function init() {
        particles = [];
        for (let i = 0; i < 60; i++) {
            particles.push({
                x: Math.random() * w, y: Math.random() * h,
                r: 1 + Math.random() * 3,
                dx: (Math.random() - 0.5) * 0.3,
                dy: (Math.random() - 0.5) * 0.3,
                color: colors[Math.floor(Math.random() * colors.length)],
                alpha: 0.06 + Math.random() * 0.1
            });
        }
    }
    function draw() {
        ctx.clearRect(0, 0, w, h);
        for (const p of particles) {
            p.x += p.dx; p.y += p.dy;
            if (p.x < -10) p.x = w + 10;
            if (p.x > w + 10) p.x = -10;
            if (p.y < -10) p.y = h + 10;
            if (p.y > h + 10) p.y = -10;
            ctx.beginPath();
            ctx.arc(p.x, p.y, p.r, 0, Math.PI * 2);
            ctx.fillStyle = 'rgba(' + p.color + ',' + p.alpha + ')';
            ctx.fill();
        }
        /* Faint connecting lines between nearby particles */
        for (let i = 0; i < particles.length; i++) {
            for (let j = i + 1; j < particles.length; j++) {
                const dx = particles[i].x - particles[j].x;
                const dy = particles[i].y - particles[j].y;
                const dist = Math.sqrt(dx * dx + dy * dy);
                if (dist < 120) {
                    ctx.beginPath();
                    ctx.moveTo(particles[i].x, particles[i].y);
                    ctx.lineTo(particles[j].x, particles[j].y);
                    ctx.strokeStyle = 'rgba(212,112,44,' + (0.04 * (1 - dist / 120)) + ')';
                    ctx.stroke();
                }
            }
        }
        requestAnimationFrame(draw);
    }
    const obs = new IntersectionObserver(e => {
        if (e[0].isIntersecting) { resize(); init(); draw(); obs.disconnect(); }
    }, { threshold: 0.1 });
    obs.observe(canvas.parentElement);
    window.addEventListener('resize', () => { resize(); init(); });
})();

/* ========================================================
   LICENSE VIZ — Animated journey illustration
   3 tier hubs with orbiting nodes, data flowing left→right,
   auto-cycling spotlight, hoverable labels
   ======================================================== */
(function() {
    const canvas = document.getElementById('licenseCanvas');
    if (!canvas) return;
    const ctx = canvas.getContext('2d');
    let w, h, t = 0, mx = -1, my = -1, hovered = -1;

    const tiers = [
        { label:'Sprint', sub:'Sprints 1–2', color:[54,209,183], nodes:8, orbR:0 },
        { label:'Program', sub:'Sprints 3–5', color:[212,112,44], nodes:12, orbR:0 },
        { label:'Enterprise', sub:'Sprints 6–8', color:[245,100,147], nodes:10, orbR:0 }
    ];
    let hubs = [], orbiters = [], flowPulses = [];

    function resize() {
        const r = window.devicePixelRatio || 1;
        w = canvas.offsetWidth; h = canvas.offsetHeight;
        canvas.width = w * r; canvas.height = h * r;
        ctx.scale(r, r);
    }

    function layout() {
        hubs = []; orbiters = []; flowPulses = [];
        const spacing = w / (tiers.length + 1);
        const maxOrb = Math.min(spacing * 0.35, h * 0.35);
        tiers.forEach((tier, i) => {
            const cx = spacing * (i + 1);
            const cy = h / 2;
            tier.orbR = maxOrb * (0.7 + i * 0.15);
            hubs.push({ x: cx, y: cy, r: 18 + i * 4 });
            /* Orbiting nodes */
            for (let n = 0; n < tier.nodes; n++) {
                const angle = (Math.PI * 2 / tier.nodes) * n;
                const dist = tier.orbR * (0.6 + Math.random() * 0.4);
                orbiters.push({
                    hub: i, angle, dist,
                    speed: 0.15 + Math.random() * 0.2,
                    r: 2 + Math.random() * 2.5,
                    phase: Math.random() * Math.PI * 2
                });
            }
        });
    }

    canvas.addEventListener('mousemove', function(e) {
        const rect = canvas.getBoundingClientRect();
        mx = e.clientX - rect.left; my = e.clientY - rect.top;
    });
    canvas.addEventListener('mouseleave', function() { mx = -1; my = -1; hovered = -1; });

    function draw() {
        t += 0.005;
        ctx.clearRect(0, 0, w, h);
        const spacing = w / (tiers.length + 1);

        /* Auto-cycle active tier */
        const activeIdx = Math.floor((t * 0.3) % 3);

        /* Draw flow connections between hubs */
        for (let i = 0; i < hubs.length - 1; i++) {
            const a = hubs[i], b = hubs[i + 1];
            /* Curved connector */
            const cpY = h / 2 - 40;
            ctx.beginPath();
            ctx.moveTo(a.x + a.r + 10, a.y);
            ctx.quadraticCurveTo((a.x + b.x) / 2, cpY, b.x - b.r - 10, b.y);
            ctx.strokeStyle = 'rgba(212,112,44,0.08)';
            ctx.lineWidth = 1.5;
            ctx.stroke();

            /* Flowing data pulses along path */
            for (let p = 0; p < 3; p++) {
                const pt = ((t * 0.8 + p * 0.33 + i * 0.5) % 1);
                const px = a.x + a.r + 10 + (b.x - b.r - 10 - a.x - a.r - 10) * pt;
                const py = a.y + (cpY - a.y) * 2 * pt * (1 - pt) + 0;
                /* Quadratic bezier point */
                const tt = pt;
                const bx = (1-tt)*(1-tt)*(a.x+a.r+10) + 2*(1-tt)*tt*((a.x+b.x)/2) + tt*tt*(b.x-b.r-10);
                const by = (1-tt)*(1-tt)*a.y + 2*(1-tt)*tt*cpY + tt*tt*b.y;
                const alpha = Math.sin(pt * Math.PI) * 0.6;
                ctx.beginPath();
                ctx.arc(bx, by, 3, 0, Math.PI * 2);
                ctx.fillStyle = 'rgba(' + tiers[i].color.join(',') + ',' + alpha * 0.4 + ')';
                ctx.fill();
                ctx.beginPath();
                ctx.arc(bx, by, 1.5, 0, Math.PI * 2);
                ctx.fillStyle = 'rgba(' + tiers[i].color.join(',') + ',' + alpha + ')';
                ctx.fill();
            }
        }

        /* Draw orbit rings */
        tiers.forEach((tier, i) => {
            const hub = hubs[i];
            const isActive = i === activeIdx;
            const isHov = hovered === i;
            const highlight = isActive || isHov;

            /* Orbit circle */
            ctx.beginPath();
            ctx.arc(hub.x, hub.y, tier.orbR, 0, Math.PI * 2);
            ctx.strokeStyle = 'rgba(' + tier.color.join(',') + ',' + (highlight ? 0.12 : 0.05) + ')';
            ctx.lineWidth = 1;
            ctx.stroke();

            /* Inner orbit */
            ctx.beginPath();
            ctx.arc(hub.x, hub.y, tier.orbR * 0.6, 0, Math.PI * 2);
            ctx.strokeStyle = 'rgba(' + tier.color.join(',') + ',' + (highlight ? 0.08 : 0.03) + ')';
            ctx.stroke();
        });

        /* Draw orbiters */
        for (const orb of orbiters) {
            const hub = hubs[orb.hub];
            const tier = tiers[orb.hub];
            const isActive = orb.hub === activeIdx || hovered === orb.hub;
            const a = orb.angle + t * orb.speed;
            const ox = hub.x + Math.cos(a) * orb.dist;
            const oy = hub.y + Math.sin(a) * orb.dist;
            const pulse = (Math.sin(t * 2 + orb.phase) + 1) / 2;
            const alpha = isActive ? (0.3 + pulse * 0.3) : (0.1 + pulse * 0.08);

            /* Faint line to hub */
            ctx.beginPath();
            ctx.moveTo(hub.x, hub.y);
            ctx.lineTo(ox, oy);
            ctx.strokeStyle = 'rgba(' + tier.color.join(',') + ',' + (alpha * 0.15) + ')';
            ctx.lineWidth = 0.5;
            ctx.stroke();

            ctx.beginPath();
            ctx.arc(ox, oy, orb.r + (isActive ? pulse : 0), 0, Math.PI * 2);
            ctx.fillStyle = 'rgba(' + tier.color.join(',') + ',' + alpha + ')';
            ctx.fill();
        }

        /* Draw hub centers */
        hovered = -1;
        tiers.forEach((tier, i) => {
            const hub = hubs[i];
            const isActive = i === activeIdx;

            /* Check hover */
            if (mx > 0) {
                const dx = mx - hub.x, dy = my - hub.y;
                if (Math.sqrt(dx * dx + dy * dy) < tier.orbR) hovered = i;
            }
            const highlight = isActive || hovered === i;

            /* Outer glow */
            if (highlight) {
                ctx.beginPath();
                ctx.arc(hub.x, hub.y, hub.r + 20, 0, Math.PI * 2);
                const g = ctx.createRadialGradient(hub.x, hub.y, hub.r, hub.x, hub.y, hub.r + 20);
                g.addColorStop(0, 'rgba(' + tier.color.join(',') + ',0.1)');
                g.addColorStop(1, 'rgba(' + tier.color.join(',') + ',0)');
                ctx.fillStyle = g;
                ctx.fill();
            }

            /* Hub circle */
            ctx.beginPath();
            ctx.arc(hub.x, hub.y, hub.r, 0, Math.PI * 2);
            ctx.fillStyle = 'rgba(' + tier.color.join(',') + ',' + (highlight ? 0.2 : 0.08) + ')';
            ctx.fill();

            /* Inner dot */
            ctx.beginPath();
            ctx.arc(hub.x, hub.y, 4, 0, Math.PI * 2);
            ctx.fillStyle = 'rgba(' + tier.color.join(',') + ',' + (highlight ? 0.8 : 0.4) + ')';
            ctx.fill();

            /* Label */
            ctx.font = '600 13px Inter, sans-serif';
            ctx.fillStyle = highlight ? 'rgba(45,37,100,0.8)' : 'rgba(45,37,100,0.35)';
            ctx.textAlign = 'center';
            ctx.fillText(tier.label, hub.x, hub.y + hub.r + 28);

            ctx.font = '400 11px Inter, sans-serif';
            ctx.fillStyle = highlight ? 'rgba(79,85,107,0.7)' : 'rgba(79,85,107,0.25)';
            ctx.fillText(tier.sub, hub.x, hub.y + hub.r + 44);
        });

        canvas.style.cursor = hovered >= 0 ? 'pointer' : 'default';
        requestAnimationFrame(draw);
    }

    const obs = new IntersectionObserver(e => {
        if (e[0].isIntersecting) { resize(); layout(); draw(); obs.disconnect(); }
    }, { threshold: 0.1 });
    obs.observe(canvas.parentElement);
    window.addEventListener('resize', () => { resize(); layout(); });
})();

/* ========================================================
   CURRICULUM — Animated sprint progress timeline
   ======================================================== */
(function() {
    const canvas = document.getElementById('curriculumCanvas');
    if (!canvas) return;
    const ctx = canvas.getContext('2d');
    let w, h, t = 0, mx = -1, my = -1, hovered = -1;

    const sprints = [
        'Innovation System','Applied Intelligence',
        'Optimization System','Cognitive System','Translation System',
        'Starling OS','Org Strategy','Governance & Impact'
    ];
    const tiers = [
        { name:'System Librarian', color:[54,209,183], start:0, end:1 },
        { name:'Cognitive Designer', color:[212,112,44], start:2, end:4 },
        { name:'Chief Intelligence Officer', color:[245,100,147], start:5, end:7 }
    ];

    function resize() {
        const r = window.devicePixelRatio || 1;
        w = canvas.offsetWidth; h = canvas.offsetHeight;
        canvas.width = w * r; canvas.height = h * r;
        ctx.scale(r, r);
    }

    canvas.addEventListener('mousemove', e => {
        const rect = canvas.getBoundingClientRect();
        mx = e.clientX - rect.left; my = e.clientY - rect.top;
    });
    canvas.addEventListener('mouseleave', () => { mx = -1; my = -1; hovered = -1; });

    function getNodeX(i) { return w * 0.08 + (w * 0.84 / 7) * i; }
    const nodeY = () => h * 0.45;

    function draw() {
        t += 0.004;
        ctx.clearRect(0, 0, w, h);
        const cy = nodeY();

        /* Beam sweep (cycles every ~8s) */
        const beamPos = ((t * 0.5) % 1);
        const beamX = w * 0.08 + beamPos * w * 0.84;

        /* Tier zone backgrounds */
        tiers.forEach(tier => {
            const x1 = getNodeX(tier.start) - 20;
            const x2 = getNodeX(tier.end) + 20;
            ctx.fillStyle = 'rgba(' + tier.color.join(',') + ',0.03)';
            ctx.fillRect(x1, cy - 50, x2 - x1, 100);

            /* Tier label */
            ctx.font = '500 11px Inter, sans-serif';
            ctx.fillStyle = 'rgba(' + tier.color.join(',') + ',0.5)';
            ctx.textAlign = 'center';
            ctx.fillText(tier.name, (x1 + x2) / 2, cy + 70);
        });

        /* Main timeline line */
        ctx.beginPath();
        ctx.moveTo(getNodeX(0), cy);
        ctx.lineTo(getNodeX(7), cy);
        ctx.strokeStyle = 'rgba(0,0,0,0.06)';
        ctx.lineWidth = 2;
        ctx.stroke();

        /* Beam glow */
        const g = ctx.createRadialGradient(beamX, cy, 0, beamX, cy, 60);
        g.addColorStop(0, 'rgba(212,112,44,0.12)');
        g.addColorStop(1, 'rgba(212,112,44,0)');
        ctx.fillStyle = g;
        ctx.fillRect(beamX - 60, cy - 60, 120, 120);

        /* Sprint nodes */
        hovered = -1;
        for (let i = 0; i < 8; i++) {
            const nx = getNodeX(i);
            const tier = tiers.find(t => i >= t.start && i <= t.end);
            const col = tier.color;

            /* Check hover */
            if (mx > 0) {
                const dx = mx - nx, dy = my - cy;
                if (Math.sqrt(dx * dx + dy * dy) < 25) hovered = i;
            }

            const isLit = nx < beamX;
            const isHov = hovered === i;
            const pulse = (Math.sin(t * 3 + i * 0.8) + 1) / 2;

            /* Memory dots orbiting lit nodes */
            if (isLit) {
                const memCount = 3 + (i % 3);
                for (let m = 0; m < memCount; m++) {
                    const ma = (Math.PI * 2 / memCount) * m + t * (1.5 + i * 0.2);
                    const md = 16 + Math.sin(t + m) * 4;
                    const mmx = nx + Math.cos(ma) * md;
                    const mmy = cy + Math.sin(ma) * md;
                    ctx.beginPath();
                    ctx.arc(mmx, mmy, 1.5, 0, Math.PI * 2);
                    ctx.fillStyle = 'rgba(' + col.join(',') + ',' + (0.2 + pulse * 0.2) + ')';
                    ctx.fill();
                }
            }

            /* Connecting lines within tier */
            if (i > 0) {
                const prevTier = tiers.find(t => (i-1) >= t.start && (i-1) <= t.end);
                if (prevTier === tier) {
                    ctx.beginPath();
                    ctx.moveTo(getNodeX(i - 1), cy);
                    ctx.lineTo(nx, cy);
                    ctx.strokeStyle = 'rgba(' + col.join(',') + ',' + (isLit ? 0.25 : 0.08) + ')';
                    ctx.lineWidth = 2;
                    ctx.stroke();

                    /* Data pulse along segment */
                    if (isLit) {
                        const pp = ((t * 1.2 + i * 0.3) % 1);
                        const ppx = getNodeX(i - 1) + (nx - getNodeX(i - 1)) * pp;
                        ctx.beginPath();
                        ctx.arc(ppx, cy, 2, 0, Math.PI * 2);
                        ctx.fillStyle = 'rgba(' + col.join(',') + ',' + (Math.sin(pp * Math.PI) * 0.5) + ')';
                        ctx.fill();
                    }
                }
            }

            /* Node glow */
            if (isHov || isLit) {
                ctx.beginPath();
                ctx.arc(nx, cy, isHov ? 22 : 16, 0, Math.PI * 2);
                ctx.fillStyle = 'rgba(' + col.join(',') + ',' + (isHov ? 0.1 : 0.05) + ')';
                ctx.fill();
            }

            /* Node circle */
            const nr = isHov ? 8 : (isLit ? 6 + pulse : 5);
            ctx.beginPath();
            ctx.arc(nx, cy, nr, 0, Math.PI * 2);
            ctx.fillStyle = 'rgba(' + col.join(',') + ',' + (isLit ? (0.5 + pulse * 0.3) : 0.15) + ')';
            ctx.fill();

            /* Sprint number */
            ctx.font = '600 10px Inter, sans-serif';
            ctx.fillStyle = 'rgba(45,37,100,' + (isLit ? 0.5 : 0.2) + ')';
            ctx.textAlign = 'center';
            ctx.fillText((i + 1), nx, cy - 18);

            /* Hover label */
            if (isHov) {
                canvas.style.cursor = 'pointer';
                ctx.font = '500 12px Inter, sans-serif';
                ctx.fillStyle = 'rgba(45,37,100,0.8)';
                ctx.fillText(sprints[i], nx, cy - 32);
            }
        }
        if (hovered === -1) canvas.style.cursor = 'default';

        requestAnimationFrame(draw);
    }

    const obs = new IntersectionObserver(e => {
        if (e[0].isIntersecting) { resize(); draw(); obs.disconnect(); }
    }, { threshold: 0.1 });
    obs.observe(canvas.parentElement);
    window.addEventListener('resize', resize);
})();

/* ========================================================
   EXIT GUARANTEE — Career pathway visualization
   ======================================================== */
(function() {
    const canvas = document.getElementById('exitCanvas');
    if (!canvas) return;
    const ctx = canvas.getContext('2d');
    let w, h, t = 0, mx = -1, my = -1, hovered = -1;
    let travelers = [];

    const roles = [
        { name:'System Librarian', salary:'$65–85K', color:[54,209,183] },
        { name:'Cognitive Designer', salary:'$95–120K', color:[212,112,44] },
        { name:'Chief Intelligence Officer', salary:'$150–200K+', color:[245,100,147] }
    ];

    function resize() {
        const r = window.devicePixelRatio || 1;
        w = canvas.offsetWidth; h = canvas.offsetHeight;
        canvas.width = w * r; canvas.height = h * r;
        ctx.scale(r, r);
    }

    function initTravelers() {
        travelers = [];
        for (let i = 0; i < 12; i++) {
            travelers.push({
                path: i % 2, /* 0=left, 1=right */
                y: Math.random(),
                speed: 0.002 + Math.random() * 0.003,
                r: 2.5 + Math.random() * 1.5,
                phase: Math.random() * Math.PI * 2
            });
        }
    }

    canvas.addEventListener('mousemove', e => {
        const rect = canvas.getBoundingClientRect();
        mx = e.clientX - rect.left; my = e.clientY - rect.top;
    });
    canvas.addEventListener('mouseleave', () => { mx = -1; my = -1; hovered = -1; });

    function getTierY(i) { return h * 0.78 - (h * 0.56 / 2) * i; }
    function getPathX(p) { return p === 0 ? w * 0.35 : w * 0.65; }

    function draw() {
        t += 0.005;
        ctx.clearRect(0, 0, w, h);
        const activeIdx = Math.floor((t * 0.4) % 3);

        /* Path labels */
        ctx.font = '600 11px Inter, sans-serif';
        ctx.textAlign = 'center';
        ctx.fillStyle = 'rgba(45,37,100,0.3)';
        ctx.fillText('OPTION A', getPathX(0), h * 0.92);
        ctx.fillText('OPTION B', getPathX(1), h * 0.92);
        ctx.font = '400 10px Inter, sans-serif';
        ctx.fillStyle = 'rgba(79,85,107,0.25)';
        ctx.fillText('Certify Internal', getPathX(0), h * 0.96);
        ctx.fillText('Place from Network', getPathX(1), h * 0.96);

        /* Vertical path lines */
        for (let p = 0; p < 2; p++) {
            const px = getPathX(p);
            ctx.beginPath();
            ctx.moveTo(px, h * 0.85);
            ctx.lineTo(px, h * 0.08);
            ctx.strokeStyle = 'rgba(0,0,0,0.04)';
            ctx.lineWidth = 1.5;
            ctx.stroke();
        }

        /* Draw tier nodes + connecting arcs */
        hovered = -1;
        for (let i = 0; i < 3; i++) {
            const ty = getTierY(i);
            const col = roles[i].color;
            const isActive = i === activeIdx;

            /* Check hover */
            if (mx > 0) {
                const cx = w / 2;
                const dx = mx - cx, dy = my - ty;
                if (Math.abs(dy) < 30 && Math.abs(dx) < w * 0.35) hovered = i;
            }
            const highlight = isActive || hovered === i;

            /* Connecting arc between paths */
            ctx.beginPath();
            ctx.moveTo(getPathX(0), ty);
            ctx.quadraticCurveTo(w / 2, ty - (highlight ? 20 : 12), getPathX(1), ty);
            ctx.strokeStyle = 'rgba(' + col.join(',') + ',' + (highlight ? 0.2 : 0.06) + ')';
            ctx.lineWidth = 1;
            ctx.stroke();

            /* Horizontal zone glow */
            if (highlight) {
                const g = ctx.createLinearGradient(getPathX(0) - 30, 0, getPathX(1) + 30, 0);
                g.addColorStop(0, 'rgba(' + col.join(',') + ',0)');
                g.addColorStop(0.5, 'rgba(' + col.join(',') + ',0.04)');
                g.addColorStop(1, 'rgba(' + col.join(',') + ',0)');
                ctx.fillStyle = g;
                ctx.fillRect(getPathX(0) - 30, ty - 25, getPathX(1) - getPathX(0) + 60, 50);
            }

            /* Nodes on both paths */
            for (let p = 0; p < 2; p++) {
                const px = getPathX(p);
                const pulse = (Math.sin(t * 2.5 + i + p) + 1) / 2;
                const nr = highlight ? 10 + pulse * 2 : 6;

                /* Outer glow */
                if (highlight) {
                    ctx.beginPath();
                    ctx.arc(px, ty, 22, 0, Math.PI * 2);
                    ctx.fillStyle = 'rgba(' + col.join(',') + ',0.06)';
                    ctx.fill();
                }

                ctx.beginPath();
                ctx.arc(px, ty, nr, 0, Math.PI * 2);
                ctx.fillStyle = 'rgba(' + col.join(',') + ',' + (highlight ? 0.5 + pulse * 0.3 : 0.15) + ')';
                ctx.fill();
            }

            /* Center label */
            ctx.textAlign = 'center';
            ctx.font = (highlight ? '600' : '500') + ' 13px Inter, sans-serif';
            ctx.fillStyle = highlight ? 'rgba(45,37,100,0.85)' : 'rgba(45,37,100,0.25)';
            ctx.fillText(roles[i].name, w / 2, ty - 2);

            /* Salary */
            ctx.font = '500 11px Inter, sans-serif';
            ctx.fillStyle = highlight ? 'rgba(' + col.join(',') + ',0.7)' : 'rgba(' + col.join(',') + ',0.25)';
            ctx.fillText(roles[i].salary, w / 2, ty + 14);
        }

        /* Traveling dots */
        for (const tr of travelers) {
            tr.y -= tr.speed;
            if (tr.y < 0) tr.y = 1;
            const px = getPathX(tr.path);
            const yy = h * 0.85 - tr.y * (h * 0.77);
            const wobble = Math.sin(t * 3 + tr.phase) * 3;
            const alpha = Math.sin(tr.y * Math.PI) * 0.4;

            ctx.beginPath();
            ctx.arc(px + wobble, yy, tr.r, 0, Math.PI * 2);

            /* Color based on which tier zone */
            let col = roles[0].color;
            if (yy < getTierY(2) + 20) col = roles[2].color;
            else if (yy < getTierY(1) + 20) col = roles[1].color;

            ctx.fillStyle = 'rgba(' + col.join(',') + ',' + alpha + ')';
            ctx.fill();
        }

        canvas.style.cursor = hovered >= 0 ? 'pointer' : 'default';
        requestAnimationFrame(draw);
    }

    const obs = new IntersectionObserver(e => {
        if (e[0].isIntersecting) { resize(); initTravelers(); draw(); obs.disconnect(); }
    }, { threshold: 0.1 });
    obs.observe(canvas.parentElement);
    window.addEventListener('resize', () => { resize(); initTravelers(); });
})();

/* ========================================================
   HOW WE WORK — Interactive panel canvases
   ======================================================== */
(function() {
    const canvases = document.querySelectorAll('.hww__panel-canvas');
    if (!canvases.length) return;

    canvases.forEach(canvas => {
        const type = canvas.dataset.type;
        const ctx = canvas.getContext('2d');
        let w, h, t = 0, mx = -1, my = -1;

        function resize() {
            const r = window.devicePixelRatio || 1;
            w = canvas.offsetWidth; h = canvas.offsetHeight;
            canvas.width = w * r; canvas.height = h * r;
            ctx.scale(r, r);
        }

        canvas.closest('.hww__panel').addEventListener('mousemove', e => {
            const rect = canvas.getBoundingClientRect();
            mx = e.clientX - rect.left; my = e.clientY - rect.top;
        });
        canvas.closest('.hww__panel').addEventListener('mouseleave', () => { mx = -1; my = -1; });

        /* Shared: particle burst system */
        const CONFIGS = {
            build:   { colors: [[212,112,44],[245,158,11],[245,100,147]], count: 80, spread: 0.9, speed: 1 },
            license: { colors: [[54,209,183],[0,178,97],[54,209,183]], count: 80, spread: 0.85, speed: 0.8 },
            certify: { colors: [[155,93,229],[139,92,246],[245,100,147]], count: 80, spread: 0.9, speed: 0.9 }
        };
        const cfg = CONFIGS[type];
        if (!cfg) return;

        let particles = [], streams = [];

        function initParticles() {
            particles = []; streams = [];
            const cx = w / 2, cy = h / 2;
            for (let i = 0; i < cfg.count; i++) {
                const angle = Math.random() * Math.PI * 2;
                const dist = 20 + Math.random() * Math.min(w, h) * cfg.spread * 0.45;
                const col = cfg.colors[Math.floor(Math.random() * cfg.colors.length)];
                particles.push({
                    x: cx + Math.cos(angle) * dist,
                    y: cy + Math.sin(angle) * dist,
                    ox: cx + Math.cos(angle) * dist,
                    oy: cy + Math.sin(angle) * dist,
                    r: 1 + Math.random() * 3.5,
                    col: col,
                    phase: Math.random() * Math.PI * 2,
                    vx: (Math.random() - 0.5) * 0.3,
                    vy: (Math.random() - 0.5) * 0.3
                });
            }
            // Flowing streams (curved arcs)
            for (let i = 0; i < 5; i++) {
                const a = (Math.PI * 2 / 5) * i + Math.random() * 0.5;
                streams.push({
                    angle: a,
                    innerR: 30 + Math.random() * 20,
                    outerR: Math.min(w, h) * 0.35 + Math.random() * 30,
                    width: 1 + Math.random() * 1.5,
                    col: cfg.colors[i % cfg.colors.length],
                    phase: Math.random() * Math.PI * 2,
                    arcLen: 0.6 + Math.random() * 0.8
                });
            }
        }

        function drawPanel() {
            t += 0.004 * cfg.speed;
            ctx.clearRect(0, 0, w, h);
            const cx = w / 2, cy = h / 2;
            const hover = mx > 0;
            const hoverScale = hover ? 1.3 : 1;

            // Flowing arc streams
            for (const s of streams) {
                const startAngle = s.angle + t * 0.3 + Math.sin(t + s.phase) * 0.2;
                const endAngle = startAngle + s.arcLen;
                const r = (s.innerR + s.outerR) / 2 + Math.sin(t * 0.8 + s.phase) * 10;
                ctx.beginPath();
                ctx.arc(cx, cy, r, startAngle, endAngle);
                ctx.strokeStyle = 'rgba(' + s.col.join(',') + ',' + (hover ? 0.12 : 0.06) + ')';
                ctx.lineWidth = s.width * hoverScale;
                ctx.stroke();
            }

            // Central glow
            const glowR = 25 + Math.sin(t * 1.5) * 5;
            const grad = ctx.createRadialGradient(cx, cy, 0, cx, cy, glowR * 2);
            grad.addColorStop(0, 'rgba(' + cfg.colors[0].join(',') + ',' + (hover ? 0.2 : 0.1) + ')');
            grad.addColorStop(1, 'rgba(' + cfg.colors[0].join(',') + ',0)');
            ctx.fillStyle = grad;
            ctx.fillRect(cx - glowR * 2, cy - glowR * 2, glowR * 4, glowR * 4);

            // Central hub
            ctx.beginPath(); ctx.arc(cx, cy, 10 + Math.sin(t * 2) * 2, 0, Math.PI * 2);
            ctx.fillStyle = 'rgba(' + cfg.colors[0].join(',') + ',' + (hover ? 0.35 : 0.18) + ')';
            ctx.fill();
            ctx.beginPath(); ctx.arc(cx, cy, 4, 0, Math.PI * 2);
            ctx.fillStyle = 'rgba(' + cfg.colors[0].join(',') + ',' + (hover ? 0.7 : 0.4) + ')';
            ctx.fill();

            // Particles with mouse attraction
            for (const p of particles) {
                // Drift
                p.x = p.ox + Math.sin(t * 1.2 + p.phase) * 8 + p.vx * Math.sin(t * 0.5);
                p.y = p.oy + Math.cos(t * 0.9 + p.phase) * 6 + p.vy * Math.cos(t * 0.5);

                // Mouse attraction
                if (hover) {
                    const dx = mx - p.x, dy = my - p.y;
                    const dist = Math.sqrt(dx * dx + dy * dy);
                    if (dist < 120) {
                        const force = (1 - dist / 120) * 8;
                        p.x += (dx / dist) * force;
                        p.y += (dy / dist) * force;
                    }
                }

                const pulse = (Math.sin(t * 2.5 + p.phase) + 1) / 2;
                const baseAlpha = hover ? 0.25 + pulse * 0.35 : 0.1 + pulse * 0.15;
                const r = p.r * (hover ? 1 + pulse * 0.3 : 0.8 + pulse * 0.2);

                // Soft glow
                ctx.beginPath(); ctx.arc(p.x, p.y, r * 3, 0, Math.PI * 2);
                ctx.fillStyle = 'rgba(' + p.col.join(',') + ',' + (baseAlpha * 0.15) + ')';
                ctx.fill();
                // Particle
                ctx.beginPath(); ctx.arc(p.x, p.y, r, 0, Math.PI * 2);
                ctx.fillStyle = 'rgba(' + p.col.join(',') + ',' + baseAlpha + ')';
                ctx.fill();
            }

            // Connection lines to center (sparse, elegant)
            for (let i = 0; i < particles.length; i += 4) {
                const p = particles[i];
                const dx = p.x - cx, dy = p.y - cy;
                const dist = Math.sqrt(dx * dx + dy * dy);
                if (dist < Math.min(w, h) * 0.35) {
                    ctx.beginPath();
                    ctx.moveTo(cx, cy);
                    ctx.lineTo(p.x, p.y);
                    ctx.strokeStyle = 'rgba(' + p.col.join(',') + ',' + (hover ? 0.06 : 0.025) + ')';
                    ctx.lineWidth = 0.5;
                    ctx.stroke();
                }
            }

            requestAnimationFrame(drawPanel);
        }

        const obs = new IntersectionObserver(e => {
            if (e[0].isIntersecting) { resize(); initParticles(); drawPanel(); obs.disconnect(); }
        }, { threshold: 0.1 });
        obs.observe(canvas.parentElement);
        window.addEventListener('resize', () => { resize(); initParticles(); });
    });
})();

/* ========================================================
   WHO THIS IS FOR — Interactive audience canvases
   ======================================================== */
(function() {
    const canvases = document.querySelectorAll('.audience-canvas');
    if (!canvases.length) return;

    canvases.forEach(canvas => {
        const type = canvas.dataset.audience;
        const ctx = canvas.getContext('2d');
        let w, h, t = 0, mx = -1, my = -1;

        function resize() {
            const r = window.devicePixelRatio || 1;
            w = canvas.offsetWidth; h = canvas.offsetHeight;
            canvas.width = w * r; canvas.height = h * r;
            ctx.scale(r, r);
        }

        const card = canvas.closest('.card');
        card.addEventListener('mousemove', e => {
            const rect = canvas.getBoundingClientRect();
            mx = e.clientX - rect.left; my = e.clientY - rect.top;
        });
        card.addEventListener('mouseleave', () => { mx = -1; my = -1; });

        const CONFIGS = {
            enterprise:  { colors: [[212,112,44],[245,158,11],[245,100,147]], count: 70, spread: 0.85, speed: 1 },
            accelerator: { colors: [[54,209,183],[0,178,97],[54,209,183]], count: 70, spread: 0.8, speed: 0.85 },
            consulting:  { colors: [[155,93,229],[139,92,246],[245,100,147]], count: 70, spread: 0.85, speed: 0.9 }
        };
        const cfg = CONFIGS[type];
        if (!cfg) return;

        let particles = [], streams = [];

        function initParticles() {
            particles = []; streams = [];
            const cx = w / 2, cy = h / 2;
            for (let i = 0; i < cfg.count; i++) {
                const angle = Math.random() * Math.PI * 2;
                const dist = 15 + Math.random() * Math.min(w, h) * cfg.spread * 0.45;
                const col = cfg.colors[Math.floor(Math.random() * cfg.colors.length)];
                particles.push({
                    x: cx + Math.cos(angle) * dist,
                    y: cy + Math.sin(angle) * dist,
                    ox: cx + Math.cos(angle) * dist,
                    oy: cy + Math.sin(angle) * dist,
                    r: 1 + Math.random() * 3,
                    col: col,
                    phase: Math.random() * Math.PI * 2,
                    vx: (Math.random() - 0.5) * 0.3,
                    vy: (Math.random() - 0.5) * 0.3
                });
            }
            for (let i = 0; i < 4; i++) {
                const a = (Math.PI * 2 / 4) * i + Math.random() * 0.5;
                streams.push({
                    angle: a,
                    innerR: 25 + Math.random() * 15,
                    outerR: Math.min(w, h) * 0.32 + Math.random() * 25,
                    width: 1 + Math.random() * 1.5,
                    col: cfg.colors[i % cfg.colors.length],
                    phase: Math.random() * Math.PI * 2,
                    arcLen: 0.5 + Math.random() * 0.7
                });
            }
        }

        function draw() {
            t += 0.004 * cfg.speed;
            ctx.clearRect(0, 0, w, h);
            const cx = w / 2, cy = h / 2;
            const hover = mx > 0;
            const hoverScale = hover ? 1.3 : 1;

            // Arc streams
            for (const s of streams) {
                const startAngle = s.angle + t * 0.3 + Math.sin(t + s.phase) * 0.2;
                const endAngle = startAngle + s.arcLen;
                const r = (s.innerR + s.outerR) / 2 + Math.sin(t * 0.8 + s.phase) * 8;
                ctx.beginPath();
                ctx.arc(cx, cy, r, startAngle, endAngle);
                ctx.strokeStyle = 'rgba(' + s.col.join(',') + ',' + (hover ? 0.12 : 0.06) + ')';
                ctx.lineWidth = s.width * hoverScale;
                ctx.stroke();
            }

            // Central glow
            const glowR = 20 + Math.sin(t * 1.5) * 4;
            const grad = ctx.createRadialGradient(cx, cy, 0, cx, cy, glowR * 2);
            grad.addColorStop(0, 'rgba(' + cfg.colors[0].join(',') + ',' + (hover ? 0.2 : 0.1) + ')');
            grad.addColorStop(1, 'rgba(' + cfg.colors[0].join(',') + ',0)');
            ctx.fillStyle = grad;
            ctx.fillRect(cx - glowR * 2, cy - glowR * 2, glowR * 4, glowR * 4);

            // Central hub
            ctx.beginPath(); ctx.arc(cx, cy, 8 + Math.sin(t * 2) * 2, 0, Math.PI * 2);
            ctx.fillStyle = 'rgba(' + cfg.colors[0].join(',') + ',' + (hover ? 0.35 : 0.18) + ')';
            ctx.fill();
            ctx.beginPath(); ctx.arc(cx, cy, 3.5, 0, Math.PI * 2);
            ctx.fillStyle = 'rgba(' + cfg.colors[0].join(',') + ',' + (hover ? 0.7 : 0.4) + ')';
            ctx.fill();

            // Particles with mouse attraction
            for (const p of particles) {
                p.x = p.ox + Math.sin(t * 1.2 + p.phase) * 7 + p.vx * Math.sin(t * 0.5);
                p.y = p.oy + Math.cos(t * 0.9 + p.phase) * 5 + p.vy * Math.cos(t * 0.5);

                if (hover) {
                    const dx = mx - p.x, dy = my - p.y;
                    const dist = Math.sqrt(dx * dx + dy * dy);
                    if (dist < 100) {
                        const force = (1 - dist / 100) * 7;
                        p.x += (dx / dist) * force;
                        p.y += (dy / dist) * force;
                    }
                }

                const pulse = (Math.sin(t * 2.5 + p.phase) + 1) / 2;
                const baseAlpha = hover ? 0.25 + pulse * 0.35 : 0.1 + pulse * 0.15;
                const r = p.r * (hover ? 1 + pulse * 0.3 : 0.8 + pulse * 0.2);

                ctx.beginPath(); ctx.arc(p.x, p.y, r * 2.5, 0, Math.PI * 2);
                ctx.fillStyle = 'rgba(' + p.col.join(',') + ',' + (baseAlpha * 0.12) + ')';
                ctx.fill();
                ctx.beginPath(); ctx.arc(p.x, p.y, r, 0, Math.PI * 2);
                ctx.fillStyle = 'rgba(' + p.col.join(',') + ',' + baseAlpha + ')';
                ctx.fill();
            }

            // Sparse connection lines
            for (let i = 0; i < particles.length; i += 5) {
                const p = particles[i];
                const dx = p.x - cx, dy = p.y - cy;
                const dist = Math.sqrt(dx * dx + dy * dy);
                if (dist < Math.min(w, h) * 0.3) {
                    ctx.beginPath();
                    ctx.moveTo(cx, cy);
                    ctx.lineTo(p.x, p.y);
                    ctx.strokeStyle = 'rgba(' + p.col.join(',') + ',' + (hover ? 0.06 : 0.025) + ')';
                    ctx.lineWidth = 0.5;
                    ctx.stroke();
                }
            }

            requestAnimationFrame(draw);
        }

        const obs = new IntersectionObserver(e => {
            if (e[0].isIntersecting) { resize(); initParticles(); draw(); obs.disconnect(); }
        }, { threshold: 0.1 });
        obs.observe(canvas.parentElement);
        window.addEventListener('resize', () => { resize(); initParticles(); });
    });
})();

/* ========================================================
   SCROLL REVEAL + ANIMATED COUNTERS
   ======================================================== */
const io = new IntersectionObserver((entries) => {
    entries.forEach(e => {
        if (e.isIntersecting) {
            e.target.classList.add('is-visible');
            // Animate counters inside
            e.target.querySelectorAll('.counter').forEach(el => {
                if (el.dataset.counted) return;
                el.dataset.counted = '1';
                const target = parseInt(el.dataset.target);
                const suffix = el.dataset.suffix || '';
                const duration = 2000;
                const start = performance.now();
                function tick(now) {
                    const elapsed = now - start;
                    const progress = Math.min(elapsed / duration, 1);
                    const eased = 1 - Math.pow(1 - progress, 3);
                    el.textContent = Math.floor(eased * target) + suffix;
                    if (progress < 1) requestAnimationFrame(tick);
                }
                requestAnimationFrame(tick);
            });
        }
    });
}, { threshold: 0.08, rootMargin: '0px 0px -60px 0px' });
document.querySelectorAll('.reveal').forEach(el => io.observe(el));

// Smooth scroll
document.querySelectorAll('a[href^="#"]').forEach(a => {
    a.addEventListener('click', function(e) {
        const t = document.querySelector(this.getAttribute('href'));
        if (t) { e.preventDefault(); t.scrollIntoView({ behavior: 'smooth', block: 'start' }); }
    });
});

