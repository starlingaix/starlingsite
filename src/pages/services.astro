---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---
<BaseLayout title="Starling AIX | Enterprise Organizational Intelligence" description="Starling builds organizational intelligence systems — then makes sure someone in your organization can run them.">
<Nav currentPage="services" />
<main>

<!-- ===== HERO ===== -->
<section class="hero">
    <div class="hero__ai-visual">
        <canvas id="heroAiCanvas"></canvas>
    </div>

    <div class="hero__content">
        <div class="hero__text">
            <div class="hero__eyebrow reveal">
                <span>Organizational intelligence built and staffed:</span>
                <strong>28 memory systems</strong>
            </div>
            <h1 class="h1 hero__title reveal reveal-d1">
                <em>Organizational intelligence to power your enterprise.</em>
                <span>We build it, teach it, and staff it — so every engagement ends with a person, not a report.</span>
            </h1>
            <div class="btn-group reveal reveal-d2">
                <a class="btn btn--primary btn--large" href="#ready">
                    Book a Discovery Call
                    <svg class="arrow" width="10" height="10" fill="none" stroke="currentColor" stroke-width="2"><path d="M0.5 5.5h7"/><path d="M5.5 1.5l4 4-4 4"/></svg>
                </a>
                <a class="btn btn--secondary btn--large" href="#how-we-work">See How We Work</a>
            </div>
        </div>
    </div>

    <div class="hero__logos">
        <div class="hero__logos-inner">
            <span class="hero__logos-label">Trusted by leaders in</span>
            <div class="hero__logos-marquee">
                <div class="hero__logos-track">
                    <span>Enterprise AI</span><span>Healthcare</span><span>Financial Services</span><span>Higher Education</span><span>Government</span><span>Consulting</span><span>Accelerators</span><span>Manufacturing</span>
                    <span>Enterprise AI</span><span>Healthcare</span><span>Financial Services</span><span>Higher Education</span><span>Government</span><span>Consulting</span><span>Accelerators</span><span>Manufacturing</span>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- ===== THE MACH 1 PROBLEM — Linear-style split heading + visual below ===== -->
<section class="mach1" id="mach1">
    <div class="mach1__inner">
        <!-- Split heading row like Linear screenshot 2 -->
        <div class="mach1__header reveal">
            <div class="mach1__header-left">
                <h2 class="mach1__h"><strong>The Mach 1 Problem.</strong> Your AI works. Your organization can't absorb what it produces.</h2>
            </div>
            <div class="mach1__header-right">
                <p class="body-lg">Most companies adopt AI tools without the organizational memory to use them. The result: faster outputs, same bottlenecks. The Org Brain fixes the root cause.</p>
            </div>
        </div>

        <!-- Interactive Before/After visualization -->
        <div class="mach1__morph reveal reveal-d1" id="mach1Morph">
            <canvas id="mach1MorphCanvas"></canvas>
            <div class="mach1__morph-bar">
                <span class="mach1__morph-opt is-active" data-mode="chaos">Without Org Brain</span>
                <span class="mach1__morph-opt" data-mode="order">With Org Brain</span>
                <div class="mach1__morph-slider mach1__morph-slider--chaos" id="mach1Slider"></div>
            </div>
            <div class="mach1__morph-caption" id="mach1Caption">
                <span class="mach1__morph-tag mach1__morph-tag--red" id="mach1Tag">Chaotic</span>
                <span id="mach1Desc">Fast outputs. No memory. Every prompt starts from zero.</span>
            </div>
        </div>

        <!-- Stats row below -->
        <div class="mach1__stats-row reveal reveal-d2">
            <div class="mach1-stat">
                <div class="mach1-stat__val"><span class="counter" data-target="28">0</span></div>
                <div class="mach1-stat__label">Constitutional Memories</div>
            </div>
            <div class="mach1-stat">
                <div class="mach1-stat__val"><span class="counter" data-target="8">0</span></div>
                <div class="mach1-stat__label">Sprints to full intelligence</div>
            </div>
            <div class="mach1-stat">
                <div class="mach1-stat__val"><span class="counter" data-target="250" data-suffix="+">0</span></div>
                <div class="mach1-stat__label">Enterprise integrations</div>
            </div>
            <div class="mach1-stat">
                <div class="mach1-stat__val"><span class="counter" data-target="3">0</span></div>
                <div class="mach1-stat__label">Certification levels</div>
            </div>
        </div>

        <!-- AI Compare: interactive prompt-switching mockup -->
        <div class="ai-compare reveal reveal-d3" id="aiCompare">
            <div class="ai-compare__tabs" id="aicTabs">
                <div class="ai-compare__tab is-active" data-aic="0">Win-back Email</div>
                <div class="ai-compare__tab" data-aic="1">Product Launch</div>
                <div class="ai-compare__tab" data-aic="2">Investor Update</div>
                <div class="ai-compare__tab" data-aic="3">Competitive Brief</div>
            </div>
            <div class="ai-compare__frame">
                <div class="ai-compare__col ai-compare__col--before" id="aicGeneric">
                    <span class="ai-compare__tag ai-compare__tag--generic">Generic AI</span>
                    <div class="ai-compare__prompt-bar" id="aicPromptL"></div>
                    <div class="ai-compare__stream" id="aicStreamL"></div>
                </div>
                <div class="ai-compare__col ai-compare__col--after" id="aicDlm">
                    <span class="ai-compare__tag ai-compare__tag--dlm">Starling DLM</span>
                    <div class="ai-compare__prompt-bar" id="aicPromptR"></div>
                    <div class="ai-compare__stream" id="aicStreamR"></div>
                    <div class="ai-compare__refs" id="aicRefs"></div>
                </div>
            </div>
        </div>

    </div>
</section>

<!-- Clean transition: Mach1 → How We Work -->

<!-- ===== HOW WE WORK — Linear-style split heading + interactive graphic ===== -->
<section class="hww" id="how-we-work">
    <div class="hww__inner">
        <!-- Split heading row -->
        <div class="hww__header reveal">
            <div class="hww__header-left">
                <h2 class="hww__h"><strong>Three ways to build intelligence.</strong> Every engagement produces a working system and a certified person to run it.</h2>
            </div>
            <div class="hww__header-right">
                <p class="body-lg">We don't leave you with a PDF. We leave you with a person — trained, certified, and embedded — who operates the system we built together.</p>
                <a href="#curriculum" class="hww__link">
                    See the curriculum
                    <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 7h11M8 3l4 4-4 4"/></svg>
                </a>
            </div>
        </div>

        <!-- Large interactive graphic area — 3 engagement panels -->
        <div class="hww__panels reveal reveal-d1">
            <!-- Panel 1: Build -->
            <div class="hww__panel hww__panel--build">
                <div class="hww__panel-visual">
                    <div class="hww__fig-label">FIG 0.1</div>
                    <canvas class="hww__panel-canvas" data-type="build"></canvas>
                </div>
                <div class="hww__panel-text">
                    <strong>Build your Org Brain</strong>
                    <span>Starling builds it directly. C-suite immersion, guided extraction, values codified into persistent memory.</span>
                </div>
            </div>

            <!-- Panel 2: License -->
            <div class="hww__panel hww__panel--license">
                <div class="hww__panel-visual">
                    <div class="hww__fig-label">FIG 0.2</div>
                    <canvas class="hww__panel-canvas" data-type="license"></canvas>
                </div>
                <div class="hww__panel-text">
                    <strong>License the methodology</strong>
                    <span>Train your trainers. Certify your people. The curriculum is yours to deploy at scale.</span>
                </div>
            </div>

            <!-- Panel 3: Certify -->
            <div class="hww__panel hww__panel--certify">
                <div class="hww__panel-visual">
                    <div class="hww__fig-label">FIG 0.3</div>
                    <canvas class="hww__panel-canvas" data-type="certify"></canvas>
                </div>
                <div class="hww__panel-text">
                    <strong>Certify or place a person</strong>
                    <span>Every engagement ends with a human — System Librarian, Cognitive Designer, or CIO — yours to keep.</span>
                </div>
            </div>
        </div>

        <!-- Brain Map — constellation visualization -->
        <div class="brain-map reveal reveal-d2">
            <div class="brain-map__frame">
                <div class="brain-map__visual">
                    <!-- Orbit rings -->
                    <div class="brain-map__ring brain-map__ring--1"></div>
                    <div class="brain-map__ring brain-map__ring--2"></div>
                    <div class="brain-map__ring brain-map__ring--3"></div>

                    <!-- Animated connection lines -->
                    <svg class="brain-map__lines" viewBox="0 0 400 380" preserveAspectRatio="xMidYMid meet">
                        <path class="brain-map__line" d="M200,190 Q200,60 200,40"/>
                        <path class="brain-map__line" d="M200,190 Q320,140 340,100"/>
                        <path class="brain-map__line" d="M200,190 Q330,230 350,270"/>
                        <path class="brain-map__line" d="M200,190 Q200,320 200,350"/>
                        <path class="brain-map__line" d="M200,190 Q80,140 60,100"/>
                        <path class="brain-map__line" d="M200,190 Q70,240 50,270"/>
                        <!-- Animated pulses traveling along lines -->
                        <path class="brain-map__pulse" d="M200,190 Q200,60 200,40"/>
                        <path class="brain-map__pulse brain-map__pulse--alt" d="M200,190 Q330,230 350,270"/>
                        <path class="brain-map__pulse brain-map__pulse--alt2" d="M200,190 Q80,140 60,100"/>
                    </svg>

                    <!-- Center hub -->
                    <div class="brain-map__hub">
                        <span class="brain-map__hub-label">Brain</span>
                        <span class="brain-map__hub-val">28</span>
                    </div>

                    <!-- Floating memory nodes -->
                    <div class="brain-map__node brain-map__node--n1">
                        <span class="brain-map__node-dot" style="background:var(--brand)"></span>Brand Voice
                    </div>
                    <div class="brain-map__node brain-map__node--n2">
                        <span class="brain-map__node-dot" style="background:var(--accent-teal)"></span>Strategy
                    </div>
                    <div class="brain-map__node brain-map__node--n3">
                        <span class="brain-map__node-dot" style="background:#8b5cf6"></span>Operations
                    </div>
                    <div class="brain-map__node brain-map__node--n4">
                        <span class="brain-map__node-dot" style="background:#ec4899"></span>Culture
                    </div>
                    <div class="brain-map__node brain-map__node--n5">
                        <span class="brain-map__node-dot" style="background:#f59e0b"></span>Innovation
                    </div>
                    <div class="brain-map__node brain-map__node--n6">
                        <span class="brain-map__node-dot" style="background:var(--accent-teal)"></span>Compliance
                    </div>
                </div>

                <div class="brain-map__sidebar">
                    <div class="brain-map__sidebar-title">Memory Systems</div>
                    <div class="brain-map__stat">
                        <span class="brain-map__stat-dot" style="background:var(--brand)"></span>
                        <div class="brain-map__stat-info">
                            <div class="brain-map__stat-name">Identity</div>
                            <div class="brain-map__stat-meta">6 memories trained</div>
                            <div class="brain-map__stat-bar"><div class="brain-map__stat-fill" style="width:100%;background:var(--brand)"></div></div>
                        </div>
                    </div>
                    <div class="brain-map__stat">
                        <span class="brain-map__stat-dot" style="background:var(--accent-teal)"></span>
                        <div class="brain-map__stat-info">
                            <div class="brain-map__stat-name">Strategy</div>
                            <div class="brain-map__stat-meta">4 memories trained</div>
                            <div class="brain-map__stat-bar"><div class="brain-map__stat-fill" style="width:75%;background:var(--accent-teal)"></div></div>
                        </div>
                    </div>
                    <div class="brain-map__stat">
                        <span class="brain-map__stat-dot" style="background:#8b5cf6"></span>
                        <div class="brain-map__stat-info">
                            <div class="brain-map__stat-name">Operations</div>
                            <div class="brain-map__stat-meta">3 memories training</div>
                            <div class="brain-map__stat-bar"><div class="brain-map__stat-fill" style="width:50%;background:#8b5cf6"></div></div>
                        </div>
                    </div>
                    <div class="brain-map__stat">
                        <span class="brain-map__stat-dot" style="background:#ec4899"></span>
                        <div class="brain-map__stat-info">
                            <div class="brain-map__stat-name">Culture</div>
                            <div class="brain-map__stat-meta">2 memories pending</div>
                            <div class="brain-map__stat-bar"><div class="brain-map__stat-fill" style="width:25%;background:#ec4899"></div></div>
                        </div>
                    </div>
                    <div class="brain-map__divider"></div>
                    <div class="brain-map__total">
                        <div class="brain-map__total-val">67%</div>
                        <div class="brain-map__total-label">Brain completeness</div>
                        <div class="brain-map__total-bar"><div class="brain-map__total-fill"></div></div>
                    </div>
                </div>
            </div>
        </div>

    </div>
</section>

<!-- ===== THE CURRICULUM ===== -->
<section class="section section--topo section--hoverable" id="curriculum">
    <div class="container">
        <div class="section-header reveal" style="display:grid;grid-template-columns:1fr;gap:24px;max-width:none;text-align:left;margin-bottom:64px">
            <h2 class="hww__h"><strong>Eight sprints. Three certifications.</strong> The Cognitive Design Accelerator takes an organization from zero to full organizational intelligence.</h2>
        </div>

        <div class="curriculum-viz reveal" id="curriculumViz">
            <canvas id="curriculumCanvas"></canvas>
        </div>

        <!-- Sprint Tracker -->
        <div class="sprint-tracker reveal reveal-d1">
            <div class="sprint-tracker__frame">
                <div class="sprint-tracker__header">
                    <span class="sprint-tracker__title"><span class="sprint-tracker__title-dot"></span>Accelerator Progress</span>
                    <span class="sprint-tracker__meta">8 Sprints · 36 Weeks</span>
                </div>
                <div class="sprint-tracker__grid">
                    <div class="sprint-tracker__row">
                        <span class="sprint-tracker__label">01 — Discovery</span>
                        <div class="sprint-tracker__bar"><div class="sprint-tracker__bar-fill sprint-tracker__bar-fill--done" style="width:100%"></div></div>
                        <span class="sprint-tracker__pct sprint-tracker__pct--done">100%</span>
                    </div>
                    <div class="sprint-tracker__row">
                        <span class="sprint-tracker__label">02 — Memory Arch.</span>
                        <div class="sprint-tracker__bar"><div class="sprint-tracker__bar-fill sprint-tracker__bar-fill--done" style="width:100%"></div></div>
                        <span class="sprint-tracker__pct sprint-tracker__pct--done">100%</span>
                    </div>
                    <div class="sprint-tracker__row">
                        <span class="sprint-tracker__label">03 — Prompts</span>
                        <div class="sprint-tracker__bar"><div class="sprint-tracker__bar-fill sprint-tracker__bar-fill--done" style="width:100%"></div></div>
                        <span class="sprint-tracker__pct sprint-tracker__pct--done">100%</span>
                    </div>
                    <div class="sprint-tracker__row is-current">
                        <span class="sprint-tracker__label">04 — Workflows</span>
                        <div class="sprint-tracker__bar"><div class="sprint-tracker__bar-fill sprint-tracker__bar-fill--active"></div></div>
                        <span class="sprint-tracker__pct sprint-tracker__pct--active">72%</span>
                    </div>
                    <div class="sprint-tracker__row">
                        <span class="sprint-tracker__label">05 — Integration</span>
                        <div class="sprint-tracker__bar"><div class="sprint-tracker__bar-fill sprint-tracker__bar-fill--pending"></div></div>
                        <span class="sprint-tracker__pct sprint-tracker__pct--pending">0%</span>
                    </div>
                    <div class="sprint-tracker__row">
                        <span class="sprint-tracker__label">06 — DLM Calib.</span>
                        <div class="sprint-tracker__bar"><div class="sprint-tracker__bar-fill sprint-tracker__bar-fill--pending"></div></div>
                        <span class="sprint-tracker__pct sprint-tracker__pct--pending">0%</span>
                    </div>
                    <div class="sprint-tracker__row">
                        <span class="sprint-tracker__label">07 — Governance</span>
                        <div class="sprint-tracker__bar"><div class="sprint-tracker__bar-fill sprint-tracker__bar-fill--pending"></div></div>
                        <span class="sprint-tracker__pct sprint-tracker__pct--pending">0%</span>
                    </div>
                    <div class="sprint-tracker__row">
                        <span class="sprint-tracker__label">08 — Handoff</span>
                        <div class="sprint-tracker__bar"><div class="sprint-tracker__bar-fill sprint-tracker__bar-fill--pending"></div></div>
                        <span class="sprint-tracker__pct sprint-tracker__pct--pending">0%</span>
                    </div>
                </div>
                <div class="sprint-tracker__footer">
                    <span class="sprint-tracker__cert">Next: Cognitive Designer certification</span>
                    <span class="sprint-tracker__badge" style="color:var(--brand);background:rgba(212,112,44,0.06);border:1px solid rgba(212,112,44,0.15)">System Librarian ✓</span>
                </div>
            </div>
        </div>

        <hr class="glow-line reveal mb-48">

        <div class="curriculum-timeline">
            <!-- System Librarian -->
            <div class="track reveal">
                <div class="track__header">
                    <span class="badge badge--green">System Librarian</span>
                    <span class="track__meta">Sprints 1–2 · 9 weeks</span>
                </div>
                <div class="card-grid card-grid--2 mb-24">
                    <div class="sprint"><span class="sprint__label">Sprint 1</span><div class="sprint__title">Innovation System</div><div class="sprint__desc">Identity, Market, Innovation, Brand. The First Fifteen Constitutional Memories — your values, market position, product strategy, and brand voice.</div></div>
                    <div class="sprint"><span class="sprint__label">Sprint 2</span><div class="sprint__title">Applied Intelligence</div><div class="sprint__desc">Deep strategy, active project architecture, organizational learning. Your Org Brain goes from repository to working system.</div></div>
                </div>
                <div class="gate"><span class="gate__icon">&#9734;</span><p class="gate__text"><strong>Gate:</strong> Build and govern an Org Brain. For most startups and mid-market companies, this is the complete package.</p></div>
            </div>

            <hr class="glow-line" style="margin:40px 0">

            <!-- Cognitive Designer -->
            <div class="track reveal">
                <div class="track__header">
                    <span class="badge badge--orange">Cognitive Designer</span>
                    <span class="track__meta">Sprints 3–5 · 12 weeks</span>
                </div>
                <div class="card-grid card-grid--3 mb-24">
                    <div class="sprint"><span class="sprint__label">Sprint 3</span><div class="sprint__title">Optimization System</div><div class="sprint__desc">Productivity, Workflow, Process, Culture. How decisions get made and how work flows.</div></div>
                    <div class="sprint"><span class="sprint__label">Sprint 4</span><div class="sprint__title">Cognitive System</div><div class="sprint__desc">System configuration, dual metrics, full Org Brain activation. All 28 Constitutional Memories complete.</div></div>
                    <div class="sprint"><span class="sprint__label">Sprint 5</span><div class="sprint__title">Translation System</div><div class="sprint__desc">Connect your Org Brain to enterprise systems. SAP, Salesforce, Workday, and 250+ integrations.</div></div>
                </div>
                <div class="gate"><span class="gate__icon">&#9734;</span><p class="gate__text"><strong>Gate:</strong> Design how an organization thinks. Build systems that compound. Connect knowledge to enterprise infrastructure.</p></div>
            </div>

            <hr class="glow-line" style="margin:40px 0">

            <!-- Chief Intelligence Officer -->
            <div class="track reveal">
                <div class="track__header">
                    <span class="badge badge--rust">Chief Intelligence Officer</span>
                    <span class="track__meta">Sprints 6–8 · 8 weeks</span>
                </div>
                <div class="card-grid card-grid--3 mb-24">
                    <div class="sprint"><span class="sprint__label">Sprint 6</span><div class="sprint__title">Starling OS</div><div class="sprint__desc">Operating prompt design, architecture, constitutional memory, governance, semantic addressing.</div></div>
                    <div class="sprint"><span class="sprint__label">Sprint 7</span><div class="sprint__title">Org Strategy</div><div class="sprint__desc">Buy-in, deployment, executive communication. Leading intelligence as a C-suite function.</div></div>
                    <div class="sprint"><span class="sprint__label">Sprint 8</span><div class="sprint__title">Governance & Impact</div><div class="sprint__desc">AI governance, social impact, the certification economy, and the responsibility framework.</div></div>
                </div>
                <div class="gate"><span class="gate__icon">&#9734;</span><p class="gate__text"><strong>Gate:</strong> Architect, deploy, and govern enterprise-wide organizational intelligence responsibly. The C-suite function.</p></div>
            </div>
        </div>

        <div style="text-align:center;margin-top:40px" class="reveal">
            <a class="btn btn--primary btn--large" href="#guide">Explore the Full Curriculum <svg class="arrow" width="10" height="10" fill="none" stroke="currentColor" stroke-width="2"><path d="M0.5 5.5h7"/><path d="M5.5 1.5l4 4-4 4"/></svg></a>
        </div>
    </div>
</section>


<!-- ===== CORPORATE LICENSING ===== -->
<section class="section section--stripes section--hoverable" id="licensing">
    <div class="orb orb--1" style="background:var(--accent-teal)"></div>
    <div class="container">
        <div class="section-header reveal" style="text-align:left;max-width:none;margin-bottom:64px">
            <h2 class="hww__h"><strong>Corporate Licensing.</strong> License the methodology. Train your people. Scale without us.</h2>
        </div>

        <!-- Animated licensing journey illustration -->
        <div class="license-viz reveal" id="licenseViz">
            <canvas id="licenseCanvas"></canvas>
        </div>

        <div class="table-wrap reveal">
            <table class="table">
                <thead><tr><th></th><th>Sprint License</th><th>Program License</th><th>Enterprise License</th></tr></thead>
                <tbody>
                    <tr><td>Curriculum</td><td data-label="Sprint License">Sprints 1–2</td><td data-label="Program License">Sprints 3–5</td><td data-label="Enterprise License">Sprints 6–8</td></tr>
                    <tr><td>Certification</td><td data-label="Sprint License">System Librarian</td><td data-label="Program License">Cognitive Designer</td><td data-label="Enterprise License">Chief Intelligence Officer</td></tr>
                    <tr><td>Cohort Size</td><td data-label="Sprint License">15–25 participants</td><td data-label="Program License">8–15 participants</td><td data-label="Enterprise License">3–8 participants</td></tr>
                    <tr><td>Duration</td><td data-label="Sprint License">9 weeks</td><td data-label="Program License">12 weeks</td><td data-label="Enterprise License">8 weeks</td></tr>
                    <tr class="row--hl"><td>Cohort License</td><td data-label="Sprint License">$25,000</td><td data-label="Program License">$50,000</td><td data-label="Enterprise License">$75,000</td></tr>
                    <tr class="row--hl"><td>Per-Seat Certification</td><td data-label="Sprint License">$500</td><td data-label="Program License">$1,500</td><td data-label="Enterprise License">$5,000</td></tr>
                    <tr><td>Includes</td><td data-label="Sprint License">iPub library, installer frameworks, facilitator guides, SY12 diagnostic, Starling support</td><td data-label="Program License">Everything in Sprint + train-the-trainer delivery, advanced diagnostics</td><td data-label="Enterprise License">Everything in Program + OS customization, governance architecture</td></tr>
                </tbody>
            </table>
        </div>

        <!-- Mobile tier cards -->
        <div class="tier-cards reveal">
            <div class="tier-card tier-card--sprint">
                <div class="tier-card__accent"></div>
                <div class="tier-card__head">
                    <span class="tier-card__name">Sprint License</span>
                    <span class="tier-card__price">$25,000</span>
                </div>
                <div class="tier-card__body">
                    <div class="tier-card__row"><span class="tier-card__label">Curriculum</span><span class="tier-card__value">Sprints 1–2</span></div>
                    <div class="tier-card__row"><span class="tier-card__label">Certification</span><span class="tier-card__value">System Librarian</span></div>
                    <div class="tier-card__row"><span class="tier-card__label">Cohort Size</span><span class="tier-card__value">15–25 participants</span></div>
                    <div class="tier-card__row"><span class="tier-card__label">Duration</span><span class="tier-card__value">9 weeks</span></div>
