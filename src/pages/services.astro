    function renderLines(container, lines, baseDelay) {
        container.innerHTML = '';
        lines.forEach(function(line, i) {
            var div = document.createElement('div');
            div.className = 'ai-compare__line' + (line.cls ? ' ' + line.cls : '');
            div.innerHTML = line.text + (line.cursor ? '<span class="ai-compare__cursor"></span>' : '');
            container.appendChild(div);
            var timer = setTimeout(function() {
                div.classList.add('is-visible');
            }, baseDelay + i * 400);
            lineTimers.push(timer);
        });
    }

    function renderRefs(refs, delay) {
        refsEl.innerHTML = '';
        refs.forEach(function(name, i) {
            var span = document.createElement('span');
            span.className = 'ai-compare__ref-pill';
            span.textContent = name;
            refsEl.appendChild(span);
            var timer = setTimeout(function() {
                span.classList.add('is-visible');
            }, delay + i * 150);
            lineTimers.push(timer);
        });
    }

    function showScenario(idx) {
        clearTimers();
        var s = scenarios[idx];
        promptL.innerHTML = 'Prompt: <strong>"' + s.prompt + '"</strong>';
        promptR.innerHTML = 'Prompt: <strong>"' + s.prompt + '"</strong>';

        // Fade out
        colL.classList.add('is-fading');
        colR.classList.add('is-fading');

        var t1 = setTimeout(function() {
            renderLines(streamL, s.generic, 200);
            renderLines(streamR, s.dlm, 350);
            renderRefs(s.refs, 350 + s.dlm.length * 400 + 200);
            colL.classList.remove('is-fading');
            colR.classList.remove('is-fading');
        }, 250);
        lineTimers.push(t1);
    }

    // Initial render
    showScenario(0);

    // Tab click
    tabs.addEventListener('click', function(e) {
        var tab = e.target.closest('.ai-compare__tab');
        if (!tab || tab.classList.contains('is-active')) return;
        tabs.querySelectorAll('.ai-compare__tab').forEach(function(t) { t.classList.remove('is-active'); });
        tab.classList.add('is-active');
        currentIdx = parseInt(tab.getAttribute('data-aic'));
        showScenario(currentIdx);
        userInteracted = true;
        clearTimeout(autoTimer);
    });

    // Auto-cycle
    var userInteracted = false;
    var autoTimer;
    function autoCycle() {
        if (userInteracted) return;
        currentIdx = (currentIdx + 1) % scenarios.length;
        tabs.querySelectorAll('.ai-compare__tab').forEach(function(t) { t.classList.remove('is-active'); });
        var nextTab = tabs.querySelector('[data-aic="' + currentIdx + '"]');
        if (nextTab) nextTab.classList.add('is-active');
        showScenario(currentIdx);
        autoTimer = setTimeout(autoCycle, 6000);
    }
    autoTimer = setTimeout(autoCycle, 5000);
})();

