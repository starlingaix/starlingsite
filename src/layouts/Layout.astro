---
import '../styles/global.css';
interface Props {
  title?: string;
  description?: string;
}
const {
  title = 'Starling AIX — Mach 1 Business',
  description = 'Organizational intelligence architecture. The Org Brain is where your company\'s knowledge lives. Cognitive Design is how it gets built.',
} = Astro.props;

const CDN = 'https://cdn.prod.website-files.com/68a8c21bc88f17902fc14981';

const navLinks = [
  { href: '/ai-guide',         label: 'AI Guide' },
  { href: '/cognitive-design', label: 'Cognitive Design' },
  { href: '/platform',         label: 'Workspace' },
  { href: '/services',         label: 'Services' },
  { href: '/about',            label: 'About' },
];
const path = Astro.url.pathname;

function isActive(href: string) {
  if (href === '/') return path === '/';
  return path === href || path.startsWith(href + '/');
}
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="icon" type="image/png" href={`${CDN}/68eab1e00524fcbfe1637153_StarlingAIx06A.png`} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
</head>
<body>

<!-- ── Nav ──────────────────────────────────────────── -->
<header class="nav-wrap" id="nav">
  <div class="container" style="display:flex;align-items:center;justify-content:space-between;height:56px;">

    <a href="/" class="nav-logo" style="font-family:'Space Grotesk',sans-serif;font-weight:600;font-size:1.1rem;color:#fff;text-decoration:none;letter-spacing:-0.01em;">
      Starling AIX
    </a>

    <!-- Desktop nav -->
    <nav class="desktop-links" aria-label="Main">
      {navLinks.map(l => (
        <a
          href={l.href}
          class={`nav-link${isActive(l.href) ? ' active' : ''}`}
        >
          {l.label}
        </a>
      ))}
    </nav>

    <!-- Desktop CTA -->
    <div class="desktop-cta-wrap">
      <a href="https://calendly.com/starlingaix" target="_blank" rel="noopener" class="btn btn-ghost" style="padding:0.4rem 1rem;font-size:0.85rem;">
        Contact
      </a>
      <a href="/cognitive-design" class="btn btn-primary" style="padding:0.4rem 1rem;font-size:0.85rem;">
        Enroll Now
      </a>
    </div>

    <!-- Hamburger -->
    <button id="ham" class="ham-btn" aria-label="Toggle menu">
      <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
        <path d="M3 5h14M3 10h14M3 15h14" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
      </svg>
    </button>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu">
    {navLinks.map(l => (
      <a href={l.href} class="mobile-link">{l.label}</a>
    ))}
    <div style="display:flex;gap:0.75rem;margin-top:0.75rem;padding-top:0.75rem;border-top:1px solid rgba(255,255,255,0.06);">
      <a href="https://calendly.com/starlingaix" target="_blank" rel="noopener" class="btn btn-ghost" style="flex:1;justify-content:center;font-size:0.85rem;">Contact</a>
      <a href="/cognitive-design" class="btn btn-primary" style="flex:1;justify-content:center;font-size:0.85rem;">Enroll Now</a>
    </div>
  </div>
</header>

<div style="height:56px;"></div>

<!-- ── Page content ─────────────────────────────────── -->
<main>
  <slot />
</main>

<!-- ── Footer ───────────────────────────────────────── -->
<footer style="border-top:1px solid rgba(255,255,255,0.07);padding:3.5rem 0 2rem;">
  <div class="container">
    <div class="footer-grid">
      <!-- Brand col -->
      <div>
        <div style="font-family:'Space Grotesk',sans-serif;font-weight:600;font-size:1.05rem;color:#fff;margin-bottom:0.75rem;">
          Starling AIX
        </div>
        <p style="font-size:0.875rem;color:#52525b;line-height:1.75;max-width:280px;margin:0 0 1.25rem;">
          Organizational intelligence architecture. The Org Brain is where your company's knowledge lives. Cognitive Design is how it gets built.
        </p>
        <div style="display:flex;flex-wrap:wrap;gap:0.25rem 1rem;">
          <a href="tel:+18442497827" class="footer-meta-link">+1 (844) AIX-STAR</a>
          <a href="mailto:hello@starlingaix.com" class="footer-meta-link">hello@starlingaix.com</a>
        </div>
      </div>

      <!-- Link columns -->
      <div class="footer-cols">
        <div>
          <p class="footer-col-head">Product</p>
          <a href="/platform"         class="footer-link-item">Starling Workspace</a>
          <a href="/cognitive-design" class="footer-link-item">Org Brain</a>
          <a href="/ai-guide"         class="footer-link-item">UCA Free Standard</a>
        </div>
        <div>
          <p class="footer-col-head">Company</p>
          <a href="/about"    class="footer-link-item">About</a>
          <a href="/services" class="footer-link-item">Services</a>
          <a href="https://calendly.com/starlingaix" target="_blank" rel="noopener" class="footer-link-item">Contact Sales</a>
        </div>
        <div>
          <p class="footer-col-head">Resources</p>
          <a href="/ai-guide"         class="footer-link-item">AI Guide</a>
          <a href="/cognitive-design" class="footer-link-item">Cognitive Design</a>
          <a href="#newsletter"       class="footer-link-item">Newsletter</a>
        </div>
      </div>
    </div>

    <div class="divider" style="margin:2rem 0 1.25rem;"></div>
    <div style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:0.75rem;">
      <p style="font-size:0.78rem;color:#3f3f46;margin:0;">© 2026 Starling AIX</p>
      <div style="display:flex;gap:1.5rem;">
        <a href="https://www.linkedin.com/company/starlingaix" target="_blank" rel="noopener" class="footer-social">LinkedIn</a>
        <a href="https://www.instagram.com/starlingaix"        target="_blank" rel="noopener" class="footer-social">Instagram</a>
        <a href="https://www.youtube.com/@StarlingAIX"         target="_blank" rel="noopener" class="footer-social">YouTube</a>
      </div>
    </div>
  </div>
</footer>

<style>
  /* Nav desktop */
  .desktop-links  { display:none; }
  .desktop-cta-wrap { display:none; }
  .ham-btn { display:flex; background:none; border:none; cursor:pointer; color:#71717a; padding:0.35rem; }
  .ham-btn:hover { color:#fff; }

  @media(min-width:768px) {
    .desktop-links  { display:flex; gap:0.15rem; align-items:center; }
    .desktop-cta-wrap { display:flex; align-items:center; gap:0.75rem; }
    .ham-btn { display:none; }
  }

  .nav-link {
    font-size:0.875rem; font-weight:400; color:#71717a;
    text-decoration:none; padding:0.4rem 0.7rem; border-radius:6px;
    transition:color 0.15s;
  }
  .nav-link:hover, .nav-link.active { color:#fff; }

  .mobile-link {
    display:block; padding:0.55rem 0; font-size:0.95rem;
    color:#71717a; text-decoration:none;
    border-bottom:1px solid rgba(255,255,255,0.05);
    transition:color 0.15s;
  }
  .mobile-link:hover { color:#fff; }

  /* Footer */
  .footer-grid  { display:grid; grid-template-columns:1fr; gap:2.5rem; margin-bottom:0; }
  .footer-cols  { display:grid; grid-template-columns:repeat(3,1fr); gap:1.5rem; }

  @media(min-width:768px) {
    .footer-grid { grid-template-columns:300px 1fr; }
  }

  .footer-col-head {
    font-family:'JetBrains Mono',monospace; font-size:0.68rem;
    letter-spacing:0.1em; text-transform:uppercase; color:#3f3f46;
    margin:0 0 0.85rem;
  }
  .footer-link-item {
    display:block; font-size:0.875rem; color:#71717a; text-decoration:none;
    margin-bottom:0.45rem; transition:color 0.15s;
  }
  .footer-link-item:hover { color:#e4e4e7; }
  .footer-meta-link { font-size:0.78rem; color:#52525b; text-decoration:none; transition:color 0.15s; }
  .footer-meta-link:hover { color:#a1a1aa; }
  .footer-social { font-size:0.78rem; color:#3f3f46; text-decoration:none; transition:color 0.15s; }
  .footer-social:hover { color:#71717a; }
</style>

<script>
  // Nav scroll
  let last = window.scrollY;
  const nav = document.getElementById('nav');
  window.addEventListener('scroll', () => {
    const y = window.scrollY;
    if (nav) nav.classList.toggle('hide', y > last && y > 80);
    last = y;
  }, { passive: true });

  // Hamburger
  document.getElementById('ham')?.addEventListener('click', () => {
    document.getElementById('mobile-menu')?.classList.toggle('open');
  });

  // Fade-up on scroll
  const obs = new IntersectionObserver(entries => {
    entries.forEach(e => {
      if (!e.isIntersecting) return;
      const el = e.target as HTMLElement;
      const d = parseFloat(el.dataset.delay ?? '0');
      setTimeout(() => el.classList.add('in'), d * 1000);
      obs.unobserve(el);
    });
  }, { threshold: 0.08 });
  document.querySelectorAll('.fade-up').forEach(el => obs.observe(el));
</script>

</body>
</html>
